-- | A mock implementation of a test token for the purpose of testing V2 token standard workflows.
module Splice.Testing.Tokens.TestTokenV2 where

import DA.Action (when)
import DA.Assert
import DA.Foldable (forA_)
import DA.List (dedupSort)
import DA.Map qualified as Map
import DA.Optional
import DA.Set qualified as Set
import DA.Text qualified as T
import DA.TextMap qualified as TextMap

import Splice.Api.Token.MetadataV1
import Splice.Api.Token.HoldingV2 qualified as V2
import Splice.Api.Token.AllocationV2 qualified as V2
import Splice.Api.Token.AllocationInstructionV2 qualified as V2
import Splice.Api.Token.TransferInstructionV2 qualified as V2
import Splice.Api.Token.TransferEventsV2 as TransferEventsV2
import Splice.Testing.Tokens.TestTokenV2.AccountConfig
import Splice.TokenStandard.Utils


-- TODO(#4542): improve testing of accountable hodling support by adding AccountConfig that determines authorization for an account

template Token with
     holding : V2.HoldingView
  where
    -- We model a token that is jointly maintained by the account parties and the instrument admin
    -- to test that the authorization rules work our for that as well.
    --
    -- TODO(#4542): add a test with a jointly maintained token; and one with actions driven by the account provider
    -- it will likely not work, as archival and creation needs owner and provider authorization.
    -- What's missing is to add the intermediate instruction workflows to gather the authorization from the other party.
    signatory accountParties holding.account, holding.instrumentId.admin

    ensure
      holding.amount > 0.0 -- positive amounts

    interface instance V2.Holding for Token where
      view = holding

-- | Implementation of a V2-only allocation.
template TokenAllocationV2 with
    lockedTokens : [ContractId Token]
    allocation : V2.AllocationSpecification
    admin : Party
  where
    ensure isValidAllocationSpecificationV2 (\instrumentId -> instrumentId.admin == admin) allocation
    signatory accountParties allocation.authorizer, allocationAdmin allocation
    observer allocation.settlement.executors

    interface instance V2.Allocation for TokenAllocationV2 where
      view = V2.AllocationView with
        originalAllocationCid = None
        expiresAt = None
          -- Note: in a production implementation we would also want to add a choice
          -- for the `admin` to expire the allocation. We don't need it for testing though.
        allocation
        holdingCids = map toInterfaceContractId lockedTokens
        extraSettlementAuthorizers = []
        availableActions = allocationV2_availableActionsDefault allocation []
        meta = emptyMetadata

      -- No extra observers required, as the choice bodies do not introduce further informees.
      -- Note that the executors are controllers on these two choices.
      allocation_settleExtraObservers _arg = []
      allocation_cancelExtraObservers _arg = []

      -- Add executors as extra observers so there is no extra view for the archival of the holding
      allocation_withdrawExtraObservers _arg = allocation.settlement.executors

      allocation_withdrawImpl self arg@(V2.Allocation_Withdraw{..}) = do
        archiveAndCheckActors self arg.actors [[allocation.authorizer.owner]]
        authorizerHoldingCids <- unlockTokenAllocationV2 this extraArgs
        pure V2.Allocation_WithdrawResult
          with
            authorizerHoldingCids
            meta = emptyMetadata

      allocation_cancelImpl self arg@(V2.Allocation_Cancel{..}) = do
        archiveAndCheckActors self arg.actors [allocation.settlement.executors]
        authorizerHoldingCids <- unlockTokenAllocationV2 this extraArgs
        pure V2.Allocation_CancelResult
          with
            authorizerHoldingCids
            meta = emptyMetadata

      allocation_settleImpl self arg@(V2.Allocation_Settle{..}) = do
        -- check actors and deadline
        archiveAndCheckActors self arg.actors [admin :: allocation.settlement.executors]
        forA_ allocation.settlement.settlementDeadline $ \deadline ->
          assertWithinDeadline "allocation.settlement.settlementDeadline" deadline

        -- archive the locked tokens
        debitAmounts <- fmap (Map.fromListWithR (+)) $ forA lockedTokens $ \cid -> do
          token <- fetch cid
          let holding = token.holding
          archive cid
          require' ("lockedToken", holding.account) isEqualR ("allocation.authorizer", allocation.authorizer)
          pure (holding.instrumentId, holding.amount)

        -- log v2 transfer events
        tokenRulesCid <- getEventLogFromContext extraArgs.context
        logAllocationSettlement (toInterfaceContractId tokenRulesCid) allocation

        -- prudent engineering: compare debits with expected debits based on the transfer legs, and settle
        let creditAmounts = netAllocationCreditAmounts allocation.authorizer allocation.transferLegs
        let combinedAmounts = mergeAmountMaps debitAmounts creditAmounts
        authorizerHoldingCids <- forA (Map.toList combinedAmounts) $ \(instrumentId, (debitAmount, creditAmount)) -> do
          require'
            ("archived lockedAmulet.amount for " <> show instrumentId, debitAmount)
            isEqualR
            ("transferLegs.debitAmount", negate (min 0.0 creditAmount))
          if creditAmount > 0.0
            then do
              -- Net credit of Token ==> create the holding
              newHoldingCid <- create Token with
                holding = V2.HoldingView with
                  account = allocation.authorizer
                  amount = creditAmount
                  instrumentId
                  lock = None
                  meta = emptyMetadata
              pure (instrumentId.id, [toInterfaceContractId newHoldingCid])
            else
              -- No credit of Token ==> no holding change
              pure (instrumentId.id, [])

        pure V2.Allocation_SettleResult with
          authorizerHoldingCids = TextMap.fromListWithR (++) $ authorizerHoldingCids
          meta = emptyMetadata
            -- Note: for V1 tx history we would need create extra choices for
            -- the creation, as this choice here cannot express the creation and
            -- archival of multiple holdings for different instrument-ids.


-- | Transfer instruction representing a token transfer offer.
--
-- Its input holdings reference the locked tokens.
template TokenTransferOffer with
    existingRequests : Map.Map V2.TransferInstructionAction Party
      -- ^ A map from requests for particular actions to happen to the requestor.
    transfer : V2.Transfer
    originalInstructionCid : Optional (ContractId V2.TransferInstruction)
  where
    ensure isValidTransferV2 transfer &&
      hasValidAccountId transfer.sender &&
      hasValidAccountId transfer.receiver

    signatory jointAuthorizers transfer.sender, transfer.instrumentId.admin
    observer accountParties transfer.receiver

    interface instance V2.TransferInstruction for TokenTransferOffer where
      view = V2.TransferInstructionView with
        originalInstructionCid = None
        transfer
        availableActions =
          let extract account = (account, accountConfigFromId account.id) in
          mkAvailableTransferActions existingRequests (extract transfer.sender) (extract transfer.receiver)
        meta = emptyMetadata

      transferInstruction_acceptExtraObservers = transferInstruction_acceptDefaultExtraObservers this
      transferInstruction_rejectExtraObservers = transferInstruction_rejectDefaultExtraObservers this
      transferInstruction_withdrawExtraObservers = transferInstruction_withdrawDefaultExtraObservers this

      transferInstruction_withdrawImpl self arg = do
        let actionWithConfig = (V2.TIA_Withdraw, transfer.sender, accountConfigFromId transfer.sender.id)
        executeOrRecordRequest this self arg.actors actionWithConfig $ do
          archiveLockedHoldingsForTransfer transfer
          tokenCid <- create Token with
            holding = senderHoldingFromTransfer transfer
          pure V2.TransferInstructionResult with
            output = V2.TransferInstructionResult_Failed
            senderChangeCids = [toInterfaceContractId tokenCid]
            meta = emptyMetadata

      transferInstruction_rejectImpl self arg = do
        let actionWithConfig = (V2.TIA_Reject, transfer.receiver, accountConfigFromId transfer.receiver.id)
        executeOrRecordRequest this self arg.actors actionWithConfig $ do
          archiveLockedHoldingsForTransfer transfer
          tokenCid <- create Token with
            holding = senderHoldingFromTransfer transfer
          pure V2.TransferInstructionResult with
            output = V2.TransferInstructionResult_Failed
            senderChangeCids = [toInterfaceContractId tokenCid]
            meta = emptyMetadata

      transferInstruction_acceptImpl self arg = do
        let actionWithConfig = (V2.TIA_Accept, transfer.receiver, accountConfigFromId transfer.receiver.id)
        executeOrRecordRequest this self arg.actors actionWithConfig $ do
          archiveLockedHoldingsForTransfer transfer
          tokenCid <- create Token with
            holding = (senderHoldingFromTransfer transfer) with
              account = transfer.receiver
          pure V2.TransferInstructionResult with
            senderChangeCids = []
            output = V2.TransferInstructionResult_Completed with
              receiverHoldingCids = [toInterfaceContractId tokenCid]
            meta = mkMetaTransferFrom transfer.sender.owner (reasonFromMeta transfer.meta)

executeOrRecordRequest
  : TokenTransferOffer -> ContractId V2.TransferInstruction -> [Party]
  -> (V2.TransferInstructionAction, V2.Account, AccountConfig)
  -> Update V2.TransferInstructionResult
  -> Update V2.TransferInstructionResult
executeOrRecordRequest this self actors (action, account, config) execute = do
    archiveAndCheckActors self actors (nextActorsFor action this.existingRequests config account)
    let previousActor = Map.lookup action this.existingRequests
    let currentApprovers = Set.fromList $ actors <> optionalToList previousActor
    let expectedApprovers = requiredApprovers config account
    if currentApprovers == expectedApprovers
      then execute
      else do
        actor <- case actors of
          [a] -> pure a
          actors -> fail $ T.unlines
            [ "unexpected: the actor check should ensure that multiple actors are equal to the expected approvers"
            , "action: " <> show action
            , "actors: " <> show actors
            ]
        -- record the request for this actor
        let newOriginalInstructionCid = Some $ fromOptional (toInterfaceContractId self) this.originalInstructionCid
        pendingInstrCid <- create this with
          existingRequests = Map.insert action actor this.existingRequests
          originalInstructionCid = newOriginalInstructionCid
        pure V2.TransferInstructionResult with
          output = V2.TransferInstructionResult_Pending with
            transferInstructionCid = toInterfaceContractId pendingInstrCid
          senderChangeCids = []
          meta = emptyMetadata


-- | A template representing a transfer being created, but not yet offered.
--
-- Note: we should get rid of this and instead use the same action-approval logic as for the transfer offer.
--
-- FIXME: use `TokenTransferOffer` after defining a `V2.TransferInstruction_Confirm` action on the `V2.TransferInstruction` interface
-- so that wallets can use accountable holdings using standard actions only.
template TokenTransferCreation with
    missingConfirmers : [Party]
    transfer : V2.Transfer
  where
    ensure isValidTransferV2 transfer

    signatory existingConfirmers this, transfer.instrumentId.admin
    observer missingConfirmers

    choice TokenTransferCreation_ConfirmCreation : V2.TransferInstructionResult
      with
        inputHoldingCids : [ContractId V2.Holding]
        actors : [Party]
        -- FIXME: extraArgs
        tokenRulesCid : ContractId TokenRules -- FIXME: hack
      controller actors
      do
        let origId = Some (toInterfaceContractId self)
        token_transferFactory_transferImpl transfer.instrumentId.admin (toInterfaceContractId tokenRulesCid) origId actors missingConfirmers
          (transfer with inputHoldingCids)

    interface instance V2.TransferInstruction for TokenTransferCreation where
      view = V2.TransferInstructionView with
        originalInstructionCid = None
        transfer
        availableActions = Map.fromList
          [([actor], [V2.TIA_Withdraw]) | actor <- jointAuthorizers transfer.sender]
          -- FIXME: add TIA_Confirm action to confirm the creation
        meta = emptyMetadata

      transferInstruction_acceptExtraObservers _arg = []
      transferInstruction_rejectExtraObservers _arg = []
      transferInstruction_withdrawExtraObservers _arg = observer this

      transferInstruction_withdrawImpl self arg = do
        archiveAndCheckActors self arg.actors [ [actor] | actor <- jointAuthorizers transfer.sender]
        archiveLockedHoldingsForTransfer transfer
        tokenCid <- create Token with
          holding = senderHoldingFromTransfer transfer
        pure V2.TransferInstructionResult with
          output = V2.TransferInstructionResult_Failed
          senderChangeCids = [toInterfaceContractId tokenCid]
          meta = emptyMetadata

      transferInstruction_rejectImpl _self _arg = fail "TokenTransferCreation: reject not supported"
      transferInstruction_acceptImpl  _self _arg = fail "TokenTransferCreation: accept not supported"

existingConfirmers : TokenTransferCreation -> [Party]
existingConfirmers co = do
  p <- jointAuthorizers co.transfer.sender
  guard (p `notElem` co.missingConfirmers)
  pure p


-- | Template providing all the rules for how the tokens can be changed.
--
-- For this test token, they are given by the ones of the V2 token standard factories.
template TokenRules with
    admin : Party
  where
    signatory admin

    interface instance V2.TransferFactory for TokenRules where
      view = V2.TransferFactoryView with
        admin
        meta = emptyMetadata

      transferFactory_publicFetchImpl = publicFetchDefaultImpl this
      transferFactory_transferExtraObservers = transferFactoryV2_privateAsset_transferExtraObserversDefaultImpl

      transferFactory_transferImpl self arg = do
        let missingConfirmers = jointAuthorizers arg.transfer.sender
        token_transferFactory_transferImpl admin (coerceContractId self) None arg.actors missingConfirmers arg.transfer

    -- TODO(#5001): test all calls to this event log using submitTree
    interface instance TransferEventsV2.EventLog for TokenRules where
      view = TransferEventsV2.EventLogView with
        admin = admin
        meta = emptyMetadata

      eventLog_transferOutImpl = eventLog_transferOutDefaultImpl admin
      eventLog_transferInImpl = eventLog_transferInDefaultImpl admin


    interface instance V2.SettlementFactory for TokenRules where
      view = V2.SettlementFactoryView with
        admin
        meta = emptyMetadata

      settlementFactory_settleBatchImpl self arg0 =
        let arg = arg0 with
              extraArgs = arg0.extraArgs with
                context = ChoiceContext with
                  values = textMapSingleton tokenRulesContextKey (AV_ContractId (coerceContractId self))
            createReceiptAllocation =
              settlementFactoryV2_defaultCreateReceiptAllocation
                (coerceContractId self)
                (\account -> [account.owner])
                arg
        in
          settlementFactoryV2_settleBatchDefaultImpl createReceiptAllocation this self arg

      -- no extra observers to avoid leaking the settlement of different allocations to the other authorizers
      settlementFactory_settleBatchExtraObservers _arg = []

      settlementFactory_publicFetchImpl = publicFetchDefaultImpl this

    -- FIXME: carry over the account authorization logic to the allocation factory and allocations once it has been reviewed
    interface instance V2.AllocationFactory for TokenRules where
      view = V2.AllocationFactoryView with
        admin
        meta = emptyMetadata

      allocationFactory_allocateExtraObservers = allocationFactoryV2_privateAsset_allocateExtraObserversDefaultImpl

      allocationFactory_allocateImpl self arg = token_allocationFactoryV2_allocateImpl this self arg
      allocationFactory_publicFetchImpl = publicFetchDefaultImpl this

-- | Create a V2 transfer offer
token_transferFactory_transferImpl
  : Party
  -> ContractId TransferEventsV2.EventLog
  -> Optional (ContractId V2.TransferInstruction)
  -> [Party]
  -> [Party]
  -> V2.Transfer
  -> Update V2.TransferInstructionResult
token_transferFactory_transferImpl admin eventLogCid originalInstructionCid actors missingConfirmers transfer = do
  -- FIXME: the code below disregards the account config ==> fix that by
  -- switching to the same action-approval workflow as in the transfer offer.
  require' ("actors", actors) isSubsetOfR ("missingConfirmers", missingConfirmers)
  require' ("actors", actors) (notR isEqualR) ("empty list", [])
  require' ("transfer.instrumentId.admin", transfer.instrumentId.admin) isEqualR ("transferFactory.admin", admin)
  let newMissingConfirmers = Set.fromList missingConfirmers `Set.difference` Set.fromList actors
  if Set.null newMissingConfirmers
    then token_transferFactory_transferImplCore eventLogCid originalInstructionCid transfer
    else do
      -- initate workflow to get the missing confirmation from the other party
      instrCid <- create TokenTransferCreation with
        missingConfirmers = Set.toList newMissingConfirmers
        transfer = transfer with inputHoldingCids = []
      pure V2.TransferInstructionResult with
        output = V2.TransferInstructionResult_Pending with transferInstructionCid = coerceContractId instrCid
        senderChangeCids = transfer.inputHoldingCids
        meta = emptyMetadata


-- | Create a V2 transfer offer
token_transferFactory_transferImplCore
  : ContractId TransferEventsV2.EventLog
  -> Optional (ContractId V2.TransferInstruction)
  -> V2.Transfer
  -> Update V2.TransferInstructionResult
token_transferFactory_transferImplCore eventLogCid originalInstructionCid transfer = do
  -- consume all inputs
  inputAmounts <- forA transfer.inputHoldingCids $ \cid -> do
    let tokenCid = coerceContractId cid : ContractId Token
    token <- fetch tokenCid
    archive tokenCid
    require' ("inputHolding.account", token.holding.account) isEqualR ("transfer.sender", transfer.sender)
    require' ("inputHolding.instrumentId", token.holding.instrumentId) isEqualR ("transfer.instrumentId", transfer.instrumentId)
    pure token.holding.amount
  let inputAmount = sum inputAmounts
  require' ("inputAmount for " <> show transfer.instrumentId, inputAmount) isGreaterOrEqualR
    ("transfer.amount", transfer.amount)

  -- split off change
  let remainder = inputAmount - transfer.amount
  senderChangeCids <-
      if remainder <= 0.0 then pure [] else do
        cid <- create Token with
          holding = (senderHoldingFromTransfer transfer) with
            amount = remainder
        pure [toInterfaceContractId cid]

  -- execute transfer if the senderApprovers cover the receiverApprovers, otherwise create transfer offer
  let senderApprovers = requiredApprovers (accountConfigFromId transfer.sender.id) transfer.sender
  let receiverApprovers = requiredApprovers (accountConfigFromId transfer.receiver.id) transfer.receiver
  if receiverApprovers `Set.isSubsetOf` senderApprovers
    then do
      -- report v2 event
      logTransfer eventLogCid transfer
      outputCid <- create Token with
        holding = (senderHoldingFromTransfer transfer) with
          account = transfer.receiver
      pure V2.TransferInstructionResult with
        output = V2.TransferInstructionResult_Completed with
          receiverHoldingCids = [toInterfaceContractId outputCid]
        senderChangeCids
        meta = emptyMetadata
    else do
      -- lock the amount to be transferred
      lockedCid <- create Token with
        holding = (senderHoldingFromTransfer transfer) with
          lock = Some $ V2.Lock with
            holders = transfer.instrumentId.admin :: accountParties transfer.sender
            expiresAt = Some transfer.executeBefore
            expiresAfter = None
            context = Some $ "transfer to " <> show transfer.receiver
      -- create transfer offer
      transferInstructionCid <- toInterfaceContractId <$> create TokenTransferOffer with
        existingRequests = Map.fromList
          -- the sender approvers already approved the accept
          [ (V2.TIA_Accept, p) | p <- Set.toList $ receiverApprovers `Set.intersection` senderApprovers ]
        originalInstructionCid
        transfer = transfer with
          inputHoldingCids = [toInterfaceContractId lockedCid]
      pure V2.TransferInstructionResult with
        senderChangeCids
        -- Note: we skip over explaining the change in locked holdings to V1 history parsers,
        -- as their fallback to just show the updated locked balance together with the instruction
        -- should be sufficient for wallet users to understand what happened.
        meta = emptyMetadata
        output = V2.TransferInstructionResult_Pending with transferInstructionCid

-- | Create a V2 allocation
token_allocationFactoryV2_allocateImpl
  : TokenRules
  -> ContractId V2.AllocationFactory
  -> V2.AllocationFactory_Allocate
  -> Update V2.AllocationInstructionResult
token_allocationFactoryV2_allocateImpl tokenRules _self arg = do
  let authorizer = arg.allocation.authorizer
  checkActors arg.actors [jointAuthorizers authorizer]
  -- debit all input amounts
  inputAmounts <- fmap (Map.fromListWithR (+)) $ forA arg.inputHoldingCids $ \cid -> do
    let tokenCid = coerceContractId cid : ContractId Token
    token <- fetch tokenCid
    archive tokenCid
    let holding = token.holding
    require' ("inputHolding.account", holding.account) isEqualR ("allocation.authorizer", authorizer)
    pure (holding.instrumentId, holding.amount)
  -- create locked tokens and change for the sender
  let creditAmounts = netAllocationCreditAmounts authorizer arg.allocation.transferLegs
  let combinedAmounts = mergeAmountMaps inputAmounts creditAmounts
  locksAndChange <- forA (Map.toList combinedAmounts) $ \(instrumentId, (inputAmount, creditAmount)) -> do
    let netAmount = min 0.0 creditAmount + inputAmount
    when (netAmount < 0.0) $
      fail $ T.unlines
        [ "Net debit of " <> show netAmount <> " for " <> show instrumentId <> " is not allowed"
        , "Input amount: " <> show inputAmount
        , "Credit amount: " <> show creditAmount
        ]
    lockedTokens <-
      if creditAmount >= 0.0 then pure [] else do
        cid <- create Token with
          holding = V2.HoldingView with
            account = authorizer
            amount = negate creditAmount
            instrumentId
            lock = Some $ V2.Lock with
              holders = instrumentId.admin :: accountParties authorizer
              expiresAt = Some arg.allocation.settlement.settleAt
              expiresAfter = None
              context = Some $ "allocation for settlement of " <> arg.allocation.settlement.settlementRef.id
            meta = emptyMetadata
        pure [cid]
    changeTokens <-
      if netAmount <= 0.0 then pure [] else do
        cid <- create Token with
          holding = V2.HoldingView with
            account = authorizer
            amount = netAmount
            instrumentId
            lock = None
            meta = emptyMetadata
        pure [(instrumentId.id, [toInterfaceContractId cid])]
    pure (lockedTokens, changeTokens)
  -- create allocation
  let lockedTokens = concatMap fst locksAndChange
  allocationCid <- toInterfaceContractId <$> create TokenAllocationV2 with
    lockedTokens
    allocation = arg.allocation
    admin = tokenRules.admin
  -- return change
  let authorizerChangeCids = TextMap.fromListWithR (++) $ concatMap snd locksAndChange
  pure V2.AllocationInstructionResult with
    authorizerChangeCids
    meta = emptyMetadata
    output = V2.AllocationInstructionResult_Completed with allocationCid


-- Utilities
------------

unlockTokenAllocationV2 : TokenAllocationV2 -> ExtraArgs -> Update (TextMap.TextMap [ContractId V2.Holding])
unlockTokenAllocationV2 tokenAllocation _extraArgs = do
  holdingCids <- forA tokenAllocation.lockedTokens $ \lockedCid -> do
    token <- fetch lockedCid
    archive lockedCid
    let holding = token.holding
    require' ("lockedToken", holding.account) isEqualR ("allocation.authorizer", tokenAllocation.allocation.authorizer)
    unlockedCid <- create Token with
      holding = holding with lock = None
    pure $ (holding.instrumentId.id, [toInterfaceContractId unlockedCid])
  pure $ TextMap.fromListWithR (++) holdingCids

mergeAmountMaps : Ord k => Map.Map k Decimal -> Map.Map k Decimal -> Map.Map k (Decimal, Decimal)
mergeAmountMaps = Map.merge (\_ x -> Some (x, 0.0)) (\_ y -> Some (0.0, y)) (\_ x y -> Some (x, y))

archiveLockedHoldingsForTransfer : V2.Transfer -> Update ()
archiveLockedHoldingsForTransfer transfer =
  forA_ transfer.inputHoldingCids archive

senderHoldingFromTransfer : V2.Transfer -> V2.HoldingView
senderHoldingFromTransfer transfer = V2.HoldingView with
  account = transfer.sender
  amount = transfer.amount
  instrumentId = transfer.instrumentId
  lock = None
  meta = emptyMetadata

jointAuthorizers : V2.Account -> [Party]
jointAuthorizers = dedupSort . accountParties


-- Event log retrieval
----------------------

tokenRulesContextKey : Text
tokenRulesContextKey = "token-rules"

getTokenRulesFromContext : ChoiceContext -> Update (ContractId TokenRules)
getTokenRulesFromContext context = do
  case TextMap.lookup tokenRulesContextKey context.values of
    Some (AV_ContractId cid) -> pure (coerceContractId cid)
    None -> fail $ "Context value for '" <> tokenRulesContextKey <> "' not found"
    v -> fail $ "Failed to decode context value for '" <> tokenRulesContextKey <> "': " <> show v

getEventLogFromContext : ChoiceContext -> Update (ContractId TransferEventsV2.EventLog)
getEventLogFromContext context = toInterfaceContractId <$> getTokenRulesFromContext context
