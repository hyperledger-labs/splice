-- | A mock implementation of a test token for the purpose of testing V2 token standard workflows.
module Splice.Testing.Tokens.TestTokenV2 where

import DA.Assert
import DA.Foldable (forA_)
import DA.Optional
import DA.Map qualified as Map

import Splice.Api.Token.MetadataV1
import Splice.Api.Token.HoldingV2 qualified as V2
import Splice.Api.Token.AllocationV2 qualified as V2
import Splice.Api.Token.AllocationInstructionV2 qualified as V2
import Splice.TokenStandard.Utils


-- FIXME: add AccountConfig that determines authorization for an account and private info

template Token with
     holding : V2.HoldingView
  where
    -- We model a token that is jointly maintained by the account parties and the instrument admin
    -- to test that the authorization rules work our for that as well.
    signatory accountParties holding.account, holding.instrumentId.admin

    ensure
      holding.amount > 0.0 -- positive amounts

    interface instance V2.Holding for Token where
      view = holding

-- | Implementation of a V2-only allocation.
template TokenAllocationV2 with
    lockedTokens : [ContractId Token]
    allocation : V2.AllocationSpecification
    admin : Party
  where
    ensure isValidAllocationSpecificationV2 (\instrumentId -> instrumentId.admin == admin) allocation
    signatory accountParties allocation.authorizer, allocationAdmin allocation
    observer allocation.settlement.executors

    interface instance V2.Allocation for TokenAllocationV2 where
      view = V2.AllocationView with
        expiresAt = None
          -- Note: in a production implementation we would also want to add a choice
          -- for the `admin` to expire the allocation. We don't need it for testing though.
        allocation
        holdingCids = map toInterfaceContractId lockedTokens
        extraSettlementAuthorizers = []
        availableActions = allocationV2_availableActionsDefault allocation []
        meta = emptyMetadata

      -- No extra observers required, as the choice bodies do not introduce further informees.
      -- Note that the executors are controllers on these two choices.
      allocation_settleExtraObservers _arg = []
      allocation_cancelExtraObservers _arg = []

      -- Add executors as extra observers so there is no extra view for the archival of the holding
      allocation_withdrawExtraObservers _arg = allocation.settlement.executors

      allocation_withdrawImpl self arg@(V2.Allocation_Withdraw{..}) = do
        archiveAndCheckActors self arg.actors [[allocation.authorizer.owner]]
          -- FIXME: enable different account authorization configurations
        authorizerHoldingCids <- unlockTokenAllocation this extraArgs
        pure V2.Allocation_WithdrawResult
          with
            authorizerHoldingCids
            meta = emptyMetadata

      allocation_cancelImpl self arg@(V2.Allocation_Cancel{..}) = do
        archiveAndCheckActors self arg.actors [allocation.settlement.executors]
        authorizerHoldingCids <- unlockTokenAllocation this extraArgs
        pure V2.Allocation_CancelResult
          with
            authorizerHoldingCids
            meta = emptyMetadata

      allocation_settleImpl self arg@(V2.Allocation_Settle{..}) = do
        -- check actors and deadline
        archiveAndCheckActors self arg.actors [admin :: allocation.settlement.executors]
        forA_ allocation.settlement.settlementDeadline $ \deadline ->
          assertWithinDeadline "allocation.settlement.settlementDeadline" deadline

        -- archive the locked tokens
        debits <- fmap (Map.fromListWithR (+)) $ forA lockedTokens $ \cid -> do
          token <- fetch cid
          let holding = token.holding
          archive cid
          require' ("lockedToken", holding.account) isEqualR ("allocation.authorizer", allocation.authorizer)
          pure (holding.instrumentId, holding.amount)

        -- compute net funds to move
        let netAmounts = netAllocationCreditAmounts allocation.authorizer allocation.transferLegs
        authorizerHoldingCids <- forA (Map.toList netAmounts) $ \(instrumentId, netAmount) ->
          case Map.lookup instrumentId debits of
            None
              | netAmount > 0.0 -> do
                  -- Net credit of Token ==> create the holding
                  newHoldingCid <- create Token with
                    holding = V2.HoldingView with
                      account = allocation.authorizer
                      amount = netAmount
                      instrumentId
                      lock = None
                      meta = emptyMetadata
                  pure (instrumentId, [toInterfaceContractId newHoldingCid])
              | netAmount == 0.0 ->
                  -- No holding change ==> no tx history metadata
                  pure (instrumentId, [])
              | otherwise ->
                  fail $ "unexpected: no locked instrument archived for net negative amount " <> show netAmount <>
                    " of " <> show instrumentId
            Some debitAmount
              | netAmount == debitAmount -> do
                  -- Net debit of Token and token was archived
                  pure (instrumentId, [])
              | otherwise ->
                  fail $ "unexpected: locked instrument archived for net amount " <> show netAmount <>
                    " does not match expected debit amount " <> show debitAmount <> " for " <> show instrumentId

        pure V2.Allocation_SettleResult with
          authorizerHoldingCids = concatMap snd authorizerHoldingCids
          meta = emptyMetadata
            -- Note: for V1 tx history we would need create extra choices for
            -- the creation, as this choice here cannot express the creation and
            -- archival of multiple holdings for different instrument-ids.

unlockTokenAllocationV2 : TokenAllocationV2 -> ExtraArgs -> Update [ContractId V2.Holding]
unlockTokenAllocationV2 tokenAllocation _extraArgs = do
  forA tokenAllocation.lockedTokens $ \lockedCid -> do
    token <- fetch lockedCid
    archive lockedCid
    let holding = token.holding
    require' ("lockedToken", holding.account) isEqualR ("allocation.authorizer", tokenAllocation.allocation.authorizer)
    unlockedCid <- create Token with
      holding = holding with lock = None
    pure $ toInterfaceContractId unlockedCid





-- | Template providing all the rules for how the tokens can be changed.
--
-- For this test token, they are given by the ones of the V2 token standard factories.
template TokenRules with
    admin : Party
  where
    signatory admin

    interface instance V2.SettlementFactory for TokenRules where
      view = V2.SettlementFactoryView with
        admin
        meta = emptyMetadata

      settlementFactory_settleBatchImpl self arg =
        let createReceiptAllocation =
              settlementFactoryV2_defaultCreateReceiptAllocation
                (coerceContractId self)
                (\account -> [account.owner])
                arg
        in
          settlementFactoryV2_settleBatchDefaultImpl createReceiptAllocation this self arg

      -- no extra observers to avoid leaking the settlement of different allocations to the other authorizers
      settlementFactory_settleBatchExtraObservers arg = []

      settlementFactory_publicFetchImpl = publicFetchDefaultImpl this


    interface instance V2.AllocationFactory for TokenRules where
      view = V2.AllocationFactoryView with
        admin
        meta = emptyMetadata

      allocationFactory_allocateExtraObservers = allocationFactoryV2_publicAsset_allocateExtraObserverDefaultImpl

      allocationFactory_allocateImpl self arg = token_allocationFactoryV2_allocateImpl this self arg
      allocationFactory_publicFetchImpl = publicFetchDefaultImpl this


-- | Create a V2 allocation
token_allocationFactoryV2_allocateImpl
  : TokenRules
  -> ContractId V2.AllocationFactory
  -> V2.AllocationFactory_Allocate
  -> Update V2.AllocationInstructionResult
token_allocationFactoryV2_allocateImpl externalTokenRules _self arg = do

  let authorizer = arg.allocation.authorizer.owner

  -- debit all input amounts
  fundingAmounts <- fmap (Map.fromListWithR (+)) $ forA inputHoldingCids $ \cid -> do
    token <- fetch cid
    archive cid
    let holding = token.holding
    require' ("inputHolding.account", holding.account) isEqualR ("allocation.authorizer", authorizer)
    pure (holding.instrumentId, holding.amount)

  -- create locked tokens and change for the sender
  let creditAmounts = netAllocationCreditAmounts authorizer arg.allocation.transferLegs
  let combinedAmounts = Map.merge
        (\_ fundingAmount -> (fundingAmount, 0.0))
        (\_ creditAmount -> (0.0, creditAmount))
        (\_ fundingAmount creditAmount -> (fundingAmount, creditAmount))
        fundingAmounts
        creditAmounts
  locksAndChange <- forA (Map.toList combinedAmounts) $ \(instrumentId, (fundingAmount, creditAmount)) -> do
    let netAmount = min 0.0 creditAmount + fundingAmount
    when (netAmount < 0.0) $
      fail $ T.unlines
        [ "Net debit of " <> show netAmount <> " for " <> show instrumentId <> " is not allowed"
        , "Funding amount: " <> show fundingAmount  -- FIXME: renaming "funding" to "input"
        , "Credit amount: " <> show creditAmount
        ]

    lockedTokens <-
      if creditAmount >= 0.0 then pure [] else do
        cid <- create Token with
          holding = V2.HoldingView with
            account = authorizer
            amount = netAmount
            instrumentId
            lock = Some $ V2.Lock with
              holders = instrumentId.admin :: accountParties authorizer
              expiresAt = Some arg.allocation.settlement.settleAt
              expiresAfter = None
              context = Some $ TokenAllocationV1.mkAllocationLockContext (downcast arg.allocation.settlement.settlementRef)
            meta = emptyMetadata
        pure [toInterfaceContractId cid]

    changeTokens <-
      if netAmount <= 0.0 then pure [] else do
        cid <- create Token with
          holding = V2.HoldingView with
            account = authorizer
            amount = netAmount
            instrumentId
            lock = None
            meta = emptyMetadata
        pure [toInterfaceContractId cid]

    pure (lockedTokens, changeTokens)

  let lockedTokens = concatMap fst locksAndChange
  let authorizerChangeCids = concatMap snd locksAndChange

  allocCid <- toInterfaceContractId <$> create TokenAllocationV2 with
    allocation = arg.allocation
    lockedTokens
    admin

  pure V2.AllocationInstructionResult with
    authorizerChangeCids







{-

-- | Core of the V2 allocation creation, which is used for both V1 and V2 factories.
token_allocationFactoryV2_allocateImplCore
  : TokenRules
  -> V2.AllocationFactory_Allocate
  -> Decimal
  -> Update (Optional (ContractId LockedToken), [ContractId V1.Holding], Time, Metadata)
token_allocationFactoryV2_allocateImplCore externalTokenRules arg fundingAmount = do
  let dso = externalTokenRules.dso
  let (V2.AllocationFactory_Allocate with allocation, requestedAt, inputHoldingCids, extraArgs, actors) = arg

  -- We are using an unfeatured payment context, as the locking to self should not be featured.
  paymentContext <- unfeaturedPaymentContextFromChoiceContext dso extraArgs.context

  -- check actors
  ensureBasicAccount "allocation.authorizer" allocation.authorizer
  let authorizer = allocation.authorizer.owner
  checkActors actors [[authorizer]]

  -- == validate each field of the requested allocation
  let settlement = allocation.settlement
  let transferLegs = allocation.transferLegs

  -- settlement.executors: no check
  -- settlement.settlementRef: no check
  -- settlement.requestedAt:
  assertDeadlineExceeded "Allocation.settlement.requestedAt" settlement.requestedAt
  -- settlement.settlementDeadline:
  whenSome settlement.settlementDeadline \d -> do
      assertWithinDeadline "Allocation.settlement.settlementDeadline" d

  let
    -- TODO(#4665): make max duration configurable; and also implement for transfer instructions
    latestExpiresAt = requestedAt `addRelTime` days 90
    expiresAt = optional latestExpiresAt (min latestExpiresAt) allocation.settlement.settlementDeadline
  require "Allocation.settlement.settleAt <= Allocation.expiresAt"
    (settlement.settleAt <= expiresAt)

  -- transferLegs:
  requireUnique "allocation.transferLegs" transferLegs
  forA_ transferLegs $ \transferLeg -> do
      -- transferLegId: no check
      -- transferLeg.sender
      ensureBasicAccount "transferLeg.sender" transferLeg.sender
      -- transferLeg.receiver
      ensureBasicAccount "transferLeg.receiver" transferLeg.receiver
      -- transferLeg.amount
      require "Transfer amount must be positive" (transferLeg.amount > 0.0)
      -- transferLeg.instrumentId
      require "Instrument-id must match the factory" (transferLeg.instrumentId == tokenInstrumentIdV2 dso)
      -- transferLeg.meta: check no redundant account information
      ensureNoAccountMeta "transferLeg" "sender" transferLeg.meta
      ensureNoAccountMeta "transferLeg" "receiver" transferLeg.meta

  -- requestedAt (of the allocation instruction itself):
  assertDeadlineExceeded "requestedAt" requestedAt

  -- create locked token if required
  if fundingAmount <= 0.0
  then do
    require "Must not provide holding cids for allocations that do not require funding" (null inputHoldingCids)
    return (None, [], expiresAt, emptyMetadata)
  else do
    require "At least one input holding must be provided for allocations that require funding" (not (null inputHoldingCids))
    -- lock the funds
    let twoStepTransfer = TwoStepTransfer with
          dso
          sender = authorizer
          amount = fundingAmount
          -- TODO(#4550): consider storing a contract-id in the v2 lock context for better correlation on V2
          lockContext = TokenAllocationV1.mkAllocationLockContext (downcast settlement.settlementRef)
          transferBefore = expiresAt
          transferBeforeDeadline = "allocation.expiresAt"
          -- Minor hack: we use the authorizer for receiver and provider as these fields are irrlevant
          -- for preparing the two-step transfer .
          receiver = authorizer
          provider = authorizer
          allowFeaturing = False
    (la, cids, meta) <- prepareTwoStepTransfer twoStepTransfer arg.requestedAt (map downcast inputHoldingCids) paymentContext
    return (Some la, cids, expiresAt, meta)




-- Utilities
------------

requireExpectedAdminMatch : Party -> Party -> Update ()
requireExpectedAdminMatch expected actual =   require ("Expected admin " <> show expected <> " matches actual admin " <> show actual) (expected == actual)


{-
    -- allocationFactoryV1
    -- settlementFactoryV2

    interface instance V2.AllocationFactory for TokenRules where
      view = V2.AllocationFactoryView with
        admin
        meta = emptyMetadata

      allocationFactory_publicFetchImpl _self _arg = pure V2.AllocationFactoryView with
