-- | A mock implementation of a test token for the purpose of testing V2 token standard workflows.
module Splice.Testing.Tokens.TestTokenV2 where

import DA.Assert
import DA.Optional

import Splice.Api.Token.MetadataV1
import Splice.Api.Token.HoldingV1 qualified as V1
import Splice.Api.Token.AllocationV1 qualified as V1
import Splice.Api.Token.AllocationInstructionV1 qualified as V1
import Splice.Api.Token.HoldingV2 qualified as V2
import Splice.Api.Token.AllocationV2 qualified as V2
import Splice.Api.Token.AllocationInstructionV2 qualified as V2
import Splice.TokenStandard.Utils


template Token with
     holding : V2.HoldingView
  where
    signatory holding.owner, holding.instrumentId.admin

    ensure
      holding.amount > 0.0 -- positive amounts

    interface instance V2.Holding for Token where
      view = holding


template TokenAllocation with
    lockedToken : Optional (ContractId Token)
    allocation : V2.AllocationSpecification
    admin : Party
  where
    signatory allocation.transferLeg.sender, allocation.transferLeg.instrumentId.admin
    observer allocation.settlement.executor
    ensure isValidAllocationSpecificationV2 (\instrumentId -> instrumentId.admin == admin) allocation

    -- Note: in a production implementation we would also want to add a choice
    -- for the `admin` to expire the allocation. We don't need it for testing though.
{-
    interface instance V2.Allocation for TokenAllocation where
      view = V2.AllocationView with
        allocation
        holdingCids = optionalToList lockedToken
        meta = emptyMetadata

      allocation_withdrawImpl _self _arg = do
        tokenCid <- create Token with
          holding = (allocationHoldingView allocation) with lock = None
        pure V2.Allocation_WithdrawResult with
          authorizerHoldingCids = [toInterfaceContractId tokenCid]
          meta = emptyMetadata

      allocation_cancelImpl _self _arg = do
        tokenCid <- create Token with
          holding = (allocationHoldingView allocation) with lock = None
        pure V2.Allocation_CancelResult with
          authorizerHoldingCids = [toInterfaceContractId tokenCid]
          meta = emptyMetadata
-}

    interface instance V1.Allocation for TokenAllocation where
      view = V1.AllocationView with
        allocation
        holdingCids = [toInterfaceContractId lockedToken]
        meta = emptyMetadata

      allocation_executeTransferImpl _self V1.Allocation_ExecuteTransfer{..} =
        transferTokenAllocation this extraArgs

      allocation_withdrawImpl _self V1.Allocation_Withdraw{..} = do
        senderHoldingCids <- unlockTokenAllocation this extraArgs
        pure V1.Allocation_WithdrawResult
          with
            senderHoldingCids
            meta = emptyMetadata

      allocation_cancelImpl _self V1.Allocation_Cancel{..} = do
        senderHoldingCids <- unlockTokenAllocation this extraArgs
        pure V1.Allocation_CancelResult
          with
            senderHoldingCids
            meta = emptyMetadata

    interface instance V2.Allocation for TokenAllocation where
      view = upcast (view (toInterface @V1.Allocation this))

      -- executors are required actors on the settle choice, and thus do not have to be added as extra observers for settle
      allocation_settleExtraObservers _arg = []

      -- add the executor as an extra observer on the choices below, as they otherwise only see the V1 choice by default
      allocation_cancelExtraObservers _arg = [allocation.settlement.executor]
      allocation_withdrawExtraObservers _arg = [allocation.settlement.executor]

      allocation_withdrawImpl = allocationV2_withdrawDefaultImplUsingV1 (toInterface this)
      allocation_cancelImpl = allocationV2_cancelDefaultImplUsingV1 (toInterface this)
      allocation_settleImpl = allocationV2_settleDefaultImplUsingV1 (toInterface this)


transferTokenAllocation : TokenAllocation -> ExtraArgs -> Update V1.Allocation_ExecuteTransferResult
transferTokenAllocation allocation extraArgs = do
  case allocation.lockedToken of
    None -> fail "unexpected: V1 a"
      -- no locked token, just create the output token directly
      tokenCid <- create Token with
        holding = (allocationHoldingView allocation.allocation) with
          owner = allocation.allocation.transferLeg.receiver
          lock = None
      pure V1.Allocation_ExecuteTransferResult with
        senderHoldingCids = []
        receiverHoldingCids = [toInterfaceContractId tokenCid]
        meta = emptyMetadata
    Some lockedTokenCid -> do
      -- we have a locked token, we need to unlock it first and then transfer it to the receiver
      unlockResult <- exercise lockedTokenCid V2.Holding_UnlockV2 with extraArgs
      let unlockedTokenCid = unlockResult.holdingCid

      -- transfer the unlocked token to the receiver by exercising a choice on it that changes the owner
      transferredTokenCid <- exercise unlockedTokenCid Token_Transfer with newOwner = allocation.allocation.transferLeg.receiver

      pure V1.Allocation_ExecuteTransferResult with
        senderHoldingCids = []
        receiverHoldingCids = [toInterfaceContractId transferredTokenCid]
        meta = emptyMetadata
  tokenCid <- create Token with
    holding = (allocationHoldingView allocation) with
      owner = allocation.transferLeg.receiver
      lock = None
  pure V1.Allocation_ExecuteTransferResult with
    senderHoldingCids = []
    receiverHoldingCids = [toInterfaceContractId tokenCid]
    meta = emptyMetadata

{-
      allocation_settleImpl _self _arg = do
        tokenCid <- create Token with
          holding = (allocationHoldingView allocation) with
            owner = allocation.transferLeg.receiver
            lock = None
        pure V2.Allocation_SettleResult with
          authorizerHoldingCids = []
          receiverHoldingCids = [toInterfaceContractId tokenCid]
          meta = emptyMetadata
-}

