-- | Account authorization configuration and functions to make use of it.
module Splice.Testing.Tokens.TestTokenV2.AccountConfig where

import DA.Map qualified as Map
import DA.Optional
import DA.Set qualified as Set
import DA.Text qualified as T

import Splice.Api.Token.HoldingV2 qualified as V2
import Splice.Api.Token.TransferInstructionV2 qualified as V2


data PartyConfig = PartyConfig with
    canInitiate : Bool
    mustApprove : Bool
  deriving (Eq, Show)

-- | A configuration of the authorization rules for an account.
--
-- Note: this is but one possible way to configure account authorization rules.
-- It was built to demonstrate a non-trivial rule-set and test that the `V2.TransferInstruction` APIs
-- are sufficient for wallets to interact with the assets.
template AccountConfig
  with
    admin : Party
    account : V2.Account
    ownerConfig : PartyConfig
    providerConfig : PartyConfig
  where
    signatory account.owner, account.provider
    observer admin
    ensure isValidAccountConfig this

data AccountProposal_Accept_Result = AccountProposal_Accept_Result with
    accountConfig : ContractId AccountConfig
  deriving (Eq, Show)

data AccountProposal_Reject_Result = AccountProposal_Reject_Result with
  deriving (Eq, Show)

data AccountProposal_Withdraw_Result = AccountProposal_Withdraw_Result with
  deriving (Eq, Show)

template AccountProposal
  with
    config : AccountConfig
  where
    signatory (config.account.provider)
    observer config.account.owner

    choice AccountProposal_Accept : AccountProposal_Accept_Result
      controller config.account.owner
      do AccountProposal_Accept_Result <$> create config

    choice AccountProposal_Reject : AccountProposal_Reject_Result
      controller config.account.owner
      do return AccountProposal_Reject_Result
    
    choice AccountProposal_Withdraw : AccountProposal_Withdraw_Result
      controller (signatory this)
      do return AccountProposal_Withdraw_Result

-- | Valid accounts must have at least one party that can initiate an action and
-- at least one party that must approve an action.
isValidAccountConfig : AccountConfig -> Bool
isValidAccountConfig config =
  (config.ownerConfig.canInitiate || config.providerConfig.canInitiate) &&
  (config.ownerConfig.mustApprove || config.providerConfig.mustApprove)

partyConfigToString : PartyConfig -> Text
partyConfigToString config =
  (if config.canInitiate then "i" else "") <>
  (if config.mustApprove then "a" else "")

accountConfigToString : AccountConfig -> Text
accountConfigToString config = T.implode $
  [ "o", partyConfigToString config.ownerConfig
  , "p", partyConfigToString config.providerConfig]


-- Actors
----------

-- | The parties that can acct next on an account given the previous actor and the account config.
-- This function encodes the core of the state machine for who needs to act when.
nextActors : Optional Party -> AccountConfig -> Set.Set Party
nextActors previousActor config =
    Set.fromList $
      [ config.account.owner | canAct config.ownerConfig config.account.owner ] <>
      [ p | Some p <- [config.account.provider], canAct config.providerConfig p ]
  where
    hasNotActed p = Some p /= previousActor
    canAct (PartyConfig with canInitiate; mustApprove) p =
      hasNotActed p &&
      (canInitiate || isSome previousActor && mustApprove)

-- | Parties that must approve an action on the account.
requiredApprovers : AccountConfig -> Set.Set Party
requiredApprovers (AccountConfig with ownerConfig = owner, providerConfig = provider, account) =
  Set.fromList $
    [ account.owner | ownerApproval ] <>
    [ p | providerApproval, Some p <- [account.provider] ]
  where
    ownerApproval = owner.mustApprove || (owner.canInitiate && not provider.canInitiate)
    providerApproval = provider.mustApprove || (provider.canInitiate && not owner.canInitiate)

-- | Available actions on a transfer instruction.
--
-- FIXME: invert the Map of actions in a separate PR to simplify this code.
mkAvailableTransferActions
  : Map.Map V2.TransferInstructionAction Party
  -> AccountConfig -> AccountConfig -> Map.Map [Party] [V2.TransferInstructionAction]
mkAvailableTransferActions existingRequests sender receiver =
    Map.fromListWithR (++) $
      actionsFor V2.TIA_Accept receiver <>
      actionsFor V2.TIA_Reject receiver <>
      actionsFor V2.TIA_Withdraw sender
  where
    actionsFor action config =
      [ (actors, [action]) | actors <- nextActorsFor action existingRequests config ]

-- | Next actors for a particular action.
--
-- Used both for computing the available actions, as well as the actors that are allowed to exercise a particular action.
nextActorsFor : V2.TransferInstructionAction -> Map.Map V2.TransferInstructionAction Party -> AccountConfig -> [[Party]]
nextActorsFor action existingRequests config  =
  Set.toList (requiredApprovers config) ::
  [ [actor] | actor <- Set.toList (nextActors (Map.lookup action existingRequests) config) ]

-- FIXME: move to the definition of V2.TransferInstructionAction
deriving instance Ord V2.TransferInstructionAction
