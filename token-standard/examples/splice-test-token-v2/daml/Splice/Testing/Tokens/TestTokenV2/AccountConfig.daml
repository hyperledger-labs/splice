-- | Account authorization configuration and functions to make use of it.
module Splice.Testing.Tokens.TestTokenV2.AccountConfig where

import DA.Map qualified as Map

import Splice.Api.Token.HoldingV2 qualified as V2
import Splice.Api.Token.TransferInstructionV2 qualified as V2
import Splice.TokenStandard.Utils (accountParties)
import Splice.Api.Token.MetadataV1 (AnyValue(..), ExtraArgs)
import DA.List (dedupSort, dedup, (\\))
import DA.Assert ((===))
import DA.Optional (fromSome, isSome, isNone, fromOptional)
import qualified DA.TextMap as TextMap
import DA.Action (foldlA)


data PartyConfig = PartyConfig with
    canInitiate : Bool
    mustApprove : Bool
  deriving (Eq, Show)

-- | A configuration of the authorization rules for an account.
--
-- Note: this is but one possible way to configure account authorization rules.
-- It was built to demonstrate a non-trivial rule-set and test that the `V2.TransferInstruction` APIs
-- are sufficient for wallets to interact with the assets.
template AccountConfig
  with
    admin : Party
    account : V2.Account
    ownerConfig : PartyConfig
    providerConfig : PartyConfig
  where
    signatory account.owner, account.provider
    -- In this example, the admin accepts any Account configs agreed between owner and 
    -- provider. They are an observer in order to be able to serve account
    -- configs as choice context.
    observer admin
    ensure isValidAccountConfig this

    nonconsuming choice AuthorizeTransferInstructionAction : V2.TransferInstructionResult
     -- ^ This choice allos one of the two account parties to get authority from the other
     -- if their mustApprove flag is False.
      with
        actor : Party
        authorizer : Party
        action : V2.TransferInstructionAction
        transferInstructionCid : ContractId V2.TransferInstruction
        extraArgs : ExtraArgs
      controller actor
      do 
        assertMsg ("Authorization transfer from " <> show actor <> " to " <> show authorizer <> " is not allowed.") 
          ((actor, authorizer) `elem` authorizationTransfers this)
        
        trasferInstructionView <- view <$> fetch transferInstructionCid
        admin === trasferInstructionView.transfer.instrumentId.admin
        
        case action of
          V2.TIA_Accept -> exercise transferInstructionCid (V2.TransferInstruction_Accept [authorizer] extraArgs)
          V2.TIA_Reject -> exercise transferInstructionCid (V2.TransferInstruction_Reject [authorizer] extraArgs)
          V2.TIA_Withdraw -> exercise transferInstructionCid (V2.TransferInstruction_Withdraw [authorizer] extraArgs)
          _ -> abort "Custom actions are not supported."

data AccountProposal_Accept_Result = AccountProposal_Accept_Result with
    accountConfig : ContractId AccountConfig
  deriving (Eq, Show)

data AccountProposal_Reject_Result = AccountProposal_Reject_Result with
  deriving (Eq, Show)

data AccountProposal_Withdraw_Result = AccountProposal_Withdraw_Result with
  deriving (Eq, Show)

template AccountProposal
  with
    config : AccountConfig
  where
    signatory (config.account.provider)
    observer config.account.owner

    choice AccountProposal_Accept : AccountProposal_Accept_Result
      controller config.account.owner
      do AccountProposal_Accept_Result <$> create config

    choice AccountProposal_Reject : AccountProposal_Reject_Result
      controller config.account.owner
      do return AccountProposal_Reject_Result
    
    choice AccountProposal_Withdraw : AccountProposal_Withdraw_Result
      controller (signatory this)
      do return AccountProposal_Withdraw_Result

-- | Valid accounts must have at least one party that can initiate an action and
-- at least one party that must approve an action.
isValidAccountConfig : AccountConfig -> Bool
isValidAccountConfig config =
  (config.ownerConfig.canInitiate || config.providerConfig.canInitiate) &&
  (config.ownerConfig.mustApprove || config.providerConfig.mustApprove)

-- Actors
----------

-- | Available actions on a transfer instruction.
-- This function encodes the core of the state machine for who needs to act when.
--
-- FIXME: invert the Map of actions in a separate PR to simplify this code.
mkAvailableTransferActions
  : Map.Map V2.TransferInstructionAction [Party]
  -> AccountConfig -> AccountConfig -> Map.Map [Party] [V2.TransferInstructionAction]
mkAvailableTransferActions actionAuthorizers sender receiver =
    Map.fromListWithR (++) $
      actionsFor V2.TIA_Accept missingAcceptAuthorizers acceptAccount <>
      actionsFor V2.TIA_Reject missingRejectAuthorizers receiver <>
      actionsFor V2.TIA_Withdraw missingWithdrawAuthorizers sender
  where
    acceptAuthorizers = fromOptional [] $ Map.lookup V2.TIA_Accept actionAuthorizers
    isSenderAccepted = null (accountParties sender.account \\ acceptAuthorizers)
    (missingAcceptAuthorizers, acceptAccount) = 
      if isSenderAccepted
        then ((accountParties receiver.account \\ acceptAuthorizers), receiver)
        else ((accountParties sender.account \\ acceptAuthorizers), sender)
    
    rejectAuthorizers = fromOptional [] $ Map.lookup V2.TIA_Reject actionAuthorizers
    missingRejectAuthorizers = 
      if isSenderAccepted
        then (accountParties receiver.account \\ rejectAuthorizers)
        else []

    withdrawAuthorizers = fromOptional [] $ Map.lookup V2.TIA_Withdraw actionAuthorizers
    missingWithdrawAuthorizers = 
      if isSenderAccepted
        then (accountParties sender.account \\ withdrawAuthorizers)
        else (acceptAuthorizers \\ withdrawAuthorizers)
    
    actionsFor action missingAuthorizers config =
      [ (actors, [action]) | actors <- nextActors' missingAuthorizers config, not (null actors) ]

nextActors' : [Party] -> AccountConfig -> [[Party]]
nextActors' missingAuthorizers config = dedupSort $
  [[config.account.owner] | canAct config.account.owner config.ownerConfig] <>
  [[provider] | Some provider <- [config.account.provider], provider `elem` missingAuthorizers && (isInitialized || config.providerConfig.canInitiate)] <>
  [missingAuthorizers]
  where
    canAct p c = p `elem` missingAuthorizers && (isInitialized || c.canInitiate)
    isInitialized = missingAuthorizers /= (accountParties config.account)
    
reverseMap : (Ord b) => Map.Map a [b] -> Map.Map b [a]
reverseMap m = 
  Map.fromListWithR (++) $
  concatMap (\(x, ys) -> map (, [x]) ys) $
  Map.toList m

-- A function to determine whose authority can be transferred to another via
-- AuthorizeTransferInstructionAction.
authorizationTransfers : AccountConfig -> [(Party, Party)]
authorizationTransfers config = case config.account.provider of
  None -> []
  Some provider ->
    let cs = [(config.account.owner, config.ownerConfig), (provider, config.providerConfig)]
     in [(p, q) | (p, pConfig) <- cs, (q, qConfig) <- cs, q /= p, not qConfig.mustApprove, pConfig.canInitiate]

-- Utility function to use sender/receiver accounts to transfer authority between owner and provider
-- via AuthorizeTransferInstructionAction
tryUseAccountAuthority : 
  [Party] 
  -> [[Party]]
  -> V2.TransferInstructionAction
  -> (AccountConfig, Optional (ContractId AccountConfig))
  -> (AccountConfig, Optional (ContractId AccountConfig))
  -> ContractId V2.TransferInstruction
  -> ExtraArgs
  -> Update (Optional V2.TransferInstructionResult)
tryUseAccountAuthority actors neededActors action (senderConfig, oSenderCid) (receiverConfig, oReceiverCid) instrCid extraArgs = do
  let senderAuthorizationTransfers = 
        filter (\(actor, authorizer) -> actor `elem` actors && [authorizer] `elem` neededActors) 
        (authorizationTransfers senderConfig)
  let receiverAuthorizationTransfers = 
        filter (\(actor,authorizer) -> actor `elem` actors && [authorizer] `elem` neededActors) 
        (authorizationTransfers receiverConfig)

  let transferAuthority actor authorizer accountCid =
        exercise accountCid AuthorizeTransferInstructionAction with
          actor
          authorizer
          extraArgs
          transferInstructionCid = instrCid
          action

  -- Deal with a special case where the authorizer is a party on both accounts.
  -- In that case, we only want to transfer authority if it's allowed on _both_
  -- accounts.
  let
    authorizerOnBothAccounts authorizer = 
      authorizer `elem` accountParties senderConfig.account && 
      authorizer `elem` accountParties receiverConfig.account
    transferAllowedByBothAccounts actor authorizer =
      (actor, authorizer) `elem` senderAuthorizationTransfers &&
      (actor, authorizer) `elem` receiverAuthorizationTransfers
    acceptTransferAllowed actor authorizer = 
      not (authorizerOnBothAccounts authorizer) ||
      transferAllowedByBothAccounts actor authorizer

  case (senderAuthorizationTransfers, receiverAuthorizationTransfers, oSenderCid, oReceiverCid, action) of
    ((actor, authorizer)::_, _, Some accountCid, _, V2.TIA_Withdraw) -> Some <$> transferAuthority actor authorizer accountCid
    (_, (actor, authorizer)::_, _, Some accountCid, V2.TIA_Reject) -> Some <$> transferAuthority actor authorizer accountCid
    ((actor, authorizer)::_, _, Some accountCid, _, V2.TIA_Accept) -> 
      if acceptTransferAllowed actor authorizer 
        then Some <$> transferAuthority actor authorizer accountCid
        else pure None
    (_, (actor, authorizer)::_, _, Some accountCid, V2.TIA_Accept) ->
      if acceptTransferAllowed actor authorizer 
        then Some <$> transferAuthority actor authorizer accountCid
        else pure None

    _ -> pure None


-- Parsing Choice Context
-------------------------

extractAccountConfigMap
  : Party -> ExtraArgs -> [V2.Account] -> Update (Map.Map V2.Account (AccountConfig, Optional (ContractId AccountConfig)))
extractAccountConfigMap admin extraArgs as = do
  let
    cids = case TextMap.lookup "testTokenV2/accountConfigs" extraArgs.context.values of
      Some (AV_List cs) -> map (\(AV_ContractId cid) -> cid) cs
      None -> []
      _ -> error "unexpected value in testTokenV2/accountConfigs"
  
  suppliedMap <- Map.fromList <$>
    mapA (\cid -> do
        config <- fetch @AccountConfig (coerceContractId cid)
        return (config.account, (config, Some (coerceContractId cid)))
      )
      cids
  
  let
    basicConfig account = AccountConfig with
      admin
      account
      ownerConfig = PartyConfig True True
      providerConfig = PartyConfig False False
    addBasicValidated accountMap account = do
      case account.provider of
        None -> do
          assertMsg "Not expecting account contract for self-custodial account" (isNone (Map.lookup account accountMap))
          return (Map.insert account (basicConfig account, None) accountMap)
        Some _ -> do
          assertMsg ("No account config supplies for account " <> (show account)) (isSome (Map.lookup account accountMap))
          return accountMap

  foldlA addBasicValidated suppliedMap (dedup as)

-- Convenience to get account configs as a list.
extractAccountConfigs
  : Party -> ExtraArgs -> [V2.Account] -> Update [(AccountConfig, Optional (ContractId AccountConfig))]
extractAccountConfigs admin extraArgs as = do
  accountConfigsMap <- extractAccountConfigMap admin extraArgs as
  return $ map (\a -> fromSome (Map.lookup a accountConfigsMap)) as

