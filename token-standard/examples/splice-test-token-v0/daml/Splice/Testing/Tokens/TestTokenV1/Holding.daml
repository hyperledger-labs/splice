module Splice.Testing.Tokens.TestTokenV1.Holding where

import Splice.Api.Token.MetadataV1
import Splice.Api.Token.HoldingV1 qualified as Holding
import DA.Text qualified as Text

template Token
  with
    admin : Party
    owner : Party
    amount : Decimal
    createdAt : Time
  where
    signatory admin
    observer owner

    interface instance Holding.Holding for Token where
      view = Holding.HoldingView with
        owner
        instrumentId = Holding.InstrumentId
          with
            admin
            id = Text.sha256 $ show createdAt <> show owner
        amount
        lock = None
        meta = emptyMetadata
