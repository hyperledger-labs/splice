-- | An example of how to build an OTC trading app that supports V1/V2 mixed settlements
-- with extra privacy for V2 allocations..
--
-- Used as part of the testing infrastructure to test the V2 token standard DvP workflows.
module Splice.Testing.Apps.TradingAppV2 where

import DA.Assert
import DA.Either (partitionEithers)
import DA.Foldable (forA_)
import DA.Optional (fromSomeNote)
import DA.Map qualified as Map
import DA.TextMap qualified as TextMap

import Splice.Api.Token.MetadataV1
import Splice.Api.Token.AllocationRequestV1 qualified as V1
import Splice.Api.Token.AllocationV1 qualified as V1
import Splice.Api.Token.AllocationV2 qualified as V2
import Splice.Api.Token.AllocationInstructionV2 qualified as V2
import Splice.Api.Token.AllocationRequestV2 qualified as V2
import Splice.Api.Token.HoldingV2 qualified as V2

import Splice.TokenStandard.Utils


-- | A request to a single trading account to authorize their legs to the trade.
template OTCTradeAllocationRequest with
    authorizer : V2.Account
    settlement : V2.SettlementInfo
    transferLegs : [V2.TransferLeg]
  where
    signatory settlement.executors
    observer accountParties authorizer

    interface instance V1.AllocationRequest for OTCTradeAllocationRequest where
      view = downcast (view @V2.AllocationRequest (toInterface this))

      allocationRequest_RejectImpl = allocationRequestV1_rejectDefaultImpl (accountParties authorizer)
      allocationRequest_WithdrawImpl = allocationRequestV1_withdrawDefaultImpl (toInterface this)

    interface instance V2.AllocationRequest for OTCTradeAllocationRequest where
      view = V2.AllocationRequestView with
        settlement
        transferLegs
        authorizer
        availableActions = Map.fromList
          [ ([p], [V2.ARA_Accept, V2.ARA_Reject]) | p <- accountParties authorizer ]
        meta = emptyMetadata

      allocationRequest_acceptExtraObservers = allocationRequestV2_acceptDefaultExtraObservers this
      allocationRequest_rejectExtraObservers = allocationRequestV2_rejectDefaultExtraObservers this
      allocationRequest_withdrawExtraObservers = allocationRequestV2_withdrawDefaultExtraObservers this

      allocationRequest_acceptImpl = allocationRequestV2_acceptDefaultImpl [[p] | p <- accountParties authorizer]
      allocationRequest_rejectImpl = allocationRequestV2_rejectDefaultImplUsingV1 [[p] | p <- accountParties authorizer]
      allocationRequest_withdrawImpl = allocationRequestV2_withdrawDefaultImplUsingV1 (toInterface this)

-- | A V1 allocation with enough context to settle or cancel it.
data AllocationWithContextV1 = AllocationWithContextV1 with
    allocationCid : ContractId V1.Allocation
    extraArgs : ExtraArgs
    senderAgreementCid : ContractId TradeSettlementAgreement
    receiverAgreementCid : ContractId TradeSettlementAgreement
  deriving (Eq, Show)

data MissingAllocation = MissingAllocation with
    authorizerAgreementCid : Optional (ContractId TradeSettlementAgreement)
      -- ^ None for missing allocations of the venue itself.
    factoryCid : ContractId V2.AllocationFactory
    choiceArg : V2.AllocationFactory_Allocate
  deriving (Eq, Show)

-- | A batch of allocations for the same admin together with the extra arguments required to settle them.
data SettlementBatch
  = -- | Batch for V1-only admins
    SettlementBatchV1 with
      allocationsWithContext : TextMap.TextMap AllocationWithContextV1
  | SettlementBatchV2 with
      allocationCids : [ContractId V2.Allocation]
      missingAllocations : [MissingAllocation]
       -- ^ Allocations that should be created as part of settlement.
       --
       -- These are:
       --   - the allocation(s) of the venue to receive fees
       --   - the allocations for the receipt of V2 assets for traders that use V1 wallets,
       --     which do not create receipt allocations on their own
      factoryCid : ContractId V2.SettlementFactory
      extraArgs : ExtraArgs
  deriving (Eq, Show)


-- | A matched trade ready to settle.
template OTCTrade with
    venue : Party
    transferLegs : [V2.TransferLeg] -- ^ Transfers to settle.
    createdAt : Time -- ^ When the matched trade was created on-ledger.
    settleAt : Time -- ^ When the trade should be settled by.
    settlementDeadline : Optional Time -- ^ Deadline for when the settlement should be completed.
  where
    signatory venue

    nonconsuming choice OTCTrade_RequestAllocations : [ContractId OTCTradeAllocationRequest]
      with
      controller venue
      do
        let settlement = mkOtcTradeSettlementInfo self this
        forA (Map.toList $ splitLegsByAuthorizer transferLegs) $ \(authorizer, transferLegs) -> do
          create OTCTradeAllocationRequest with
            authorizer
            settlement
            transferLegs

    choice OTCTrade_Settle : OTCTrade_SettleResult
      with
        batchesByAdmin : Map.Map Party SettlementBatch
          -- ^ Allocations
        allocationRequests : [ContractId OTCTradeAllocationRequest]
          -- ^ Allocation request to archive as part of settlement.
      controller venue
      do
        forA_ settlementDeadline $ \deadline ->
          assertWithinDeadline "settlementDeadline" deadline

        -- compute reference data
        let settlement = mkOtcTradeSettlementInfo self this
            transferLegsByAdmin = splitLegsByAdmin transferLegs

        -- Archive requests known to be active at this point, so that trader
        -- wallets won't see the archival of the allocation without a
        -- corresponding archival of the request.
        forA_ allocationRequests $ \reqCid -> do
          req <- fetch reqCid
          archive reqCid
          requireMatchExpected ("AllocationRequest.settlement", req.settlement) settlement
          -- note: we are not checking that there is a request for every traders, as it could be
          -- there there is a request that got rejected but the allocation still got created.
          --
          -- In a real app, we expect that the trading app runs cleanup automation that
          -- archives requests for which no matching trade exists.

        -- important: we must iterate over all transfer legs to ensure that ALL of them get settled
        results <- forA (Map.toList transferLegsByAdmin) $ \(admin, transferLegs) -> do
          case Map.lookup admin batchesByAdmin of
            None -> abort $ "No settlement batch found for admin " <> show admin

            Some (SettlementBatchV2 with factoryCid; allocationCids; extraArgs; missingAllocations) -> do
              -- Create missing receipt allocations
              receiptAllocCids <- forA missingAllocations $ \missingAlloc ->
                case missingAlloc.authorizerAgreementCid of
                  None -> do
                    result <- exercise missingAlloc.factoryCid missingAlloc.choiceArg
                    extractAllocationCidFromResult result
                  Some agreementCid -> do
                    -- This is a receipt allocation for a trader that still has
                    -- a V1 wallet ==> use their agreement to create the allocation on their behalf
                    exercise agreementCid TradeSettlementAgreement_CreateReceiptAllocation with
                      factoryCid = missingAlloc.factoryCid
                      choiceArg = missingAlloc.choiceArg

              -- For V2 settlement, the _SettleBatch choice itself checks that the allocations match the legs
              result <- exercise factoryCid V2.SettlementFactory_SettleBatch with
                settlement
                transferLegs
                allocationCids = allocationCids <> receiptAllocCids
                actors = [venue]
                extraArgs = extraArgs
              pure $ Right (admin, result)

            Some (SettlementBatchV1 with allocationsWithContext) -> do
              -- For V1 settlement, we need to check that the allocations match the legs here
              let expectedAllocations = expectedTradeAllocationsV1 settlement transferLegs
              let mergedMaps = textMapZip allocationsWithContext expectedAllocations
              results <- textMapTraverseWithKey mergedMaps \legId (optSettleableAlloc,  optExpectedAlloc) -> do
                let AllocationWithContextV1 {allocationCid, extraArgs, receiverAgreementCid, senderAgreementCid} =
                      fromSomeNote ("Settleable allocation is missing for leg " <> legId) optSettleableAlloc
                let expectedAlloc = fromSomeNote ("Allocation with context provided for unexpected leg " <> legId) optExpectedAlloc
                -- fetch and validate the allocation
                alloc <- fetch @V1.Allocation allocationCid
                let allocView = view @V1.Allocation alloc
                requireMatchExpected ("allocation for leg " <> legId, allocView.allocation) expectedAlloc
                exercise senderAgreementCid TradeSettlementAgreement_ExecuteTransferAsSender with
                  receiverAgreementCid
                  allocationCid
                  extraArgs
              pure $ Left (admin, results)

        let (resultsByAdminV1, resultsByAdminV2) = partitionEithers results
        pure OTCTrade_SettleResult with
          resultsByAdminV1 = Map.fromList resultsByAdminV1
          resultsByAdminV2 = Map.fromList resultsByAdminV2


    -- NOTE: this choice is an approximation to what a real app would do.
    -- As it stands, the venue can't cancel allocations that come right after
    -- the first cancellation.  A better approach would be to leave a marker
    -- contract in place until the `settleBefore` time, so that the venue
    -- retains the ability to cancel the allocations that are created.
    choice OTCTrade_Cancel : OTCTrade_CancelResult
      with
        allocationsWithContextV1 : [AllocationWithContextV1]
          -- ^ V1 allocations to cancel, together with the context required to cancel them.
        allocationsWithContextV2 : [(ContractId V2.Allocation, ExtraArgs)]
        allocationRequestCids : [ContractId OTCTradeAllocationRequest]
      controller venue
      do
        let settlementV2 = mkOtcTradeSettlementInfo self this
        let settlementV1 = downcast settlementV2
        forA_ allocationRequestCids $ \reqCid -> do
            req <- fetch reqCid
            archive reqCid
            requireMatchExpected ("AllocationRequest.settlement", req.settlement) settlementV2
        resultsV1 <- forA allocationsWithContextV1 $ \allocWithContext -> do
            let AllocationWithContextV1 {allocationCid, extraArgs, senderAgreementCid, receiverAgreementCid} = allocWithContext
            alloc <- fetch allocationCid
            let allocation = (view alloc).allocation
            requireMatchExpected ("Allocation.settlement", allocation.settlement) settlementV1
            result <- exercise senderAgreementCid TradeSettlementAgreement_CancelAsSender with
              receiverAgreementCid
              allocationCid
              extraArgs
            pure (allocation, result)
        resultsV2 <- forA allocationsWithContextV2 $ \(allocCid, extraArgs) -> do
            alloc <- fetch allocCid
            let allocView = view alloc
            requireMatchExpected ("Allocation.settlement", allocView.allocation.settlement) settlementV2
            result <- exercise allocCid $ V2.Allocation_Cancel with
              actors = [venue]
              extraArgs
            pure (allocView.allocation, result)
        pure OTCTrade_CancelResult with
          resultsV1 = TextMap.fromList [ (allocation.transferLegId, result) | (allocation, result) <- resultsV1 ]
          resultsV2 = [ (allocation.authorizer, result) | (allocation, result) <- resultsV2 ]

data OTCTrade_SettleResult = OTCTrade_SettleResult with
  resultsByAdminV1 : Map.Map Party (TextMap.TextMap V1.Allocation_ExecuteTransferResult)
    -- ^ Results for V1-only admins
  resultsByAdminV2 : Map.Map Party V2.SettlementFactory_SettleBatchResult
    -- ^ Result for admins that support V2

data OTCTrade_CancelResult = OTCTrade_CancelResult with
  resultsV1 : TextMap.TextMap V1.Allocation_CancelResult
    -- ^ Results for V1 allocation cancellations keyed by transferLegId
  resultsV2 : [(V2.Account, V2.Allocation_CancelResult)]

makeTradeRef : ContractId OTCTrade -> V2.Reference
makeTradeRef tradeCid = V2.Reference with
  id = "OTCTradeProposal" -- set to the name of the template to simplify debugging
  cid = Some (coerceContractId tradeCid)

mkOtcTradeSettlementInfo : ContractId OTCTrade -> OTCTrade -> V2.SettlementInfo
mkOtcTradeSettlementInfo otcTradeCid otcTrade = V2.SettlementInfo with
  executors = [otcTrade.venue]
  requestedAt = otcTrade.createdAt
  settlementRef = makeTradeRef otcTradeCid
  settleAt = otcTrade.settleAt
  meta = emptyMetadata
  settlementDeadline = otcTrade.settlementDeadline

-- | The expected allocations for a trade that involves an asset implementing
-- the V1 token standard only. There we expect exactly one allocation per transfer leg.
-- That allocation is created by the sender, and settleed with the authority of sender
-- and receiver
expectedTradeAllocationsV1
  : V2.SettlementInfo -> [V2.TransferLeg] -> TextMap.TextMap V1.AllocationSpecification
expectedTradeAllocationsV1 settlementInfoV2 transferLegs =
  TextMap.fromList $ do
    transferLeg <- transferLegs
    let spec = V1.AllocationSpecification with
          settlement = settlementInfo
          transferLegId = transferLeg.transferLegId
          transferLeg = downcast transferLeg
    pure (transferLeg.transferLegId, spec)
  where
    settlementInfo = downcast settlementInfoV2


-- V1 Authorization infrastructure
----------------------------------

-- | An agreement to authorize the settlement of a trade by the venue, as an
-- additional settlementAuthorizer. Used to settle V1 allocations, which require
-- extra settlement authorizers to authorize the batch settlement.
template TradeSettlementAgreement with
    venue : Party
    trader : Party
  where
    signatory venue, trader

    nonconsuming choice TradeSettlementAgreement_ExecuteTransferAsSender : V1.Allocation_ExecuteTransferResult
      with
        receiverAgreementCid : ContractId TradeSettlementAgreement
        allocationCid : ContractId V1.Allocation
        extraArgs : ExtraArgs
      controller venue
      do
        validateAllocationAsSender this receiverAgreementCid allocationCid
        exercise receiverAgreementCid TradeSettlementAgreement_ExecuteTransferAsReceiver with
          sender = trader
          allocationCid
          extraArgs

    nonconsuming choice TradeSettlementAgreement_ExecuteTransferAsReceiver : V1.Allocation_ExecuteTransferResult
      with
        sender : Party
        allocationCid : ContractId V1.Allocation
        extraArgs : ExtraArgs
      controller venue, sender
      do
        validateAllocationAsReceiver this sender allocationCid
        exercise allocationCid (V1.Allocation_ExecuteTransfer extraArgs)

    nonconsuming choice TradeSettlementAgreement_CancelAsSender : V1.Allocation_CancelResult
      with
        receiverAgreementCid : ContractId TradeSettlementAgreement
        allocationCid : ContractId V1.Allocation
        extraArgs : ExtraArgs
      controller venue
      do
        validateAllocationAsSender this receiverAgreementCid allocationCid
        exercise receiverAgreementCid TradeSettlementAgreement_CancelAsReceiver with
          sender = trader
          allocationCid
          extraArgs

    nonconsuming choice TradeSettlementAgreement_CancelAsReceiver : V1.Allocation_CancelResult
      with
        sender : Party
        allocationCid : ContractId V1.Allocation
        extraArgs : ExtraArgs
      controller venue, sender
      do
        validateAllocationAsReceiver this sender allocationCid
        exercise allocationCid (V1.Allocation_Cancel extraArgs)

    nonconsuming choice TradeSettlementAgreement_CreateReceiptAllocation : ContractId V2.Allocation
      with
        factoryCid : ContractId V2.AllocationFactory
        choiceArg : V2.AllocationFactory_Allocate
      controller venue
      do
        -- Important: validate the factory call to create a receipt allocation
        -- to avoid accidentally delegating sending assets to the venue .
        ensureIsReceiptAllocation [venue] trader (basicAccount trader) choiceArg
        result <- exercise factoryCid choiceArg
        extractAllocationCidFromResult result


extractAllocationCidFromResult : V2.AllocationInstructionResult -> Update (ContractId V2.Allocation)
extractAllocationCidFromResult result =
  case result.output of
    V2.AllocationInstructionResult_Completed allocCid -> pure allocCid
    V2.AllocationInstructionResult_Pending _ ->
      abort "Receipt allocation with multi-step allocation workflows is not supported"
    V2.AllocationInstructionResult_Failed ->
      abort $ "Failed to create receipt allocation with " <> show result.meta

validateAllocationAsSender : TradeSettlementAgreement -> ContractId TradeSettlementAgreement -> ContractId V1.Allocation -> Update ()
validateAllocationAsSender this receiverAgreementCid allocationCid = do
  alloc <- fetch allocationCid
  receiverAgreement <- fetch receiverAgreementCid
  let allocation = (view alloc).allocation
  require' ("allocation.settlement.executor", allocation.settlement.executor) isEqualR ("venue", this.venue)
  require' ("receiverAgreement.venue", receiverAgreement.venue) isEqualR ("venue", this.venue)
  require' ("allocation.transferLeg.sender", allocation.transferLeg.sender) isEqualR ("trader", this.trader)
  require' ("allocation.transferLeg.receiver", allocation.transferLeg.receiver)
    isEqualR ("receiverAgreement.trader", receiverAgreement.trader)

validateAllocationAsReceiver : TradeSettlementAgreement -> Party -> ContractId V1.Allocation -> Update ()
validateAllocationAsReceiver this sender allocationCid = do
  alloc <- fetch allocationCid
  let allocation = (view alloc).allocation
  require' ("allocation.settlement.executor", allocation.settlement.executor) isEqualR ("venue", this.venue)
  require' ("allocation.transferLeg.sender", allocation.transferLeg.sender) isEqualR ("sender", sender)
  require' ("allocation.transferLeg.receiver", allocation.transferLeg.receiver) isEqualR ("trader", this.trader)
