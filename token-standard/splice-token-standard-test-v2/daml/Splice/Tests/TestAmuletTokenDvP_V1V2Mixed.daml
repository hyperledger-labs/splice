-- | Daml script tests showing how to batch settle allocations created using
-- both the V1 and V2 allocation factories in a single settlement using the V2
-- settlement factory.
--
-- Uses Amulet as the test token, but can be extened to use multiple tokens from
-- different registries as well.
--
-- TODO(#4542): do so by implementing a test asset with accountable holdings and privacy
module Splice.Tests.TestAmuletTokenDvP_V1V2Mixed where

import Daml.Script

import DA.Action
import DA.Foldable (forA_, foldMap)
import DA.Map as Map hiding (filter)
import DA.List (dedupOn, dedupSort)
import DA.Optional
import DA.Set qualified as Set
import DA.Text qualified as T
import DA.Time

import Splice.Api.Token.MetadataV1
import Splice.Api.Token.AllocationV1 qualified as V1
import Splice.Api.Token.AllocationRequestV1 qualified as V1
import Splice.Api.Token.HoldingV2 qualified as V2
import Splice.Api.Token.AllocationV2 qualified as V2
import Splice.Api.Token.AllocationRequestV2 qualified as V2

import Splice.TokenStandard.Utils

import Splice.Amulet (LockedAmulet, LockedAmulet_OwnerExpireLockV2(..))

import Splice.Testing.Apps.TradingAppV2 hiding (require)
import Splice.Testing.UtilsV2
import Splice.Testing.Registries.AmuletRegistryV2 qualified as AmuletRegistryV2
import Splice.Testing.TokenStandard.RegistryApiV2 qualified as RegistryApiV2
import Splice.Testing.TokenStandard.WalletClientV2 qualified as WalletClientV2

import Splice.Testing.Registries.AmuletRegistry qualified as AmuletRegistryV1
import Splice.Testing.TokenStandard.MultiRegistry qualified as MultiRegistry


-- Tests definitions
--------------------

data TestEnvironment = TestEnvironment
  with
    venue : Party
    alice : Party
    bob : Party
    charlie : Party
    dora : Party
    allParties : [Party]
    registryV2 : AmuletRegistryV2.AmuletRegistry
    registryV1 : AmuletRegistryV1.AmuletRegistry
    registries : MultiRegistry.MultiRegistry
    amuletId : V2.InstrumentId
    -- TODO(#4515): add the registry for the private asset

data TestHolding = TestHolding with
    owner : Party
    amount : Decimal
    locked : Bool
    -- TODO(#4517): add instrument-id, test funding from locked holdings, and expired locked holdings
  deriving (Eq, Show)

mkH : Party -> Decimal -> TestHolding
mkH owner amount = TestHolding owner amount False

mkLH : Party -> Decimal -> TestHolding
mkLH owner amount = TestHolding owner amount True

data TestLeg = TestLeg with
    sender : Party
    receiver : Party
    amount : Decimal
    -- TODO(#4517): add instrument-id once we have private holdings
  deriving (Eq, Show)

data TestWorkflow
  = SettleTrade
  | WithdrawAndCancel with
      withdrawers : [Party]
      locksToExpireBeforeWithdrawal : [TestHolding]
  deriving (Eq, Show)

data TestTrade = TestTrade with
    partiesWithV1Wallet : [Party]
    partiesWithSettlementAgreements : [Party]
    partiesWithAutoReceipt : [Party]
      -- ^ Parties that have enabled auto-receipt for their trades at the venue.
      -- Unless they are the venue itself, they must have a settlement agreement in place to enable settlement.
    initialHoldings : [TestHolding]
    transferLegs : [TestLeg]
    expectedNumRequests : Int
    expectedNumAllocations : Int
    expectedHoldingsAfterAllocation : [TestHolding]
    testWorkflow : TestWorkflow
    expectedFinalHoldings : [TestHolding]
  deriving (Eq, Show)

-- Test suite: single transfers
-------------------------------

singleTransferTest : TestEnvironment -> TestTrade
singleTransferTest TestEnvironment{..} =
  TestTrade with
    partiesWithV1Wallet = []
    partiesWithSettlementAgreements = []
    partiesWithAutoReceipt = []
    initialHoldings = [mkH alice 100.0]
    transferLegs = [aliceToBob]
    expectedNumRequests = 2
    expectedNumAllocations = 2
    expectedHoldingsAfterAllocation = [mkLH alice 1.0, mkH alice 99.0]
    testWorkflow = SettleTrade
    expectedFinalHoldings = [mkH bob 1.0, mkH alice 99.0]
  where
    aliceToBob = TestLeg with
        sender = alice
        receiver = bob
        amount = 1.0

singleTransferTest_allV2 = runTest $ \env ->
  singleTransferTest env

singleTransferTest_senderV1 = runTest $ \env@TestEnvironment{..} ->
  (singleTransferTest env) with
    partiesWithV1Wallet = [alice]
    expectedNumAllocations = 2
    partiesWithSettlementAgreements = [alice, bob]

singleTransferTest_receiverV1 = runTest $ \env@TestEnvironment{..} ->
  (singleTransferTest env) with
    partiesWithV1Wallet = [bob]
    partiesWithAutoReceipt = [bob]
    expectedNumRequests = 1 -- only one request is sent, as bob has enabled auto-receipt
    expectedNumAllocations = 1
    partiesWithSettlementAgreements = [bob]

singleTransferTest_allV2_cancel = runTest $ \env@TestEnvironment{..} ->
  (singleTransferTest env) with
    testWorkflow = WithdrawAndCancel with
      withdrawers = [alice]
      locksToExpireBeforeWithdrawal = []
    expectedFinalHoldings = [mkH alice 99.0, mkH alice 1.0]

-- TODO(#4517): expand coverage of cancellation and withdrawal tests


-- Test suite: bilateral DvPs with fees
---------------------------------------

dvpWithFeeTest : TestEnvironment -> TestTrade
dvpWithFeeTest TestEnvironment{..} =
  TestTrade with
    partiesWithV1Wallet = []
    partiesWithSettlementAgreements = []
    partiesWithAutoReceipt = []
    initialHoldings = [mkH alice 100.0, mkH bob 100.0]
    transferLegs = [aliceToBob, bobToVenue]
    expectedNumRequests = 3
    expectedNumAllocations = 3
    expectedHoldingsAfterAllocation = [mkLH alice 20.0, mkH alice 80.0, mkH bob 100.0]
    testWorkflow = SettleTrade
    expectedFinalHoldings = [mkH alice 80.0, mkH bob 100.0, mkH bob 19.0, mkH venue 1.0]
  where
    aliceToBob = TestLeg with
        sender = alice
        receiver = bob
        amount = 20.0
    bobToVenue = TestLeg with
        sender = bob
        receiver = venue
        amount = 1.0

dvpWithFeeTest_onlyV2 = runTest $ \env ->
  dvpWithFeeTest env

dvpWithFeeTest_onlyV2_venueAutoReceipt = runTest $ \env@TestEnvironment{..} ->
  (dvpWithFeeTest env) with
    partiesWithAutoReceipt = [venue]
    expectedNumRequests = 2 -- no request sent to venue, as it has enabled auto-receipt
    expectedNumAllocations = 2
    partiesWithSettlementAgreements = [bob]

dvpWithFeeTest_onlyV2_venueBobAutoReceipt = runTest $ \env@TestEnvironment{..} ->
  (dvpWithFeeTest env) with
    partiesWithAutoReceipt = [venue, bob]
    expectedNumRequests = 2 -- request still sent to bob as they are a sender
    expectedNumAllocations = 2
    partiesWithSettlementAgreements = [bob]

dvpWithFeeTest_onlyV2_cancel = runTest $ \env@TestEnvironment{..} ->
  (dvpWithFeeTest env) with
    testWorkflow = WithdrawAndCancel with
      withdrawers = []
      locksToExpireBeforeWithdrawal = [mkLH alice 20.0]
    expectedFinalHoldings = [mkH alice 80.0, mkH alice 20.0, mkH bob 100.0]

