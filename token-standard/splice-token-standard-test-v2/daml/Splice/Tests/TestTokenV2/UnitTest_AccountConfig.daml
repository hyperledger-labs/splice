module Splice.Tests.TestTokenV2.UnitTest_AccountConfig where

import DA.Action (unless)
import DA.Foldable (forA_)
import DA.Set qualified as Set
import DA.Text qualified as T

import Daml.Script

import Splice.Api.Token.HoldingV2 qualified as V2
import Splice.Testing.Tokens.TestTokenV2.AccountConfig

accountConfigFromPartyConfigs : Text -> PartyConfig -> PartyConfig -> AccountConfig
accountConfigFromPartyConfigs id ownerConfig providerConfig =
  AccountConfig with
    admin
    account = V2.Account with
      owner
      provider = partyFromText "provider"
      id
    ownerConfig
    providerConfig
  where
    Some admin = partyFromText "admin"
    Some owner = partyFromText "owner"

jointControl : AccountConfig
jointControl =
  accountConfigFromPartyConfigs
    "jointControl"
    PartyConfig with canInitiate = True; mustApprove = True
    PartyConfig with canInitiate = True; mustApprove = True
  

providerControl : AccountConfig
providerControl =
  accountConfigFromPartyConfigs
    "providerControl"
    PartyConfig with canInitiate = False; mustApprove = False
    PartyConfig with canInitiate = True; mustApprove = True

providerConfirmation : AccountConfig
providerConfirmation =
  accountConfigFromPartyConfigs
  "providerConfirmation"
  PartyConfig with canInitiate = True; mustApprove = False
  PartyConfig with canInitiate = False; mustApprove = True

test_nextActors : Script ()
test_nextActors = do
  let Some o = partyFromText "owner"
  let Some p = partyFromText "provider"
  let testCases =
        [ ( jointControl
          , None
          , [o, p]
          )
        , ( jointControl
          , Some o
          , [p]
          )
        , ( jointControl
          , Some p
          , [o]
          )
        ] <>
        [ ( providerControl
          , None
          , [p]
          )
        , ( providerControl
          , Some o
          , [p]
          )
        , ( providerControl
          , Some p
          , []
          )
        ] <>
        [ ( providerConfirmation
          , None
          , [o]
          )
        , ( providerConfirmation
          , Some o
          , [p]
          )
        , ( providerConfirmation
          , Some p -- this case cannot be reached in practice
          , [o]
          )
        ]
  forA_ testCases $ \(config, previousAction, expectedActors) -> do
    let actualActors = nextActors previousAction config
    unless (actualActors == Set.fromList expectedActors) $
      error $ T.unlines [
        "Unexpected next actors with " <> config.account.id,
        "Previous action: " <> show previousAction,
        "Actual: " <> show actualActors,
        "Expected: " <> show expectedActors
      ]

test_requiredApprovers : Script ()
test_requiredApprovers = do
  let Some o = partyFromText "owner"
  let Some p = partyFromText "provider"
  let testCases =
        [ ( jointControl
          , [o, p]
          )
        , ( providerControl
          , [p]
          )
        , ( providerConfirmation
          , [o, p] -- owner approval is indirectly required, as the provider cannot initiate an action on their own
          )
        ]
  forA_ testCases $ \(config, expectedApprovers) -> do
    let actualApprovers = requiredApprovers config
    unless (actualApprovers == Set.fromList expectedApprovers) $
      error $ T.unlines [
        "Unexpected approvers with " <> config.account.id,
        "Actual: " <> show actualApprovers,
        "Expected: " <> show expectedApprovers
      ]


