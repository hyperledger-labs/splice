acceptTransferOffers : MultiRegistry.MultiRegistry -> Party -> V2.InstrumentId -> Script WalletClientV2.TSABatch
acceptTransferOffers registries actor instrumentId = do
  offers <- WalletClientV2.listTransferOffersV2 actor instrumentId
  acceptChoices <- forA offers $ \(cid, offer) -> do
    case Map.lookup [actor] offer.availableActions of
      Some actions | V2.TIA_Accept `elem` actions ->
        WalletClientV2.mkAcceptTransferOffer registries actor (cid, offer.transfer)
      _ -> pure mempty
  pure (mconcat acceptChoices)
