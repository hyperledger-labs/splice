-- | Mock version of the backend for the TradingAppV2. Used to drive end-to-end integration
-- tests of multi-registry DvP settlement involving both token standard V1 and V2 registries.
module Splice.Testing.Apps.TradingAppV2_Backend
  (
    TradeWithAllocations(..)
  , queryTradesWithAllocations

  , SettleableTrade(..)
  , querySettleableTrades

  , settleWithTradeAgreements
  , cancelWithTradeAgreements
  ) where


import Daml.Script

import DA.Action
import DA.Foldable (foldMap)
import DA.Map as Map hiding (filter)
import DA.Optional
import DA.Set qualified as Set
import DA.TextMap qualified as TextMap

import Splice.Api.Token.MetadataV1
import Splice.Api.Token.AllocationV1 qualified as V1
import Splice.Api.Token.HoldingV2 qualified as V2
import Splice.Api.Token.AllocationV2 qualified as V2
import Splice.Api.Token.AllocationInstructionV2 qualified as V2

import Splice.TokenStandard.Utils

import Splice.Testing.Apps.TradingAppV2 hiding (require)
import Splice.Testing.Utils
import Splice.Testing.TokenStandard.RegistryApi qualified as RegistryApiV1
import Splice.Testing.TokenStandard.RegistryApiV2 qualified as RegistryApiV2
import Splice.Testing.TokenStandard.MultiRegistry qualified as MultiRegistry


-- Test version of the trading app backend functionality
---------------------------------------------------------

data TradeWithAllocations = TradeWithAllocations
  with
    otcTradeCid : ContractId OTCTrade
    otcTrade : OTCTrade
    allocationsV2 : [(ContractId V2.Allocation, V2.AllocationView)]
      -- ^ Allocations that implement the V2 token standard
    allocationsV1 : [(ContractId V1.Allocation, V1.AllocationView)]
      -- ^ V1-only allocations
    allocationRequestCids : [ContractId OTCTradeAllocationRequest]
  deriving (Eq, Show)

data SettleableTrade = SettleableTrade with
    otcTradeCid : ContractId OTCTrade
    otcTrade : OTCTrade
    disclosures : Disclosures'
    batchesByAdmin : Map Party SettlementBatch
    allocationRequestCids : [ContractId OTCTradeAllocationRequest]

-- | Helper type of a transfer leg together with its authorizer.
type AuthorizedLeg = (V2.Account, V2.TransferLeg)

toAuthorizedLegs : V2.TransferLeg -> [AuthorizedLeg]
toAuthorizedLegs leg
  | leg.sender == leg.receiver = [(leg.sender, leg)] -- self-transfers are authorized only once
  | otherwise = [(leg.sender, leg), (leg.receiver, leg)]

groupAsMapBy : Ord k => (a -> k) -> [a] -> Map k [a]
groupAsMapBy k xs = Map.fromListWithR (++) [ (k x, [x]) | x <- xs ]

-- | Find all trades for the venue together with their allocations and allocation requests.
queryTradesWithAllocations : Party -> Script [TradeWithAllocations]
queryTradesWithAllocations venue = do
  otcTrades <- query @OTCTrade venue
  forA otcTrades $ \(otcTradeCid, otcTrade) -> do
    let settlementRef = makeTradeRef otcTradeCid
    -- query matching allocation requests
    allocationRequests <- queryFilter @OTCTradeAllocationRequest venue
      (\req -> req.settlement.settlementRef == settlementRef)
    -- query matching allocations
    allAllocationsV2 <- queryInterface @V2.Allocation venue
    let allocationsV2 = do
          (cid, Some allocView) <- allAllocationsV2
          guard (allocView.allocation.settlement.settlementRef == settlementRef)
          pure (cid, allocView)
    let allocationCidsV1 = Set.fromList $ map fst allocationsV2
    allAllocationsV1 <- queryInterface @V1.Allocation venue
    let settlementRefV1 = downcast settlementRef
    let allocationsV1 = do
          (cid, Some allocView) <- allAllocationsV1
          guard (allocView.allocation.settlement.settlementRef == settlementRefV1)
          guard (upcast cid `Set.notMember` allocationCidsV1)
          pure (cid, allocView)

    pure TradeWithAllocations with
      otcTradeCid
      otcTrade
      allocationsV1
      allocationsV2
      allocationRequestCids = map fst allocationRequests

-- | Find all trades for the venue that can be settled.
querySettleableTrades : MultiRegistry.MultiRegistry -> Party -> Script [SettleableTrade]
querySettleableTrades registries venue = do
  trades <- queryTradesWithAllocations venue
  agreements <- queryFilter @TradeSettlementAgreement venue (\a -> a.venue == venue)
  let agreementsByTrader = Map.fromList [ (a.trader, cid) | (cid, a) <- agreements ]
  fmap catOptionals $ forA trades $ \trade -> do
    -- check whether the required authorization are present
    let otcTrade = trade.otcTrade
    let receiversWithAgreements = map basicAccount (Map.keys agreementsByTrader)
    let minimallyRequiredAuthorizations = do
          authz@(authorizer, leg) <- concatMap toAuthorizedLegs otcTrade.transferLegs
          -- the venue can create their own allocations directly as part of settlement
          guard (authorizer.owner /= venue)
          -- authorization is only required for senders, and for receivers without trade agreements
          guard (leg.sender == authorizer || authorizer `notElem` receiversWithAgreements)
          pure authz

    let actualAuthorizations =
          do
            (_cid, allocView) <- trade.allocationsV2
            leg <- allocView.allocation.transferLegs
            pure (allocView.allocation.authorizer, leg)
          <>
          do
            (_cid, allocView) <- trade.allocationsV1
            let legV1 = allocView.allocation.transferLeg
            let legV2 = upcast_v1_v2_TransferLeg allocView.allocation.transferLegId legV1
            -- V1 allocations cover both sender and receiver authorization
            [(basicAccount legV1.sender, legV2), (basicAccount legV1.receiver, legV2)]

    if Set.fromList minimallyRequiredAuthorizations `Set.isSubsetOf` Set.fromList actualAuthorizations
      then do
        Some <$> mkSettleableTrade trade agreementsByTrader
      else pure None
  where
    mkSettleableTrade trade agreementsByTrader = do
      let otcTrade = trade.otcTrade
      let otcTradeCid = trade.otcTradeCid
      let settlement = mkOtcTradeSettlementInfo otcTradeCid otcTrade
      let transferLegsByAdmin = splitLegsByAdmin otcTrade.transferLegs

      -- create V1 contexts
      let allocationsV1ByAdmin = groupAsMapBy (._2.allocation.transferLeg.instrumentId.admin) trade.allocationsV1
      settleBatchContextsV1 <-
        forA (Map.toList allocationsV1ByAdmin) $ \(admin, allocations) -> do
          registry <- MultiRegistry.getRegistryApiV1 registries admin
          richAllocationsWithContext <- forA allocations $ \(allocCid, allocView) -> do
            context <- RegistryApiV1.getAllocation_TransferContext registry allocCid emptyMetadata
            let extraArgs = ExtraArgs with
                  context = context.choiceContext
                  meta = emptyMetadata
            let transferLeg = allocView.allocation.transferLeg
            senderAgreementCid <- getSettlementAgreement venue transferLeg.sender
            receiverAgreementCid <- getSettlementAgreement venue transferLeg.receiver
            let allocationWithContext = AllocationWithContextV1 with
                  allocationCid = allocCid
                  extraArgs
                  senderAgreementCid
                  receiverAgreementCid
            pure ((allocView.allocation.transferLegId, allocationWithContext), context.disclosures)
          let batch = SettlementBatchV1 with
                allocationsWithContext = TextMap.fromList $ map fst richAllocationsWithContext
              disclosures = foldMap snd richAllocationsWithContext
          pure ((admin, batch), disclosures)

      -- create V2 contexts
      let allocationsV2ByAdmin = groupAsMapBy (\(_, allocView) -> allocationAdmin allocView.allocation) trade.allocationsV2
      settleBatchContextsV2 <-
        forA (Map.toList transferLegsByAdmin) $ \(admin, requiredLegs) -> do
          supportsV2 <- MultiRegistry.supportsV2 registries admin
          if not supportsV2 then pure None else do
            registry <- MultiRegistry.getRegistryApiV2 registries admin
            now <- getTime
            -- compute factory calls to create the missing (receipt) allocations
            let existingAllocations = fromOptional [] $ Map.lookup admin allocationsV2ByAdmin
            let actualAuthorizations = Set.fromList $ do
                  (_, allocView) <- existingAllocations
                  leg <- allocView.allocation.transferLegs
                  pure (allocView.allocation.authorizer, leg)
            let requiredAuthorizations = Set.fromList $ concatMap toAuthorizedLegs requiredLegs
            let missingAuthorizations = requiredAuthorizations `Set.difference` actualAuthorizations
            let missingByAuthorizer = groupAsMapBy fst $ Set.toList missingAuthorizations
            missingAllocations <- forA (Map.toList missingByAuthorizer) $ \(authorizer, missingLegs) -> do
              unless (isBasicAccount authorizer || authorizer.owner == trade.otcTrade.venue) $
                fail $ "unexpected internal failure: missing authorizer is a non-basic account " <> show authorizer
              enrichedChoice <- RegistryApiV2.getAllocationFactory registry V2.AllocationFactory_Allocate with
                allocation = V2.AllocationSpecification with
                  transferLegs = map snd missingLegs
                  settlement
                  authorizer
                inputHoldingCids = []
                requestedAt = now
                extraArgs = emptyExtraArgs
                actors = [authorizer.owner]
              pure $ MissingAllocation with
                authorizerAgreementCid = Map.lookup authorizer.owner agreementsByTrader
                factoryCid = enrichedChoice.factoryCid
                choiceArg = enrichedChoice.arg
            -- query off-ledger API of admin to get the settlement context.
            let allocationCids = map fst existingAllocations
            let settleBatchArg = V2.SettlementFactory_SettleBatch with
                  settlement
                  transferLegs = requiredLegs
                  allocationCids
                  extraArgs = emptyExtraArgs
                  actors = [venue]
            context <- RegistryApiV2.getSettlementFactory registry settleBatchArg
            let batch = SettlementBatchV2 with
                  factoryCid = context.factoryCid
                  missingAllocations
                  allocationCids
                  extraArgs = context.arg.extraArgs
            pure (Some ((admin, batch), context.disclosures))

      let settleBatchContexts = catOptionals settleBatchContextsV2 <> settleBatchContextsV1
      pure $ SettleableTrade with
        otcTradeCid
        otcTrade
        disclosures = foldMap (._2) settleBatchContexts
        batchesByAdmin = Map.fromList $ map (._1) settleBatchContexts
        allocationRequestCids = trade.allocationRequestCids

-- | Settle a trade using the trade agreements for the required extra authority.
settleWithTradeAgreements : SettleableTrade -> Script OTCTrade_SettleResult
settleWithTradeAgreements trade = do
  let venue = trade.otcTrade.venue
  let settleArg = OTCTrade_Settle with
        batchesByAdmin = trade.batchesByAdmin
        allocationRequests = trade.allocationRequestCids

  -- settle directly if no extra authorizations are required
  submitWithDisclosures' venue trade.disclosures $ exerciseCmd trade.otcTradeCid settleArg

-- | Cancel a trade using the trade agreements for the required extra authority for cancelling V1 allocations.
cancelWithTradeAgreements : MultiRegistry.MultiRegistry -> TradeWithAllocations -> Script OTCTrade_CancelResult
cancelWithTradeAgreements registries trade = do
  -- grab contexts for V1 allocation cancellation
  allocationsWithContextV1 <- forA trade.allocationsV1 $ \(allocCid, allocView) -> do
    let admin = allocView.allocation.transferLeg.instrumentId.admin
    registry <- MultiRegistry.getRegistryApiV1 registries admin
    context <- RegistryApiV1.getAllocation_CancelContext registry allocCid emptyMetadata
    let transferLeg = allocView.allocation.transferLeg
    let venue = trade.otcTrade.venue
    senderAgreementCid <- getSettlementAgreement venue transferLeg.sender
    receiverAgreementCid <- getSettlementAgreement venue transferLeg.receiver
    let allocationWithContext = AllocationWithContextV1 with
          allocationCid = allocCid
          extraArgs = ExtraArgs with
            context = context.choiceContext
            meta = emptyMetadata
          senderAgreementCid
          receiverAgreementCid
    pure (allocationWithContext, context.disclosures)
  -- grab contexts for V2 allocation cancellation
  allocationsWithContextV2 <- forA trade.allocationsV2 $ \(allocCid, allocView) -> do
    registry <- MultiRegistry.getRegistryApiV2 registries (allocationAdmin allocView.allocation)
    context <- RegistryApiV2.getAllocation_CancelContext registry allocCid emptyMetadata
    let extraArgs = ExtraArgs with
          context = context.choiceContext
          meta = emptyMetadata
    pure ((allocCid, extraArgs), context.disclosures)

  let venue = trade.otcTrade.venue
  let cancelArg = OTCTrade_Cancel with
        allocationsWithContextV1 = map fst allocationsWithContextV1
        allocationsWithContextV2 = map fst allocationsWithContextV2
        allocationRequestCids = trade.allocationRequestCids
  let disclosures = foldMap snd allocationsWithContextV1 <> foldMap snd allocationsWithContextV2

  -- cancel directly if no extra authorizations are required
  submitWithDisclosures' venue disclosures $ exerciseCmd trade.otcTradeCid cancelArg

getSettlementAgreement : Party -> Party -> Script (ContractId TradeSettlementAgreement)
getSettlementAgreement venue trader = do
  agreements <- queryFilter @TradeSettlementAgreement venue (\a -> a.trader == trader)
  case agreements of
    [] -> error $ "No settlement agreement found for trader " <> show trader
    (agreementCid, _) :: _ -> pure agreementCid
