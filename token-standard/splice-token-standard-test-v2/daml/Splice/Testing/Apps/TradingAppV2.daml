-- | An example of how to build an OTC trading app for multi-leg standard token trades.
--
-- Used as part of the testing infrastructure to test the DvP workflows based on the token standard.
module Splice.Testing.Apps.TradingAppV2 where

import DA.Optional (optionalToList, fromOptional)
import DA.Set qualified as Set
import DA.Map qualified as Map
import DA.TextMap qualified as TextMap

import Splice.Api.Token.MetadataV1 as Api.Token.MetadataV1
import Splice.Api.Token.AllocationV2 as Api.Token.AllocationV2
import Splice.Api.Token.AllocationRequestV2
import Splice.Api.Token.AllocationV1 qualified as AllocationV1
import Splice.Api.Token.AllocationRequestV1 qualified as AllocationRequestV1
import Splice.Api.Token.HoldingV2 (Account)
import Splice.Api.Token.UtilsV2

import DA.List (dedupSort)
import DA.Foldable (mapA_)
import DA.Assert ((===))
import DA.Time
import DA.Date

maxTime : Time
maxTime = time (date 9999 Dec 31) 23 59 59

template OTCTradeAllocationRequest with
    venue : Party
    otcTradeCid : ContractId OTCTrade
    authorizer : Account
    transferLegs : [TransferLeg]
    createdAt : Time
    settleAt : Time
    settlementDeadline : Optional Time
    settlementV1Authorizers : [Party]
      -- ^ Extra executor for testing multi-executor and mixed version settlement.
      -- FIXME: cleaup this code
  where
    signatory venue
    observer accountParties authorizer

    interface instance AllocationRequest for OTCTradeAllocationRequest where
      view = AllocationRequestView with
        settlement = SettlementInfo with
          executor = venue
          requestedAt = createdAt
          settlementRef = makeTradeRef otcTradeCid
          settleAt = settleAt
          meta = emptyMetadata
          settlementDeadline = settlementDeadline
        transferLegs = transferLegs
        meta = emptyMetadata

      allocationRequest_RejectImpl _self AllocationRequest_Reject{..} = do
        -- Note: this corresponds to signalling early that assets won't be allocated / that the trade is being rejected.
        require "Actor is is the needed authorizer"
          (actor == authorizer.owner || Some actor == authorizer.provider)
        pure ChoiceExecutionMetadata with meta = emptyMetadata

      allocationRequest_WithdrawImpl _self _extraArgs =
        -- just archiving the trade is enough
        pure ChoiceExecutionMetadata with meta = emptyMetadata

    interface instance AllocationRequestV1.AllocationRequest for OTCTradeAllocationRequest where
      -- FIXME: package downcast
      view = AllocationRequestV1.AllocationRequestView with
        settlement = AllocationV1.SettlementInfo with
          executor = venue
          requestedAt = createdAt
          settlementRef = downcast (makeTradeRef otcTradeCid)
          allocateBefore = settleAt
          settleBefore = fromOptional maxTime settlementDeadline
          meta = emptyMetadata
        transferLegs = TextMap.fromList $ map (\leg -> (leg.transferLegId, downcast leg)) transferLegs
        meta = emptyMetadata

      allocationRequest_RejectImpl = error "Not implemented for V1"
      allocationRequest_WithdrawImpl = error "Not implemented for V1"

mkOtcTradeSettlementInfo : ContractId OTCTrade -> OTCTrade -> Api.Token.AllocationV2.SettlementInfo
mkOtcTradeSettlementInfo otcTradeCid otcTrade = Api.Token.AllocationV2.SettlementInfo with
  executor = otcTrade.venue
  requestedAt = otcTrade.createdAt
  settlementRef = makeTradeRef otcTradeCid
  settleAt = otcTrade.settleAt
  meta = emptyMetadata
  settlementDeadline = otcTrade.settlementDeadline

template OTCTrade with
    venue : Party
    transferLegsByAdmin : Map.Map Party [TransferLeg]
    createdAt : Time
    settleAt : Time
    settlementDeadline : Optional Time
    settlementV1Authorizers : [Party]
      -- ^ Parties approving the settlement of v1 allocations affecting them.
  where
    signatory venue
    observer venue, tradingParties (concat $ Map.values transferLegsByAdmin)

    nonconsuming choice OTCTrade_RequestAllocations : [ContractId OTCTradeAllocationRequest]
      with
      controller venue
      do
        requestss <- forA (Map.values transferLegsByAdmin) $ \transferLegs -> do
          let traders = dedupSort $ concatMap (\tl -> [tl.sender, tl.receiver]) transferLegs
          forA traders $ \trader -> do
            create OTCTradeAllocationRequest with
              venue
              otcTradeCid = self
              authorizer = trader
              transferLegs = filter (\leg -> trader == leg.sender || trader == leg.receiver) transferLegs
              createdAt = createdAt
              settleAt = settleAt
              settlementDeadline = settlementDeadline
              settlementV1Authorizers
        pure (concat requestss)

    -- Nonconsuming to avoid disclosures inside.
    -- FIXME: check whether this really does what we want it to do
    nonconsuming choice OTCTrade_Settle : [Api.Token.AllocationV2.SettlementFactory_SettleBatchResult] -- FIXME: better type
      with
        allocationBatchesByAdmin : Map.Map Party (ContractId Api.Token.AllocationV2.SettlementFactory, [ContractId Api.Token.AllocationV2.Allocation], ExtraArgs)
        -- ^ Allocations sorted by admin party
        allocationRequests : [ContractId OTCTradeAllocationRequest]
      controller venue, settlementV1Authorizers
        -- FIXME: change choice or build infra to trigger this choice w/o resorting to a submitMulti step
      do
        archive self
        -- Could be safer by validating the requests match the trade, but venue is the only authorizer
        -- so we can assume the checks happened off-ledger.
        -- FIXME: don't make this assumption

        mapA_ archive allocationRequests

        -- FIXME: consider what other validation is missing here
        require "Admins of batches match expected legs" (Map.keys allocationBatchesByAdmin == Map.keys transferLegsByAdmin)
        forA (Map.toList allocationBatchesByAdmin) $ \(admin, (factoryCid, allocationCids, extraArgs)) -> do
          Some transferLegs <- pure (Map.lookup admin transferLegsByAdmin)
          exercise factoryCid Api.Token.AllocationV2.SettlementFactory_SettleBatch with
            expectedAdmin = admin
            settlementV1Authorizers = settlementV1Authorizers
            settlement = mkOtcTradeSettlementInfo self this
            transferLegs
            allocationCids
            controllersOverride = None
            extraArgs


    -- NOTE: this choice is an approximation to what a real app would do.
    -- As it stands, the venue can't cancel allocations that come right after
    -- the first cancellation.  A better approach would be to leave a marker
    -- contract in place until the `settleBefore` time, so that the venue
    -- retains the ability to cancel the allocations that are created.
    choice OTCTrade_Cancel : [Allocation_CancelResult]
      with
        allocationsWithContext : [(ContractId Allocation, ExtraArgs)]
        allocationRequests : [ContractId OTCTradeAllocationRequest]
      controller venue
      do
        mapA_ (\arCid -> do
            ar <- fetch arCid
            -- validate the allocation request matches this trade
            ar.otcTradeCid ===  self
            signatory ar === [venue]
            archive arCid
          )
          allocationRequests
        mapA (\(allocCid, extraArgs) -> do
            alloc <- fetch allocCid
            -- validate the allocation request matches this trade
            (view alloc).allocation.settlement.settlementRef === makeTradeRef self
            (view alloc).allocation.settlement.executor === venue
            exercise allocCid (Allocation_Cancel with actors = [venue]; extraArgs)
          )
          allocationsWithContext

accountParties : Account -> [Party]
accountParties account = account.owner::optionalToList account.provider

transferLegParties : TransferLeg -> [Party]
transferLegParties tl = accountParties tl.sender ++ accountParties tl.receiver

tradingParties : [Api.Token.AllocationV2.TransferLeg] -> Set.Set Party
tradingParties tls = Set.fromList $ concatMap transferLegParties tls

-- | Check whether a required condition is true. If it's not, abort the
-- transaction with a message saying that the requirement was not met.
require : CanAssert m => Text -> Bool -> m ()
require msg invariant =
  assertMsg ("The requirement '" <> msg <> "' was not met.") invariant

makeTradeRef : ContractId OTCTrade -> Api.Token.AllocationV2.Reference
makeTradeRef tradeCid = Api.Token.AllocationV2.Reference with
  id = "OTCTradeProposal" -- set to the name of the template to simplify debugging
  cid = Some (coerceContractId tradeCid)



