-- | An example of how to build an OTC trading app for multi-leg standard token trades.
--
-- Used as part of the testing infrastructure to test the DvP workflows based on the token standard.
module Splice.Testing.Apps.TradingAppV2 where

import DA.Assert ((===))
import DA.Date
import DA.Foldable (forA_)
import DA.List (dedupSort)
import DA.Map qualified as Map
import DA.Optional (optionalToList)
import DA.Set qualified as Set
import DA.Time

import Splice.Api.Token.MetadataV1
import Splice.Api.Token.AllocationRequestV1 qualified as V1
import Splice.Api.Token.AllocationV2 qualified as V2
import Splice.Api.Token.AllocationRequestV2 qualified as V2

import Splice.Api.Token.HoldingV2 qualified as V2
import Splice.Api.Token.UtilsV2


maxTime : Time
maxTime = time (date 9999 Dec 31) 23 59 59

template OTCTradeAllocationRequest with
    authorizer : V2.Account
    request : V2.AllocationRequestView
  where
    signatory request.settlement.executor
    observer accountParties authorizer

    interface instance V2.AllocationRequest for OTCTradeAllocationRequest where
      view = request

      -- FIXME: introduce default implementations in UtilsV2
      allocationRequest_RejectImpl _self V2.AllocationRequest_Reject{..} = do
        -- Note: this corresponds to signalling early that assets won't be allocated / that the trade is being rejected.
        require "Actor is is the needed authorizer"
          (actor == authorizer.owner || Some actor == authorizer.provider)
        pure ChoiceExecutionMetadata with meta = emptyMetadata

      allocationRequest_WithdrawImpl _self _extraArgs =
        -- just archiving the trade is enough
        pure ChoiceExecutionMetadata with meta = emptyMetadata

    interface instance V1.AllocationRequest for OTCTradeAllocationRequest where
      view = downcast request

      -- FIXME: introduce default implementations in UtilsV2; and use them here
      allocationRequest_RejectImpl = error "Not implemented for V1"
      allocationRequest_WithdrawImpl = error "Not implemented for V1"

mkOtcTradeSettlementInfo : ContractId OTCTrade -> OTCTrade -> V2.SettlementInfo
mkOtcTradeSettlementInfo otcTradeCid otcTrade = V2.SettlementInfo with
  executor = otcTrade.venue
  requestedAt = otcTrade.createdAt
  settlementRef = makeTradeRef otcTradeCid
  settleAt = otcTrade.settleAt
  meta = emptyMetadata
  settlementDeadline = otcTrade.settlementDeadline

template OTCTrade with
    venue : Party
    transferLegsByAdmin : Map.Map Party [V2.TransferLeg]
    createdAt : Time
    settleAt : Time
    settlementDeadline : Optional Time
    settlementV1Authorizers : [Party]
      -- ^ Parties approving the settlement of v1 allocations affecting them.
  where
    signatory venue
    observer venue, tradingParties (concat $ Map.values transferLegsByAdmin)

    nonconsuming choice OTCTrade_RequestAllocations : [ContractId OTCTradeAllocationRequest]
      with
      controller venue
      do
        let settlement = mkOtcTradeSettlementInfo self this
        requestss <- forA (Map.values transferLegsByAdmin) $ \transferLegs -> do
          let traders = dedupSort $ concatMap (\tl -> [tl.sender, tl.receiver]) transferLegs
          forA traders $ \trader -> do
            create OTCTradeAllocationRequest with
              authorizer = trader
              request = V2.AllocationRequestView with
                settlement
                transferLegs = filter (\leg -> trader == leg.sender || trader == leg.receiver) transferLegs
                meta = emptyMetadata
        pure (concat requestss)

    -- Nonconsuming to avoid disclosures inside.
    -- FIXME: check with Bernhard what problem that the 'nonconsuming' is intended to solve.
    nonconsuming choice OTCTrade_Settle : [V2.SettlementFactory_SettleBatchResult] -- FIXME: better type
      with
        allocationBatchesByAdmin : Map.Map Party (ContractId V2.SettlementFactory, [ContractId V2.Allocation], ExtraArgs)
        -- ^ Allocations and their batch settlement factories sorted by admin party
        -- FIXME: introduce suitable utility types in UtilsV2
        allocationRequests : [ContractId OTCTradeAllocationRequest]
      controller venue, settlementV1Authorizers
        -- FIXME: change choice or build infra to trigger this choice w/o resorting to a submitMulti step
      do
        archive self

        -- Archive requests
        let settlement = mkOtcTradeSettlementInfo self this
        forA_ allocationRequests $ \reqCid -> do
          req <- fetch reqCid
          archive reqCid
          requireMatchExpected (reqCid, "AllocationRequest.settlement") settlement req.request.settlement

        -- FIXME: consider what other validation is missing here
        requireMatchExpected ("OTCTrade_Settle", "Admins of batches match expected legs")
          (Map.keys allocationBatchesByAdmin) (Map.keys transferLegsByAdmin)

        forA (Map.toList allocationBatchesByAdmin) $ \(admin, (factoryCid, allocationCids, extraArgs)) -> do
          Some transferLegs <- pure (Map.lookup admin transferLegsByAdmin)
          exercise factoryCid V2.SettlementFactory_SettleBatch with
            expectedAdmin = admin
            extraReceiptAuthorizers =
              -- Here we assume that the trading app only allows transfers to the basic account
              -- of v1 authorizers. More complex strategies to determine the extra receipt authorizers
              -- are possible by determining the accounts form the transfer legs and app specific config.
              map V2.basicAccount settlementV1Authorizers
            settlement
            transferLegs
            allocationCids
            actors = venue :: settlementV1Authorizers
            extraArgs


    -- NOTE: this choice is an approximation to what a real app would do.
    -- As it stands, the venue can't cancel allocations that come right after
    -- the first cancellation.  A better approach would be to leave a marker
    -- contract in place until the `settleBefore` time, so that the venue
    -- retains the ability to cancel the allocations that are created.
    choice OTCTrade_Cancel : [V2.Allocation_CancelResult]
      with
        allocationsWithContext : [(ContractId V2.Allocation, ExtraArgs)]
        allocationRequests : [ContractId OTCTradeAllocationRequest]
      controller venue, settlementV1Authorizers
      do
        let settlement = mkOtcTradeSettlementInfo self this
        forA_ allocationRequests $ \reqCid -> do
            req <- fetch reqCid
            archive reqCid
            requireMatchExpected (reqCid, "AllocationRequest.settlement") settlement req.request.settlement
        forA allocationsWithContext $ \(allocCid, extraArgs) -> do
            alloc <- fetch allocCid
            -- validate the allocation request matches this trade
            let allocView = view alloc
            allocView.allocation.settlement.settlementRef === makeTradeRef self
            allocView.allocation.settlement.executor === venue
            exercise allocCid $ V2.Allocation_Cancel with
              actors = venue :: settlementV1Authorizers
              extraArgs

accountParties : V2.Account -> [Party]
accountParties account = account.owner :: optionalToList account.provider

transferLegParties : V2.TransferLeg -> [Party]
transferLegParties tl = accountParties tl.sender ++ accountParties tl.receiver

tradingParties : [V2.TransferLeg] -> Set.Set Party
tradingParties tls = Set.fromList $ concatMap transferLegParties tls

-- | Check whether a required condition is true. If it's not, abort the
-- transaction with a message saying that the requirement was not met.
require : CanAssert m => Text -> Bool -> m ()
require msg invariant =
  assertMsg ("The requirement '" <> msg <> "' was not met.") invariant

makeTradeRef : ContractId OTCTrade -> V2.Reference
makeTradeRef tradeCid = V2.Reference with
  id = "OTCTradeProposal" -- set to the name of the template to simplify debugging
  cid = Some (coerceContractId tradeCid)



