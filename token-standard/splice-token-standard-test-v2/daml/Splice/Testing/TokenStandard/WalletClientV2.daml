-- | Daml script test utilities for simulating the actions of token standard V2 wallet.
--
-- NOTE: there are likely more functions that could/should be added to this module. PRs welcome.
module Splice.Testing.TokenStandard.WalletClientV2
  (
    -- * Reading/checking holdings
    listHoldings,
    listHoldingCids,
    listLockedHoldings,
    listUnlockedHoldingCidsFor,

    checkHoldingWithAmountExists,
    checkBalanceBounds,
    checkBalance,
    checkBalanceApprox,
    checkHolding,
    checkHoldingBounds,
    checkHoldingApprox,

    -- * Reading transfer instructions
    listTransferOffers,

    -- * Managing allocations
    listRequestedAllocationsForAdmin,
    listAllocationRequestsV2,
    listAllocationsV2,

    listAllocationRequestsV1,

    createBatchingUtility,
    acceptAllocationRequestV1,
    acceptAllocationRequestV2,

  ) where

import DA.Action (unless)
import DA.Foldable (foldMap)
import DA.List (dedupSort)
import DA.Map qualified as Map
import DA.Optional (isSome, isNone)
import DA.TextMap qualified as TextMap

import Splice.Api.Token.AllocationInstructionV1 qualified as V1
import Splice.Api.Token.AllocationRequestV1 qualified as V1
import Splice.Api.Token.AllocationV1 qualified as V1
import Splice.Api.Token.HoldingV2 qualified as V2
import Splice.Api.Token.AllocationInstructionV2 qualified as V2
import Splice.Api.Token.AllocationRequestV2 qualified as V2
import Splice.Api.Token.AllocationV2 qualified as V2
import Splice.Api.Token.TransferInstructionV2 qualified as V2

import Splice.TokenStandard.Utils qualified as TokenStandard.Utils
import Splice.Util.Token.Wallet.BatchingUtilityV2 qualified as BatchingUtilityV2

import Splice.Testing.TokenStandard.RegistryApi qualified as V1
import Splice.Testing.TokenStandard.RegistryApiV2 qualified as V2
import Splice.Testing.Utils qualified as V1
import Splice.Testing.UtilsV2 qualified as V2

import Daml.Script

-- | List the holdings of a party of a specific instrument.
listHoldings : Party -> V2.InstrumentId -> Script [(ContractId V2.Holding, V2.HoldingView)]
listHoldings p instrumentId = do
  holdings <- queryInterface @V2.Holding p
  let instrumentHoldings = do
        (cid, Some holding) <- holdings
        guard (holding.instrumentId == instrumentId)
        guard (holding.account.owner == p)
        pure (cid, holding)
  pure instrumentHoldings


listLockedHoldings : Party -> V2.InstrumentId -> Script [(ContractId V2.Holding, V2.HoldingView)]
listLockedHoldings p instrumentId =
  filter (\(_, holding) -> isSome (holding.lock)) <$> listHoldings p instrumentId

-- | List the cids of the holdings of a party of a specific instrument.
listHoldingCids : Party -> V2.InstrumentId -> Script [ContractId V2.Holding]
listHoldingCids p instrumentId = (map fst) <$> listHoldings p instrumentId

listUnlockedHoldingCidsFor : V2.Account -> Party -> V2.InstrumentId -> Script [ContractId V2.Holding]
listUnlockedHoldingCidsFor account actor instrumentId = do
  holdings <- listHoldings actor instrumentId
  pure [cid | (cid, holding) <- holdings, holding.account == account, isNone holding.lock]

-- | Check that a holding with a specific amount exists for the given owner.
checkHoldingWithAmountExists : Party -> V2.InstrumentId -> Decimal -> Script ()
checkHoldingWithAmountExists p instrumentId amount = do
  holdings <- map snd <$> listHoldings p instrumentId
  unless (any (\holding -> holding.amount == amount) holdings) $
    fail (show p <> " is missing holding of value " <> show amount <> " in " <> show holdings)

-- | Check the bounds on a party's total balance of all holdings of the given instrument.
checkBalanceBounds : Party -> V2.InstrumentId -> (Decimal, Decimal) -> Script ()
checkBalanceBounds p instrumentId (lb, ub) = do
  holdings <- listHoldings p instrumentId
  let total = sum $ map (._2.amount) holdings
  unless (total >= lb && total <= ub) $ fail $
    "Wallet " <> show p <> ": balance of " <> show total <> " for " <> show instrumentId <>
    " is not within the expected range [" <> show lb <> ", " <> show ub <> "]"

-- | Check the exact value of an individual holding's amount.
checkHolding : Party -> ContractId V2.Holding -> Decimal -> Script ()
checkHolding p holdingCid amount = checkHoldingBounds p holdingCid (amount, amount)

-- | Check the bounds on an individual holding's amount.
checkHoldingBounds : Party -> ContractId V2.Holding -> (Decimal, Decimal) -> Script ()
checkHoldingBounds p holdingCid (lb, ub) = do
  holdingO <- queryInterfaceContractId p holdingCid
  let holding = case holdingO of
        None -> error $ "Holding " <> show holdingCid <> " was not found"
        Some holding -> holding
  unless (holding.amount >= lb && holding.amount <= ub) $ fail $
    "Holding " <> show holding <>
    " is not within the expected range [" <> show lb <> ", " <> show ub <> "]"

-- | Check the approximate value (+/- 1.0) a party's total balance of all holdings of the given instrument.
checkBalanceApprox : Party -> V2.InstrumentId -> Decimal -> Script ()
checkBalanceApprox p instrumentId approximateBalance =
  checkBalanceBounds p instrumentId (approximateBalance - 1.0, approximateBalance + 1.0)

-- | Check the approximate (+/- 1.0) amount of an individual holding.
checkHoldingApprox : Party -> ContractId V2.Holding -> Decimal -> Script ()
checkHoldingApprox p holdingCid approximateAmount = checkHoldingBounds p holdingCid (approximateAmount - 1.0, approximateAmount + 1.0)

-- | Check the exact value a party's total balance of all holdings of the given instrument.
checkBalance : Party -> V2.InstrumentId -> Decimal -> Script ()
checkBalance p instrumentId balance =
  checkBalanceBounds p instrumentId (balance, balance)

-- | List pending transfer offers (as sender or receiver)
listTransferOffers : Party -> V2.InstrumentId -> Script [(ContractId V2.TransferInstruction, V2.TransferInstructionView)]
listTransferOffers p instrumentId = do
  instrs <- queryInterface @V2.TransferInstruction p
  let pendingOffers = do
        (cid, Some instr) <- instrs
        guard (instr.transfer.instrumentId == instrumentId)
        guard ([p] `Map.member` instr.availableActions)
        guard (p == instr.transfer.sender.owner || p == instr.transfer.receiver.owner)
        pure (cid, instr)
  pure pendingOffers

-- | List all allocations requested from the actor for instruments by the admin.
listRequestedAllocationsForAdmin : Party -> V2.Account -> Party -> Script [V2.AllocationSpecification]
listRequestedAllocationsForAdmin admin tradingAccount actor = do
  reqs <- queryInterface @V2.AllocationRequest actor
  let amuletAllocs = do
        (_reqCid, Some req) <- reqs
        let transferLegs = do
              tf <- req.transferLegs
              guard (tf.instrumentId.admin ==  admin)
              guard (tradingAccount == tf.sender || tradingAccount == tf.receiver)
              return tf
        pure V2.AllocationSpecification with
          authorizer = tradingAccount
          settlement = req.settlement
          transferLegs
  pure amuletAllocs

listAllocationsV2 : V2.Account -> Party -> Script [(ContractId V2.Allocation, V2.AllocationView)]
listAllocationsV2 tradingAccount actor = do
  allocs <- queryInterface @V2.Allocation actor
  pure [ (allocCid, allocView) | (allocCid, Some allocView) <- allocs, tradingAccount == allocView.allocation.authorizer ]

listAllocationRequestsV1 : Party -> Script [(ContractId V1.AllocationRequest, V1.AllocationRequestView)]
listAllocationRequestsV1 actor = do
  reqs <- queryInterface @V1.AllocationRequest actor
  return [(reqCid, reqView) | (reqCid, Some reqView) <- reqs]

listAllocationRequestsV2 : V2.Account -> Party -> Script [(ContractId V2.AllocationRequest, V2.AllocationRequestView)]
listAllocationRequestsV2 tradingAccount actor = do
  reqs <- queryInterface @V2.AllocationRequest actor
  return [ (reqCid, reqView) | (reqCid, Some reqView) <- reqs, tradingAccount == reqView.authorizer ]

-- | Simulate a V2 wallet accepting an allocation request from a V1 app.
--
-- TODO(#4517): add multi-registry support once we have private assets
acceptAllocationRequestV1
  :  V1.RegistryApi registry => Party -> registry -> Party -> V1.AllocationRequestView -> Script ()
acceptAllocationRequestV1 admin registry actor req = do
  let requestedAllocations = do
        (legId, leg) <- TextMap.toList req.transferLegs
        guard (leg.instrumentId.admin == admin)
        guard (actor == leg.sender)
        pure V1.AllocationSpecification with
          settlement = req.settlement
          transferLegId = legId
          transferLeg = leg
  now <- getTime
  -- create the allocations one-by-one
  factoryCallsWithD <- forA requestedAllocations $ \allocation -> do
    enrichedChoice <- V1.getAllocationFactory registry V1.AllocationFactory_Allocate with
      expectedAdmin = admin
      allocation
      inputHoldingCids = []
      requestedAt = now
      extraArgs = V2.emptyExtraArgs
    pure ((allocation.transferLegId, (enrichedChoice.factoryCid, enrichedChoice.arg.extraArgs)), enrichedChoice.disclosures)


  -- Get holdings for relevant admins
  let senderAccount = TokenStandard.Utils.basicAccount actor
  inputHoldingMap <- getHoldingMap actor
    [(senderAccount, TokenStandard.Utils.upcast alloc.transferLeg.instrumentId) | alloc <- requestedAllocations]

  -- find batching utility for actor
  [(batchingUtilityCid, _)] <- queryFilter @BatchingUtilityV2.BatchingUtility actor (\u -> u.provider == actor)

  let disclosures = foldMap snd factoryCallsWithD
  let factoryCalls = TextMap.fromList $ map fst factoryCallsWithD
  V1.submitWithDisclosures' actor disclosures $
    exerciseCmd batchingUtilityCid BatchingUtilityV2.BatchingUtility_AcceptAllocationRequestV1 with
        reqView = req
        acceptedAt = now
        factoryCalls
        inputHoldingMap
        actor

  pure ()


-- | Accept the allocation request by authorizing the transfer of all its requested legs.
acceptAllocationRequestV2
  :  V2.MultiRegistry -> Party -> (ContractId V2.AllocationRequest, V2.AllocationRequestView) -> Script ()
acceptAllocationRequestV2 registries actor (reqCid, req) = do
  now <- getTime
  let legsByAdmin = TokenStandard.Utils.splitLegsByAdmin req.transferLegs
  -- Allocate the legs grouped by instrument.
  factoriesByAdminWithD <- forA (Map.toList legsByAdmin) $ \(admin, legs) -> do
    registry <- V2.getRegistryFor registries admin
    enrichedChoice <- V2.getAllocationFactory registry V2.AllocationFactory_Allocate with
      inputHoldingCids = []
      allocation = V2.AllocationSpecification with
          authorizer = req.authorizer
          settlement = req.settlement
          transferLegs = legs
      requestedAt = now
      extraArgs = V2.emptyExtraArgs
      actors = [actor]
    pure ((admin, (enrichedChoice.factoryCid, enrichedChoice.arg.extraArgs)), enrichedChoice.disclosures)

  -- Get holdings for relevant admins
  inputHoldingMap <- getHoldingMap actor [(req.authorizer, leg.instrumentId) | legs <- Map.values legsByAdmin, leg <- legs]

  -- find batching utility for actor
  [(batchingUtilityCid, _)] <- queryFilter @BatchingUtilityV2.BatchingUtility actor (\u -> u.provider == actor)

  -- Create all the allocations in a single transaction together with accepting the allocation request
  -- to ensure deduplication via the requests' consumption.
  let disclosures = foldMap snd factoriesByAdminWithD
  let factoriesByAdmin = Map.fromList $ map fst factoriesByAdminWithD
  V2.submitWithDisclosures' actor disclosures $
    exerciseCmd batchingUtilityCid BatchingUtilityV2.BatchingUtility_AcceptAllocationRequestV2 with
        reqCid
        acceptExtraArgs = V2.emptyExtraArgs
        acceptedAt = now
        factoriesByAdmin
        inputHoldingMap
        actor

  pure ()

-- FIXME: move
createBatchingUtility : Party -> Script (ContractId BatchingUtilityV2.BatchingUtility)
createBatchingUtility p = do
  submit p $ createCmd BatchingUtilityV2.BatchingUtility with provider = p

-- | Get a map of unlocked holding cids for the given accounts and instruments.
getHoldingMap : Party -> [(V2.Account, V2.InstrumentId)] -> Script BatchingUtilityV2.HoldingMap
getHoldingMap actor accountAndInstruments0 = do
  taggedHoldings <- forA (dedupSort accountAndInstruments0) $ \(account, instrumentId) -> do
    holdings <- listHoldings actor instrumentId
    pure [ ((instrumentId.admin, account), [holdingCid])
         | (holdingCid, holding) <- holdings, holding.account == account, isNone holding.lock ]
  pure $ BatchingUtilityV2.HoldingMap $ Map.fromListWithR (++) (concat taggedHoldings)
