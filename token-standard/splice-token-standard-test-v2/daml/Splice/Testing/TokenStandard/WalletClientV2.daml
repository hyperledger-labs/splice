import Daml.Script

-- | List the holdings of a party of a specific instrument.
listHoldings : Party -> V2.InstrumentId -> Script [(ContractId V2.Holding, V2.HoldingView)]
listHoldings p instrumentId = do
  filter (\(_, holding) -> holding.instrumentId == instrumentId) <$> listHoldings' p

-- | List the holdings of a party of a specific instrument.
listHoldings' : Party -> Script [(ContractId V2.Holding, V2.HoldingView)]
listHoldings' p = do
  holdingsV2 <- queryInterface @V2.Holding p
  let instrumentHoldingsV2 = Map.fromList $ do
        (cid, Some holding) <- holdingsV2
        guard (holding.account.owner == p)
        pure (cid, holding)
  -- enrich with V1 only holdings
  holdingsV1 <- queryInterface @V1.Holding p
  let instrumentHoldingsV1 = do
        (cidV1, Some holding) <- holdingsV1
        let cid = TSU.upcast cidV1
        guard (holding.owner == p && not (Map.member cid instrumentHoldingsV2))
        pure (cid, TSU.upcast holding)
  pure $ instrumentHoldingsV1 ++ Map.toList instrumentHoldingsV2

listLockedHoldings : Party -> V2.InstrumentId -> Script [(ContractId V2.Holding, V2.HoldingView)]
listLockedHoldings p instrumentId =
  filter (\(_, holding) -> isSome (holding.lock)) <$> listHoldings p instrumentId

-- | List the cids of the holdings of a party of a specific instrument.
listHoldingCids : Party -> V2.InstrumentId -> Script [ContractId V2.Holding]
listHoldingCids p instrumentId = (map fst) <$> listHoldings p instrumentId

listUnlockedHoldingCidsFor : V2.Account -> Party -> V2.InstrumentId -> Script [ContractId V2.Holding]
listUnlockedHoldingCidsFor account actor instrumentId = do
  holdings <- listHoldings actor instrumentId
  pure [cid | (cid, holding) <- holdings, holding.account == account, isNone holding.lock]

-- | Check that a holding with a specific amount exists for the given owner.
checkHoldingWithAmountExists : Party -> V2.InstrumentId -> Decimal -> Script ()
checkHoldingWithAmountExists p instrumentId amount = do
  holdings <- map snd <$> listHoldings p instrumentId
  unless (any (\holding -> holding.amount == amount) holdings) $
    fail (show p <> " is missing holding of value " <> show amount <> " in " <> show holdings)

-- | Check the bounds on a party's total balance of all holdings of the given instrument.
checkBalanceBounds : Party -> V2.InstrumentId -> (Decimal, Decimal) -> Script ()
checkBalanceBounds p instrumentId (lb, ub) = do
  holdings <- listHoldings p instrumentId
  let total = sum $ map (._2.amount) holdings
  unless (total >= lb && total <= ub) $ fail $
    "Wallet " <> show p <> ": balance of " <> show total <> " for " <> show instrumentId <>
    " is not within the expected range [" <> show lb <> ", " <> show ub <> "]"

-- | Check the exact value of an individual holding's amount.
checkHolding : Party -> ContractId V2.Holding -> Decimal -> Script ()
checkHolding p holdingCid amount = checkHoldingBounds p holdingCid (amount, amount)

-- | Check the bounds on an individual holding's amount.
checkHoldingBounds : Party -> ContractId V2.Holding -> (Decimal, Decimal) -> Script ()
checkHoldingBounds p holdingCid (lb, ub) = do
  holdingO <- queryInterfaceContractId p holdingCid
  let holding = case holdingO of
        None -> error $ "Holding " <> show holdingCid <> " was not found"
        Some holding -> holding
  unless (holding.amount >= lb && holding.amount <= ub) $ fail $
    "Holding " <> show holding <>
    " is not within the expected range [" <> show lb <> ", " <> show ub <> "]"

-- | Check the approximate value (+/- 1.0) a party's total balance of all holdings of the given instrument.
checkBalanceApprox : Party -> V2.InstrumentId -> Decimal -> Script ()
checkBalanceApprox p instrumentId approximateBalance =
  checkBalanceBounds p instrumentId (approximateBalance - 1.0, approximateBalance + 1.0)

-- | Check the approximate (+/- 1.0) amount of an individual holding.
checkHoldingApprox : Party -> ContractId V2.Holding -> Decimal -> Script ()
checkHoldingApprox p holdingCid approximateAmount = checkHoldingBounds p holdingCid (approximateAmount - 1.0, approximateAmount + 1.0)

-- | Check the exact value a party's total balance of all holdings of the given instrument.
checkBalance : Party -> V2.InstrumentId -> Decimal -> Script ()
checkBalance p instrumentId balance =
  checkBalanceBounds p instrumentId (balance, balance)

-- | List pending V2 transfer offers (as sender or receiver)
listTransferOffersV2 : Party -> V2.InstrumentId -> Script [(ContractId V2.TransferInstruction, V2.TransferInstructionView)]
listTransferOffersV2 p instrumentId = do
  instrs <- queryInterface @V2.TransferInstruction p
  let pendingOffers = do
        (cid, Some instr) <- instrs
        guard (instr.transfer.instrumentId == instrumentId)
        guard ([p] `Map.member` instr.availableActions)
        pure (cid, instr)
  pure pendingOffers

-- | List pending transfer offers.
listTransferOffers : Party -> V2.InstrumentId -> Script [(ContractId V2.TransferInstruction, V2.Transfer)]
listTransferOffers p instrumentId = do
  offersV2 <- listTransferOffersV2 p instrumentId
  offersV1 <- WalletClientV1.listTransferOffers p (TSU.downcast instrumentId)
  let adjustedOffersV2 = do
        (cid, instrView) <- offersV2
        pure (cid, instrView.transfer)
  let trimmedOffersV1 = do
        (cidV1, instrView) <- offersV1
        let cid = TSU.upcast cidV1
        guard (all (\(cidV2, _) -> cidV2 /= cid) offersV2) -- filter out any offers that also exist in V2
        pure (cid, TSU.upcast instrView.transfer)
  pure (adjustedOffersV2 <> trimmedOffersV1)

-- | List all allocations requested from the actor for instruments by the admin.
listRequestedAllocationsForAdmin : Party -> V2.Account -> Party -> Script [V2.AllocationSpecification]
listRequestedAllocationsForAdmin admin tradingAccount actor = do
  reqs <- queryInterface @V2.AllocationRequest actor
  let amuletAllocs = do
        (_reqCid, Some req) <- reqs
        let transferLegs = do
              tf <- req.transferLegs
              guard (tf.instrumentId.admin ==  admin)
              guard (tradingAccount == tf.sender || tradingAccount == tf.receiver)
              return tf
        pure V2.AllocationSpecification with
          authorizer = tradingAccount
          settlement = req.settlement
          transferLegs
  pure amuletAllocs

listAllocationsV2 : V2.Account -> Party -> Script [(ContractId V2.Allocation, V2.AllocationView)]
listAllocationsV2 tradingAccount actor = do
  allocs <- queryInterface @V2.Allocation actor
  pure [ (allocCid, allocView) | (allocCid, Some allocView) <- allocs, tradingAccount == allocView.allocation.authorizer ]

listAllocationRequestsV1 : Party -> Script [(ContractId V1.AllocationRequest, V1.AllocationRequestView)]
listAllocationRequestsV1 actor = do
  reqs <- queryInterface @V1.AllocationRequest actor
  return [(reqCid, reqView) | (reqCid, Some reqView) <- reqs]

listAllocationRequestsV2 : V2.Account -> Party -> Script [(ContractId V2.AllocationRequest, V2.AllocationRequestView)]
listAllocationRequestsV2 tradingAccount actor = do
  reqs <- queryInterface @V2.AllocationRequest actor
  return [ (reqCid, reqView) | (reqCid, Some reqView) <- reqs, tradingAccount == reqView.authorizer ]

-- | Simulate a V2 wallet accepting an allocation request from a V1 app.
acceptAllocationRequestV1
  :  MultiRegistry.MultiRegistry -> Party -> V1.AllocationRequestView
  -> Script BatchingUtilityV2.BatchingUtility_ExecuteBatchResult
acceptAllocationRequestV1 registries actor req = do
  batch <- mkAcceptAllocationRequestV1 registries actor req
  executeTSABatch actor batch

-- | Simulate a V2 wallet accepting an allocation request from a V2 app.
acceptAllocationRequestV2
  :  MultiRegistry.MultiRegistry -> Party -> (ContractId V2.AllocationRequest, V2.AllocationRequestView)
  -> Script BatchingUtilityV2.BatchingUtility_ExecuteBatchResult
acceptAllocationRequestV2 registries actor (reqCid, req) = do
  batch <- mkAcceptAllocationRequestV2 registries actor (reqCid, req)
  executeTSABatch actor batch

-- | Execute a batch of token standard actions.
executeTSABatch : Party -> TSABatch -> Script BatchingUtilityV2.BatchingUtility_ExecuteBatchResult
executeTSABatch actor batch
  | null batch.actions = pure $ BatchingUtilityV2.BatchingUtility_ExecuteBatchResult with
      actionResults = []
      outputHoldingMap = mempty
  | otherwise = do
    inputHoldingMap <- getHoldingMap actor (Set.toList batch.accountsAndInstruments)
    [(batchingUtilityCid, _)] <- queryFilter @BatchingUtilityV2.BatchingUtility actor (\u -> u.user == actor)
    submitWithDisclosures' actor batch.disclosures $
      exerciseCmd batchingUtilityCid BatchingUtilityV2.BatchingUtility_ExecuteBatch with
          actions = batch.actions
          inputHoldingMap
          archiveAfterExecution = False

-- | Get a map of unlocked holding cids for the given accounts and instruments.
getHoldingMap : Party -> [(V2.Account, V2.InstrumentId)] -> Script BatchingUtilityV2.HoldingMap
getHoldingMap actor accountAndInstruments0 = do
  taggedHoldings <- forA (dedupSort accountAndInstruments0) $ \(account, instrumentId) -> do
    holdings <- listHoldings actor instrumentId
    let scopedAccount = BatchingUtilityV2.ScopedAccount instrumentId.admin account
    pure [ (scopedAccount, TextMap.fromList [(instrumentId.id, [holdingCid])])
         | (holdingCid, holding) <- holdings, holding.account == account, isNone holding.lock ]
  pure $ BatchingUtilityV2.holdingMapFromList (concat taggedHoldings)


-- Batching utility functions
---------------------------------

data TSABatch = TSABatch with
  actions : [BatchingUtilityV2.TokenStandardAction]
  accountsAndInstruments : Set.Set (V2.Account, V2.InstrumentId)
  disclosures : Disclosures'

instance Semigroup TSABatch where
  TSABatch actions1 accountsAndInstruments1 ds1 <> TSABatch actions2 accountsAndInstruments2 ds2 =
    TSABatch (actions1 <> actions2) (accountsAndInstruments1 <> accountsAndInstruments2) (ds1 <> ds2)

instance Monoid TSABatch where
  mempty = TSABatch mempty mempty mempty

-- | Create the batching utility for the given party.
createBatchingUtility : Party -> Script (ContractId BatchingUtilityV2.BatchingUtility)
createBatchingUtility p =
  submit p $ createCmd BatchingUtilityV2.BatchingUtility with user = p


-- | Create the batch of actions for issuing a transfer from a V1 factory
mkTransferFactory_TransferV1
  : MultiRegistry.MultiRegistry -> V1.TransferFactory_Transfer -> Script TSABatch
mkTransferFactory_TransferV1 registries arg = do
  registry <- MultiRegistry.getRegistryApiV1 registries arg.transfer.instrumentId.admin
  enrichedChoice <- V1.getTransferFactory registry arg
  pure $ TSABatch with
    actions =
      [ BatchingUtilityV2.TSA_TransferFactory_TransferV1 BatchingUtilityV2.ChoiceCall with
          cid = TSU.toAnyContractId enrichedChoice.factoryCid
          arg = enrichedChoice.arg
      ]
    disclosures = enrichedChoice.disclosures
    accountsAndInstruments = Set.singleton
      ( TSU.basicAccount arg.transfer.sender
      , TSU.upcast arg.transfer.instrumentId
      )

-- | Create the batch of actions for issuing a transfer from a V2 factory
mkTransferFactory_TransferV2
  : MultiRegistry.MultiRegistry -> V2.TransferFactory_Transfer -> Script TSABatch
mkTransferFactory_TransferV2 registries arg = do
  registry <- MultiRegistry.getRegistryApiV2 registries arg.transfer.instrumentId.admin
  enrichedChoice <- V2.getTransferFactory registry arg
  pure $ TSABatch with
    actions =
      [ BatchingUtilityV2.TSA_TransferFactory_TransferV2 BatchingUtilityV2.ChoiceCall with
          cid = TSU.toAnyContractId enrichedChoice.factoryCid
          arg = enrichedChoice.arg
      ]
    disclosures = enrichedChoice.disclosures
    accountsAndInstruments = Set.singleton (arg.transfer.sender, arg.transfer.instrumentId)

mkTransferInstruction_AcceptV1
  : MultiRegistry.MultiRegistry -> Party -> ContractId V1.TransferInstruction -> Script TSABatch
mkTransferInstruction_AcceptV1 registries actor cid = do
  Some instrView <- queryInterfaceContractId @V1.TransferInstruction actor cid
  registry <- MultiRegistry.getRegistryApiV1 registries (instrView.transfer.instrumentId.admin)
  context <- V1.getTransferInstruction_AcceptContext registry cid emptyMetadata
  pure $ TSABatch with
    actions =
      [ BatchingUtilityV2.TSA_TransferInstruction_AcceptV1 BatchingUtilityV2.ChoiceCall with
          cid = TSU.toAnyContractId cid
          arg = V1.TransferInstruction_Accept with
            extraArgs = ExtraArgs with
              context = context.choiceContext
              meta = emptyMetadata
      ]
    disclosures = context.disclosures
    accountsAndInstruments = Set.empty

mkTransferInstruction_AcceptV2
  : MultiRegistry.MultiRegistry -> Party -> ContractId V2.TransferInstruction -> Script TSABatch
mkTransferInstruction_AcceptV2 registries actor cid = do
  Some instrView <- queryInterfaceContractId @V2.TransferInstruction actor cid
  registry <- MultiRegistry.getRegistryApiV2 registries (instrView.transfer.instrumentId.admin)
  context <- V2.getTransferInstruction_AcceptContext registry cid emptyMetadata
  pure $ TSABatch with
    actions =
      [ BatchingUtilityV2.TSA_TransferInstruction_AcceptV2 BatchingUtilityV2.ChoiceCall with
          cid = TSU.toAnyContractId cid
          arg = V2.TransferInstruction_Accept with
            actors = [actor]
            extraArgs = ExtraArgs with
              context = context.choiceContext
              meta = emptyMetadata
      ]
    disclosures = context.disclosures
    accountsAndInstruments = Set.empty

mkAllocationFactory_AllocateV1
  : V1.RegistryApi api => api -> Party -> V1.AllocationSpecification -> Script TSABatch
mkAllocationFactory_AllocateV1 registry actor allocation = do
    now <- getTime
    enrichedChoice <- V1.getAllocationFactory registry V1.AllocationFactory_Allocate with
      expectedAdmin = admin
      allocation
      inputHoldingCids = []
      requestedAt = now
      extraArgs = emptyExtraArgs
    let action = BatchingUtilityV2.TSA_AllocationFactory_AllocateV1 BatchingUtilityV2.ChoiceCall with
          cid = coerceContractId enrichedChoice.factoryCid
          arg = enrichedChoice.arg
    pure TSABatch with
      actions = [action]
      accountsAndInstruments = Set.singleton (senderAccount, instrumentId)
      disclosures = enrichedChoice.disclosures
  where
    instrumentId = TSU.upcast allocation.transferLeg.instrumentId
    admin = instrumentId.admin
    senderAccount = TSU.basicAccount actor

mkAllocationFactory_AllocateV2
  : V2.RegistryApi api => api -> Party -> V2.AllocationSpecification -> Script TSABatch
mkAllocationFactory_AllocateV2 registryV2 actor allocation = do
  now <- getTime
  enrichedChoice <- V2.getAllocationFactory registryV2 V2.AllocationFactory_Allocate with
    allocation
    inputHoldingCids = []
    requestedAt = now
    extraArgs = emptyExtraArgs
    actors = [actor]
  let action = BatchingUtilityV2.TSA_AllocationFactory_AllocateV2 BatchingUtilityV2.ChoiceCall with
        cid = TSU.toAnyContractId enrichedChoice.factoryCid
        arg = enrichedChoice.arg
  pure TSABatch with
    actions = [action]
    accountsAndInstruments = Set.fromList
      [ (allocation.authorizer, leg.instrumentId) | leg <- allocation.transferLegs ]
    disclosures = enrichedChoice.disclosures

mkAllocationRequest_AcceptV2 : Party -> ContractId V2.AllocationRequest -> Script TSABatch
mkAllocationRequest_AcceptV2 actor reqCid = do
  let acceptRequest = BatchingUtilityV2.TSA_AllocationRequestV2_Accept BatchingUtilityV2.ChoiceCall with
        cid = TSU.toAnyContractId reqCid
        arg = V2.AllocationRequest_Accept with
          extraArgs = emptyExtraArgs
          actors = [actor]
  pure TSABatch with
    actions = [acceptRequest]
    accountsAndInstruments = mempty
    disclosures = mempty

-- | Combined acceptance of all allocations required to be created by an actor
-- for a V1 allocation request.
mkAcceptAllocationRequestV1 :  MultiRegistry.MultiRegistry -> Party -> V1.AllocationRequestView -> Script TSABatch
mkAcceptAllocationRequestV1 registries actor req = do
  batches <- forA (TextMap.toList req.transferLegs) $ \(legId, leg) -> do
    let admin = leg.instrumentId.admin
    if actor == leg.sender
      then do
        registry <- MultiRegistry.getRegistryApiV1 registries admin
        mkAllocationFactory_AllocateV1 registry actor V1.AllocationSpecification with
          settlement = req.settlement
          transferLegId = legId
          transferLeg = leg
      else pure mempty -- in V1, receivers do not create allocations

  pure $ mconcat batches

-- | Combined acceptance and creation of allocaitons for V2 allocation requests.
mkAcceptAllocationRequestV2
  :  MultiRegistry.MultiRegistry -> Party -> (ContractId V2.AllocationRequest, V2.AllocationRequestView) -> Script TSABatch
mkAcceptAllocationRequestV2 registries actor (reqCid, req) = do
  acceptRequestBatch <- mkAllocationRequest_AcceptV2 actor reqCid
  let legsByAdmin = TSU.splitLegsByAdmin req.transferLegs
  batches <- forA (Map.toList legsByAdmin) $ \(admin, legs) -> do
    apis <- MultiRegistry.getRegistryApis registries admin
    case (apis.v2Api, apis.v1Api) of
      (Some registryV2, _) -> do
        -- when possible use the V2 factory
        mkAllocationFactory_AllocateV2 registryV2 actor V2.AllocationSpecification with
          authorizer = req.authorizer
          settlement = req.settlement
          transferLegs = legs

      (None, Some _) -> do
        -- allocate legs for V1-only admins via their V1 factory
        let reqV1 = V1.AllocationRequestView with
              settlement = TSU.downcast req.settlement
              transferLegs = TextMap.fromList [(leg.transferLegId, TSU.downcast leg) | leg <- legs]
              meta = emptyMetadata
        mkAcceptAllocationRequestV1 registries actor reqV1

      (None, None) -> fail $ "unknown registry admin " <> show admin

  pure (acceptRequestBatch <> mconcat batches)

-- | Accept a transfer offer.
mkAcceptTransferOffer : MultiRegistry.MultiRegistry -> Party -> (ContractId V2.TransferInstruction, V2.Transfer) -> Script TSABatch
mkAcceptTransferOffer registries actor (instrCid, transfer) = do
  supportsV2 <- MultiRegistry.supportsV2 registries transfer.instrumentId.admin
  if supportsV2
    then mkTransferInstruction_AcceptV2 registries actor instrCid
    else mkTransferInstruction_AcceptV1 registries actor (TSU.downcast instrCid)


-- Simplified transfers specifications
--------------------------------------

-- | Simple transfer spec for testing purposes.
data SimpleTransfer = SimpleTransfer with
    sender : Party
    receiver : Party
    amount : Decimal
    instrumentId : V2.InstrumentId
    offerTime : RelTime
    reason : Text
  deriving (Eq, Show)

-- | Create a simplified transfer.
mkTransferFactory_TransferV1' : MultiRegistry.MultiRegistry -> SimpleTransfer -> Script TSABatch
mkTransferFactory_TransferV1' registries t = do
  now <- getTime
  mkTransferFactory_TransferV1 registries V1.TransferFactory_Transfer with
    expectedAdmin = t.instrumentId.admin
    transfer = V1.Transfer with
      sender = t.sender
      receiver = t.receiver
      amount = t.amount
      instrumentId = TSU.downcast t.instrumentId
      requestedAt = now
      executeBefore = now `addRelTime` t.offerTime
      inputHoldingCids = []
      meta = TSU.reasonToMeta t.reason emptyMetadata
    extraArgs = emptyExtraArgs

-- | Create a simplified transfer.
mkTransferFactory_TransferV2' : MultiRegistry.MultiRegistry -> SimpleTransfer -> Script TSABatch
mkTransferFactory_TransferV2' registries t = do
  now <- getTime
  mkTransferFactory_TransferV2 registries V2.TransferFactory_Transfer with
    actors = [t.sender]
    transfer = V2.Transfer with
      sender = TSU.basicAccount t.sender
      receiver = TSU.basicAccount t.receiver
      amount = t.amount
      instrumentId = t.instrumentId
      requestedAt = now
      executeBefore = now `addRelTime` t.offerTime
      inputHoldingCids = []
      meta = TSU.reasonToMeta t.reason emptyMetadata
    extraArgs = emptyExtraArgs

