-- | Tooling to simulate the lookup of the registry API and its version support
-- based on the admin party of the instrument, for testing multi-registry and
-- multi-version scenarios.
module Splice.Testing.TokenStandard.MultiRegistry
  (
    MultiRegistry
  , RegistryApis(..)
  , getRegistryApis
  , getRegistryApiV1
  , getRegistryApiV2
  , supportsV2

  , mkRegistryApisV1
  , mkRegistryApisV2
  , mkRegistryApisV1V2

  -- * Default setup
  , Config(..)
  , Env(..)
  , defaultConfig
  , initialize
  ) where

import DA.Map qualified as Map
import DA.Optional

import Splice.TokenStandard.Utils (downcast)

import Splice.Testing.TokenStandard.RegistryApi qualified as V1
import Splice.Testing.TokenStandard.RegistryApiV2 qualified as V2

import Splice.Testing.Registries.AmuletRegistry qualified as AmuletRegistryV1
import Splice.Testing.Registries.AmuletRegistryV2 qualified as AmuletRegistryV2
import Splice.Testing.Registries.TestTokenV1_RegistryV1 qualified as TestTokenV1_RegistryV1
import Splice.Testing.Registries.TestTokenV2_RegistryV2 qualified as TestTokenV2_RegistryV2

import Daml.Script


-- Multi-registry support
-------------------------

-- | Type alias for a map of registries, keyed by the party that administers them.
type MultiRegistry = Map.Map Party RegistryApis

-- | A handle to the APIs of a registry, which may support V1, V2 or both versions of the token standard.
data RegistryApis = RegistryApis with
  v1Api : Optional V1.GenericRegistry
  v2Api : Optional V2.GenericRegistry

-- | Lookup the registry APIs for a given admin party.
getRegistryApis : MultiRegistry -> Party -> Script RegistryApis
getRegistryApis registries admin = do
  case Map.lookup admin registries of
    None -> fail $ "Registry with admin " <> show admin <> " not found"
    Some apis -> return apis

getRegistryApiV1 : MultiRegistry -> Party -> Script V1.GenericRegistry
getRegistryApiV1 registries admin = do
  apis <- getRegistryApis registries admin
  case apis.v1Api of
    None -> fail $ "Registry with admin " <> show admin <> " does not support V1 API"
    Some api -> return api

getRegistryApiV2 : MultiRegistry -> Party -> Script V2.GenericRegistry
getRegistryApiV2 registries admin = do
  apis <- getRegistryApis registries admin
  case apis.v2Api of
    None -> fail $ "Registry with admin " <> show admin <> " does not support V2 API"
    Some api -> return api

supportsV2 : MultiRegistry -> Party -> Script Bool
supportsV2 registries admin = do
  apis <- getRegistryApis registries admin
  pure (isSome apis.v2Api)

mkRegistryApisV1 : V1.RegistryApi registry => registry -> RegistryApis
mkRegistryApisV1 v1Api = RegistryApis with
  v1Api = Some (V1.mkGenericRegistry v1Api)
  v2Api = None

mkRegistryApisV2 : V2.RegistryApi registry => registry -> RegistryApis
mkRegistryApisV2 v2Api = RegistryApis with
  v1Api = None
  v2Api = Some (V2.mkGenericRegistry v2Api)

mkRegistryApisV1V2 : (V1.RegistryApi v1, V2.RegistryApi v2) => v1 -> v2 -> RegistryApis
mkRegistryApisV1V2 v1Api v2Api = RegistryApis with
  v1Api = Some (V1.mkGenericRegistry v1Api)
  v2Api = Some (V2.mkGenericRegistry v2Api)

-- Default setup
---------------------

-- Note: this is not placed exactly right, as it uses the concrete registries
-- defined here. Move this default config into its own module if there are dependency issues.

data Config = Config with
    amulet : AmuletRegistryV2.AmuletRegistryConfig
    testTokenV1 : TestTokenV1_RegistryV1.TestTokenV1RegistryConfig
    testTokenV2 : TestTokenV2_RegistryV2.TestTokenV2RegistryConfig
  deriving (Eq, Show)

data Env = Env with
  registries : MultiRegistry
  amuletV1 : AmuletRegistryV1.AmuletRegistry
  amuletV2 : AmuletRegistryV2.AmuletRegistry
  testTokenV1 : TestTokenV1_RegistryV1.TestTokenV1Registry
  testTokenV2 : TestTokenV2_RegistryV2.TestTokenV2Registry

defaultConfig : Config
defaultConfig = Config with
  amulet = AmuletRegistryV2.defaultAmuletRegistryConfig
  testTokenV1 = TestTokenV1_RegistryV1.defaultTestTokenV1RegistryConfig
  testTokenV2 = TestTokenV2_RegistryV2.defaultTestTokenV2RegistryConfig

initialize : Config -> Script Env
initialize config = do
  -- setup
  amuletV2 <- AmuletRegistryV2.initialize config.amulet
  let amuletId = amuletV2.instrumentId
  let amuletV1 = AmuletRegistryV1.AmuletRegistry with
        dso = amuletV2.dso
        instrumentId = downcast amuletId

  -- test token v1 registry setup
  testTokenV1 <- TestTokenV1_RegistryV1.initialize config.testTokenV1

  -- test token v2 registry setup
  testTokenV2 <- TestTokenV2_RegistryV2.initialize config.testTokenV2

  let registries = Map.fromList
        [ (amuletV2.dso, mkRegistryApisV1V2 amuletV1 amuletV2)
        , (testTokenV1.admin, mkRegistryApisV1 testTokenV1)
        , (testTokenV2.admin, mkRegistryApisV2 testTokenV2 )
        ]

  pure Env with ..
