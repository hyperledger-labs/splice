-- | V2 registry for the TestTokenV2.
module Splice.Testing.Registries.TestTokenV2_RegistryV2
  (
    -- * Setup
    TestTokenV2RegistryConfig(..)
  , defaultTestTokenV2RegistryConfig

  , TestTokenV2Registry(..)
  , initialize

  , mint
  ) where


import Splice.Api.Token.MetadataV1
import Splice.Api.Token.HoldingV2 qualified as V2
import Splice.Api.Token.AllocationV2 qualified as V2
import Splice.Api.Token.TransferInstructionV2 qualified as V2
import Splice.Api.Token.AllocationInstructionV2 qualified as V2

import Splice.TokenStandard.Utils

import Splice.Testing.Tokens.TestTokenV2 as TestTokenV2
import Splice.Testing.Tokens.TestTokenV2.AccountConfig as AccountConfig
import Splice.Testing.TokenStandard.RegistryApiV2
import Splice.Testing.Utils

import Daml.Script
import DA.Action (foldlA)
import qualified DA.TextMap as TextMap
import DA.List (dedup)
import DA.Optional (catOptionals)
import DA.Foldable (Foldable(foldMap))


-- Registry representation
--------------------------

-- | A reference to a mock amulet registry.
data TestTokenV2Registry = TestTokenV2Registry with
    admin : Party
  deriving (Eq, Ord, Show)

instance RegistryApi TestTokenV2Registry where
  getTransferFactory = registryApi_getTransferFactory
  getAllocationFactory = registryApi_getAllocationFactory
  getSettlementFactory = registryApi_getSettlementFactory
  getAllocation_WithdrawContext = registryApi_getWithdrawContext
  getAllocation_CancelContext = registryApi_getCancelContext
  getAllocationInstruction_WithdrawContext = registryApi_getAllocationInstructionContext
  getAllocationInstruction_AcceptContext = registryApi_getAllocationInstructionContext
  getTransferInstruction_AcceptContext = registryApi_getTransferOfferContext
  getTransferInstruction_RejectContext = registryApi_getTransferOfferContext
  getTransferInstruction_WithdrawContext = registryApi_getTransferOfferContext


-- Registry initialization
--------------------------

data TestTokenV2RegistryConfig = TestTokenV2RegistryConfig
  with
    adminPartyName : Text
  deriving (Eq, Show)

defaultTestTokenV2RegistryConfig : TestTokenV2RegistryConfig
defaultTestTokenV2RegistryConfig = TestTokenV2RegistryConfig with
  adminPartyName = "adminTT2"

-- | Initialize the test token v2 registry.
initialize : TestTokenV2RegistryConfig -> Script TestTokenV2Registry
initialize config = do
  admin <- allocateParty config.adminPartyName
  submit admin $ createCmd TestTokenV2.TokenRules with admin
  pure TestTokenV2Registry with admin

-- | Mint test token instrument
mint : TestTokenV2Registry -> V2.Account -> Text -> Decimal -> Script (ContractId V2.Holding)
mint registry account intrumentName amount = do
  -- TODO(#4813): perform the mint via a transfer from `Account admin "cip-112/mint` once we have transfer support
  -- FIXME: perform mint in a way that produces the proper transfer events
  tokenCid <- submitMulti (registry.admin :: accountParties account) [] $ createCmd TestTokenV2.Token with
    holding = V2.HoldingView with
      account
      amount = amount
      lock = None
      meta = emptyMetadata
      instrumentId = V2.InstrumentId with
        id = intrumentName
        admin = registry.admin
  return $ toInterfaceContractId tokenCid


-- Token standard registry methods
----------------------------------

registryApi_getTransferFactory : TestTokenV2Registry -> V2.TransferFactory_Transfer -> Script (EnrichedFactoryChoice factory V2.TransferFactory_Transfer)
registryApi_getTransferFactory registry transfer = do
  (tokenRulesCid, tokenRulesD) <- getTokenRulesWithDisclosures registry
  (accountConfigs, accountConfigD) <- getAccountMapAndDisclosures registry [transfer.transfer.sender, transfer.transfer.receiver]
  let 
    transfer' = 
      transfer with
        extraArgs.context.values = TextMap.insert accountConfigsContextKey accountConfigs transfer.extraArgs.context.values

  pure EnrichedFactoryChoice with
    factoryCid = coerceContractId tokenRulesCid
    arg = transfer'
    disclosures = tokenRulesD <> accountConfigD

registryApi_getAllocationFactory : TestTokenV2Registry -> V2.AllocationFactory_Allocate -> Script (EnrichedFactoryChoice factory V2.AllocationFactory_Allocate)
registryApi_getAllocationFactory registry allocation = do
  (tokenRulesCid, tokenRulesD) <- getTokenRulesWithDisclosures registry
  (accountConfigs, accountConfigD) <- getAccountMapAndDisclosures registry [allocation.allocation.authorizer]
  let 
    allocation' = 
      allocation with
        extraArgs.context.values = TextMap.insert accountConfigsContextKey accountConfigs allocation.extraArgs.context.values
  pure EnrichedFactoryChoice with
    factoryCid = coerceContractId tokenRulesCid
    arg = allocation'
    disclosures = tokenRulesD <> accountConfigD

registryApi_getSettlementFactory
  : TestTokenV2Registry
  -> V2.SettlementFactory_SettleBatch
  -> Script (EnrichedFactoryChoice V2.SettlementFactory V2.SettlementFactory_SettleBatch)
registryApi_getSettlementFactory registry arg = do
  let accounts = dedup $ concatMap (\leg -> [leg.sender, leg.receiver]) arg.transferLegs
  (accountConfigs, accountConfigD) <- getAccountMapAndDisclosures registry accounts
  (tokenRulesCid, tokenRulesD) <- getTokenRulesWithDisclosures registry
  lockedDs <- forA arg.allocationCids $ \allocCid -> do
    getLockedTokensForAllocationsD registry allocCid
  let 
    arg' = 
      arg with
        extraArgs.context.values = 
          TextMap.insert accountConfigsContextKey accountConfigs $
          TextMap.insert tokenRulesContextKey (AV_ContractId $ coerceContractId tokenRulesCid) arg.extraArgs.context.values
 
  pure EnrichedFactoryChoice with
    factoryCid = coerceContractId tokenRulesCid
    arg = arg'
    disclosures = accountConfigD <> tokenRulesD <> mconcat lockedDs

registryApi_getTransferOfferContext : TestTokenV2Registry -> ContractId V2.TransferInstruction -> Metadata -> Script OpenApiChoiceContext
registryApi_getTransferOfferContext registry instrCid _meta = do
  Some instrView <- queryInterfaceContractId @V2.TransferInstruction registry.admin instrCid
  (accountConfigs, accountConfigD) <- getAccountMapAndDisclosures registry [instrView.transfer.sender, instrView.transfer.receiver]
  let 
    choiceContext = 
      emptyChoiceContext with
        values = TextMap.insert accountConfigsContextKey accountConfigs TextMap.empty

  lockedDs <- forA instrView.transfer.inputHoldingCids $ \holdingCid -> do
    let tokenCid = coerceContractId holdingCid : ContractId Token
    queryDisclosure' @Token registry.admin tokenCid
  pure OpenApiChoiceContext with
    disclosures = accountConfigD <> mconcat lockedDs
    choiceContext

registryApi_getAllocationInstructionContext : TestTokenV2Registry -> ContractId V2.AllocationInstruction -> Metadata -> Script OpenApiChoiceContext
registryApi_getAllocationInstructionContext registry instrCid _meta = do
  Some instrView <- queryInterfaceContractId @V2.AllocationInstruction registry.admin instrCid
  (accountConfigs, accountConfigD) <- getAccountMapAndDisclosures registry [instrView.allocation.authorizer]
  let 
    choiceContext = 
      emptyChoiceContext with
        values = TextMap.insert accountConfigsContextKey accountConfigs TextMap.empty

  pure OpenApiChoiceContext with
    disclosures = accountConfigD
    choiceContext

registryApi_getWithdrawContext
  : TestTokenV2Registry
  -> ContractId V2.Allocation
  -> Metadata
  -> Script OpenApiChoiceContext
registryApi_getWithdrawContext registry cid _meta = do
  Some allocView <- queryInterfaceContractId @V2.Allocation registry.admin cid
  (accountConfigs, accountConfigD) <- getAccountMapAndDisclosures registry [allocView.allocation.authorizer]
  let 
    choiceContext = 
      emptyChoiceContext with
        values = TextMap.insert accountConfigsContextKey accountConfigs TextMap.empty

  pure OpenApiChoiceContext with
    disclosures = accountConfigD
    choiceContext

registryApi_getCancelContext
  : TestTokenV2Registry
  -> ContractId V2.Allocation
  -> Metadata
  -> Script OpenApiChoiceContext
registryApi_getCancelContext registry cid _meta = do
  Some allocView <- queryInterfaceContractId @V2.Allocation registry.admin cid
  (accountConfigs, accountConfigD) <- getAccountMapAndDisclosures registry [allocView.allocation.authorizer]
  let 
    choiceContext = 
      emptyChoiceContext with
        values = TextMap.insert accountConfigsContextKey accountConfigs TextMap.empty

  lockedTokensD <- getLockedTokensForAllocationsD registry cid
  pure OpenApiChoiceContext with
    disclosures = accountConfigD <> lockedTokensD
    choiceContext

getTokenRules : TestTokenV2Registry -> Script (ContractId TestTokenV2.TokenRules, TestTokenV2.TokenRules)
getTokenRules registry = getTokenRules' registry.admin

getTokenRules' : Party -> Script (ContractId TestTokenV2.TokenRules, TestTokenV2.TokenRules)
getTokenRules' admin = do
  rules <- query @TestTokenV2.TokenRules admin
  case rules of
    [rule] -> return rule
    [] -> fail $ "No TestTokenV2Rules found: did you initialize the TestTokenV2 registry?"
    _ -> fail "Multiple TestTokenV2Rules found: are you initializing the TestTokenV2 registry multiple times?"

getTokenRulesWithDisclosures
  : TestTokenV2Registry -> Script (ContractId TestTokenV2.TokenRules, Disclosures')
getTokenRulesWithDisclosures registry = do
  (tokenRulesCid, _) <- getTokenRules registry
  tokenRulesD <- queryDisclosure' @TestTokenV2.TokenRules registry.admin tokenRulesCid
  pure (tokenRulesCid, tokenRulesD)

getLockedTokensForAllocationsD : TestTokenV2Registry -> ContractId V2.Allocation -> Script Disclosures'
getLockedTokensForAllocationsD registry allocCid = do
  Some allocView <- queryInterfaceContractId @V2.Allocation registry.admin allocCid
  discs <- forA allocView.holdingCids $ \holdingCid -> do
    let tokenCid = coerceContractId holdingCid : ContractId Token
    queryDisclosure' @Token registry.admin tokenCid
  pure $ mconcat discs

getAccountMapAndDisclosures : TestTokenV2Registry -> [V2.Account] -> Script (AnyValue, Disclosures')
getAccountMapAndDisclosures registry accounts = do
  accountConfigs <- catOptionals <$> forA accounts (getAccountConfig registry)
  pure (AV_List (map (AV_ContractId . coerceContractId . fst) accountConfigs), foldMap snd accountConfigs)

getAccountConfig : TestTokenV2Registry -> V2.Account -> Script (Optional (ContractId AccountConfig.AccountConfig, Disclosures'))
getAccountConfig registry account = do
  cids <- queryFilter @AccountConfig.AccountConfig registry.admin (\config -> config.account == account) 
  case cids of
    [(cid, _config)] -> do
      disclosure <- queryDisclosure' @AccountConfig.AccountConfig registry.admin cid
      return (Some (cid, disclosure))
    [] -> return None
    _ -> abort ("More than one account config found for " <> (show account))
