-- TODO(#4621): this code should not exist on its own at all. There's only one
-- TestTokenV1Registry, and it should implement both APIs fix this as part of merging
-- the V1 and V2 test suites.


-- Registry representation
--------------------------

-- | A reference to a mock amulet registry.
data TestTokenV1Registry = TestTokenV1Registry with
    admin : Party
  deriving (Eq, Ord, Show)

instance RegistryApi TestTokenV1Registry where
  getTransferFactory = registryApi_getTransferFactory
  getAllocationFactory = registryApi_getAllocationFactory
  getSettlementFactory = registryApi_getSettlementFactory
  getAllocation_WithdrawContext app cid _meta = registryApi_getAllocation_abortTwoStepTransferContext app cid
  getAllocation_CancelContext app cid _meta = registryApi_getAllocation_abortTwoStepTransferContext app cid
  getTransferInstruction_AcceptContext app cid _meta = registryApi_getTransferInstruction_AcceptContext app cid
  getTransferInstruction_RejectContext app cid _meta = registryApi_getTransferInstruction_abortTwoStepTransferContext app cid
  getTransferInstruction_WithdrawContext app cid _meta = registryApi_getTransferInstruction_abortTwoStepTransferContext app cid

-- | Convert the single registry to a multi-registry.
amuletToMultiRegistry : TestTokenV1Registry -> MultiRegistry
amuletToMultiRegistry registry = Map.singleton registry.dso (mkGenericRegistry registry)


-- Registry initialization
--------------------------
data TestTokenV1RegistryConfig = TestTokenV1RegistryConfig
  with
    adminPartyName : Text
  deriving (Eq, Show)

-- | Initialize the mock amulet registry.
initialize : TestTokenV1RegistryConfig -> Script TestTokenV1Registry
initialize config = do
  admin <- allocateParty config.adminPartyName
  let registry = TestTokenV1Registry with
        admin = admin

  submit admin $ createCmd TestTokenV1.TokenRules with
    configSchedule = defaultTestTokenV1ConfigSchedule
    isDevNet = True
    contractStateSchemaVersion = None
    ..

  _ <- submit dso $ createCmd ExternalPartyTestTokenV1Rules with dso

  (amuletRulesCid, _) <- getTestTokenV1Rules registry
  _ <- submit registry.dso $ exerciseCmd amuletRulesCid TestTokenV1Rules_Bootstrap_Rounds with
      amuletPrice = config.initialTestTokenV1Price
      round0Duration = minutes 10 -- no special setup for normal tests
      initialRound = None

  -- return the off-ledger reference to the registry for later script steps
  return registry


-- | Tap the faucet on DevNet to get a specified amount of TestTokenV1.
tapFaucet : TestTokenV1Registry -> Party -> Decimal -> Script (ContractId Holding)
tapFaucet registry user amount = do
  (openRound, _) <- getLatestOpenRound registry
  (amuletRulesCid, _) <- getTestTokenV1Rules registry
  amuletRulesD <- queryDisclosure' @TestTokenV1Rules registry.dso amuletRulesCid
  openMiningRoundD <- queryDisclosure' @OpenMiningRound registry.dso openRound
  let disclosures = amuletRulesD <> openMiningRoundD
  result <- submitWithDisclosures' user disclosures $ exerciseCmd amuletRulesCid TestTokenV1Rules_DevNet_Tap with
    receiver = user
    amount
    openRound
  return $ toInterfaceContractId result.amuletSum.amulet


-- | Direct-create locked amulet -- used for testing purposes only.
createLockedTestTokenV1 : TestTokenV1Registry -> Party -> Decimal -> TimeLock -> Script (ContractId Holding)
createLockedTestTokenV1 registry user amount lock = do
  (_, openRound) <- getLatestOpenRound registry
  let transferConfigTestTokenV1 = transferConfigTestTokenV1FromOpenRound openRound
  lockedTestTokenV1Cid <- submitMulti [user, registry.dso] [] $ createCmd LockedTestTokenV1 with
    lock
    amulet = TestTokenV1 with
      dso = registry.dso
      owner = user
      amount = ExpiringAmount with
        initialAmount = amount
        createdAt = openRound.round
        ratePerRound = transferConfigTestTokenV1.holdingFee
  pure (toInterfaceContractId lockedTestTokenV1Cid)

-- | Simulate that a validator operator created a transfer pre-approval for a party
-- for the purpose of that party being able to receive TestTokenV1 from any other party.
createTransferPreapproval : TestTokenV1Registry -> Party -> Party -> Time -> Script (ContractId TransferPreapproval)
createTransferPreapproval registry receiver provider expiresAt = do
  now <- getTime
  submitMulti [receiver, provider, registry.dso] [] $ createCmd TransferPreapproval with
      receiver
      provider
      dso = registry.dso
      validFrom = now
      lastRenewedAt = now
      expiresAt

-- | Mark a particular registry provider part as featured.
featureApp : TestTokenV1Registry -> Party -> Script (ContractId FeaturedAppRight)
featureApp registry provider = do
  (amuletRulesCid, _) <- getTestTokenV1Rules registry
  result <- submitMulti [provider] [registry.dso] $ exerciseCmd amuletRulesCid TestTokenV1Rules_DevNet_FeatureApp with
    provider
  return result.featuredAppRightCid

-- | Encode a list of beneficiaries as metadata to pass in via token standard choices.
-- Currently only supported for allocation execution.
beneficiariesToMetadata : [(Party, Decimal)] -> Metadata
beneficiariesToMetadata [] = emptyMetadata
beneficiariesToMetadata bs = Metadata with
    values = TextMap.fromList
      [ (appRewardBeneficiariesMetaKey, commaSeparated [ partyToText b._1 | b <- bs])
      , (appRewardBeneficiaryWeightsMetaKey, commaSeparated [ show b._2 | b <- bs])
      ]
  where
    commaSeparated = T.intercalate ","


-- Token standard registry implementation
-----------------------------------------

registryApi_getTransferFactory
  : TestTokenV1Registry -> TransferFactory_Transfer
  -> Script (EnrichedFactoryChoice TransferFactory TransferFactory_Transfer)
registryApi_getTransferFactory registry arg = do
  (extTestTokenV1RulesCid, extTestTokenV1RulesD) <- getExtTestTokenV1RulesWithDisclosures registry
  transferC <- getExternalPartyConfigStateContext registry
  let isSelfTransfer = arg.transfer.sender.owner == arg.transfer.receiver.owner
  (optPreapproval, preapprovalC) <-
    if isSelfTransfer
      then pure (None, emptyOpenApiChoiceContext)
      else lookupPreapprovalWithContext registry arg.transfer.receiver.owner
  featuredAppRightC <- case optPreapproval of
    None -> pure emptyOpenApiChoiceContext
    Some preapproval -> getFeaturedAppRightContext registry preapproval.provider
  let fullContext = withExtraDisclosures extTestTokenV1RulesD
        (transferC <> preapprovalC <> featuredAppRightC)
  pure EnrichedFactoryChoice with
    factoryCid = toInterfaceContractId @TransferFactory extTestTokenV1RulesCid
    arg = arg with extraArgs = arg.extraArgs with context = fullContext.choiceContext
    disclosures = fullContext.disclosures

registryApi_getAllocationFactory
  : TestTokenV1Registry -> AllocationFactory_Allocate
  -> Script (EnrichedFactoryChoice AllocationFactory AllocationFactory_Allocate)
registryApi_getAllocationFactory registry arg = do
  (extTestTokenV1RulesCid, extTestTokenV1RulesD) <- getExtTestTokenV1RulesWithDisclosures registry
  transferC <- getExternalPartyConfigStateContext registry
  let fullContext = withExtraDisclosures extTestTokenV1RulesD transferC
  pure EnrichedFactoryChoice with
    factoryCid = toInterfaceContractId @AllocationFactory extTestTokenV1RulesCid
    arg = arg with extraArgs = arg.extraArgs with context = fullContext.choiceContext
    disclosures = fullContext.disclosures

registryApi_getSettlementFactory
  : TestTokenV1Registry
  -> SettlementFactory_SettleBatch
  -> Script (EnrichedFactoryChoice SettlementFactory SettlementFactory_SettleBatch)
registryApi_getSettlementFactory registry arg = do
  (extTestTokenV1RulesCid, extTestTokenV1RulesD) <- getExtTestTokenV1RulesWithDisclosures registry
  transferC <- getExternalPartyConfigStateContext registry
  -- Note: the real backend implementation has two options:
  --
  -- 1. fetch the interface view of `V2.Allocation` and use the `holdingCids` field to
  --    determine the candidate locked amulets to disclose as done below
  -- 2. fetch the allocation contract directly as either an `TestTokenV1AllocationV2` or `TestTokenV1Allocation`
  --    and use the `lockedTestTokenV1` field to determine the locked amulet to disclose.
  --
  -- Option 2 seems preferable from given an architecture where the backend does not
  -- ingest interfaces, but only works with the concrete templates.
  --
  lockedDs <- forA arg.allocationCids $ \allocCid -> do
    getLockedTestTokenV1ForAllocationsD registry allocCid
  let fullContext = withExtraDisclosures (extTestTokenV1RulesD <> mconcat lockedDs) transferC
  pure EnrichedFactoryChoice with
    factoryCid = toInterfaceContractId @SettlementFactory extTestTokenV1RulesCid
    arg = arg with extraArgs = arg.extraArgs with context = fullContext.choiceContext
    disclosures = fullContext.disclosures

registryApi_getTransferInstruction_AcceptContext
  : TestTokenV1Registry -> ContractId TransferInstruction -> Script OpenApiChoiceContext
registryApi_getTransferInstruction_AcceptContext registry instrCid = do
  transferC <- getExternalPartyConfigStateContext registry
  Some amuletInstr <- queryContractId @TestTokenV1TransferInstruction registry.dso (coerceContractId instrCid)
  -- need to disclose the amulet contract, as the receiver has no visibility into it
  lockedTestTokenV1D <- queryDisclosure' @LockedTestTokenV1 registry.dso amuletInstr.lockedTestTokenV1
  pure $ withExtraDisclosures lockedTestTokenV1D transferC

registryApi_getTransferInstruction_abortTwoStepTransferContext
  : TestTokenV1Registry -> ContractId TransferInstruction -> Script OpenApiChoiceContext
registryApi_getTransferInstruction_abortTwoStepTransferContext registry instrCid = do
  -- check whether the locked amulet is still active, so that aborts still work
  -- even if the owner of the LockedTestTokenV1 expired it
  Some amuletInstr <- queryContractId @TestTokenV1TransferInstruction registry.dso (coerceContractId instrCid)
  optLockedTestTokenV1 <- queryContractId @LockedTestTokenV1 registry.dso amuletInstr.lockedTestTokenV1
  let lockedTestTokenV1Active = isSome optLockedTestTokenV1
  -- this can only happen if the locked amulet already expired
  now <- getTime
  unless (lockedTestTokenV1Active || amuletInstr.transfer.executeBefore <= now) $
    fail "Invariant violation: the locked amulet is archived, but the transfer is not yet expired"
  -- this context communicates whether to unlock the amulet
  let expireLockC = OpenApiChoiceContext with
        disclosures = mempty
        choiceContext = mkTestTokenV1Context $ TextMap.fromList [(expireLockKey, AV_Bool lockedTestTokenV1Active)]
  if lockedTestTokenV1Active
    then do
      -- disclose the amulet contract, as the caller might not be able to see it
      lockedTestTokenV1D <- queryDisclosure' @LockedTestTokenV1 registry.dso amuletInstr.lockedTestTokenV1
      pure $ withExtraDisclosures lockedTestTokenV1D expireLockC
    else
      pure expireLockC

registryApi_getAllocation_abortTwoStepTransferContext
  : TestTokenV1Registry -> ContractId Allocation -> Script OpenApiChoiceContext
registryApi_getAllocation_abortTwoStepTransferContext registry instrCid = do
  -- check whether the locked amulet is still active, so that aborts still work
  -- even if the owner of the LockedTestTokenV1 expired it
  lockedCid <- lookupLockedTestTokenV1OfAllocation registry instrCid
  case lockedCid of
    None -> pure emptyOpenApiChoiceContext
    Some la -> do
      optLockedTestTokenV1 <- queryContractId @LockedTestTokenV1 registry.dso la
      let lockedTestTokenV1Active = isSome optLockedTestTokenV1
      let expireLockC = OpenApiChoiceContext with
            disclosures = mempty
            choiceContext = mkTestTokenV1Context $ TextMap.fromList [(expireLockKey, AV_Bool lockedTestTokenV1Active)]
      if lockedTestTokenV1Active
        then do
          -- disclose the amulet contract, as the caller might not be able to see it
          lockedTestTokenV1D <- queryDisclosure' @LockedTestTokenV1 registry.dso la
          pure $ withExtraDisclosures lockedTestTokenV1D expireLockC
        else
          pure expireLockC


-- Internal functions
---------------------

mkTestTokenV1Context : TextMap.TextMap AnyValue -> ChoiceContext
mkTestTokenV1Context values = ChoiceContext with
  values

getTestTokenV1Rules : TestTokenV1Registry -> Script (ContractId TestTokenV1Rules, TestTokenV1Rules)
getTestTokenV1Rules registry = getTestTokenV1Rules' registry.dso

getTestTokenV1Rules' : Party -> Script (ContractId TestTokenV1Rules, TestTokenV1Rules)
getTestTokenV1Rules' dso = do
  rules <- query @TestTokenV1Rules dso
  case rules of
    [rule] -> return rule
    [] -> failNotInitialized "No TestTokenV1Rules found"
    _ -> fail "Multiple TestTokenV1Rules found: are you initializing the TestTokenV1 registry multiple times?"

-- Primarily used by submitters to decide against which round they should try to transact.
getLatestOpenRound : TestTokenV1Registry -> Script (ContractId OpenMiningRound, OpenMiningRound)
getLatestOpenRound registry = getLatestOpenRound' registry.dso

getLatestOpenRound' : Party -> Script (ContractId OpenMiningRound, OpenMiningRound)
getLatestOpenRound' dso = do
  now <- getTime
  -- only get open rounds
  rounds <- queryFilter @OpenMiningRound dso (\round -> now >= round.opensAt)
  case maximumOn (\(_, r) -> r.round) rounds of
    None -> failNotInitialized "No open open mining round found"
    Some r-> pure r

failNotInitialized : Text -> Script a
failNotInitialized problem =
  fail $ problem <> ": have you called 'initialize' to initialize the TestTokenV1 registry?"

getExtTestTokenV1RulesWithDisclosures : TestTokenV1Registry -> Script (ContractId ExternalPartyTestTokenV1Rules, Disclosures')
getExtTestTokenV1RulesWithDisclosures registry = do
  [(extTestTokenV1RulesCid, _)] <- query @ExternalPartyTestTokenV1Rules registry.dso
  extTestTokenV1RulesD <- queryDisclosure' registry.dso extTestTokenV1RulesCid
  pure (extTestTokenV1RulesCid, extTestTokenV1RulesD)

getExternalPartyConfigStateContext : TestTokenV1Registry -> Script OpenApiChoiceContext
getExternalPartyConfigStateContext registry = do
  extPartyConfigs <- query @ExternalPartyConfigState registry.dso
  let (newestConfigCid, _) = case maximumOn (\(_, c) -> c.targetArchiveAfter) extPartyConfigs of
        None -> error "No ExternalPartyConfigState found: have you initialized the TestTokenV1 registry?"
        Some c -> c
  extConfigDD <- queryDisclosure' @ExternalPartyConfigState registry.dso newestConfigCid
  pure OpenApiChoiceContext with
    choiceContext = mkTestTokenV1Context $ TextMap.fromList
        [(externalPartyConfigStateContextKey, AV_ContractId $ coerceContractId newestConfigCid)]
    disclosures = extConfigDD

lookupPreapprovalWithContext : TestTokenV1Registry -> Party -> Script (Optional TransferPreapproval, OpenApiChoiceContext)
lookupPreapprovalWithContext registry receiver = do
  preapprovals  <- queryFilter @TransferPreapproval receiver (\preapproval -> preapproval.receiver == receiver)
  case preapprovals of
    [] -> pure (None, emptyOpenApiChoiceContext)
    (preapprovalCid, preapproval) :: _ ->  do
      preapprovalD <- queryDisclosure' @TransferPreapproval registry.dso preapprovalCid
      pure
        ( Some preapproval
        , OpenApiChoiceContext with
          disclosures = preapprovalD
          choiceContext = mkTestTokenV1Context $
            TextMap.fromList [(transferPreapprovalContextKey, AV_ContractId (coerceContractId preapprovalCid))]
        )

getFeaturedAppRightContext : TestTokenV1Registry -> Party -> Script OpenApiChoiceContext
getFeaturedAppRightContext registry provider = do
  appRights <- queryFilter @FeaturedAppRight registry.dso (\appRight -> appRight.provider == provider)
  case appRights of
    [] -> pure emptyOpenApiChoiceContext
    (rightCid, _) :: _ -> do
      rightDisc <- queryDisclosure' @FeaturedAppRight registry.dso rightCid
      pure OpenApiChoiceContext with
        disclosures = rightDisc
        choiceContext = mkTestTokenV1Context $
          TextMap.fromList [ (featuredAppRightContextKey, AV_ContractId (coerceContractId rightCid)) ]

lookupLockedTestTokenV1OfAllocation : TestTokenV1Registry -> ContractId Allocation -> Script (Optional (ContractId LockedTestTokenV1))
lookupLockedTestTokenV1OfAllocation registry allocCid = do
  Some allocView <- queryInterfaceContractId @Allocation registry.dso allocCid
  case allocView.holdingCids of
    [] -> pure None
    [holdingCid] -> pure (Some (coerceContractId holdingCid))
    _ -> fail $ T.unlines ["unexpected: multiple holding cids for allocation:", show allocView]

getLockedTestTokenV1ForAllocationsD : TestTokenV1Registry -> ContractId Allocation -> Script Disclosures'
getLockedTestTokenV1ForAllocationsD registry allocCid = do
  optLockedTestTokenV1Cid <- lookupLockedTestTokenV1OfAllocation registry allocCid
  case optLockedTestTokenV1Cid of
    None -> return mempty
    Some la -> queryDisclosure' @LockedTestTokenV1 registry.dso la

emptyOpenApiChoiceContext : OpenApiChoiceContext
emptyOpenApiChoiceContext = OpenApiChoiceContext with
  disclosures = mempty
  choiceContext = mkTestTokenV1Context TextMap.empty

expireLockAsOwner : TestTokenV1Registry -> ContractId Holding -> Script (ContractId Holding)
expireLockAsOwner  registry lockedHoldingCid = do
  let lockedTestTokenV1Cid = coerceContractId lockedHoldingCid
  Some lockedTestTokenV1 <- queryContractId @LockedTestTokenV1 registry.dso lockedTestTokenV1Cid
  result <- submit lockedTestTokenV1.amulet.owner $ exerciseCmd lockedTestTokenV1Cid
    LockedTestTokenV1_OwnerExpireLockV2
  pure (toInterfaceContractId result.amuletCid)

-- | Get funds in equal splits as locked and unlocked holdings to test using
-- expired locked holdings as transfer inputs.
tapLockedAndUnlockedFunds : TestTokenV1Registry -> Party -> Decimal -> Script [ContractId Holding]
tapLockedAndUnlockedFunds registry user amount = do
  let lockedAmount = amount / 2.0
  let unlockedAmount = amount - lockedAmount
  unlockedCid <- tapFaucet registry user unlockedAmount
  now <- getTime
  lockedCid <- createLockedTestTokenV1 registry user lockedAmount TimeLock with
   holders = [registry.dso]
   expiresAt = now -- we want these funds to already be expired
   optContext = Some "test expired lock"
  pure [unlockedCid, lockedCid]

-- | Advance time to next round change
advanceToNextRoundChange : Party -> Script ()
advanceToNextRoundChange dso = do
  [(_, oldest), _, (_, newest)] <- getActiveOpenRoundsSorted dso
  now <- getTime
  let roundChangePossibleAt = max oldest.targetClosesAt newest.opensAt
  when (now < roundChangePossibleAt) $ setTime roundChangePossibleAt

getActiveOpenRoundsSorted : Party -> Script [(ContractId OpenMiningRound, OpenMiningRound)]
getActiveOpenRoundsSorted dso = do
  rounds <- query @OpenMiningRound dso
  return $ sortOn (\(_, openRound) -> openRound.round) rounds

convertAllFeaturedAppActivityMarkers : Party -> Script ()
convertAllFeaturedAppActivityMarkers dso = do
  markers <- queryFilter @FeaturedAppActivityMarker dso (\m -> m.dso == dso)
  (latestOpenRoundCid, _) <- getLatestOpenRound' dso
  (amuletRulesCid, _) <- getTestTokenV1Rules' dso
  submit dso $ exerciseCmd amuletRulesCid TestTokenV1Rules_ConvertFeaturedAppActivityMarkers with
    markerCids = map fst markers
    openMiningRoundCid = latestOpenRoundCid
    observers = None
  pure ()


-- Only directly call this function if you know what you are doing.
-- Due to effective-dating, the price you give here is not the amulet price that can be used immediately
runNextIssuance : Party -> Decimal -> Script ()
runNextIssuance dso amuletPrice = do
    [(amuletRulesCid, _)] <- query @TestTokenV1Rules dso
    advanceToNextRoundChange dso
    -- expire rewards for closed rounds
    closedRounds <- query @ClosedMiningRound dso
    forA_ closedRounds $ \(closedRoundCid, miningRound) -> do
      -- app rewards
      rewards <- queryFilter @AppRewardCoupon dso (\r -> r.round == miningRound.round)
      forA_ rewards $ \(rcid, _) ->
        submit dso $ exerciseCmd rcid AppRewardCoupon_DsoExpire with closedRoundCid
      -- validator rewards
      rewards <- queryFilter @ValidatorRewardCoupon dso (\r -> r.round == miningRound.round)
      forA_ rewards $ \(rcid, _) ->
        submit dso $ exerciseCmd rcid ValidatorRewardCoupon_DsoExpire with closedRoundCid
      -- the closed round


      submit dso $ exerciseCmd amuletRulesCid TestTokenV1Rules_MiningRound_Archive with
        closedRoundCid

    -- close issuing rounds that are ready for close
    now <- getTime
    imcs <- queryFilter @IssuingMiningRound dso (\r -> r.targetClosesAt <= now)
    forA_ imcs $ \(issuingRoundCid, _) ->
      submit dso $ exerciseCmd amuletRulesCid TestTokenV1Rules_MiningRound_Close with
        issuingRoundCid

    -- transition the oldest OpenMiningRound into a SummarizingMiningRound and
    -- create a new OpenMiningRound
    [(roundToArchiveCid, roundToArchive), (r2Cid, _), (r3Cid, _)] <- getActiveOpenRoundsSorted dso
    advanceResult <- submit dso $ exerciseCmd amuletRulesCid TestTokenV1Rules_AdvanceOpenMiningRounds with
      amuletPrice
      roundToArchiveCid
      middleRoundCid = r2Cid
      latestRoundCid = r3Cid
    let closingRoundCid = advanceResult.summarizingRoundCid

    -- compute total burn
    appRewardCoupons <- queryFilter @AppRewardCoupon dso (\bc -> bc.round == roundToArchive.round)
    validatorRewardCoupons <- queryFilter @ValidatorRewardCoupon dso (\bc -> bc.round == roundToArchive.round)
    validatorFaucetCoupons <- queryFilter @ValidatorFaucetCoupon dso (\bc -> bc.round == roundToArchive.round)
    validatorLivenessActivityRecords <- queryFilter @ValidatorLivenessActivityRecord dso (\bc -> bc.round == roundToArchive.round)
    svRewardCoupons <- queryFilter @SvRewardCoupon dso (\bc -> bc.round == roundToArchive.round)

    let summary = OpenMiningRoundSummary with
          totalValidatorRewardCoupons = sum [ c.amount | (_, c) <- validatorRewardCoupons]
          totalFeaturedAppRewardCoupons = sum [ c.amount | (_, c) <- appRewardCoupons, c.featured]
          totalUnfeaturedAppRewardCoupons = sum [ c.amount | (_, c) <- appRewardCoupons, not (c.featured)]
          totalSvRewardWeight = sum [ c.weight | (_, c) <- svRewardCoupons]
          optTotalValidatorFaucetCoupons = Some (length validatorFaucetCoupons + length validatorLivenessActivityRecords)

    -- create issuing mining round
    submit dso $ exerciseCmd amuletRulesCid TestTokenV1Rules_MiningRound_StartIssuing with
      miningRoundCid = closingRoundCid
      summary

    pure ()
