-- | Daml script test utilities for simulating the actions of wallet client
-- based on the token standard.
--
-- NOTE: there are likely more functions that could/should be added to this module. PRs welcome.
module Splice.Testing.TokenStandard.WalletClient
  (
    -- * Reading/checking holdings
    listHoldings,
    listHoldingCids,
    listLockedHoldings,

    checkHoldingWithAmountExists,
    checkBalanceBounds,
    checkBalance,
    checkBalanceApprox,
    checkHolding,
    checkHoldingBounds,
    checkHoldingApprox,

    -- * Reading transfer instructions
    listTransferOffers,

    -- * Reading allocations
    listRequestedAllocations,

    listAllocationRequests,
    acceptAllocationRequest,
  ) where

import DA.Action (unless)
import DA.Foldable (forA_)
import DA.Optional
import DA.TextMap qualified as TextMap

import Splice.Api.Token.AllocationV1 qualified as V1
import Splice.Api.Token.AllocationInstructionV1 qualified as V1
import Splice.Api.Token.AllocationRequestV1 qualified as V1
import Splice.Api.Token.HoldingV1 qualified as V1
import Splice.Api.Token.TransferInstructionV1 qualified as V1

import Splice.Testing.TokenStandard.RegistryApi
import Splice.Testing.Utils

import Daml.Script

-- | List the hodlings of a party of a specific instrument.
listHoldings : Party -> V1.InstrumentId -> Script [(ContractId V1.Holding, V1.HoldingView)]
listHoldings p instrumentId = do
  holdings <- queryInterface @V1.Holding p
  let instrumendHoldings = do
        (cid, Some holding) <- holdings
        guard (holding.instrumentId == instrumentId)
        guard (holding.owner == p)
        pure (cid, holding)
  pure instrumendHoldings

listLockedHoldings : Party -> V1.InstrumentId -> Script [(ContractId V1.Holding, V1.HoldingView)]
listLockedHoldings p instrumentId =
  filter (\(_, holding) -> isSome (holding.lock)) <$> listHoldings p instrumentId

listUnlockedHoldings : Party -> V1.InstrumentId -> Script [(ContractId V1.Holding, V1.HoldingView)]
listUnlockedHoldings p instrumentId =
  filter (\(_, holding) -> isNone (holding.lock)) <$> listHoldings p instrumentId

-- | List the cids of the hodlings of a party of a specific instrument.
listHoldingCids : Party -> V1.InstrumentId -> Script [ContractId V1.Holding]
listHoldingCids p instrumentId = (map fst) <$> listHoldings p instrumentId

-- | Check that a holding with a specific amount exists for the given owner.
checkHoldingWithAmountExists : Party -> V1.InstrumentId -> Decimal -> Script ()
checkHoldingWithAmountExists p instrumentId amount = do
  holdings <- map snd <$> listHoldings p instrumentId
  unless (any (\holding -> holding.amount == amount) holdings) $
    fail (show p <> " is missing holding of value " <> show amount <> " in " <> show holdings)

-- | Check the bounds on a party's total balance of all holdings of the given instrument.
checkBalanceBounds : Party -> V1.InstrumentId -> (Decimal, Decimal) -> Script ()
checkBalanceBounds p instrumentId (lb, ub) = do
  holdings <- listHoldings p instrumentId
  let total = sum $ map (._2.amount) holdings
  unless (total >= lb && total <= ub) $ fail $
    "Wallet " <> show p <> ": balance of " <> show total <> " for " <> show instrumentId <>
    " is not within the expected range [" <> show lb <> ", " <> show ub <> "]"

-- | Check the exact value of on an individual holding's amount.
checkHolding : Party -> ContractId V1.Holding -> Decimal -> Script ()
checkHolding p holdingCid amount = checkHoldingBounds p holdingCid (amount, amount)

-- | Check the bounds on an individual holding's amount.
checkHoldingBounds : Party -> ContractId V1.Holding -> (Decimal, Decimal) -> Script ()
checkHoldingBounds p holdingCid (lb, ub) = do
  holdingO <- queryInterfaceContractId p holdingCid
  let holding = case holdingO of
        None -> error $ "Holding " <> show holdingCid <> " was not found"
        Some holding -> holding
  unless (holding.amount >= lb && holding.amount <= ub) $ fail $
    "Holding " <> show holding <>
    " is not within the expected range [" <> show lb <> ", " <> show ub <> "]"

-- | Check the approximate value (+/- 1.0) a party's total balance of all holdings of the given instrument.
checkBalanceApprox : Party -> V1.InstrumentId -> Decimal -> Script ()
checkBalanceApprox p instrumentId approximateBalance =
  checkBalanceBounds p instrumentId (approximateBalance - 1.0, approximateBalance + 1.0)

-- | Check the approximate (+/- 1.0) amount of an individual holding.
checkHoldingApprox : Party -> ContractId V1.Holding -> Decimal -> Script ()
checkHoldingApprox p holdingCid approximateAmount = checkHoldingBounds p holdingCid (approximateAmount - 1.0, approximateAmount + 1.0)

-- | Check the exact value a party's total balance of all holdings of the given instrument.
checkBalance : Party -> V1.InstrumentId -> Decimal -> Script ()
checkBalance p instrumentId balance =
  checkBalanceBounds p instrumentId (balance, balance)

-- | List pending transfer offers (as sender or receiver)
listTransferOffers : Party -> V1.InstrumentId -> Script [(ContractId V1.TransferInstruction, V1.TransferInstructionView)]
listTransferOffers p instrumentId = do
  instrs <- queryInterface @V1.TransferInstruction p
  let pendingOffers = do
        (cid, Some instr) <- instrs
        guard (instr.transfer.instrumentId == instrumentId)
        guard (instr.status == V1.TransferPendingReceiverAcceptance)
        guard (p == instr.transfer.sender || p == instr.transfer.receiver)
        pure (cid, instr)
  pure pendingOffers

-- | List all allocations requested from the owner for a specific instrument.
listRequestedAllocations : Party -> V1.InstrumentId -> Script [V1.AllocationSpecification]
listRequestedAllocations p instrumentId = do
  reqs <- queryInterface @V1.AllocationRequest p
  trace reqs $ pure ()
  let amuletAllocs = do
        (_reqCid, Some req) <- reqs
        (tfId, tf) <- TextMap.toList req.transferLegs
        guard (tf.instrumentId == instrumentId)
        guard (p == tf.sender)
        pure V1.AllocationSpecification with
          settlement = req.settlement
          transferLegId = tfId
          transferLeg = tf
  pure amuletAllocs

-- | List all allocation requests of the given party.
listAllocationRequests : Party -> Script [V1.AllocationRequestView]
listAllocationRequests p = do
  reqs <- queryInterface @V1.AllocationRequest p
  return [ reqView | (_, Some reqView) <- reqs ]

-- | Simulate a V1 wallet accepting an allocation request from a V1 or V2 app.
--
-- TODO(#4517): add multi-registry support once we have private assets
acceptAllocationRequest
  :  RegistryApi registry => Party -> registry -> Party -> V1.AllocationRequestView -> Script ()
acceptAllocationRequest admin registry sender req = do
  let requestedAllocations = do
        (legId, leg) <- TextMap.toList req.transferLegs
        guard (leg.instrumentId.admin == admin)
        guard (sender == leg.sender)
        pure V1.AllocationSpecification with
          settlement = req.settlement
          transferLegId = legId
          transferLeg = leg
  now <- getTime
  -- create the allocations one-by-one
  forA_ requestedAllocations $ \allocation -> do
    inputHoldings <- listUnlockedHoldings sender allocation.transferLeg.instrumentId
    enrichedChoice <- getAllocationFactory registry V1.AllocationFactory_Allocate with
      expectedAdmin = admin
      allocation
      inputHoldingCids = map fst inputHoldings
      requestedAt = now
      extraArgs = emptyExtraArgs
    submitWithDisclosures' sender enrichedChoice.disclosures $
      exerciseCmd enrichedChoice.factoryCid enrichedChoice.arg

