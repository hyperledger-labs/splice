transferInstruction_v2_acceptImpl : TransferInstructionV1.TransferInstruction -> ContractId TransferInstructionV2.TransferInstruction -> TransferInstructionV2.TransferInstruction_Accept -> Update TransferInstructionV2.TransferInstructionResult
transferInstruction_v2_acceptImpl this self TransferInstructionV2.TransferInstruction_Accept{..} = do
  ensureActorIs (view this).transfer.receiver actor
  resv2 <- TransferInstructionV1.transferInstruction_acceptImpl
    this
    (coerceInterfaceContractId @TransferInstructionV1.TransferInstruction self)
    (TransferInstructionV1.TransferInstruction_Accept {..})
  return (transfer_instruction_result_v1_to_v2 resv2)

transferInstruction_v2_rejectImpl : TransferInstructionV1.TransferInstruction -> ContractId TransferInstructionV2.TransferInstruction -> TransferInstructionV2.TransferInstruction_Reject -> Update TransferInstructionV2.TransferInstructionResult
transferInstruction_v2_rejectImpl this self TransferInstructionV2.TransferInstruction_Reject{..} = do
  ensureActorIs (view this).transfer.receiver actor
  resv2 <- TransferInstructionV1.transferInstruction_rejectImpl
    this
    (coerceInterfaceContractId @TransferInstructionV1.TransferInstruction self)
    (TransferInstructionV1.TransferInstruction_Reject{..})
  return (transfer_instruction_result_v1_to_v2 resv2)

transferInstruction_v2_withdrawImpl : TransferInstructionV1.TransferInstruction -> ContractId TransferInstructionV2.TransferInstruction -> TransferInstructionV2.TransferInstruction_Withdraw -> Update TransferInstructionV2.TransferInstructionResult
transferInstruction_v2_withdrawImpl this self TransferInstructionV2.TransferInstruction_Withdraw{..} = do
  ensureActorIs (view this).transfer.sender actor
  resv2 <- TransferInstructionV1.transferInstruction_withdrawImpl
    this
    (coerceInterfaceContractId @TransferInstructionV1.TransferInstruction self)
    (TransferInstructionV1.TransferInstruction_Withdraw{..})
  return (transfer_instruction_result_v1_to_v2 resv2)


transfer_instruction_result_output_v1_to_v2 : TransferInstructionV1.TransferInstructionResult_Output -> TransferInstructionV2.TransferInstructionResult_Output
transfer_instruction_result_output_v1_to_v2 tiro = case tiro of
  TransferInstructionV1.TransferInstructionResult_Pending with transferInstructionCid ->
    TransferInstructionV2.TransferInstructionResult_Pending with
      transferInstructionCid = (coerceInterfaceContractId transferInstructionCid)
  TransferInstructionV1.TransferInstructionResult_Completed with receiverHoldingCids ->
    TransferInstructionV2.TransferInstructionResult_Completed with
      receiverHoldingCids = (map coerceInterfaceContractId receiverHoldingCids)
  TransferInstructionV1.TransferInstructionResult_Failed  ->
    TransferInstructionV2.TransferInstructionResult_Failed

transfer_instruction_result_v1_to_v2 : TransferInstructionV1.TransferInstructionResult -> TransferInstructionV2.TransferInstructionResult
transfer_instruction_result_v1_to_v2 TransferInstructionV1.TransferInstructionResult{..} =
  TransferInstructionV2.TransferInstructionResult with
    output = transfer_instruction_result_output_v1_to_v2 output
    senderChangeCids = map coerceInterfaceContractId senderChangeCids
    meta
-}

