-- TransferFactory
------------------

instance ForwardCompatible TransferInstructionV1.TransferFactoryView TransferInstructionV2.TransferFactoryView where
  downcast v1 = TransferInstructionV1.TransferFactoryView with
    admin = v1.admin
    meta = v1.meta

instance BackwardCompatible TransferInstructionV1.TransferFactoryView TransferInstructionV2.TransferFactoryView where
  upcast v1 = TransferInstructionV2.TransferFactoryView with
    admin = v1.admin
    meta = v1.meta

instance ForwardCompatible TransferInstructionV1.TransferFactory_PublicFetch TransferInstructionV2.TransferFactory_PublicFetch where
  downcast v2 = TransferInstructionV1.TransferFactory_PublicFetch with
    actor = v2.actor
    expectedAdmin = v2.expectedAdmin

instance BackwardCompatible TransferInstructionV1.TransferFactory_PublicFetch TransferInstructionV2.TransferFactory_PublicFetch where
  upcast v1 = TransferInstructionV2.TransferFactory_PublicFetch with
    actor = v1.actor
    expectedAdmin = v1.expectedAdmin

instance ForwardCompatible (ContractId TransferInstructionV1.TransferFactory) (ContractId TransferInstructionV2.TransferFactory) where
  downcast = coerceInterfaceContractId

-- Choices

transferFactory_v2_senderActor_transferImpl
  :  ContractId TransferInstructionV2.TransferFactory
  -> TransferInstructionV2.TransferFactory_Transfer
  -> Update TransferInstructionV2.TransferInstructionResult
transferFactory_v2_senderActor_transferImpl self args = do
  ensureNoAccountMeta "sender" args.transfer.meta
  ensureNoAccountMeta "receiver" args.transfer.meta
  ensureActorIs args.transfer.sender.owner args.actor
  upcast <$> exercise (downcast @(ContractId TransferInstructionV1.TransferFactory) self) TransferInstructionV1.TransferFactory_Transfer with
    expectedAdmin = args.expectedAdmin
    transfer = downcast args.transfer
    extraArgs = args.extraArgs


transferFactory_v2_publicFetchImpl
  : TransferInstructionV1.TransferFactory
  -> ContractId TransferInstructionV2.TransferFactory
  -> TransferInstructionV2.TransferFactory_PublicFetch
  -> Update TransferInstructionV2.TransferFactoryView
transferFactory_v2_publicFetchImpl this self arg =
  upcast <$> TransferInstructionV1.transferFactory_publicFetchImpl this (downcast self) (downcast arg)



-- Choices

dropAccountMeta : Text -> Metadata -> Metadata
dropAccountMeta fieldName meta =
  Metadata $
  TextMap.delete (v2Namespace <> fieldName <> ".provider") $
  TextMap.delete (v2Namespace <> fieldName <> ".id") $
  meta.values

ensureNoAccountMeta : Text -> Metadata -> Update ()
ensureNoAccountMeta fieldName meta = do
    checkNoDuplicate (v2Namespace <> fieldName <> ".provider")
    checkNoDuplicate (v2Namespace <> fieldName <> ".id")
  where
    checkNoDuplicate k = case TextMap.lookup k meta.values of
      None -> pure ()
      Some v -> fail $ "Duplicate account information on v2 choice for '" <> fieldName <> "': " <> show v


ensureBasicAccount : Text -> HoldingV2.Account -> Update ()
ensureBasicAccount fieldName account = do
  case account.provider of
    None -> pure ()
    Some x -> fail ("self-custodied accounts do not support:" <> fieldName <> ".provider set to '" <> show x <> "'")
  case account.id of
    None -> pure ()
    Some x -> fail ("self-custodied accounts do not support:" <> fieldName <> ".id set to '" <> show x <> "'")

