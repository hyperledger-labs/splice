{
   "apiVersion": "apps/v1",
   "items": [
      {
         "apiVersion": "apps/v1",
         "kind": "Deployment",
         "metadata": {
            "labels": {
               "app": "docs"
            },
            "name": "docs"
         },
         "spec": {
            "replicas": 1,
            "selector": {
               "matchLabels": {
                  "app": "docs"
               }
            },
            "template": {
               "metadata": {
                  "labels": {
                     "app": "docs"
                  }
               },
               "spec": {
                  "containers": [
                     {
                        "image": "region-docker.pkg.dev/project/repo/docs:tag",
                        "imagePullPolicy": "Always",
                        "name": "docs",
                        "ports": [
                           {
                              "containerPort": 80,
                              "name": "http"
                           }
                        ]
                     }
                  ]
               }
            }
         }
      },
      {
         "apiVersion": "apps/v1",
         "kind": "Deployment",
         "metadata": {
            "labels": {
               "app": "svc-app"
            },
            "name": "svc-app"
         },
         "spec": {
            "replicas": 1,
            "selector": {
               "matchLabels": {
                  "app": "svc-app"
               }
            },
            "template": {
               "metadata": {
                  "labels": {
                     "app": "svc-app"
                  }
               },
               "spec": {
                  "containers": [
                     {
                        "image": "region-docker.pkg.dev/project/repo/svc-app:tag",
                        "imagePullPolicy": "Always",
                        "name": "svc-app",
                        "ports": [
                           {
                              "containerPort": 5015,
                              "name": "svc-app-adm-api"
                           },
                           {
                              "containerPort": 5013,
                              "name": "scan-api"
                           }
                        ]
                     }
                  ]
               }
            }
         }
      },
      {
         "apiVersion": "apps/v1",
         "kind": "Deployment",
         "metadata": {
            "labels": {
               "app": "canton-domain"
            },
            "name": "canton-domain"
         },
         "spec": {
            "replicas": 1,
            "selector": {
               "matchLabels": {
                  "app": "canton-domain"
               }
            },
            "template": {
               "metadata": {
                  "labels": {
                     "app": "canton-domain"
                  }
               },
               "spec": {
                  "containers": [
                     {
                        "image": "region-docker.pkg.dev/project/repo/canton-domain:tag",
                        "imagePullPolicy": "Always",
                        "livenessProbe": {
                           "failureThreshold": 5,
                           "periodSeconds": 10,
                           "tcpSocket": {
                              "port": "canton-pub-api"
                           }
                        },
                        "name": "canton-domain",
                        "ports": [
                           {
                              "containerPort": 5008,
                              "name": "canton-pub-api"
                           },
                           {
                              "containerPort": 5009,
                              "name": "canton-adm-api"
                           }
                        ],
                        "readinessProbe": {
                           "tcpSocket": {
                              "port": "canton-pub-api"
                           }
                        }
                     }
                  ]
               }
            }
         }
      },
      {
         "apiVersion": "apps/v1",
         "kind": "Deployment",
         "metadata": {
            "labels": {
               "app": "canton-participant"
            },
            "name": "canton-participant"
         },
         "spec": {
            "replicas": 1,
            "selector": {
               "matchLabels": {
                  "app": "canton-participant"
               }
            },
            "template": {
               "metadata": {
                  "labels": {
                     "app": "canton-participant"
                  }
               },
               "spec": {
                  "containers": [
                     {
                        "image": "region-docker.pkg.dev/project/repo/canton-participant:tag",
                        "imagePullPolicy": "Always",
                        "name": "canton-participant",
                        "ports": [
                           {
                              "containerPort": 5002,
                              "name": "cp-adm-api"
                           },
                           {
                              "containerPort": 5001,
                              "name": "cp-ledger-api"
                           }
                        ]
                     }
                  ]
               }
            }
         }
      },
      {
         "apiVersion": "v1",
         "kind": "Service",
         "metadata": {
            "name": "docs"
         },
         "spec": {
            "loadBalancerIP": "ipaddr",
            "loadBalancerSourceRanges": [
               "35.194.81.56/32",
               "35.198.147.95/32",
               "35.189.40.124/32",
               "34.132.91.75/32"
            ],
            "ports": [
               {
                  "port": 80,
                  "protocol": "TCP",
                  "targetPort": 80
               }
            ],
            "selector": {
               "app": "docs"
            },
            "type": "LoadBalancer"
         }
      },
      {
         "apiVersion": "v1",
         "kind": "Service",
         "metadata": {
            "name": "svc-app"
         },
         "spec": {
            "loadBalancerIP": "ipaddr",
            "loadBalancerSourceRanges": [
               "35.194.81.56/32",
               "35.198.147.95/32",
               "35.189.40.124/32",
               "34.132.91.75/32"
            ],
            "ports": [
               {
                  "name": "svc-app-adm-api",
                  "port": 5015,
                  "protocol": "TCP",
                  "targetPort": 5015
               },
               {
                  "name": "scan-api",
                  "port": 5013,
                  "protocol": "TCP",
                  "targetPort": 5013
               }
            ],
            "selector": {
               "app": "svc-app"
            },
            "type": "LoadBalancer"
         }
      },
      {
         "apiVersion": "v1",
         "kind": "Service",
         "metadata": {
            "name": "canton-domain"
         },
         "spec": {
            "loadBalancerIP": "ipaddr",
            "loadBalancerSourceRanges": [
               "35.194.81.56/32",
               "35.198.147.95/32",
               "35.189.40.124/32",
               "34.132.91.75/32"
            ],
            "ports": [
               {
                  "name": "canton-pub-api",
                  "port": 5008,
                  "protocol": "TCP",
                  "targetPort": 5008
               },
               {
                  "name": "canton-adm-api",
                  "port": 5009,
                  "protocol": "TCP",
                  "targetPort": 5009
               }
            ],
            "selector": {
               "app": "canton-domain"
            },
            "type": "LoadBalancer"
         }
      },
      {
         "apiVersion": "v1",
         "kind": "Service",
         "metadata": {
            "name": "canton-participant"
         },
         "spec": {
            "loadBalancerIP": "ipaddr",
            "loadBalancerSourceRanges": [
               "35.194.81.56/32",
               "35.198.147.95/32",
               "35.189.40.124/32",
               "34.132.91.75/32"
            ],
            "ports": [
               {
                  "name": "cp-adm-api",
                  "port": 5002,
                  "protocol": "TCP",
                  "targetPort": 5002
               },
               {
                  "name": "cp-ledger-api",
                  "port": 5001,
                  "protocol": "TCP",
                  "targetPort": 5001
               }
            ],
            "selector": {
               "app": "canton-participant"
            },
            "type": "LoadBalancer"
         }
      }
   ],
   "kind": "List"
}
