{
  "name": "validator-runbook",
  "main": "src/index.ts",
  "devDependencies": {
    "@types/node": "^16",
    "@types/sinon": "^10.0.15",
    "sinon": "^15.0.4"
  },
  "dependencies": {
    "@pulumi/auth0": "^2.19.0",
    "@pulumi/pulumi": "^3.0.0",
    "cn-pulumi-common": "1.0.0",
    "@pulumi/random": "^4.13.2"
  },
  "scripts": {
    "fix": "npm run format:fix && npm run lint:fix",
    "check": "npm run format:check && npm run lint:check && npm run type:check",
    "type:check": "tsc --noEmit",
    "format:fix": "prettier --write -- src",
    "format:check": "prettier --check -- src",
    "lint:fix": "eslint --fix --max-warnings=0 -- src",
    "lint:check": "eslint --max-warnings=0 -- src",
    "dump-config": "env -u KUBECONFIG -u GCP_CLUSTER_BASENAME ts-node ./dump-config.ts"
  }
}
