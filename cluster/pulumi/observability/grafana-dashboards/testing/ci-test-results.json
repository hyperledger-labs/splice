{
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": {
          "type": "grafana",
          "uid": "-- Grafana --"
        },
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "description": "CI test result metrics pushed from CircleCI via Prometheus Pushgateway",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "liveNow": false,
  "panels": [
    {
      "title": "Consecutive Failures by Test & Cluster",
      "description": "Current number of consecutive failures for each test/cluster combination",
      "type": "gauge",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 0 },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 1 },
              { "color": "red", "value": 3 }
            ]
          },
          "min": 0,
          "max": 10,
          "mappings": []
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "ci_result_test_consecutive_failures{cluster=~\"$cluster\", test_name=\"post_merge_ci\"}",
          "legendFormat": "post_merge_ci / {{cluster}}",
          "instant": true,
          "refId": "A"
        },
        {
          "expr": "ci_result_test_consecutive_failures{cluster=~\"$cluster\", test_name=\"upgrade\"}",
          "legendFormat": "upgrade / {{cluster}}",
          "instant": true,
          "refId": "B"
        },
        {
          "expr": "ci_result_test_consecutive_failures{cluster=~\"$cluster\", test_name=\"sv_reonboard\"}",
          "legendFormat": "sv_reonboard / {{cluster}}",
          "instant": true,
          "refId": "C"
        },
        {
          "expr": "ci_result_test_consecutive_failures{cluster=~\"$cluster\", test_name=\"LSU\"}",
          "legendFormat": "LSU / {{cluster}}",
          "instant": true,
          "refId": "D"
        }
      ],
      "options": {
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        },
        "showThresholdLabels": false,
        "showThresholdMarkers": true,
        "orientation": "auto",
        "textMode": "auto"
      }
    },
    {
      "title": "Last Success Time",
      "description": "Absolute timestamp of last successful test run",
      "type": "gauge",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 8 },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 3600 },
              { "color": "red", "value": 14400 }
            ]
          },
          "min": 0,
          "max": 86400,
          "unit": "s"
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "time() - ci_result_last_success{cluster=~\"$cluster\", test_name=\"post_merge_ci\"}",
          "legendFormat": "post_merge_ci / {{cluster}}",
          "instant": true,
          "refId": "A"
        },
        {
          "expr": "time() - ci_result_last_success{cluster=~\"$cluster\", test_name=\"upgrade\"}",
          "legendFormat": "upgrade / {{cluster}}",
          "instant": true,
          "refId": "B"
        },
        {
          "expr": "time() - ci_result_last_success{cluster=~\"$cluster\", test_name=\"sv_reonboard\"}",
          "legendFormat": "sv_reonboard / {{cluster}}",
          "instant": true,
          "refId": "C"
        },
        {
          "expr": "time() - ci_result_last_success{cluster=~\"$cluster\", test_name=\"LSU\"}",
          "legendFormat": "LSU / {{cluster}}",
          "instant": true,
          "refId": "D"
        }
      ],
      "options": {
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        },
        "showThresholdLabels": false,
        "showThresholdMarkers": true,
        "orientation": "auto",
        "textMode": "auto"
      }
    }
  ],
  "refresh": "1m",
  "schemaVersion": 39,
  "tags": ["ci", "testing"],
  "templating": {
    "list": [
      {
        "current": {
          "selected": true,
          "text": "All",
          "value": "$__all"
        },
        "datasource": {
          "type": "prometheus",
          "uid": "prometheus"
        },
        "definition": "label_values(ci_result_test_consecutive_failures, cluster)",
        "includeAll": true,
        "multi": true,
        "name": "cluster",
        "query": {
          "query": "label_values(ci_result_test_consecutive_failures, cluster)",
          "refId": "StandardVariableQuery"
        },
        "refresh": 2,
        "sort": 1,
        "type": "query"
      },
      {
        "current": {
          "selected": true,
          "text": "All",
          "value": "$__all"
        },
        "datasource": {
          "type": "prometheus",
          "uid": "prometheus"
        },
        "definition": "label_values(ci_result_test_consecutive_failures, test_name)",
        "includeAll": true,
        "multi": true,
        "name": "test_name",
        "query": {
          "query": "label_values(ci_result_test_consecutive_failures, test_name)",
          "refId": "StandardVariableQuery"
        },
        "refresh": 2,
        "sort": 1,
        "type": "query"
      }
    ]
  },
  "time": {
    "from": "now-7d",
    "to": "now"
  },
  "timepicker": {},
  "timezone": "utc",
  "title": "CI Test Results",
  "uid": "ci-test-results",
  "version": 1
}

