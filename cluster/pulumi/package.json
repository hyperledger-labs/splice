{
    "name": "canton-network-pulumi-deployment",
    "version": "1.0.0",
    "main": "src/index.ts",
    "devDependencies": {
        "@trivago/prettier-plugin-sort-imports": "^3.3.0",
        "@types/js-yaml": "^4.0.5",
        "@types/lodash": "^4.14.189",
        "@types/node": "^14",
        "@typescript-eslint/eslint-plugin": "^5.54.0",
        "@typescript-eslint/parser": "^5.54.0",
        "eslint": "^8.35.0",
        "eslint-config-prettier": "^8.6.0",
        "eslint-plugin-import": "^2.27.5",
        "prettier": "^2.7.1",
        "typescript": "^4.8.4"
    },
    "dependencies": {
        "@pulumi/gcp": "^6.0.0",
        "@pulumi/pulumi": "^3.0.0",
        "@pulumi/kubernetes-cert-manager": "^0.0.5",
        "js-yaml": "^4.1.0",
        "lodash": "^4.17.21",
        "node-fetch": "^2.6.1"
    },
    "scripts": {
        "fix": "npm run format:fix && npm run lint:fix",
        "check": "npm run format:check && npm run lint:check",
        "format:fix": "prettier --write canton-network/src && prettier --write infrastructure/src",
        "format:check": "prettier --check canton-network/src && prettier --check infrastructure/src",
        "lint:fix": "eslint canton-network/src --fix --max-warnings=0 && eslint infrastructure/src --fix --max-warnings=0",
        "lint:check": "eslint canton-network/src --max-warnings=0 && eslint infrastructure/src --max-warnings=0"
    },
    "workspaces": [
        "canton-network",
        "canton-network-gateway",
        "infrastructure",
        "sv-runbook"
    ]
}
