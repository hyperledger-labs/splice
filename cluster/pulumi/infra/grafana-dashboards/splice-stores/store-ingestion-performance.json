  "id": null,
  "links": [],
  "panels": [
    {
      "title": "$test",
      "description": "Store ingestion performance metrics. Left axis: time (ms, s). Right axis: counts (items, batches).",
      "type": "timeseries",
      "gridPos": { "h": 12, "w": 24, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "repeat": "test",
      "repeatDirection": "v",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "axisBorderShow": false,
            "axisPlacement": "auto",
            "drawStyle": "line",
            "fillOpacity": 5,
            "lineInterpolation": "linear",
            "lineWidth": 2,
            "pointSize": 6,
            "showPoints": "always",
            "spanNulls": false,
            "stacking": { "group": "A", "mode": "none" },
            "thresholdsStyle": { "mode": "off" }
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [{ "color": "green", "value": null }]
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Avg Item Time (ms)" },
            "properties": [
              { "id": "custom.axisPlacement", "value": "left" },
              { "id": "unit", "value": "ms" },
              { "id": "color", "value": { "mode": "fixed", "fixedColor": "blue" } }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "Total Time (s)" },
            "properties": [
              { "id": "custom.axisPlacement", "value": "left" },
              { "id": "unit", "value": "s" },
              { "id": "color", "value": { "mode": "fixed", "fixedColor": "purple" } }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "Total Items" },
            "properties": [
              { "id": "custom.axisPlacement", "value": "right" },
              { "id": "unit", "value": "short" },
              { "id": "color", "value": { "mode": "fixed", "fixedColor": "green" } }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "Total Batches" },
            "properties": [
              { "id": "custom.axisPlacement", "value": "right" },
              { "id": "unit", "value": "short" },
              { "id": "color", "value": { "mode": "fixed", "fixedColor": "orange" } }
            ]
          }
        ]
      },
      "options": {
        "legend": { "calcs": ["mean", "max", "lastNotNull"], "displayMode": "table", "placement": "bottom", "showLegend": true },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "splice_perf_ingestion_avg_item_time_ns{test=\"${test}\"} / 1e6",
          "legendFormat": "Avg Item Time (ms)",
          "range": true, "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "splice_perf_ingestion_total_time_ns{test=\"${test}\"} / 1e9",
          "legendFormat": "Total Time (s)",
          "range": true, "refId": "B"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "splice_perf_ingestion_total_items{test=\"${test}\"}",
          "legendFormat": "Total Items",
          "range": true, "refId": "C"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "splice_perf_ingestion_total_batches{test=\"${test}\"}",
          "legendFormat": "Total Batches",
          "range": true, "refId": "D"
        }
      ]
    }
  ],
  "preload": false,
  "schemaVersion": 42,
  "tags": [],
