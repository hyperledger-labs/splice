case "$K8S_CONTEXT" in
    gcloud)
        echo "WARNING: You are operating against the remote gcloud cluster."
        read -r -p "Are you sure you want to proceed? [y/N] " response
        if [[ "$response" =~ ^([yY][eE][sS]|[yY])$ ]]; then
            source $REPO_ROOT/cluster/lib/gcloud-connect
        else
            echo "Quitting..."
            exit 0
        fi
        ;;
    minikube)
        kubectl config use-context minikube
        ;;
    *)
        echo "Invalid option for K8S_CONTEXT supplied: $K8S_CONTEXT"
        exit 1
        ;;
esac
