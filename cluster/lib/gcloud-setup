### Setup the gcloud command line tool so that it is authenticated and
### connected to the project specified in the variable GCP_PROJECT_NAME

### Look for expected configuration variables

function expect() {
    if [ -z "$2" ]; then
        echo "Missing environment variable: $1"
        exit 1
    fi

    echo "$1=$2"
}

set +u
expect GCP_PROJECT_NAME ${GCP_PROJECT_NAME}
expect GCP_CLUSTER_NAME ${GCP_CLUSTER_NAME}
expect GCP_REPO_NAME ${GCP_REPO_NAME}
expect GCP_IP_NAME ${GCP_IP_NAME}
set -u

### Check for an authenticated gcloud account

N_ACCOUNTS=$(gcloud auth list --format 'value(account)' | wc -l)

if [ "${N_ACCOUNTS}" -eq "0" ]; then
    echo "There is not an autheticated gcloud account. You must login."
    gcloud auth login
fi

# Check for the expected project.

gcloud config set compute/region us-central1

GCP_PROJECT_ID=$(gcloud projects list --filter "name:${GCP_PROJECT_NAME}" --format 'value(project_id)')

if [ -z "${GCP_PROJECT_ID}" ]; then
    echo "Cannot find GCP Project with expected name: ${GCP_PROJECT_NAME}"
    exit 1
fi

echo "GCP Project ID: ${GCP_PROJECT_ID}"

gcloud config set project ${GCP_PROJECT_ID}
