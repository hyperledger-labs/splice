# Publicly released images
#IMAGE_REPO=digitalasset-canton-network-docker.jfrog.io/digitalasset/
# DA-internal dev repo
#IMAGE_REPO=us-central1-docker.pkg.dev/da-cn-shared/cn-images/
# Locally built images
IMAGE_REPO=

# Versions
SPLICE_POSTGRES_VERSION=14
NGINX_VERSION=1.27.1

# Database
SPLICE_DB_USER=cnadmin
SPLICE_DB_PASSWORD=supersafe
SPLICE_DB_SERVER=postgres-splice
SPLICE_DB_PORT=5432

# Participant
# TODO(#14303): make this configurable:
PARTICIPANT_IDENTIFIER=da-composeValidator-1
PARTY_HINT=da-composeValidator-1

# Validator
CONTACT_POINT=

# Authentication
AUTH_URL=""
AUTH_JWKS_URL=""
LEDGER_API_AUTH_AUDIENCE=""
LEDGER_API_ADMIN_USER=""
AUTH_WELLKNOWN_URL=""
AUTH_CLIENT_ID=""
AUTH_CLIENT_SECRET=""
WALLET_ADMIN_USER=""
VALIDATOR_AUTH_AUDIENCE=""
WALLET_UI_CLIENT_ID=""
ANS_UI_CLIENT_ID=""
