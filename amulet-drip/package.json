{
  "name": "amulet-drip",
  "version": "1.0.0",
  "description": "Batch Amulet (CC) distribution tool for Canton/Splice networks",
  "main": "build/bundle.js",
  "scripts": {
    "build": "tsc --noEmit && esbuild src/index.ts --bundle --platform=node --format=esm --outfile=build/bundle.js --sourcemap=inline --banner:js=\"import { createRequire } from 'node:module'; const require = createRequire(import.meta.url);\"",
    "compile": "tsc --noEmit",
    "start": "node ./build/bundle.js",
    "check": "tsc --noEmit && npm run format:check && npm run lint:check",
    "fix": "npm run format:fix && npm run lint:fix",
    "format:check": "prettier --check -- src __tests__",
    "format:fix": "prettier --write -- src __tests__",
    "lint:check": "eslint --max-warnings=0 -- src",
    "lint:fix": "eslint --fix --max-warnings=0 -- src",
    "test": "vitest",
    "test:sbt": "vitest --run"
  },
  "type": "module",
  "devDependencies": {
    "@lfdecentralizedtrust/canton-json-api-v2-openapi": "file:../token-standard/dependencies/canton-json-api-v2/openapi-ts-client",
    "@lfdecentralizedtrust/transfer-instruction-openapi": "file:../token-standard/splice-api-token-transfer-instruction-v1/openapi-ts-client",
    "@types/node": "^24.3.1",
    "@typescript-eslint/eslint-plugin": "^7.7.1",
    "commander": "^13.1.0",
    "dayjs": "^1.11.13",
    "dotenv": "^16.4.7",
    "esbuild": "^0.25.9",
    "eslint": "^8.57.1",
    "pino": "^9.9.5",
    "prettier": "^3.6.2",
    "typescript": "^5.7.3",
    "vitest": "^4.1.3",
    "zod": "^4.1.5"
  }
}
