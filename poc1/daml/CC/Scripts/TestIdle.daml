module CC.Scripts.TestIdle where

import Daml.Script

import CC.Scripts.Setup
import CC.Scripts.Util

test : Script ()
test = do
  -- bootstrap app
  (app, da1) <- setupApp
  bootstrapApp (app, da1)

  -- start issuing
  advanceDay app 1.1
  triggerIssuanceAs app da1
  advanceDay app 1.2
  triggerIssuanceAs app da1
  advanceDay app 1.3
  triggerIssuanceAs app da1
  advanceDay app 1.4
  triggerIssuanceAs app da1

  return ()
  