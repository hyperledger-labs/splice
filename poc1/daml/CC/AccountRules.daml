template CreditRules
  with
    sv : Party
    public : Party
  where
    signatory sv
    observer public

    key sv : Party
    maintainer key

    nonconsuming choice Credit_Redistribute : [ContractId Credit]
      with
        owner : Party
        creditCids : [ContractId UserAccount]
        splitQuantities : [Decimal]
      controller owner
      do
        accounts <- forA creditCids fetch
        forA_ accounts (\c -> assertMsg "Credit owners do not match" (owner == c.owner))
        forA_ creditCids archive
        let total = sum (map (\c -> c.quantity) accounts)
            totalSplits = sum splitQuantities
            rem = total - totalSplits
            obs = []
        forA (rem :: splitQuantities) (\quantity -> create Credit with ..)

    nonconsuming choice Credit_Burn : ContractId BurnedCredit
      with
        burner : Party
        beneficiary : Party
        validator : Party
        payload : Text
        creditCid : ContractId Credit
      controller burner
      do
        credit <- fetch creditCid
        assertMsg "Credit owners do not match" (burner == credit.owner)
        archive creditCid
        burnedAt <- getTime
        create BurnedCredit with
          quantity = credit.quantity
          ..

-}