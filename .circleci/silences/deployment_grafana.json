[
  {
    "createdBy": "ci (deploy_cluster)",
    "comment": "An initial alert silence to cover the turburlent deployment period",
    "matchers": [
      {
        "name": "alertname",
        "value": "Report Creation Time Lag",
        "isEqual": true,
        "isRegex": false
      },
      {
        "name": "report_publisher",
        "value": ".*",
        "isEqual": true,
        "isRegex": true
      }
    ]
  },
  {
    "createdBy": "ci (restore_node)",
    "comment": "An initial alert silence to cover the restore period",
    "matchers": [
      {
        "name": "alertname",
        "value": "SV Status - Node falling behind",
        "isEqual": true,
        "isRegex": false
      },
      {
        "name": "alertname",
        "value": "Reached Expected Maximum CometBFT Block Rate",
        "isEqual": true,
        "isRegex": false
      },
      {
        "name": "alertname",
        "value": "Cometbft Consensus",
        "isEqual": true,
        "isRegex": false
      },
      {
        "name": "report_publisher",
        "value": ".*",
        "isEqual": true,
        "isRegex": true
      },
      {
        "name": "alertname",
        "value": "Mediator Acknowledgement Lag",
        "isEqual": true,
        "isRegex": false
      }
    ]
  }
]
