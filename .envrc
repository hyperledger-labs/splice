use_flake_subdir() {
  watch_file nix/flake.nix
  watch_file nix/flake.lock
  mkdir -p "$(direnv_layout_dir)"
  eval "$(nix print-dev-env --profile "$(direnv_layout_dir)/flake-profile" "path:nix" "$@")"
}

# TODO(#3876) work around for $TMPDIR is removed. #3876 to investigate more
OLD_TMPDIR=$TMPDIR

use flake_subdir

# TODO(#3876) work around for $TMPDIR is removed. #3876 to investigate more
export TMPDIR=$OLD_TMPDIR

source_env .envrc.vars

# Private .envrc
[[ -f .envrc.private ]] && source_env .envrc.private || true

# Configure docker access for cluster and integration tests
## Read current credentials
DOCKER_CREDS=$(if [ -f ~/.docker/config.json ]; then cat ~/.docker/config.json | jq '.auths."digitalasset-canton-enterprise-docker.jfrog.io"'; fi)
## If no current credentials are set
[[ -z "$DOCKER_CREDS" || "$DOCKER_CREDS" == "null" ]] && \
## And artifactory user and password are set
[[ -n "$ARTIFACTORY_USER" && -n "$ARTIFACTORY_PASSWORD" ]] && \
    echo "Configuring docker credentials for cometBFT image" && \
    docker login digitalasset-canton-enterprise-docker.jfrog.io -u "$ARTIFACTORY_USER" -p "$ARTIFACTORY_PASSWORD"

# Do not tag local docker images with a git commit to simplify referencing these images from helm charts
export CNCLUSTER_STATIC_DIRTY_VERSION=1
