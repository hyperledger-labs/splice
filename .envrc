use_flake_subdir() {
  # Newer versions of direnv have watch_dir but the ancient version in
  # Ubuntu does not so we just manually watch all (git-tracked) files.
  for file in $(git ls-files nix); do
    watch_file $file
  done
  mkdir -p "$(direnv_layout_dir)"
  eval "$(nix print-dev-env --profile "$(direnv_layout_dir)/flake-profile" "path:nix" "$@")"
}

# TODO(#3876) work around for $TMPDIR is removed. #3876 to investigate more
OLD_TMPDIR=$TMPDIR

use flake_subdir

# TODO(#3876) work around for $TMPDIR is removed. #3876 to investigate more
export TMPDIR=$OLD_TMPDIR

source_env .envrc.vars

# Import tools library

# shellcheck disable=SC1091
source "${TOOLS_LIB}/libcli.source"


# Do not tag local docker images with a git commit to simplify referencing these images from helm charts
export CNCLUSTER_STATIC_DIRTY_VERSION=1

# Private .envrc
[[ -f .envrc.private ]] && source_env .envrc.private || true

# Configure docker access for cluster and integration tests
## Read current credentials
DOCKER_CREDS=$(if [ -f ~/.docker/config.json ]; then cat ~/.docker/config.json | jq '.auths."digitalasset-canton-enterprise-docker.jfrog.io"'; fi)
## If no current credentials are set
[[ -z "$DOCKER_CREDS" || "$DOCKER_CREDS" == "null" ]] && \
## And artifactory user and password are set
[[ -n "$ARTIFACTORY_USER" && -n "$ARTIFACTORY_PASSWORD" ]] && \
    echo "Configuring docker credentials for cometBFT image" && \
    docker login digitalasset-canton-enterprise-docker.jfrog.io -u "$ARTIFACTORY_USER" -p "$ARTIFACTORY_PASSWORD"

# ensure the logs directory exists
mkdir -p $LOGS_PATH

# Ensure that expected .envrc.private variables are defined

function expect_envvar() {
    varname=$1

    missing=()

    for varname in "$@"; do
        if ! declare -p "${varname}" &>/dev/null;  then
            missing+=("${varname}")
        fi
    done

    if (( ${#missing[@]} != 0 )); then
        msg="Expected private environment variable(s) undefined:"
        for varname in "${missing[@]}"; do
            msg="${msg}\n*  ${varname}"
        done

        msg="${msg}\n\nThese should be in .envrc.private.\nSee https://github.com/DACH-NY/canton-network-node#private-environment-variables for details"

        _warning "${msg}"
    fi
}

# Expected
expect_envvar \
    AUTH0_MANAGEMENT_API_TOKEN \
    AUTH0_CN_MANAGEMENT_API_CLIENT_ID \
    AUTH0_CN_MANAGEMENT_API_CLIENT_SECRET \
    AUTH0_SV_MANAGEMENT_API_CLIENT_ID \
    AUTH0_SV_MANAGEMENT_API_CLIENT_SECRET \
    AUTH0_TESTS_MANAGEMENT_API_CLIENT_ID \
    AUTH0_TESTS_MANAGEMENT_API_CLIENT_SECRET \
    ARTIFACTORY_USER \
    ARTIFACTORY_PASSWORD
