use nix

source_env .envrc.vars

# gcloud logins
[ -f ~/.config/gcloud/credentials.db ] || \
    gcloud auth login

[ -f ~/.config/gcloud/application_default_credentials.json ] || \
    gcloud auth application-default login

DOCKER_CREDS=$(if [ -f ~/.docker/config.json ]; then cat ~/.docker/config.json | jq '.credHelpers."'${CLOUDSDK_COMPUTE_REGION}'-docker.pkg.dev"'; fi)

[ -z "$DOCKER_CREDS" ] && \
    gcloud auth configure-docker ${CLOUDSDK_COMPUTE_REGION}-docker.pkg.dev

# Private .envrc
[[ -f .envrc.private ]] && source_env .envrc.private || true
