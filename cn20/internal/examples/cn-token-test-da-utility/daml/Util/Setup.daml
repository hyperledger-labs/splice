module Util.Setup where

import Daml.Script
import Splice.Scripts.Util

import Utility.Credential.V0.Credential
import Utility.Registry.App.V0.Configuration.Provider (ProviderConfiguration(..))
import Utility.Registry.App.V0.Service.Holder
import Utility.Registry.App.V0.Service.Provider
import Utility.Registry.App.V0.Service.Registrar
import Utility.Registry.Holding.V0.Holding (Holding(..))
import Utility.Registry.Holding.V0.Types (InstrumentId(..))
import Utility.Registry.V0.Configuration.Instrument (InstrumentConfiguration(..))
import Utility.Scripts.Util

data AmuletAppWithUsers = AmuletAppWithUsers
  with
    app: AmuletApp
      -- ^ Amulet app.
    alice: AmuletUser
      -- ^ An investor.
    bob: AmuletUser
      -- ^ An investor.
    tradingAppProvider: AmuletUser
      -- ^ Trading app provider / settler of the DvPs.
    operator : AmuletUser
      -- ^ Utility Operator party.
    provider : AmuletUser
      -- ^ Utility Provider party.
    registrar : AmuletUser
      -- ^ Utility Registrar party.
  deriving (Show, Eq, Ord)

setupAmuletAppWithUsers: Script AmuletAppWithUsers
setupAmuletAppWithUsers = do

  app <- setupApp
  let setup = fmap fst . setupSelfHostedUser app

  alice <- setup "Alice"
  bob <- setup "Bob"
  tradingAppProvider <- setup "TradingAppProvider"
  operator <- setup "Operator"
  registrar <- setup "Registrar"
  provider <- setup "Provider"

  return AmuletAppWithUsers with ..

-- | Bootstrap Utility services.
data BootstrapUtilityServicesResult = BootstrapUtilityServicesResult
  with
    operator : Party
      -- ^ Operator party.
    provider : Party
      -- ^ Provider party.
    providerServiceCid : ContractId ProviderService
      -- ^ Provider service.
    providerConfigurationCid : ContractId ProviderConfiguration
      -- ^ Provider configuration.
    registrar : Party
      -- ^ Registrar party.
    registrarServiceCid : ContractId RegistrarService
      -- ^ Registrar service.
    holder1 : Party
      -- ^ Holder1 party.
    holder1ServiceCid : ContractId HolderService
      -- ^ Holder1 service.
    holder1CredentialCids : [ContractId Credential]
      -- ^ Holder1 credentials.
    holder1Label : Text
      -- ^ Holder1 label.
    holder2 : Party
      -- ^ Holder2 party.
    holder2ServiceCid : ContractId HolderService
      -- ^ Holder2 service.
    holder2CredentialCids : [ContractId Credential]
      -- ^ Holder2 credentials.
    holder2Label : Text
      -- ^ Holder2 label.
    defaultIdentifier : InstrumentId
      -- ^ Default instrument identifier.
    additionalIdentifier : InstrumentId
      -- ^ Additional instrument identifier.
    instrumentConfigurationCid : ContractId InstrumentConfiguration
      -- ^ Instrument configuration.
    amount : Decimal
      -- ^ Amount of holding.
    holding1Cid : ContractId Holding
      -- ^ Holding of Holder1.
  deriving (Eq, Show)

-- | Bootstrap all services.
bootstrapUtilityServices : Party -> Party -> Party -> Party -> Party -> Script BootstrapUtilityServicesResult
bootstrapUtilityServices operator provider registrar holder1 holder2 = do

  -- Onboard parties
  operatorConfigurationCid <- createOperatorConfiguration operator
  (providerServiceCid, providerConfigurationCid) <-
    onboardProvider operator operatorConfigurationCid provider
  (registrarServiceCid, _) <-
    onboardRegistrar operator provider providerServiceCid providerConfigurationCid registrar
  holder1ServiceCid <-
    onboardHolder operator provider providerServiceCid providerConfigurationCid holder1
  holder2ServiceCid <-
    onboardHolder operator provider providerServiceCid providerConfigurationCid holder2

  -- Create instrument configuration
  let
    instrumentId = "INST"
    defaultIdentifier = InstrumentId with
      source = registrar; id = instrumentId; scheme = "RegistrarInternalScheme"
    additionalIdentifier = InstrumentId with
      source = operator; id = "3769608"; scheme = "Valoren"
    issuerRequirements = getInstrumentIssuerRequirements instrumentId registrar
    holderRequirements = getInstrumentHolderRequirements instrumentId registrar
    forceTransferRequirements = getForceTransferRequirements instrumentId registrar
  instrumentConfigurationCid <- createInstrumentConfiguration registrarServiceCid registrar
    issuerRequirements holderRequirements forceTransferRequirements instrumentId
    [additionalIdentifier]

  -- Create instrument holder credentials
  holder1CredentialCids <- mapA (createCredential holder1 operator)
    (issuerRequirements <> holderRequirements)
  holder2CredentialCids <- mapA (createCredential holder2 operator) holderRequirements

  -- Create holding
  let
    holder1Label = "Holder1Account"
    amount = 50.0

  holding1Cid <- createHolding
        operator
        provider
        registrar
        defaultIdentifier
        holder1
        amount
        holder1Label

  let
    holder2Label = "Holder2Account"

  pure BootstrapUtilityServicesResult{..}
