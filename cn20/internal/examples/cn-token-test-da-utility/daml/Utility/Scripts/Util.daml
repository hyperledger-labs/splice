module Utility.Scripts.Util where

import DA.Set qualified as Set (singleton)
import Daml.Script
import Utility.Credential.V0.Credential (Claim(..), Credential(..), PartyCredentialRequirement(..))
import Utility.Registry.App.V0.Configuration.Operator (OperatorConfiguration(..))
import Utility.Registry.App.V0.Configuration.Provider (ProviderConfiguration(..))
import Utility.Registry.App.V0.Configuration.Registrar (RegistrarConfiguration(..))
import Utility.Registry.App.V0.Service.Enforcement (EnforcementService(..), EnforcementServiceRequest_Accept(..))
import Utility.Registry.App.V0.Service.Holder (HolderService(..), HolderServiceRequest(..), HolderServiceRequest_Accept(..), HolderService_RequestEnforcementService(..))
import Utility.Registry.App.V0.Service.Provider (ProviderService(..), ProviderServiceRequest(..), ProviderServiceRequest_Accept(..), ProviderService_AcceptHolderServiceRequest(..), ProviderService_AcceptRegistrarServiceRequest(..), ProviderService_CreateProviderConfiguration(..))
import Utility.Registry.App.V0.Service.Registrar (RegistrarService(..), RegistrarServiceRequest(..), RegistrarServiceRequest_Accept(..), RegistrarService_AcceptEnforcementServiceRequest(..), RegistrarService_CreateInstrumentConfiguration(..), RegistrarService_CreateRegistrarConfiguration(..))
import Utility.Registry.Holding.V0.Holding (Holding(..))
import Utility.Registry.Holding.V0.Types (InstrumentId(..))
import Utility.Registry.V0.Configuration.Instrument (InstrumentConfiguration(..))

-- | Onboard an operator.
createOperatorConfiguration : Party -> Script (ContractId OperatorConfiguration)
createOperatorConfiguration operator =
  submit operator do
    createCmd OperatorConfiguration with
      operator
      providerRequirements = getProviderOnboardingRequirements operator

-- | Onboard a provider.
onboardProvider : Party -> ContractId OperatorConfiguration -> Party
  -> Script (ContractId ProviderService, ContractId ProviderConfiguration)
onboardProvider operator operatorConfigurationCid provider = do
  credentialCids <- mapA (createCredential provider operator) $
    getProviderOnboardingRequirements operator

  providerServiceRequestCid <- submit provider do
    createCmd ProviderServiceRequest with operator; provider

  providerServiceCid <- (.providerServiceCid) <$>
    submit operator do
      exerciseCmd providerServiceRequestCid ProviderServiceRequest_Accept with
        operatorConfigurationCid
        credentialCids

  let
    registrarRequirements = getRegistrarOnboardingRequirements operator provider
    holderRequirements = getHolderOnboardingRequirements operator provider
  providerConfigurationCid <- (.providerConfigurationCid) <$> submit provider do
    exerciseCmd providerServiceCid ProviderService_CreateProviderConfiguration with
      registrarRequirements
      holderRequirements
  pure (providerServiceCid, providerConfigurationCid)

-- | Onboard a registrar.
onboardRegistrar : Party -> Party -> ContractId ProviderService -> ContractId ProviderConfiguration
  -> Party -> Script (ContractId RegistrarService, ContractId RegistrarConfiguration)
onboardRegistrar operator provider providerServiceCid providerConfigurationCid
  registrar = do
    -- Create credential
    credentialCids <- mapA (createCredential registrar operator)
      $ getRegistrarOnboardingRequirements operator provider

    -- Onboard registrar
    registrarServiceRequestCid <- submit registrar do
      createCmd RegistrarServiceRequest with operator; provider; registrar

    -- Accept request
    registrarServiceCid <- (.registrarServiceCid) <$> submit provider do
      exerciseCmd providerServiceCid ProviderService_AcceptRegistrarServiceRequest with
        cid = registrarServiceRequestCid
        payload = RegistrarServiceRequest_Accept with providerConfigurationCid; credentialCids

    -- Create registrar configuration
    let
      enforcementRequirements = getEnforcementOnboardingRequirements operator registrar
    registrarConfigurationCid <- (.registrarConfigurationCid) <$> submit registrar do
      exerciseCmd registrarServiceCid RegistrarService_CreateRegistrarConfiguration with
        enforcementRequirements

    pure (registrarServiceCid, registrarConfigurationCid)

-- | Onboard a holder.
onboardHolder : Party -> Party -> ContractId ProviderService -> ContractId ProviderConfiguration
  -> Party -> Script (ContractId HolderService)
onboardHolder operator provider providerServiceCid providerConfigurationCid
  holder = do
    -- Create credential
    credentialCids <- mapA (createCredential holder operator)
      $ getHolderOnboardingRequirements operator provider

    -- Onboard holder
    holderServiceRequestCid <- submit holder do
      createCmd HolderServiceRequest with operator; provider; holder

    -- Accept request
    (.holderServiceCid) <$>
      submit provider do
        exerciseCmd providerServiceCid ProviderService_AcceptHolderServiceRequest with
          cid = holderServiceRequestCid
          payload = HolderServiceRequest_Accept with providerConfigurationCid; credentialCids

-- | Onboard enforcement.
onboardEnforcement : Party -> ContractId RegistrarService -> ContractId RegistrarConfiguration
  -> ContractId HolderService -> Script (ContractId EnforcementService)
onboardEnforcement operator registrarServiceCid registrarConfigurationCid holderServiceCid =
  do
    Some registrarService <- queryContractId operator registrarServiceCid
    Some holderService <- queryContractId operator holderServiceCid
    let
      registrar = registrarService.registrar
      holder = holderService.holder

    -- Create credential
    credentialCids <- mapA (createCredential holder operator)
      $ getEnforcementOnboardingRequirements operator registrar

    -- Request a enforcement service
    enforcementServiceRequestCid <- (.enforcementServiceRequestCid) <$> submit holder do
      exerciseCmd holderServiceCid HolderService_RequestEnforcementService with registrar

    -- Accept request
    (.enforcementServiceCid) <$>
      submit registrar do
        exerciseCmd registrarServiceCid RegistrarService_AcceptEnforcementServiceRequest with
          cid = enforcementServiceRequestCid
          payload = EnforcementServiceRequest_Accept with
            registrarConfigurationCid
            credentialCids

-- | Creates a credential from the given requirement and discloses it to the operator.
createCredential : Party -> Party -> PartyCredentialRequirement -> Script (ContractId Credential)
createCredential holder operator requirement =
  submitMulti [requirement.issuer, holder] [] do
    createCmd Credential with
      issuer = requirement.issuer
      holder
      id = ""
      description = ""
      validFrom = None
      validUntil = None
      claims = map
        (\(property, value) -> Claim with subject = partyToText holder; property; value)
        requirement.requiredClaims
      observers = Set.singleton operator

-- | Create instrument configuration.
createInstrumentConfiguration : ContractId RegistrarService -> Party -> [PartyCredentialRequirement]
  -> [PartyCredentialRequirement] -> Optional [PartyCredentialRequirement] -> Text
  -> [InstrumentId] -> Script (ContractId InstrumentConfiguration)
createInstrumentConfiguration registryServiceCid registrar issuerRequirements
  holderRequirements forceTransferRequirements instrumentId additionalIdentifiers = do
  res <- submit registrar do
    exerciseCmd registryServiceCid RegistrarService_CreateInstrumentConfiguration with
      instrumentId
      additionalIdentifiers
      issuerRequirements
      holderRequirements
      forceTransferRequirements
  pure res.instrumentConfigurationCid

-- | Create holding.
createHolding : Party -> Party -> Party -> InstrumentId -> Party -> Decimal -> Text
  -> Script (ContractId Holding)
createHolding operator provider registrar instrument owner amount label =
  submitMulti [registrar, owner] [] do
    createCmd Holding with
      operator
      provider
      registrar
      owner
      instrument
      label
      amount
      lock = None

-- | Get credential requirement for provider onboarding.
getProviderOnboardingRequirements : Party -> [PartyCredentialRequirement]
getProviderOnboardingRequirements operator =
  [ PartyCredentialRequirement with
      issuer = operator
      requiredClaims = [("hasRegistryRole", "Provider")]
  ]

-- | Get credential requirement for registrar onboarding.
getRegistrarOnboardingRequirements : Party -> Party -> [PartyCredentialRequirement]
getRegistrarOnboardingRequirements operator provider =
  [ PartyCredentialRequirement with
      issuer = provider
      requiredClaims = [("hasRegistryRole", "Registrar")]
  ]

-- | Get credential requirement for holder onboarding.
getHolderOnboardingRequirements : Party -> Party -> [PartyCredentialRequirement]
getHolderOnboardingRequirements operator provider =
  [ PartyCredentialRequirement with
      issuer = provider
      requiredClaims = [("hasRegistryRole", "Holder")]
  ]

-- | Get credential requirement for enforcement onboarding.
getEnforcementOnboardingRequirements : Party -> Party -> [PartyCredentialRequirement]
getEnforcementOnboardingRequirements operator registrar =
  [ PartyCredentialRequirement with
      issuer = registrar
      requiredClaims = [("hasRegistryRole", "Enforcement")]
  ]

-- | Get credential requirement for holding an instrument.
getInstrumentHolderRequirements :  Text -> Party -> [PartyCredentialRequirement]
getInstrumentHolderRequirements instrument credentialIssuer =
  [ PartyCredentialRequirement with
      issuer = credentialIssuer
      requiredClaims = [("isHolderOf", instrument)]
  ]

-- | Get credential requirement for issuing an instrument.
getInstrumentIssuerRequirements : Text -> Party -> [PartyCredentialRequirement]
getInstrumentIssuerRequirements instrument credentialIssuer =
  [ PartyCredentialRequirement with
      issuer = credentialIssuer
      requiredClaims = [("isIssuerOf", instrument)]
  ]

-- | Get credential requirement for force transferring an instrument.
getForceTransferRequirements : Text -> Party -> Optional [PartyCredentialRequirement]
getForceTransferRequirements instrument credentialIssuer = Some
  [ PartyCredentialRequirement with
      issuer = credentialIssuer
      requiredClaims = [("isIssuerOf", instrument)]
  ]
