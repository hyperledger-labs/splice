        exercise cid payload

    nonconsuming choice RegistrarService_DeleteExecutedBurn : ExecutedBurn_Delete_Result
      -- ^ Deletes an executed burn.
      with
        cid : ContractId ExecutedBurn
          -- ^ Executed burn to delete.
        payload : ExecutedBurn_Delete
          -- ^ Choice payload.
      controller operator
      do
        fetchAndValidate cid
          [ ("Operator", .burn.operator, operator)
          , ("Provider", .burn.provider, provider)
          , ("Registrar", .burn.registrar, registrar)
          ]
        exercise cid payload

    nonconsuming choice RegistrarService_DeleteRejectedLock : RejectedLock_Delete_Result
      -- ^ Deletes a rejected lock.
      with
        cid : ContractId RejectedLock
          -- ^ Rejected lock to delete.
        payload : RejectedLock_Delete
          -- ^ Choice payload.
      controller operator
      do
        fetchAndValidate cid
          [ ("Operator", .lock.operator, operator)
          , ("Provider", .lock.provider, provider)
