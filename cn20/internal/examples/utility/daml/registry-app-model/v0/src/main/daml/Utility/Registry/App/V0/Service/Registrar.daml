          ]
        exercise cid payload

    nonconsuming choice RegistrarService_DeleteRejectedMint : RejectedMint_Delete_Result
      -- ^ Deletes a rejected mint.
      with
        cid : ContractId RejectedMint
          -- ^ Rejected mint to delete.
        payload : RejectedMint_Delete
          -- ^ Choice payload.
      controller operator
      do
        fetchAndValidate cid
          [ ("Operator", .mint.operator, operator)
          , ("Provider", .mint.provider, provider)
          , ("Registrar", .mint.registrar, registrar)
          ]
        exercise cid payload

    nonconsuming choice RegistrarService_DeleteFailedMint : FailedMint_Delete_Result
      -- ^ Deletes a failed mint.
      with
        cid : ContractId FailedMint
          -- ^ Failed mint to delete.
        payload : FailedMint_Delete
          -- ^ Choice payload.
      controller operator
      do
        fetchAndValidate cid
          [ ("Operator", .mint.operator, operator)
          , ("Provider", .mint.provider, provider)
          , ("Registrar", .mint.registrar, registrar)
          ]
        exercise cid payload

    nonconsuming choice RegistrarService_DeleteExecutedMint : ExecutedMint_Delete_Result
      -- ^ Deletes an executed mint.
      with
        cid : ContractId ExecutedMint
          -- ^ Executed mint to delete.
        payload : ExecutedMint_Delete
          -- ^ Choice payload.
      controller operator
