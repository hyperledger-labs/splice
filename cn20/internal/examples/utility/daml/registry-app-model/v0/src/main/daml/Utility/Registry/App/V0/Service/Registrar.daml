          -- ^ Failed unlock to delete.
        payload : FailedUnlock_Delete
          -- ^ Choice payload.
      controller operator
      do
        fetchAndValidate cid
          [ ("Operator", .unlock.operator, operator)
          , ("Provider", .unlock.provider, provider)
          , ("Registrar", .unlock.registrar, registrar)
          ]
        exercise cid payload

    nonconsuming choice RegistrarService_DeleteExecutedUnlock : ExecutedUnlock_Delete_Result
      -- ^ Deletes an executed unlock.
      with
        cid : ContractId ExecutedUnlock
          -- ^ Executed unlock to delete.
        payload : ExecutedUnlock_Delete
          -- ^ Choice payload.
      controller operator
      do
        fetchAndValidate cid
          [ ("Operator", .unlock.operator, operator)
          , ("Provider", .unlock.provider, provider)
          , ("Registrar", .unlock.registrar, registrar)
          ]
        exercise cid payload

    nonconsuming choice RegistrarService_DeleteRejectedTransfer : RejectedTransfer_Delete_Result
      -- ^ Deletes a rejected transfer.
      with
        cid : ContractId RejectedTransfer
          -- ^ Rejected transfer to delete.
        payload : RejectedTransfer_Delete
          -- ^ Choice payload.
