        exercise cid payload

    nonconsuming choice RegistrarService_DeleteFailedLock : FailedLock_Delete_Result
      -- ^ Deletes a failed lock.
      with
        cid : ContractId FailedLock
          -- ^ Failed lock to delete.
        payload : FailedLock_Delete
          -- ^ Choice payload.
      controller operator
      do
        fetchAndValidate cid
          [ ("Operator", .lock.operator, operator)
          , ("Provider", .lock.provider, provider)
          , ("Registrar", .lock.registrar, registrar)
          ]
        exercise cid payload

    nonconsuming choice RegistrarService_DeleteExecutedLock : ExecutedLock_Delete_Result
      -- ^ Deletes an executed lock.
      with
        cid : ContractId ExecutedLock
          -- ^ Executed lock to delete.
        payload : ExecutedLock_Delete
          -- ^ Choice payload.
      controller operator
      do
        fetchAndValidate cid
          [ ("Operator", .lock.operator, operator)
          , ("Provider", .lock.provider, provider)
          , ("Registrar", .lock.registrar, registrar)
          ]
        exercise cid payload

    nonconsuming choice RegistrarService_DeleteRejectedUnlock : RejectedUnlock_Delete_Result
      -- ^ Deletes a rejected unlock.
      with
        cid : ContractId RejectedUnlock
          -- ^ Rejected unlock to delete.
        payload : RejectedUnlock_Delete
          -- ^ Choice payload.
      controller operator
      do
        fetchAndValidate cid
          [ ("Operator", .unlock.operator, operator)
          , ("Provider", .unlock.provider, provider)
          , ("Registrar", .unlock.registrar, registrar)
