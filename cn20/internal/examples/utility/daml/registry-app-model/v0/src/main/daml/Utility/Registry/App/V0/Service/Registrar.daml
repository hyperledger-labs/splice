  RegistrarService_ArchiveAndCreateRegistrarConfiguration_Result
  with
    archiveResult : RegistrarService_ArchiveRegistrarConfiguration_Result
      -- ^ Archive result.
    createResult : RegistrarService_CreateRegistrarConfiguration_Result
      -- ^ Create result.
