-- | A registrar service request.
template RegistrarServiceRequest
  with
    operator : Party
      -- ^ Service operator.
    provider : Party
      -- ^ Service provider.
    registrar : Party
      -- ^ Service registrar.
  where
    signatory registrar
    observer provider, operator

    choice RegistrarServiceRequest_Accept : RegistrarServiceRequest_Accept_Result
      -- ^ Accept request.
      with
        providerConfigurationCid : ContractId ProviderConfiguration
          -- ^ Provider configuration.
        credentialCids : [ContractId Credential]
          -- ^ Registrar credentials.
      controller provider
      do
        -- Assert configuration
        configuration <- fetchAndValidate providerConfigurationCid
          [ ("Operator", .operator, operator)
          , ("Provider", .provider, provider)
          ]

        -- Assert credentials
        credentials <- mapA fetch credentialCids
        assertFulfillsAllRequirements registrar configuration.registrarRequirements credentials

        -- Create service
        serviceCid <- create RegistrarService with operator; provider; registrar
        pure RegistrarServiceRequest_Accept_Result with registrarServiceCid = serviceCid

    choice RegistrarServiceRequest_Reject : RegistrarServiceRequest_Reject_Result
      -- ^ Reject request.
      with
        reason : Text
          -- ^ Rejection reason.
      controller provider
      do
        rejectedRegistrarServiceRequestCid <- create RejectedRegistrarServiceRequest with
          request = this; reason
        pure RegistrarServiceRequest_Reject_Result with rejectedRegistrarServiceRequestCid

    choice RegistrarServiceRequest_Cancel : RegistrarServiceRequest_Cancel_Result
      -- ^ Cancel request.
      controller registrar
      do
        pure RegistrarServiceRequest_Cancel_Result

-- | A rejected registrar service request.
template RejectedRegistrarServiceRequest
  with
    request : RegistrarServiceRequest
      -- ^ The rejected request payload.
    reason : Text
      -- ^ The rejection reason.
  where
    signatory request.provider, request.registrar
    observer request.operator

    choice RejectedRegistrarServiceRequest_Delete : RejectedRegistrarServiceRequest_Delete_Result
      -- ^ Deletes a rejected registrar service request.
      controller request.provider
      do
        pure RejectedRegistrarServiceRequest_Delete_Result

-- | Result of `RegistrarServiceRequest_Accept`.
data RegistrarServiceRequest_Accept_Result = RegistrarServiceRequest_Accept_Result
  with
    registrarServiceCid : ContractId RegistrarService
      -- ^ Registrar service.
  deriving (Eq, Show)

-- | Result of `RegistrarServiceRequest_Reject`.
data RegistrarServiceRequest_Reject_Result = RegistrarServiceRequest_Reject_Result
  with
    rejectedRegistrarServiceRequestCid : ContractId RejectedRegistrarServiceRequest
      -- ^ Rejected registrar service request.
  deriving (Eq, Show)

-- | Result of `RegistrarServiceRequest_Cancel`.
data RegistrarServiceRequest_Cancel_Result = RegistrarServiceRequest_Cancel_Result {}
  deriving (Eq, Show)

-- | Result of `RejectedRegistrarServiceRequest_Delete`.
data RejectedRegistrarServiceRequest_Delete_Result =
  RejectedRegistrarServiceRequest_Delete_Result {}
  deriving (Eq, Show)

-- | HIDE
oneOf : Eq a => a -> [a] -> Optional a
oneOf candidate = find (== candidate)
