          ]
        exercise cid payload

-- | Result of `HolderService_Terminate`.
data HolderService_Terminate_Result = HolderService_Terminate_Result {}
  deriving (Eq, Show)

-- | Result of `HolderService_RequestEnforcement_Result`.
data HolderService_RequestEnforcementService_Result =
  HolderService_RequestEnforcementService_Result
  with
    enforcementServiceRequestCid : ContractId EnforcementServiceRequest
      -- ^ Request for a enforcement service.
  deriving (Eq, Show)

-- | Result of `HolderService_RequestForceTransfer`.
data HolderService_RequestForceTransfer_Result = HolderService_RequestForceTransfer_Result
  with
    forceTransferRequestCid : ContractId ForceTransferRequest
      -- ^ Force transfer request.
  deriving (Eq, Show)

-- | Result of `HolderService_RequestMint`.
data HolderService_RequestMint_Result = HolderService_RequestMint_Result
  with
    mintRequestCid : ContractId MintRequest
      -- ^ Mint request.
  deriving (Eq, Show)

-- | Result of `HolderService_RequestBurn`.
data HolderService_RequestBurn_Result = HolderService_RequestBurn_Result
  with
    burnRequestCid : ContractId BurnRequest
      -- ^ Burn request.
  deriving (Eq, Show)

-- | Result of `HolderService_OfferTransfer`.
data HolderService_OfferTransfer_Result = HolderService_OfferTransfer_Result
  with
    transferOfferCid : ContractId TransferOffer
      -- ^ Transfer offer.
  deriving (Eq, Show)

-- | Result of `HolderService_AcceptTransferOfferr`.
data HolderService_AcceptTransferOffer_Result = HolderService_AcceptTransferOffer_Result
  with
    acceptedTransferCid : ContractId AcceptedTransfer
      -- ^ Accepted transfer.
  deriving (Eq, Show)

-- | Result of `HolderService_RequestTransfer`.
data HolderService_RequestTransfer_Result = HolderService_RequestTransfer_Result
  with
    transferRequestCid : ContractId TransferRequest
      -- ^ Transfer request.
  deriving (Eq, Show)

-- | Result of `HolderService_OfferLock`.
data HolderService_OfferLock_Result = HolderService_OfferLock_Result
  with
    lockOfferCid : ContractId LockOffer
      -- ^ Lock offer.
  deriving (Eq, Show)

-- | Result of `HolderService_RequestLock`.
data HolderService_RequestLock_Result = HolderService_RequestLock_Result
  with
    lockRequestCid : ContractId LockRequest
      -- ^ Lock request.
  deriving (Eq, Show)

-- | Result of `HolderService_OfferUnlock`.
data HolderService_OfferUnlock_Result = HolderService_OfferUnlock_Result
  with
    unlockOfferCid : ContractId UnlockOffer
      -- ^ Unlock offer.
  deriving (Eq, Show)

-- | Result of `HolderService_RequestUnlock`.
data HolderService_RequestUnlock_Result = HolderService_RequestUnlock_Result
  with
    unlockRequestCid : ContractId UnlockRequest
      -- ^ Unlock request.
  deriving (Eq, Show)

-- | A holder service request.
template HolderServiceRequest
  with
    operator : Party
      -- ^ Service operator.
    provider : Party
      -- ^ Service provider.
    holder : Party
      -- ^ Service holder.
  where
    signatory holder
    observer operator, provider

    choice HolderServiceRequest_Accept : HolderServiceRequest_Accept_Result
      -- ^ Accept request.
      with
        providerConfigurationCid : ContractId ProviderConfiguration
          -- ^ Provider configuration.
        credentialCids : [ContractId Credential]
          -- ^ Holder credentials.
      controller provider
      do
        -- Assert configuration
        configuration <- fetchAndValidate providerConfigurationCid
          [ ("Operator", .operator, operator)
          , ("Provider", .provider, provider)
          ]

        -- Assert credentials
        credentials <- mapA fetch credentialCids
        assertFulfillsAllRequirements holder configuration.holderRequirements credentials

        -- Create service
        serviceCid <- create HolderService with operator; provider; holder
        pure HolderServiceRequest_Accept_Result with holderServiceCid = serviceCid

    choice HolderServiceRequest_Reject : HolderServiceRequest_Reject_Result
      -- ^ Reject request.
      with
        reason : Text
          -- ^ Rejection reason.
      controller provider
      do
        rejectedHolderServiceRequestCid <- create RejectedHolderServiceRequest with
          request = this; reason
        pure HolderServiceRequest_Reject_Result with rejectedHolderServiceRequestCid

    choice HolderServiceRequest_Cancel : HolderServiceRequest_Cancel_Result
      -- ^ Cancel request.
      controller holder
      do
        pure HolderServiceRequest_Cancel_Result

-- | A rejected holder service request.
template RejectedHolderServiceRequest
  with
    request : HolderServiceRequest
      -- ^ The rejected request payload.
    reason : Text
      -- ^ The rejection reason.
  where
    signatory request.provider, request.holder
    observer request.operator

    choice RejectedHolderServiceRequest_Delete : RejectedHolderServiceRequest_Delete_Result
      -- ^ Deletes a rejected holder service request.
      controller request.provider
      do
        pure RejectedHolderServiceRequest_Delete_Result

-- | Result of `HolderServiceRequest_Accept`.
data HolderServiceRequest_Accept_Result = HolderServiceRequest_Accept_Result
  with
    holderServiceCid : ContractId HolderService
      -- ^ Holder service contract.
  deriving (Eq, Show)

-- | Result of `HolderServiceRequest_Reject`.
data HolderServiceRequest_Reject_Result = HolderServiceRequest_Reject_Result
  with
    rejectedHolderServiceRequestCid : ContractId RejectedHolderServiceRequest
      -- ^ Rejected holder service request contract.
  deriving (Eq, Show)

-- | Result of `HolderServiceRequest_Cancel`.
data HolderServiceRequest_Cancel_Result = HolderServiceRequest_Cancel_Result {}
  deriving (Eq, Show)

-- | Result of `RejectedHolderServiceRequest_Delete`.
data RejectedHolderServiceRequest_Delete_Result = RejectedHolderServiceRequest_Delete_Result {}
  deriving (Eq, Show)
