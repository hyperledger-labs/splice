module Utility.Credential.App.V0.Test.Service.Operator where

import Daml.Script
import Utility.Credential.App.V0.Test.Util (AppUser, bootstrapAmuletApp, onboardOperator)
import Vendored.Splice.Scripts.Util as CCUtil (AmuletApp, setupSelfHostedUser)

-- | Test app initialisation / bootstrapping.
bootstrapApp : Decimal -> Script (AppUser, AmuletApp)
bootstrapApp amuletPrice = do

  -- Bootstrap DSO and Canton Coin application.
  ccApp <- bootstrapAmuletApp amuletPrice

  -- Setup a validator node and onboard the app provider for the Credential App as a party
  -- on that node.
  (operator, operatorValidator) <- setupSelfHostedUser ccApp "CredentialAppOperator"

  -- Onboard app operator.
  appOperator <- onboardOperator operator ccApp.dso

  pure (appOperator, ccApp)

testBootstrapApp : Script (AppUser, AmuletApp)
testBootstrapApp = bootstrapApp 0.005
