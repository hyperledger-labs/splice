module Utility.Credential.App.V0.Test.Util where

import DA.Foldable (mapA_)
import DA.Optional (fromSome)
import Daml.Script
import Splice.Amulet (Amulet, FeaturedAppRight, LockedAmulet)
import Splice.AmuletRules (AmuletRules, AppTransferContext(..))
import Splice.Round (IssuingMiningRound, OpenMiningRound)
import Splice.Types (Round)
import Utility.Credential.App.V0.Model.Billing (CredentialBilling)
import Utility.Credential.App.V0.Service.Operator (OperatorService(..))
import Utility.Credential.App.V0.Service.User (UserService, UserServiceRequest(..), UserServiceRequest_Accept(..))
import Vendored.Splice.Scripts.Util as CCUtil (AmuletApp, AmuletUser, fetchAmuletRulesByKey, getFeaturedAppRight, getOpenIssuingRounds, getOpenRoundsSorted, runAmuletDepositBots, runNextIssuanceInternal, setupApp, setupSelfHostedUser)

-- | App user data.
data AppUser = AppUser
  with
    user : AmuletUser
      -- ^ The user party.
    userServiceCid : ContractId UserService
      -- ^ The `UserService` contract between the user and the provider.
  deriving (Eq, Show)

-- | Bootstrap the Amulet app.
-- Advance time to skip the long-running Round 0 and move to the start of Round 2.
bootstrapAmuletApp : Decimal -> Script AmuletApp
bootstrapAmuletApp amuletPrice = do
  ccApp <- CCUtil.setupApp amuletPrice
  runNextIssuanceInternal ccApp amuletPrice
  runAmuletDepositBots ccApp
  pure ccApp

-- | Onboard app operator.
onboardOperator : AmuletUser -> Party -> Script AppUser
onboardOperator operator dsoParty = do
  -- Operator service
  operatorServiceCid <- submit operator.primaryParty do
    createCmd OperatorService with operator = operator.primaryParty; dso = dsoParty
  -- Operator user service
  operatorUserServiceCid <- createUserService operator.primaryParty operator.primaryParty dsoParty
  pure AppUser with user = operator; userServiceCid = operatorUserServiceCid

-- | Onboard app user.
onboardUser : AppUser -> AmuletApp -> Text -> Script AppUser
onboardUser operator amuletApp userName = do
  (user, userValidator) <- setupSelfHostedUser amuletApp userName
  userServiceCid <-
    createUserService operator.user.primaryParty user.primaryParty amuletApp.dso
  pure AppUser with user; userServiceCid

-- | Creates a `UserService`.
createUserService : Party -> Party -> Party -> Script (ContractId UserService)
createUserService operator user dso = do
  offerCid <- submit user $ createCmd UserServiceRequest with operator; user
  (.userServiceCid) <$> submit operator do exerciseCmd offerCid UserServiceRequest_Accept with dso

-- | Fetch all open rounds and explicitly disclose them.
discloseOpenRounds : AmuletApp ->
  Script [(ContractId OpenMiningRound, OpenMiningRound, Disclosure)]
discloseOpenRounds app = do
  openRounds <- getOpenRoundsSorted app
  forA openRounds \(cid, round) -> do
    disclosureBlob <- fromSome <$> queryDisclosure app.dso cid
    pure (cid, round, disclosureBlob)

-- | Fetch all open issuing rounds and explicitly disclose them.
discloseOpenIssuingRounds : AmuletApp ->
  Script [(ContractId IssuingMiningRound, IssuingMiningRound, Disclosure)]
discloseOpenIssuingRounds app = do
  openRounds <- getOpenIssuingRounds app
  forA openRounds \(cid, round) -> do
    disclosureBlob <- fromSome <$> queryDisclosure app.dso cid
    pure (cid, round, disclosureBlob)

-- | Fetch a given open issuing round and explicitly disclose it.
discloseOpenIssuingRound : AmuletApp -> Round ->
  Script (ContractId IssuingMiningRound, IssuingMiningRound, Disclosure)
discloseOpenIssuingRound app round = do
  openIssuingRounds <- discloseOpenIssuingRounds app
  case find (\(_, payload, _) -> payload.round == round) openIssuingRounds of
    None -> abort ("No open issuing round for round " <> show round)
    Some (cid, issuingRound, blob) -> pure (cid, issuingRound, blob)

-- | Fetch amulet rules on behalf of the DSO party and explicitly disclose them.
discloseAmuletRules : AmuletApp -> Script (ContractId AmuletRules, Disclosure)
discloseAmuletRules app = do
  cid <- fst <$> fetchAmuletRulesByKey app.dso
  disclosureBlob <- fromSome <$> queryDisclosure app.dso cid
  pure (cid, disclosureBlob)

-- | Check if a party is "featured" by looking up the corresponding `FeaturedAppRight` instance.
-- If found, return it together with the blob for explicit disclosure.
discloseFeaturedAppRight : AmuletApp -> Party ->
  Script (Optional (ContractId FeaturedAppRight), [Disclosure])
discloseFeaturedAppRight app provider = do
  cidO <- getFeaturedAppRight app provider
  disclosureBlob <- case cidO of
    None -> pure []
    Some cid -> pure . fromSome <$> queryDisclosure provider cid
  pure (cidO, disclosureBlob)

-- | Get the `AppTransferContext` at a given round for an unfeatured transfer.
discloseUnfeaturedAppTransferContextForRound : AmuletApp -> Round ->
  Script (AppTransferContext, [Disclosure])
discloseUnfeaturedAppTransferContextForRound app round = do
  openMiningRounds <- discloseOpenRounds app
  (openMiningRound, openMiningRoundBlob) <-
    case find (\(_, payload, _) -> payload.round == round) openMiningRounds of
      None -> abort ("No open mining round for round " <> show round)
      Some (cid, _, blob) -> pure (cid, blob)
  (amuletRules, amuletRulesBlob) <- discloseAmuletRules app
  let
    appTransferContext =
      AppTransferContext with amuletRules; openMiningRound; featuredAppRight = None
    disclosures = [openMiningRoundBlob, amuletRulesBlob]
  pure (appTransferContext, disclosures)

-- | Query for a credential.
getCredential : AppUser -> Script (ContractId CredentialBilling, CredentialBilling)
getCredential user = do
  [license] <- query @CredentialBilling user.user.primaryParty
  pure license

-- | Verify the CC balance for a given app user.
verifyAmuletBalance : (AppUser, Decimal) -> Script ()
verifyAmuletBalance (appUser, expectedAmount) = do
  amulets <- fmap snd <$> query @Amulet appUser.user.primaryParty
  let actualAmount = sum $ fmap (.amount.initialAmount) amulets
  assertMsg ("CC balance mismatch for " <> show appUser.user.userId <>  ": expected " <>
    show expectedAmount <> " but got " <> show actualAmount) $
    actualAmount == expectedAmount

-- | Get the locked CC balance for a given app user.
getLockedAmuletBalance : AppUser -> Script Decimal
getLockedAmuletBalance appUser = do
  lockedAmulets <- query @LockedAmulet appUser.user.primaryParty
  pure $ foldr (\(_, locked) acc -> acc + if locked.amulet.owner == appUser.user.primaryParty then
    locked.amulet.amount.initialAmount else 0.0) 0.0 lockedAmulets

-- | Verify the locked CC balance for a given app user.
verifyLockedAmuletBalance : (AppUser, Decimal) -> Script ()
verifyLockedAmuletBalance (appUser, expectedAmount) = do
  amountLocked <- getLockedAmuletBalance appUser
  assertMsg ("Locked CC balance mismatch for " <> show appUser.user.userId <>  ": expected " <>
    show expectedAmount <> " but got " <> show amountLocked) $ amountLocked == expectedAmount

-- Verify the deposit balance on the credential billing contract for a given app user.
verifyBalanceStateDeposit : AppUser -> Script ()
verifyBalanceStateDeposit appUser = do
  expected <- (.balanceState) . snd <$> getCredential appUser
  actualDepositAmount <- getLockedAmuletBalance appUser
  assertMsg ("Current deposit amount mismatch: "
    <> "expected " <> show expected.currentDepositAmountCc
    <> " but got " <> show actualDepositAmount)
    $ expected.currentDepositAmountCc == actualDepositAmount

-- | Verify the CC balances for multiple app users.
verifyAmuletBalances : [(AppUser, Decimal)] -> Script ()
verifyAmuletBalances usersAndExpectedAmounts = mapA_ verifyAmuletBalance usersAndExpectedAmounts

-- | Verify the locked CC balances for multiple app users.
verifyLockedAmuletBalances : [(AppUser, Decimal)] -> Script ()
verifyLockedAmuletBalances usersAndExpectedAmounts =
  mapA_ verifyLockedAmuletBalance usersAndExpectedAmounts

-- | Expected fees recorded in the credential.
data ExpectedFees = ExpectedFees
  with
    totalCcFeesPaidIssuerCc : Decimal
    totalCcFeesPaidHolderCc : Decimal
  deriving (Eq, Show)

-- | Validate the CC fees recorded in the credential.
validateCcFees : AppUser -> ExpectedFees -> Script ()
validateCcFees user expected = do
  actual <- (.billingState) . snd <$> getCredential user
  assertMsg ("Total CC fees paid by issuer mismatch: "
    <> "expected " <> show expected.totalCcFeesPaidIssuerCc
    <> " but got " <> show actual.totalCcFeesPaidIssuerCc)
    $ expected.totalCcFeesPaidIssuerCc == actual.totalCcFeesPaidIssuerCc
  assertMsg ("Total CC fees paid by holder mismatch: "
    <> "expected " <> show expected.totalCcFeesPaidHolderCc
    <> " but got " <> show actual.totalCcFeesPaidHolderCc)
    $ expected.totalCcFeesPaidHolderCc == actual.totalCcFeesPaidHolderCc
