-- | Test workflow to request / accept an `UserService` contract.
testSetupUserService : Script ()
testSetupUserService = do
  (operator, ccApp) <- bootstrapApp 0.005
  holder <- onboardUser operator ccApp "holder"
  pure ()

-- | Test workflow to offer / accept a free `Credential`.
testSetupFreeCredential : Script ()
testSetupFreeCredential = do
  (operator, ccApp) <- bootstrapApp 0.005
  holder <- onboardUser operator ccApp "holder"
  issuer <- onboardUser operator ccApp "issuer"

  -- The Credential issuer does manual KYC and then proposes a free credential.
  let
    claim = Claim with
      subject = partyToText holder.user.primaryParty
      property = "mayUse"
      value = "ManagedRegistryUtility"
    claims = [claim]

  UserService_OfferFreeCredential_Result{credentialOfferCid} <- submit issuer.user.primaryParty do
    exerciseCmd issuer.userServiceCid UserService_OfferFreeCredential with
      holder = holder.user.primaryParty
      description = "Credential"
      id = "RegistryCredential12345"
      claims

  -- The holder accepts the proposal from the issuer
  CredentialOffer_AcceptFree_Result{credentialCid} <- submit holder.user.primaryParty do
    exerciseCmd holder.userServiceCid UserService_AcceptFreeCredentialOffer with
      credentialOfferCid

  credential <- fromSome <$> queryContractId operator.user.primaryParty credentialCid
  assertMsg "Unexpected issuer" $ credential.issuer == issuer.user.primaryParty
  assertMsg "Unexpected holder" $ credential.holder == holder.user.primaryParty
  assertMsg "Unexpected observers" $ credential.observers == singleton operator.user.primaryParty

  -- The Credential issuer revokes the free credential.
  submit issuer.user.primaryParty do
    exerciseCmd issuer.userServiceCid UserService_RevokeCredential with
      credentialCid

  -- Verify that balances did not change after issuing a free credential.
  verifyAmuletBalances [(holder, 1.0), (issuer, 1.0)]

  pure ()

-- | Test workflow to offer / accept a free `Credential` for the operator.
testSetupFreeCredentialToOperator : Script ()
testSetupFreeCredentialToOperator = do
  (operator, ccApp) <- bootstrapApp 0.005
  holder <- onboardUser operator ccApp "holder"
  issuer <- onboardUser operator ccApp "issuer"

  UserService_OfferFreeCredential_Result{credentialOfferCid} <- submit issuer.user.primaryParty do
    exerciseCmd issuer.userServiceCid UserService_OfferFreeCredential with
      holder = operator.user.primaryParty
      description = "Credential"
      id = "RegistryCredential12345"
      claims =
        [ Claim with
            subject = partyToText operator.user.primaryParty
            property = "mayUse"
            value = "ManagedRegistryUtility"
        ]

  -- Must fail: The issuer accepts the proposal for the operator.
  submitMustFail holder.user.primaryParty do
    exerciseCmd holder.userServiceCid UserService_AcceptFreeCredentialOffer with
      credentialOfferCid

  -- Operator accepts the proposal
  submit operator.user.primaryParty do
    exerciseCmd operator.userServiceCid UserService_AcceptFreeCredentialOffer with
      credentialOfferCid

  pure ()

-- | Test workflow to offer / accept a paid `Credential`.
testSetupPaidCredential : Script ()
testSetupPaidCredential = do
  (operator, ccApp) <- bootstrapApp 0.005
  holder <- onboardUser operator ccApp "holder"
  issuer <- onboardUser operator ccApp "issuer"
  credentialCid <- setupPaidCredential operator ccApp issuer holder defaultParams None

  -- Validate CC balances
  verifyAmuletBalances [(holder, 179981.0), (issuer, 1.0)]
  verifyLockedAmuletBalances [(holder, 20000.0)]

  -- Validate recorded CC fees
  validateCcFees holder ExpectedFees
    with
      totalCcFeesPaidIssuerCc = 0.0
      totalCcFeesPaidHolderCc = 14.0

  -- Verify the deposit balance on the credential billing contract
  verifyBalanceStateDeposit holder

  credential <- fromSome <$> queryContractId operator.user.primaryParty credentialCid
  assertMsg "Unexpected issuer" $ credential.issuer == issuer.user.primaryParty
  assertMsg "Unexpected holder" $ credential.holder == holder.user.primaryParty
  assertMsg "Unexpected observers" $ credential.observers == singleton operator.user.primaryParty

  pure ()

-- | Test workflow to offer / accept a paid `Credential` for the operator.
testSetupPaidCredentialMustFail : Script ()
testSetupPaidCredentialMustFail = do
  (operator, ccApp) <- bootstrapApp 0.005
  holder <- onboardUser operator ccApp "holder"
  issuer <- onboardUser operator ccApp "issuer"

  -- The Credential issuer does manual KYC and then proposes a credential (including price)
  let
    claim = Claim with
      subject = partyToText operator.user.primaryParty
      property = "mayUse"
      value = "ManagedRegistryUtility"
    claims = [claim]
    offerCredential = exerciseCmd issuer.userServiceCid UserService_OfferPaidCredential with
      holder = operator.user.primaryParty
      description = "Credential"
      id = "RegistryCredential12345"
      billingParams = defaultParams
      depositInitialAmountUsd = None
      claims

  UserService_OfferPaidCredential_Result credentialOfferCid <- submit issuer.user.primaryParty do
    offerCredential

  (appTransferContext, disclosures) <- discloseUnfeaturedAppTransferContextForRound ccApp (Round 2)

  coinCids <- map fst <$> query @Amulet holder.user.primaryParty

  -- The holder tries to accept the proposal from the issuer but it fails due to
  -- insufficient funds to pay for the deposit.
  submitWithDisclosuresMustFail holder.user.primaryParty disclosures do
    exerciseCmd holder.userServiceCid UserService_AcceptPaidCredentialOffer with
      credentialOfferCid
      depositAmulets = coinCids
      appTransferContext

  -- The holder taps some coins to pay for the deposit
  tapUsd ccApp operator.user 1000.0

  -- do a CC merge after tapping
  runAmuletDepositBots ccApp

  [coinCid] <- map fst <$> query @Amulet operator.user.primaryParty
  disclosedCoinCid <- fromSome <$> queryDisclosure operator.user.primaryParty coinCid

  -- Must fail: The issuer accepts the proposal for the operator
  submitWithDisclosuresMustFail issuer.user.primaryParty (disclosedCoinCid :: disclosures) do
    exerciseCmd issuer.userServiceCid UserService_AcceptPaidCredentialOffer with
      credentialOfferCid
      depositAmulets = [coinCid]
      appTransferContext

  -- Operator accepts the proposal
  submitWithDisclosures operator.user.primaryParty disclosures do
    exerciseCmd operator.userServiceCid UserService_AcceptPaidCredentialOffer with
      credentialOfferCid
      depositAmulets = [coinCid]
      appTransferContext

  pure ()

-- | Setup a paid `Credential`.
setupPaidCredential : AppUser -> AmuletApp -> AppUser -> AppUser -> BillingParams ->
  Optional Decimal -> Script (ContractId Credential)
setupPaidCredential operator ccApp issuer holder billingParams depositInitialAmountUsd = do

  -- The Credential issuer does manual KYC and then proposes a credential (including price)
  let
    claim = Claim with
      subject = partyToText holder.user.primaryParty
      property = "mayUse"
      value = "ManagedRegistryUtility"
    claims = [claim]
    offerCredential = exerciseCmd issuer.userServiceCid UserService_OfferPaidCredential with
      holder = holder.user.primaryParty
      description = "Credential"
      id = "RegistryCredential12345"
      billingParams
      depositInitialAmountUsd
      claims

  UserService_OfferPaidCredential_Result credentialOfferCid <- submit issuer.user.primaryParty do
    offerCredential

  (appTransferContext, disclosures) <- discloseUnfeaturedAppTransferContextForRound ccApp (Round 2)

  coinCids <- map fst <$> query @Amulet holder.user.primaryParty

  -- The holder tries to accept the proposal from the issuer but it fails due to
  -- insufficient funds to pay for the deposit.
  submitWithDisclosuresMustFail holder.user.primaryParty disclosures do
    exerciseCmd holder.userServiceCid UserService_AcceptPaidCredentialOffer with
      credentialOfferCid
      depositAmulets = coinCids
      appTransferContext

  -- The holder taps some coins to pay for the deposit
  tapUsd ccApp holder.user 1000.0

  -- do a CC merge after tapping
  runAmuletDepositBots ccApp

  coinCids <- map fst <$> query @Amulet holder.user.primaryParty

  -- The holder accepts the proposal from the issuer
  -- (Beware of contention with the wallet, retries may be required.)
  CredentialOffer_AcceptPaid_Result{credentialCid; credentialBillingCid} <-
    submitWithDisclosures holder.user.primaryParty disclosures do
      exerciseCmd holder.userServiceCid UserService_AcceptPaidCredentialOffer with
        credentialOfferCid
        depositAmulets = coinCids
        appTransferContext

  -- Unhappy paths
  -- Withdrawal
  credentialOffer2Cid <- (.credentialOfferCid) <$> submit issuer.user.primaryParty do
    offerCredential
  submit issuer.user.primaryParty do
    exerciseCmd issuer.userServiceCid UserService_CancelCredentialOffer with
      credentialOfferCid = credentialOffer2Cid

  -- Rejection
  credentialOffer3Cid <- (.credentialOfferCid) <$> submit issuer.user.primaryParty do
    offerCredential
  submit holder.user.primaryParty do
    exerciseCmd holder.userServiceCid UserService_RejectCredentialOffer with
      credentialOfferCid = credentialOffer3Cid
      reason = "Rejected"

  pure credentialCid

-- | Test billing of credential with unfeatured issuer.
testCredentialBillingUnfeatured : Script ()
testCredentialBillingUnfeatured = runCredentialBilling False

-- | Test billing of credential with featured issuer.
testCredentialBillingFeatured : Script ()
testCredentialBillingFeatured = runCredentialBilling True

-- | Test billing of credential from operator.
runCredentialBilling : Bool -> Script ()
runCredentialBilling issuerIsFeatured = do
  let amuletPrice = 0.005

  (operator, ccApp) <- bootstrapApp amuletPrice
  holder <- onboardUser operator ccApp "holder"
  issuer <- onboardUser operator ccApp "issuer"
  credentialCid <- setupPaidCredential operator ccApp issuer holder defaultParams None

  -- Feature the Credential issuer
  if issuerIsFeatured then void $ featureApp ccApp issuer.user else pure ()

  -- Credential is due for billing immediately after acceptance.
  billCredential operator ccApp holder
  verifyAmuletBalances [(holder, 179981.0), (issuer, 32.2854794554)]
  verifyLockedAmuletBalances [(holder, 19954.33789954)]
  validateCcFees holder ExpectedFees
    with
      totalCcFeesPaidIssuerCc = 14.3766210046
      totalCcFeesPaidHolderCc = 14.0

  -- Run second billing cycle.
  -- close round 1, open round 4, move time to start of round 3, claim rewards for round 0, bill for
  -- round 3
  runOneBillingCycle operator ccApp holder amuletPrice
  verifyAmuletBalances [(holder, 179981.0), (issuer, 57.5589989108)]
  verifyLockedAmuletBalances [(holder, 19908.67579908)]
  validateCcFees holder ExpectedFees
    with
      totalCcFeesPaidIssuerCc = 28.7572020092
      totalCcFeesPaidHolderCc = 14.0

  -- close round 2, open round 5, move time to start of round 4, claim rewards for round 1, bill for
  -- round 4
  runOneBillingCycle operator ccApp holder amuletPrice
  verifyAmuletBalances [(holder, 179981.0), (issuer, 82.8325183662)]
  verifyLockedAmuletBalances [(holder, 19863.01369862)]

  -- Run a couple more billing cycles to collect rewards
  -- close round 3, open round 6, move time to start of round 5, claim rewards for round 2, bill for
  -- round 5
  runOneBillingCycle operator ccApp holder amuletPrice
  verifyLockedAmuletBalances [(holder, 19817.35159816)]

  -- Verify the deposit balance on the credential billing contract
  verifyBalanceStateDeposit holder

  -- The Credential issuer revokes the credential and cancels the credential billing.
  (appTransferContext, disclosures, credentialBillingCid) <-
    prepareCredentialBilling operator ccApp holder
  submitWithDisclosures issuer.user.primaryParty disclosures do
    exerciseCmd issuer.userServiceCid UserService_RevokeCredentialAndCancelBilling with
      credentialCid
      credentialBillingCid
      appTransferContext

  -- Verify balances after billing the first few rounds and then canceling the credential/billing.
  let
    usersAndExpectedAmounts =
      if issuerIsFeatured
      then [(holder, 199798.35159816), (issuer, 21550.5681382816)]
      else [(holder, 199798.35159816), (issuer, 121.5320104244)]

  verifyAmuletBalances usersAndExpectedAmounts

  pure ()

-- | Test edge cases when billing a credential.
testCredentialBillingEdgeCases : Script ()
testCredentialBillingEdgeCases = do
  let amuletPrice = 0.005

  (operator, ccApp) <- bootstrapApp amuletPrice
  holder <- onboardUser operator ccApp "holder"
  issuer <- onboardUser operator ccApp "issuer"
  credentialCid <- setupPaidCredential operator ccApp issuer holder defaultParams None

  -- Feature the Credential issuer
  featureApp ccApp issuer.user

  -- Bill the credential.
  billCredential operator ccApp holder

  -- Try billing again right away afterwards and verify that if fails.
  billCredentialMustFail operator ccApp holder

  -- Forward time by 5 minutes (less than 1 billing period) and validate that billing fails.
  now <- getTime
  setTime (now `addRelTime` minutes 5)
  billCredentialMustFail operator ccApp holder

  -- Forward time by 5 minutes (1 billing period has now passed) and validate that billing works.
  now <- getTime
  setTime (now `addRelTime` minutes 5)
  billCredential operator ccApp holder
  verifyLockedAmuletBalances [(holder, 19908.67579908)]

  -- Test what happens if time passes but rounds are not created (if CN automation does not work)
  forA_ [1 .. 3] \_ -> do
    now <- getTime
    setTime (now `addRelTime` minutes 10)
    billCredential operator ccApp holder
  verifyLockedAmuletBalances [(holder, 19771.6894977)] -- after billing 30 minutes, no round changes

  -- Test what happens if rounds are created properly but our billing automation does not work
  prepareBillingCycleRound ccApp amuletPrice
  prepareBillingCycleRound ccApp amuletPrice
  runOneBillingCycle operator ccApp holder amuletPrice
  verifyLockedAmuletBalances [(holder, 19680.36529678)] -- after billing 20 minutes (instead of 10)

  -- The issuer increases the billing period from 10 to 20 minutes.
  (credentialBillingCid, credentialBilling) <- getCredential issuer
  assertMsg "billing period mismatch" $ credentialBilling.params.billingPeriodMinutes == 10
  submitMustFail issuer.user.primaryParty do
    exerciseCmd issuer.userServiceCid UserService_AdjustBillingParams with
      credentialBillingCid
      billingParams = credentialBilling.params with billingPeriodMinutes = 20

  -- Request to adjust billing params
  let
    request = UserService_RequestToAdjustBillingParams with
      credentialBillingCid
      billingParams = credentialBilling.params with billingPeriodMinutes = 20
  adjustmentRequest <- submit issuer.user.primaryParty do exerciseCmd issuer.userServiceCid request

  -- Cancel the adjustment request
  submit issuer.user.primaryParty do
    exerciseCmd issuer.userServiceCid UserService_BillingParamsAdjustmentRequest_Cancel
      with
        requestCid = adjustmentRequest.requestCid

  -- Request to adjust billing params
  adjustmentRequest <- submit issuer.user.primaryParty do exerciseCmd issuer.userServiceCid request

  -- Accept the adjustment request
  submitMustFail issuer.user.primaryParty do
    exerciseCmd issuer.userServiceCid UserService_BillingParamsAdjustmentRequest_Accept
      with
        requestCid = adjustmentRequest.requestCid
        credentialBillingCid
  submit holder.user.primaryParty do
    exerciseCmd holder.userServiceCid UserService_BillingParamsAdjustmentRequest_Accept
      with
        requestCid = adjustmentRequest.requestCid
        credentialBillingCid

  (credentialBillingCid, credentialBilling) <- getCredential issuer
  assertMsg "billing period mismatch" $ credentialBilling.params.billingPeriodMinutes == 20

  -- Verify the deposit balance on the credential billing contract
  verifyBalanceStateDeposit holder

  pure ()

-- | Test billing where operator == holder.
testOperatorAsHolder : Script ()
testOperatorAsHolder = do
  let amuletPrice = 0.005
  (operator, ccApp) <- bootstrapApp amuletPrice
  issuer <- onboardUser operator ccApp "issuer"
  operatorAsHolderCid <- setupPaidCredential operator ccApp issuer operator defaultParams None

  billCredential operator ccApp operator
  validateCcFees operator ExpectedFees
    with
      totalCcFeesPaidIssuerCc = 13.3866210046
      totalCcFeesPaidHolderCc = 13.0
  pure ()

-- | Test billing where operator == issuer.
testOperatorAsIssuer : Script ()
testOperatorAsIssuer = do
  let amuletPrice = 0.005
  (operator, ccApp) <- bootstrapApp amuletPrice
  holder <- onboardUser operator ccApp "holder"

  operatorAsIssuerCid <- setupPaidCredential operator ccApp operator holder defaultParams None

  billCredential operator ccApp operator
  validateCcFees operator ExpectedFees
    with
      totalCcFeesPaidIssuerCc = 13.3866210046
      totalCcFeesPaidHolderCc = 13.0
  pure ()

-- | Test scenarios where the deposit runs low and user top-up is required.
testCredentialBillingLowDepositAndTopUp : Script ()
testCredentialBillingLowDepositAndTopUp = do
  let amuletPrice = 0.005

  (operator, ccApp) <- bootstrapApp amuletPrice
  holder <- onboardUser operator ccApp "holder"
  issuer <- onboardUser operator ccApp "issuer"
  let params = defaultParams with
       depositTargetAmountUsd = 150.0
       feePerDayUsd = RatePerDay with rate = 300.0
  credentialCid <- setupPaidCredential operator ccApp issuer holder params (Some 2.0)

  -- Billing fails as the deposit is insufficient to cover the billing period.
  billCredentialStatusFailure operator ccApp holder

  -- The holder tops up the deposit by a minimal amount in order to cover the next payment period.
  coinCids <- map fst <$> query @Amulet holder.user.primaryParty
  (appTransferContext, disclosures, credentialBillingCid) <-
    prepareCredentialBilling operator ccApp holder
  credentialBillingCid <- (.newCredentialBillingCid) <$>
    submitWithDisclosures holder.user.primaryParty disclosures do
      exerciseCmd holder.userServiceCid UserService_TopUp with
        credentialBillingCid
        amountUsd = 1.0
        coinCids
        appTransferContext
  verifyAmuletBalances [(holder, 199367.0)]
  verifyLockedAmuletBalances [(holder, 600.0)]
  validateCcFees holder ExpectedFees
    with
      totalCcFeesPaidIssuerCc = 0.0
      totalCcFeesPaidHolderCc = 28.0

  -- billing now succeeds
  -- Deposit amount falls below 1 USD after billing, so it gets fully depleted and the rest is
  -- refunded to the user
  billCredential operator ccApp holder
  verifyAmuletBalances [(holder, 199544.33333334)]
  verifyLockedAmuletBalances [(holder, 0.0)]
  validateCcFees holder ExpectedFees
    with
      totalCcFeesPaidIssuerCc = 10.1666666666
      totalCcFeesPaidHolderCc = 34.0

  -- Billing fails as deposit is empty
  runOneBillingCycleMustFail operator ccApp holder amuletPrice

  -- The holder tops up the deposit by a large amount. The top-up amount ($200) exceeds the target
  -- amount ($150).
  coinCids <- map fst <$> query @Amulet holder.user.primaryParty
  (appTransferContext, disclosures, credentialBillingCid) <-
    prepareCredentialBilling operator ccApp holder
  submitWithDisclosures holder.user.primaryParty disclosures do
    exerciseCmd holder.userServiceCid UserService_TopUp with
      credentialBillingCid
      amountUsd = 200.0
      coinCids
      appTransferContext
  verifyAmuletBalances [(holder, 169524.32533334)]
  verifyLockedAmuletBalances [(holder, 30000.0)]
  validateCcFees holder ExpectedFees
    with
      totalCcFeesPaidIssuerCc = 10.1666666666
      totalCcFeesPaidHolderCc = 48.0

  -- billing now succeeds
  billCredential operator ccApp holder
  verifyAmuletBalances [(holder, 169524.32533334), (issuer, 800.0719999868)]
  verifyLockedAmuletBalances [(holder, 29583.33333334)]

  -- The issuer decreases the deposit target amount from $150 to $140.
  (credentialBillingCid, credentialBilling) <- getCredential issuer
  submitMustFail issuer.user.primaryParty do
    exerciseCmd issuer.userServiceCid UserService_AdjustBillingParams with
      credentialBillingCid
      billingParams = credentialBilling.params with depositTargetAmountUsd = 140.0

  -- Deprecated choices must fail
  submitMustFail issuer.user.primaryParty do
    exerciseCmd issuer.userServiceCid UserService_AdjustBillingParams with
      credentialBillingCid
      billingParams = credentialBilling.params with depositTargetAmountUsd = 140.0
  submitMustFail issuer.user.primaryParty do
    exerciseCmd credentialBillingCid CredentialBilling_AdjustBillingParams with
      newParams = credentialBilling.params with depositTargetAmountUsd = 140.0

  -- Request to adjust billing params
  adjustmentRequest <- submit issuer.user.primaryParty do
    exerciseCmd issuer.userServiceCid UserService_RequestToAdjustBillingParams with
      credentialBillingCid
      billingParams = credentialBilling.params with depositTargetAmountUsd = 140.0

  -- Issuer can't accept the adjustment request
  submitMustFail issuer.user.primaryParty do
    exerciseCmd issuer.userServiceCid UserService_BillingParamsAdjustmentRequest_Accept
      with
        requestCid = adjustmentRequest.requestCid
        credentialBillingCid

  -- Holder accepts the adjustment request
  submit holder.user.primaryParty do
    exerciseCmd holder.userServiceCid UserService_BillingParamsAdjustmentRequest_Accept
      with
        requestCid = adjustmentRequest.requestCid
        credentialBillingCid

  (credentialBillingCid, credentialBilling) <- getCredential issuer

  -- The holder tries to top up the deposit, but since the target amount has been reduced, the
  -- current deposit exceeds the target (so the holder gets some money back instead).
  topUp ccApp operator holder 200.1
  verifyAmuletBalances [(holder, 171093.65866668), (issuer, 800.0719999868)]
  verifyLockedAmuletBalances [(holder, 28000.0)]
  validateCcFees holder ExpectedFees
    with
      totalCcFeesPaidIssuerCc = 28.2533333332
      totalCcFeesPaidHolderCc = 62.0

  -- Move the amulet price to enable a reduction of the deposit.
  advanceToIssuanceWithPrice ccApp 2.0

  -- The holder tries to top up the deposit, but since the amulet price has moved favorably, the
  -- current deposit exceeds the target (so the holder gets some money back instead).
  topUp ccApp operator holder 200.0
  verifyAmuletBalances [(holder, 199023.60766668), (issuer, 794.0639999868)]
  verifyLockedAmuletBalances [(holder, 70.0)]
  validateCcFees holder ExpectedFees
    with
      totalCcFeesPaidIssuerCc = 28.2533333332
      totalCcFeesPaidHolderCc = 62.035

  -- Verify the deposit balance on the credential billing contract
  verifyBalanceStateDeposit holder

  pure ()

-- | Test distribution.
testDistribution : Script ()
testDistribution = do
  let amuletPrice = 0.005

  (operator, ccApp) <- bootstrapApp amuletPrice
  holder <- onboardUser operator ccApp "holder"
  issuer <- onboardUser operator ccApp "issuer"
  let params = defaultParams with depositTargetAmountUsd = 150.0
  credentialCid <- setupPaidCredential operator ccApp issuer holder params (Some 100.0)

  -- Feature the Credential issuer
  featureApp ccApp issuer.user

  -- Bill the credential after creation
  billCredential operator ccApp holder

  -- Run a few billing cycles (for rounds 3 to 8)
  forA_ [3 .. 8] \_ -> do runOneBillingCycle operator ccApp holder amuletPrice

  verifyAmuletBalances [(holder, 179981.0), (issuer, 85939.3629980278)]

  -- The issuer distributes some coins.
  coinCids <- map fst <$> query @Amulet issuer.user.primaryParty
  (appTransferContext, disclosures, credentialBillingCid) <-
    prepareCredentialBilling operator ccApp issuer
  submitWithDisclosures issuer.user.primaryParty disclosures do
    exerciseCmd issuer.userServiceCid UserService_Distribute with
      credentialBillingCid
      amountUsd = 100.0
      coinCids
      appTransferContext
  verifyAmuletBalances [(holder, 199981.0), (issuer, 65727.3629980278)]
  verifyLockedAmuletBalances [(holder, 19680.36529678)]

  -- The issuer distributes some coins and tops up the deposit of the holder up to the target
  -- amount.
  distributeAndTopUp ccApp operator issuer holder 100.0
  verifyAmuletBalances [(holder, 209661.36529678), (issuer, 45507.3629980278)]
  verifyLockedAmuletBalances [(holder, 30000.0)]

  -- Check distribution when the current deposit balance exceeds the target amount.
  distributeAndTopUp ccApp operator issuer holder 100.0
  verifyAmuletBalances [(holder, 229661.36529678), (issuer, 25295.3629980278)]
  verifyLockedAmuletBalances [(holder, 30000.0)]

  -- The issuer increases the depositTargetAmountUsd to $1000.
  (credentialBillingCid, credentialBilling) <- getCredential issuer
  submitMustFail issuer.user.primaryParty do
    exerciseCmd issuer.userServiceCid UserService_AdjustBillingParams with
      credentialBillingCid
      billingParams = credentialBilling.params with depositTargetAmountUsd = 1000.0

  adjustmentRequest <- submit issuer.user.primaryParty do
    exerciseCmd issuer.userServiceCid UserService_RequestToAdjustBillingParams with
      credentialBillingCid
      billingParams = credentialBilling.params with depositTargetAmountUsd = 1000.0
  submitMustFail issuer.user.primaryParty do
    exerciseCmd issuer.userServiceCid UserService_BillingParamsAdjustmentRequest_Accept
      with
        requestCid = adjustmentRequest.requestCid
        credentialBillingCid
  submit holder.user.primaryParty do
    exerciseCmd holder.userServiceCid UserService_BillingParamsAdjustmentRequest_Accept
      with
        requestCid = adjustmentRequest.requestCid
        credentialBillingCid

  tapUsd ccApp issuer.user 1000.0
  verifyAmuletBalances [(holder, 229661.36529678), (issuer, 225295.3629980278)]

  -- Check distribution when the amount distributed is not enough to reach the target amount.
  distributeAndTopUp ccApp operator issuer holder 100.0
  verifyAmuletBalances [(holder, 229661.36529678), (issuer, 205081.3629980278)]
  verifyLockedAmuletBalances [(holder, 50000.0)]

  -- The issuer decreases the deposit target amount.
  (credentialBillingCid, credentialBilling) <- getCredential issuer
  submitMustFail issuer.user.primaryParty do
    exerciseCmd issuer.userServiceCid UserService_AdjustBillingParams with
      credentialBillingCid
      billingParams = credentialBilling.params with depositTargetAmountUsd = 230.0

  adjustmentRequest <- submit issuer.user.primaryParty do
    exerciseCmd issuer.userServiceCid UserService_RequestToAdjustBillingParams with
      credentialBillingCid
      billingParams = credentialBilling.params with depositTargetAmountUsd = 230.0
  submitMustFail issuer.user.primaryParty do
    exerciseCmd issuer.userServiceCid UserService_BillingParamsAdjustmentRequest_Accept
      with
        requestCid = adjustmentRequest.requestCid
        credentialBillingCid
  submit holder.user.primaryParty do
    exerciseCmd holder.userServiceCid UserService_BillingParamsAdjustmentRequest_Accept
      with
        requestCid = adjustmentRequest.requestCid
        credentialBillingCid

  distributeAndTopUp ccApp operator issuer holder 100.0
  verifyAmuletBalances [(holder, 253647.36529678), (issuer, 184869.3629980278)]
  verifyLockedAmuletBalances [(holder, 46000.0)]

  -- Move the amulet price to enable another reduction of the deposit.
  advanceToIssuanceWithPrice ccApp 2.0

  distributeAndTopUp ccApp operator issuer holder 10.0
  verifyAmuletBalances [(holder, 299531.27429678), (issuer, 206295.9330984878)]
  verifyLockedAmuletBalances [(holder, 115.0)]

  -- Verify the deposit balance on the credential billing contract
  verifyBalanceStateDeposit holder

  pure ()

-- | Test distribution to multiple recipients at once.
testDistributionMultipleRecipients : Script ()
testDistributionMultipleRecipients = do
  let amuletPrice = 0.005

  (operator, ccApp) <- bootstrapApp amuletPrice
  holder <- onboardUser operator ccApp "holder"
  holder2 <- onboardUser operator ccApp "holder2"
  issuer <- onboardUser operator ccApp "issuer"
  let billingParams = defaultParams with depositTargetAmountUsd = 120.0
  credentialCid <- setupPaidCredential operator ccApp issuer holder billingParams (Some 100.0)
  credential2Cid <- setupPaidCredential operator ccApp issuer holder2 billingParams (Some 100.0)

  -- Feature the Credential issuer
  featureApp ccApp issuer.user

  -- Bill the credentials after creation
  billCredential operator ccApp holder
  billCredential operator ccApp holder2

  -- Run a few billing cycles (for rounds 3 to 5)
  forA_ [3 .. 5] \_ -> do
    runOneBillingCycle operator ccApp holder amuletPrice
    billCredential operator ccApp holder2

  verifyAmuletBalances [(holder, 179981.0), (holder2, 179981.0), (issuer, 43118.1482765632)]
  verifyLockedAmuletBalances [(holder, 19817.35159816), (holder2, 19817.35159816)]

  -- The issuer distributes coins to multiple holders (with different weights).
  -- (Beware of contention with the wallet, retries may be required.)
  coinCids <- map fst <$> query @Amulet issuer.user.primaryParty
  (_, _, credentialBillingCid) <- prepareCredentialBilling operator ccApp holder
  (appTransferContext, disclosures, credentialBilling2Cid) <-
    prepareCredentialBilling operator ccApp holder2

  let
    distributionSlice1 = DistributionSlice with
      credentialBillingCid = credentialBillingCid
      percentage = 0.7
    distributionSlice2 = DistributionSlice with
      credentialBillingCid = credentialBilling2Cid
      percentage = 0.3

  submitWithDisclosures issuer.user.primaryParty disclosures do
    exerciseCmd issuer.userServiceCid UserService_DistributeMulti with
      distributionSlices = [distributionSlice1, distributionSlice2]
      amountUsd = 100.0
      coinCids
      appTransferContext
  verifyAmuletBalances [(holder, 193981.0), (holder2, 185981.0), (issuer, 22894.1482765632)]
  verifyLockedAmuletBalances [(holder, 19817.35159816), (holder2, 19817.35159816)]

  -- The issuer distributes coins to and tops up for multiple holders.
  -- (Beware of contention with the wallet, retries may be required.)
  coinCids <- map fst <$> query @Amulet issuer.user.primaryParty
  (_, _, credentialBillingCid) <- prepareCredentialBilling operator ccApp holder
  (appTransferContext, disclosures, credentialBillingHolder2Cid) <-
    prepareCredentialBilling operator ccApp holder2

  submitWithDisclosures issuer.user.primaryParty disclosures do
    exerciseCmd issuer.userServiceCid UserService_DistributeAndAdjustDepositMulti with
      distributionSlices = [distributionSlice1, distributionSlice2]
      amountUsd = 50.0
      coinCids
      appTransferContext
  verifyAmuletBalances [(holder, 196798.35159816), (holder2, 185981.0), (issuer, 12760.1482765632)]
  verifyLockedAmuletBalances [(holder, 24000.0), (holder2, 22817.35159816)]

  -- Verify the deposit balance on the credential billing contract
  verifyBalanceStateDeposit holder
  verifyBalanceStateDeposit holder2

  pure ()

-- | Prepare credential billing automation from the operator.
prepareCredentialBilling : AppUser -> AmuletApp -> AppUser ->
  Script (AppTransferContext, [Disclosure], ContractId CredentialBilling)
prepareCredentialBilling operator ccApp user = do

  (credentialCid, credential) <- getCredential user

  -- build operator transfer context for billing
  -- get latest open round
  (openRoundCid, openRound, openRoundDisclosureBlob) <- last <$> discloseOpenRounds ccApp

  (amuletRules, amuletRulesDisclosureBlob) <- discloseAmuletRules ccApp
  (featuredAppRight, featuredAppRightDisclosureBlob) <- discloseFeaturedAppRight ccApp
    credential.issuer -- issuer would get the rewards, so we check if they are featured
  let
    appTransferContext = AppTransferContext with
      amuletRules
      openMiningRound = openRoundCid
      featuredAppRight

  -- prepare disclosures
  let
    disclosures =
      [openRoundDisclosureBlob, amuletRulesDisclosureBlob] <> featuredAppRightDisclosureBlob

  pure (appTransferContext, disclosures, credentialCid)

-- | Run credential billing automation from the operator.
billCredential : AppUser -> AmuletApp -> AppUser -> Script CredentialBilling_Bill_Result
billCredential operator ccApp user = do
  (appTransferContext, disclosures, credentialCid) <- prepareCredentialBilling operator ccApp user

  submitWithDisclosures operator.user.primaryParty disclosures $ do
    exerciseCmd credentialCid CredentialBilling_Bill with
      appTransferContext

-- | Run credential billing automation from the operator (and validate that it fails).
billCredentialMustFail : AppUser -> AmuletApp -> AppUser -> Script ()
billCredentialMustFail operator ccApp user = do
  (appTransferContext, disclosures, credentialCid) <- prepareCredentialBilling operator ccApp user

  submitWithDisclosuresMustFail operator.user.primaryParty disclosures $ do
    exerciseCmd credentialCid CredentialBilling_Bill with
      appTransferContext

  pure ()

billCredentialStatusFailure : AppUser -> AmuletApp -> AppUser -> Script ()
billCredentialStatusFailure operator ccApp user = do
  (appTransferContext, disclosures, credentialCid) <- prepareCredentialBilling operator ccApp user

  result <- submitWithDisclosures operator.user.primaryParty disclosures $ do
    exerciseCmd credentialCid CredentialBilling_Bill with
      appTransferContext

  Some billCredential <- queryContractId user.user.primaryParty result.newCredentialBillingCid
  case billCredential.billingState.status of
    Failure _ _ -> pure ()
    _ -> assertFail "Expected billing Failure."

  pure ()

-- | Advance mining rounds:
-- - archive oldest open mining round and start issuing rewards for it
-- - advance time by one tick (currently 10 minutes)
-- - create a new round and set `amuletPrice` (previously opened rounds still have the old price).
-- - claim rewards and merge CCs.
prepareBillingCycleRound : AmuletApp -> Decimal -> Script ()
prepareBillingCycleRound ccApp amuletPrice = do
  runNextIssuanceInternal ccApp amuletPrice -- Advance to next round
  runAmuletDepositBots ccApp -- Claim rewards, merge CCs
  printCurrentTime ()

-- | Run credential billing automation from the operator.
runOneBillingCycle : AppUser -> AmuletApp -> AppUser -> Decimal
  -> Script CredentialBilling_Bill_Result
runOneBillingCycle operator ccApp user amuletPrice = do
  prepareBillingCycleRound ccApp amuletPrice
  billCredential operator ccApp user -- Bill the credential

-- | Try running credential billing automation from the operator and validate that it fails.
runOneBillingCycleMustFail : AppUser -> AmuletApp -> AppUser -> Decimal -> Script ()
runOneBillingCycleMustFail operator ccApp user amuletPrice = do
  prepareBillingCycleRound ccApp amuletPrice
  billCredentialStatusFailure operator ccApp user -- Bill the credential (and ensure that it fails)

-- | Distribute CC coins and top up the deposit of a holder.
-- (Beware of contention with the wallet, retries may be required.)
distributeAndTopUp : AmuletApp -> AppUser -> AppUser -> AppUser -> Decimal ->
  Script CredentialBilling_DistributeAndAdjustDeposit_Result
distributeAndTopUp ccApp operator sender receiver amountUsd = do
  coinCids <- map fst <$> query @Amulet sender.user.primaryParty
  (appTransferContext, disclosures, credentialBillingCid) <-
    prepareCredentialBilling operator ccApp sender
  submitWithDisclosures sender.user.primaryParty disclosures do
    exerciseCmd sender.userServiceCid UserService_DistributeAndAdjustDeposit with
      credentialBillingCid
      amountUsd
      coinCids
      appTransferContext

-- | Top up the deposit of a holder.
-- (Beware of contention with the wallet, retries may be required.)
topUp : AmuletApp -> AppUser -> AppUser -> Decimal -> Script CredentialBilling_TopUp_Result
topUp ccApp operator holder amountUsd = do
  coinCids <- map fst <$> query @Amulet holder.user.primaryParty
  (appTransferContext, disclosures, credentialBillingCid) <-
    prepareCredentialBilling operator ccApp holder
  submitWithDisclosures holder.user.primaryParty disclosures do
    exerciseCmd holder.userServiceCid UserService_TopUp with
      credentialBillingCid
      amountUsd
      coinCids
      appTransferContext

printCurrentTime : () -> Script ()
printCurrentTime _ = do
  now <- getTime
  debug $ "Current time: " <> show now

-- | Default parameters used for credentials.
defaultParams : BillingParams
defaultParams = BillingParams
  with
    feePerDayUsd = dailyFee
    billingPeriodMinutes = 10 -- equal to tick duration (i.e. how often a new round is created)
    depositTargetAmountUsd = 100.0
  where
    monthlyFee = 1000.0 -- USD
    dailyFee = RatePerDay with rate = 12.0 * monthlyFee / 365.0 -- USD
