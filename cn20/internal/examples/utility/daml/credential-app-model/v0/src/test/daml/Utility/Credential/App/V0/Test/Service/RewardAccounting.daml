module Utility.Credential.App.V0.Test.Service.RewardAccounting where

import DA.Action (void)
import DA.List (last)
import Daml.Script
import Splice.Types (Round(..))
import Utility.Credential.App.V0.Model.Accounting (FeeRecord, FeeRecord_Archive(..), FeeRecord_CalculateReward(..), RewardRecord, RewardRecord_Archive(..))
import Utility.Credential.App.V0.Test.Service.Operator (bootstrapApp)
import Utility.Credential.App.V0.Test.Service.User (defaultParams, runOneBillingCycle, setupPaidCredential)
import Utility.Credential.App.V0.Test.Util (AppUser, discloseOpenIssuingRound, discloseOpenIssuingRounds, onboardUser)
import Vendored.Splice.Scripts.Util as CCUtil (AmuletApp, featureApp)

-- | Test reward accounting from a credential billing (unfeatured issuer).
testRewardAccountingUnfeatured : Script (AmuletApp, AppUser, AppUser, AppUser, Decimal)
testRewardAccountingUnfeatured = runCredentialBillingRewardAccounting False

-- | Test reward accounting from a credential billing (featured issuer).
testRewardAccountingFeatured : Script (AmuletApp, AppUser, AppUser, AppUser, Decimal)
testRewardAccountingFeatured = runCredentialBillingRewardAccounting True

-- | Test billing of a credential, from a reward accounting point of view.
runCredentialBillingRewardAccounting : Bool
   -> Script (AmuletApp, AppUser, AppUser, AppUser, Decimal)
runCredentialBillingRewardAccounting issuerIsFeatured = do
  let amuletPrice = 0.005

  (operator, ccApp) <- bootstrapApp amuletPrice
  holder <- onboardUser operator ccApp "holder"
  issuer <- onboardUser operator ccApp "issuer"
  credentialCid <- setupPaidCredential operator ccApp issuer holder defaultParams None

  -- Feature the Credential issuer
  if issuerIsFeatured then void $ featureApp ccApp issuer.user else pure ()

  -- Run a first billing cycle to create a billing record
  runOneBillingCycle operator ccApp holder amuletPrice
  [feeRecordCid] <- map fst <$> query @FeeRecord operator.user.primaryParty

  -- Try to calculate the rewards right away. This fails, because the relevant round is not yet open
  -- for issuing, so the required parameters are not yet known.
  (openIssuingRoundCid, openIssuingRound, disclosures) <- last <$> discloseOpenIssuingRounds ccApp
  submitWithDisclosuresMustFail operator.user.primaryParty [disclosures] do
    exerciseCmd feeRecordCid FeeRecord_CalculateReward with
      issuingMiningRound = openIssuingRound

  -- Advance a few rounds
  runOneBillingCycle operator ccApp holder amuletPrice
  runOneBillingCycle operator ccApp holder amuletPrice
  runOneBillingCycle operator ccApp holder amuletPrice

  -- Calculating the rewards now works, because the relevant round is now open for issuing.
  (openIssuingRoundCid, openIssuingRound, disclosures) <- discloseOpenIssuingRound ccApp (Round 3)
  submitWithDisclosures operator.user.primaryParty [disclosures] do
    exerciseCmd feeRecordCid FeeRecord_CalculateReward with
      issuingMiningRound = openIssuingRound

  -- Get the reward record and verify the amount
  [(rewardRecordCid, rewardRecord)] <- query @RewardRecord operator.user.primaryParty
  let expectedAmount = if issuerIsFeatured then 21483.3202009200 else 8.8999212055
  assertMsg "The reward record does not match the expected amount"
    $ rewardRecord.ccRewardsEarned == expectedAmount

  pure (ccApp, operator, issuer, holder, amuletPrice)

-- | Test billing of a credential, from a reward accounting point of view.
-- Add a 2nd holder with a Credential (but without billing, to make reward sharing testing more
-- comparable between methods).
runCredentialBillingRewardAccountingMultipleHolders : Bool
   -> Script (AmuletApp, AppUser, AppUser, (AppUser, AppUser), Decimal)
runCredentialBillingRewardAccountingMultipleHolders issuerIsFeatured = do
  let amuletPrice = 0.005

  (operator, ccApp) <- bootstrapApp amuletPrice
  holder <- onboardUser operator ccApp "holder"
  holder2 <- onboardUser operator ccApp "holder2"
  issuer <- onboardUser operator ccApp "issuer"
  credentialCid <- setupPaidCredential operator ccApp issuer holder defaultParams None
  credential2Cid <- setupPaidCredential operator ccApp issuer holder2 defaultParams None

  -- Feature the Credential issuer
  if issuerIsFeatured then void $ featureApp ccApp issuer.user else pure ()

  -- Run a first billing cycle to create a billing record
  runOneBillingCycle operator ccApp holder amuletPrice
  [feeRecordCid] <- map fst <$> query @FeeRecord operator.user.primaryParty

  -- Try to calculate the rewards right away. This fails, because the relevant round is not yet open
  -- for issuing, so the required parameters are not yet known.
  (openIssuingRoundCid, openIssuingRound, disclosures) <- last <$> discloseOpenIssuingRounds ccApp
  submitWithDisclosuresMustFail operator.user.primaryParty [disclosures] do
    exerciseCmd feeRecordCid FeeRecord_CalculateReward with
      issuingMiningRound = openIssuingRound

  -- Advance a few rounds
  runOneBillingCycle operator ccApp holder amuletPrice
  runOneBillingCycle operator ccApp holder amuletPrice
  runOneBillingCycle operator ccApp holder amuletPrice

  -- Calculating the rewards now works, because the relevant round is now open for issuing.
  (openIssuingRoundCid, openIssuingRound, disclosures) <- discloseOpenIssuingRound ccApp (Round 3)
  submitWithDisclosures operator.user.primaryParty [disclosures] do
    exerciseCmd feeRecordCid FeeRecord_CalculateReward with
      issuingMiningRound = openIssuingRound

  -- Get the reward record and verify the amount
  [(rewardRecordCid, rewardRecord)] <- query @RewardRecord operator.user.primaryParty
  let expectedAmount = if issuerIsFeatured then 21483.3202009200 else 8.8999212055
  assertMsg "The reward record does not match the expected amount"
    $ rewardRecord.ccRewardsEarned == expectedAmount

  pure (ccApp, operator, issuer, (holder, holder2), amuletPrice)

-- | Test archiving of a fee record and a reward record.
runRewardAccountingArchive : Script ()
runRewardAccountingArchive  = do
  let amuletPrice = 0.005

  (operator, ccApp) <- bootstrapApp amuletPrice
  holder <- onboardUser operator ccApp "holder"
  issuer <- onboardUser operator ccApp "issuer"
  credentialCid <- setupPaidCredential operator ccApp issuer holder defaultParams None

  -- Run a first billing cycle to create a fee record
  runOneBillingCycle operator ccApp holder amuletPrice
  [feeRecordCid] <- map fst <$> query @FeeRecord operator.user.primaryParty

  submit operator.user.primaryParty do
    exerciseCmd feeRecordCid FeeRecord_Archive

  feeRecords <- query @FeeRecord operator.user.primaryParty
  assertMsg "Failed to archive fee record" $ null feeRecords

  -- Run another billing cycle to create a new record
  runOneBillingCycle operator ccApp holder amuletPrice
  [feeRecordCid] <- map fst <$> query @FeeRecord operator.user.primaryParty

  -- Advance a few rounds
  runOneBillingCycle operator ccApp holder amuletPrice
  runOneBillingCycle operator ccApp holder amuletPrice
  runOneBillingCycle operator ccApp holder amuletPrice

  -- Calculating the rewards now works, because the relevant round is now open for issuing.
  (openIssuingRoundCid, openIssuingRound, disclosures) <- discloseOpenIssuingRound ccApp (Round 4)
  submitWithDisclosures operator.user.primaryParty [disclosures] do
    exerciseCmd feeRecordCid FeeRecord_CalculateReward with
      issuingMiningRound = openIssuingRound

  -- Get the reward record and archive it
  [(rewardRecordCid, rewardRecord)] <- query @RewardRecord operator.user.primaryParty

  submit operator.user.primaryParty do
    exerciseCmd rewardRecordCid RewardRecord_Archive

  rewardRecords <- query @RewardRecord operator.user.primaryParty
  assertMsg "Failed to archive reward record" $ null rewardRecords

  pure ()
