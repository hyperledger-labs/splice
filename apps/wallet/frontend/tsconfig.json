{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "rootDir": "src",
    "outDir": "build",
    "types": ["node", "vite/client"],
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "baseUrl": ".",
    "paths": {
      "@daml/types": ["../../common/frontend/node_modules/@daml/types"],
      "@daml/types/*": ["../../common/frontend/node_modules/@daml/types/*"]
    }
  },
  "include": ["src"]
}
