{
  "name": "wallet-frontend",
  "version": "0.1.0",
  "private": true,
  "dependencies": {
    "@daml.js/canton-coin": "file:../../common/frontend/daml.js/canton-coin-0.1.0",
    "@daml.js/wallet": "file:../../common/frontend/daml.js/wallet-0.1.0",
    "@daml.js/wallet-payments": "file:../../common/frontend/daml.js/wallet-payments-0.1.0",
    "@daml/ledger": "file:../../../nix/vendored/daml-ledger-0.0.0.tgz",
    "@daml/ledger-api": "file:../../../nix/vendored/daml-ledger-api-0.0.0.tgz",
    "@emotion/react": "^11.10.0",
    "@emotion/styled": "^11.10.0",
    "@mui/icons-material": "^5.10.16",
    "@mui/lab": "^5.0.0-alpha.93",
    "@mui/material": "^5.9.3",
    "bignumber.js": "^9.1.1",
    "common-frontend": "^0.1.0",
    "common-protobuf": "^0.1.0",
    "grpc-web": "^1.4.1",
    "oidc-client-ts": "^2.1.0",
    "react": "18.2.0",
    "react-dom": "18.2.0",
    "react-oidc-context": "^2.2.0",
    "react-router-dom": "^6.4.2",
    "react-scripts": "5.0.1",
    "web-vitals": "^2.1.4"
  },
  "scripts": {
    "start": "react-scripts start",
    "build": "react-scripts build",
    "clean": "rm -rf node_modules",
    "test": "react-scripts test",
    "eject": "react-scripts eject",
    "fix": "npm run format:fix && npm run lint:fix",
    "check": "npm run format:check && npm run lint:check",
    "format:fix": "prettier --write src",
    "format:check": "prettier --check src",
    "lint:fix": "eslint src --ignore-pattern src/com/* --fix",
    "lint:check": "eslint src --ignore-pattern src/com/* --max-warnings=0"
  },
  "eslintConfig": {
    "extends": [
      "react-app",
      "react-app/jest"
    ],
    "rules": {
      "@typescript-eslint/no-explicit-any": "warn",
      "@typescript-eslint/explicit-module-boundary-types": "warn",
      "@typescript-eslint/ban-types": "warn",
      "react/jsx-key": [
        "warn",
        {
          "warnOnDuplicates": true,
          "checkFragmentShorthand": true
        }
      ],
      "react/jsx-boolean-value": "warn",
      "react/function-component-definition": [
        "warn",
        {
          "namedComponents": "arrow-function",
          "unnamedComponents": "arrow-function"
        }
      ]
    }
  },
  "prettier": {
    "printWidth": 100,
    "singleQuote": true,
    "arrowParens": "avoid",
    "importOrder": [
      "^@mui.*",
      "^@daml.*",
      "^[./]"
    ],
    "importOrderGroupNamespaceSpecifiers": true,
    "importOrderSeparation": true
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^5.16.5",
    "@testing-library/react": "^13.4.0",
    "@testing-library/user-event": "^14.4.3",
    "@trivago/prettier-plugin-sort-imports": "^3.3.0",
    "@types/google-protobuf": "^3.15.6",
    "@types/jest": "^29.2.0",
    "@types/node": "^18.11.0",
    "@types/react": "^18.0.21",
    "@types/react-dom": "^18.0.6",
    "prettier": "^2.7.1",
    "typescript": "^4.8.4"
  }
}
