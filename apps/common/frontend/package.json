{
  "name": "common-frontend",
  "version": "0.1.0",
  "main": "lib/index.js",
  "types": "lib/index.d.ts",
  "private": true,
  "dependencies": {
    "@daml.js/directory": "file:daml.js/directory-service-0.1.0",
    "@daml/ledger": "file:../../../nix/vendored/daml-ledger-0.0.0.tgz",
    "@daml/ledger-api": "file:../../../nix/vendored/daml-ledger-api-0.0.0.tgz",
    "@daml/types": "file:../../../nix/vendored/daml-types-0.0.0.tgz",
    "@types/google-protobuf": "^3.15.6",
    "@types/jest": "^27.5.2",
    "@types/node": "^16.11.47",
    "@types/react": "^18.0.15",
    "@types/react-dom": "^18.0.6",
    "common-protobuf": "^0.1.0",
    "google-protobuf": "^3.21.0",
    "grpc-web": "^1.3.1",
    "typescript": "^4.7.4",
    "web-vitals": "^2.1.4"
  },
  "scripts": {
    "build": "tsc",
    "start": "tsc --watch",
    "fix": "npm run format:fix && npm run lint:fix",
    "check": "npm run format:check && npm run lint:check",
    "format:fix": "prettier --write src",
    "format:check": "prettier --check src",
    "lint:fix": "eslint src --ignore-pattern src/com/* --fix",
    "lint:check": "eslint src --ignore-pattern src/com/* --max-warnings=0",
    "preinstall": "./codegen.sh"
  },
  "eslintConfig": {
    "extends": [
      "react-app",
      "react-app/jest"
    ],
    "rules": {
      "@typescript-eslint/no-explicit-any": "warn",
      "@typescript-eslint/explicit-module-boundary-types": "warn",
      "@typescript-eslint/ban-types": "warn",
      "react/jsx-key": [
        "warn",
        {
          "warnOnDuplicates": true,
          "checkFragmentShorthand": true
        }
      ],
      "react/jsx-boolean-value": "warn",
      "react/function-component-definition": [
        "warn",
        {
          "namedComponents": "arrow-function",
          "unnamedComponents": "arrow-function"
        }
      ]
    }
  },
  "prettier": {
    "printWidth": 100,
    "singleQuote": true,
    "arrowParens": "avoid",
    "importOrder": [
      "^@mui.*",
      "^@daml.*",
      "^[./]"
    ],
    "importOrderGroupNamespaceSpecifiers": true,
    "importOrderSeparation": true
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "devDependencies": {
    "@trivago/prettier-plugin-sort-imports": "^3.3.0",
    "eslint": "^8.25.0",
    "eslint-config-react-app": "^7.0.1",
    "prettier": "^2.7.1"
  },
  "peerDependencies": {
    "@mui/material": "^5.9.3",
    "react": "18.2.0",
    "react-dom": "18.2.0"
  }
}
