
nodes.local.start()

val domainUrl = sys.env.get("DOMAIN_URL").getOrElse("https://canton.global")

validator1.domains.connect("canton-network", domainUrl)

val supervalidator = validator1
  .parties
  .list(filterParty="supervalidator")
  .headOption
  .getOrElse(throw new Exception("Supervalidator consortium not found. (Check SVC health?)"))

validator1
  .health
  .ping(supervalidator
          .participants
          .headOption
          .getOrElse(throw new Exception("Supervalidator participant not reachable."))
          .participant
       )

println(
  "The config for the validator party is below. Please append this to your examples/validator-app/validator-app.conf file:\n" + 
  s"party : validator1::${validator1.adminParty.uid.namespace.unwrap}"
)
