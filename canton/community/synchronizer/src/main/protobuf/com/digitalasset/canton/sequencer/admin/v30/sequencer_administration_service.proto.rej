+message GenerateAuthenticationTokenRequest {
+  // Member for which the token is valid
+  string member = 1;
+  // Duration after which the token will expire.
+  // If unset, the maxTokenExpirationInterval configured on the sequencer will be used
+  google.protobuf.Duration expires_in = 2;
+}
+
+message GenerateAuthenticationTokenResponse {
+  // Auth token for the member
+  bytes token = 1;
+  // Timestamp when the token expires
+  google.protobuf.Timestamp expires_at = 2;
