+// Limit the throughput per member for the purpose of protecting the system availability
+message IndividualThroughputCapConfig {
+  double global_tps_cap = 1;
+  double global_kbps_cap = 2;
+  double per_client_tps_cap = 3;
+  double per_client_kbps_cap = 4;
