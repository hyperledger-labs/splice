-- | The contracts representing the long-term state of CC.
module CC.Coin where

import CC.Round
import OpenBusiness.Expiry
import OpenBusiness.Fees


-- Lockable, expiring coins
---------------------------

-- | A lock held by a particular party until its expiry.
data TimeLock = TimeLock with
    holder: Party
    -- TODO: consider adding support for groups of lock holders.
    expiresAt: Time
  deriving (Eq, Ord, Show)

-- | A Canton Coin, which can be locked and whose quantity expires over time.
--
-- The expiry serves to charge an inactivity fee, and thereby ensures that the
-- SVC can reclaim all coins at some point in the future.
template Coin
  with
    svc : Party
    owner : Party
    quantity : ExpiringQuantity
  where
    signatory svc, owner
    ensure validExpiringQuantity quantity

    implements ExpiringContract where
      contractExpiresAt = quantityExpiresAt quantity
      expiryManager = svc



template LockedCoin
  with
    coin : Coin
    lock : TimeLock
  where
    signatory lock.holder, signatory coin

    {- TODO Reenable once https://github.com/digital-asset/daml/issues/13504 is fixed
    implements ExpiringContract where
      contractExpiresAt = quantityExpiresAt coin.quantity
      expiryManager = coin.svc
    -}

    choice Coin_Unlock : ContractId Coin
      controller lock.holder
      do create coin

    let tryExpireLock : Update (ContractId Coin)
        tryExpireLock = do
            t <- getTime
            assertMsg "Lock not expired" (lock.expiresAt <= t)
            create coin

    choice Coin_OwnerExpireLock : ContractId Coin
      controller coin.owner
      do tryExpireLock

    -- NOTE: we intentionally don't combine this choice with Coin_OwnerExpireLock to
    -- provide a more expressive transaction graph.
    choice Coin_SvcExpireLock : ContractId Coin
      controller coin.svc
      do tryExpireLock


-- Contracts to implement reward issuance
-- ======================================


-- | The right to claim coin issuances for a user's burns as their validator.
template ValidatorRight with
    svc : Party
    user : Party
    validator : Party
  where
    signatory user, validator

    key this : ValidatorRight
    maintainer key.user, key.validator

    choice ValidatorRight_ArchiveAsValidator : ()
      controller validator
      do pure ()

    choice ValidatorRight_ArchiveAsUser : ()
      controller user
      do pure ()

    -- TODO: cancellation, withdrawal



-- | A receipt of a coin burn that can be used to claim part of a coin issuance.
template AppReward
  with
    svc : Party
    -- | Application owner.
    owner : Party
    quantity : Decimal
    round : Round
  where
    signatory svc, owner
    ensure quantity > 0.0

    choice AppReward_SvcExpire : ()
      with
        miningRoundCid : ContractId ClosedMiningRound
      controller svc
      do miningRound <- fetch miningRoundCid
         assertMsg "Mining round > expiry round" (round <= miningRound.round)

    choice AppReward_OwnerExpire : ()
      with
        miningRoundCid : ContractId ClosedMiningRound
      controller owner
      do miningRound <- fetch miningRoundCid
         assertMsg "Mining round > expiry round" (round <= miningRound.round)


    -- | This choice is used by the SVC to merge all burned coins per validator.
    -- The expectation is that there is at most one burned coin per validator before
    -- the issuance event is triggered.
    choice AppReward_Merge : ContractId AppReward
      with
        cids : [ContractId AppReward]
      controller svc
      do
        assertMsg "Merge with at least one burned coin" (not (null cids))
        quantities <- forA cids $ \cid -> do
          burnedCoin <- fetch cid
          archive cid
          assertMsg ("Burned coins must match") (this == burnedCoin with quantity)
          return burnedCoin.quantity
        create this with quantity = this.quantity + sum quantities



-- | A receipt of a coin burn that can be used to claim part of a coin issuance.
template ValidatorReward
  with
    svc : Party
    user : Party
    quantity : Decimal
    round : Round
  where
    signatory svc, user
    ensure quantity > 0.0

    choice ValidatorReward_SvcExpire : ()
      with
        miningRoundCid : ContractId ClosedMiningRound
      controller svc
      do miningRound <- fetch miningRoundCid
         assertMsg "Mining round > expiry round" (round <= miningRound.round)

    choice ValidatorReward_UserExpire : ()
      with
        miningRoundCid : ContractId ClosedMiningRound
      controller user
      -- TODO: consider whether we should use time-based expiry so that the
      -- user can expire it unilaterally after let's say 24h
      do miningRound <- fetch miningRoundCid
         assertMsg "Mining round > expiry round" (round <= miningRound.round)


    -- | This choice is used by the SVC to merge all burned coins per validator.
    -- The expectation is that there is at most one burned coin per validator before
    -- the issuance event is triggered.
    choice ValidatorReward_Merge : ContractId ValidatorReward
      with
        cids : [ContractId ValidatorReward]
      controller svc
      do
        assertMsg "Merge with at least one burned coin" (not (null cids))
        quantities <- forA cids $ \cid -> do
          burnedCoin <- fetch cid
          archive cid
          assertMsg ("Burned coins must match") (this == burnedCoin with quantity)
          return burnedCoin.quantity
        create this with quantity = this.quantity + sum quantities

    -- | This choice is used by validators to archive the burn receipt upon claiming its corresponding issuance.
    choice ValidatorReward_ArchiveAsValidator : ()
      with
        validator : Party
        rightCid : ContractId ValidatorRight
      controller svc, validator
      do
        right <- fetch rightCid
        assertMsg "Right must match" (right == ValidatorRight with svc; validator, user)


-- | BurnOracle records the result of a process to determine the quantity of coin burned
-- in a specific issuance round.
template BurnOracle
  with
    svc : Party
    round : Round
    quantity : Decimal
  where
    signatory svc

    key (svc, round) : (Party, Round)
    maintainer key._1

template IssuanceState
  with
    svc : Party
    -- | The most recent open round
    currentRound : Round
  where
    signatory svc

    key svc : Party
    maintainer key
