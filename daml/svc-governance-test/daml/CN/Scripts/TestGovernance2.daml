-- Vote Requests
----------------

-- | Tests vote request machinery on featured app right granting and revoking.
testVoteRequest : Script ()
testVoteRequest = do
  (app, svc, (sv1, sv2, sv3, sv4)) <- initMainNetCollective

  [(svcRulesCid, _)] <- query @SvcRules svc

  -- allocate an app provider, and check that there is no app right
  provider <- allocateParty "provider"
  [] <- query @FeaturedAppRight provider

  -- sv1 initiates the granting of the featured app right for the provider
  requestCid <- submitMulti [sv1] [svc] $ exerciseCmd svcRulesCid SvcRules_RequestVote2 with
    requester = sv1
    action = ARC_SvcRules with
      svcAction = SRARC_GrantFeaturedAppRight SvcRules_GrantFeaturedAppRight with
        provider
    reason = Reason with url = ""; body = "they are great!"
    voteRequestTimeout = Some (days 7) -- give everybody 7 days to vote

  -- sv2 rejects initially
  requestCid <- submitMulti [sv2] [svc] $ exerciseCmd svcRulesCid SvcRules_CastVote2 with
    requestCid
    vote = Vote2 with
      sv = sv2
      accept = False
      reason = Reason with url = ""; body = "the justificaiton is not good enough"

  -- there are two votes, which is not enough to consider the vote definitive and grant the app right
  executeAllDefinitiveVotes app
  [] <- query @FeaturedAppRight provider

  -- a day passes and sv2 updates their vote
  passTime (days 1)
  requestCid <- submitMulti [sv2] [svc] $ exerciseCmd svcRulesCid SvcRules_CastVote2 with
    requestCid
    vote = Vote2 with
      sv = sv2
      accept = True
      reason = Reason with url = ""; body = "OK, after rereading the materials, I agree."

  -- there are still only two votes, which is not enough to consider the vote definitive and grant the app right
  executeAllDefinitiveVotes2 app
  [] <- query @FeaturedAppRight provider

  -- sv3 accepts
  requestCid <- submitMulti [sv3] [svc] $ exerciseCmd svcRulesCid SvcRules_CastVote2 with
    requestCid
    vote = Vote2 with
      sv = sv3
      accept = True
      reason = Reason with url = ""; body = "I agree!"

  -- there are now three votes in favor of the change, which are enough to grant the right,
  -- but the vote request can only be executed early if all members have voted
  executeAllDefinitiveVotes2 app
  [] <- query @FeaturedAppRight provider

  -- sv4 rejects
  _requestCid <- submitMulti [sv4] [svc] $ exerciseCmd svcRulesCid SvcRules_CastVote2 with
    requestCid
    vote = Vote2 with
      sv = sv4
      accept = False
      reason = Reason with url = ""; body = "I agree!"

  -- now all members have voted and the request can be closed
  executeAllDefinitiveVotes2 app
  [(rightCid, right)] <- query @FeaturedAppRight provider
  right === FeaturedAppRight with svc; provider

  -- the request has been archived
  [] <- query @VoteRequest svc

  -- we can remove the granted right using a vote request, provided enough parties answer in time
  -- This uses early closure of the vote request, which is only possible if all members have voted
  initateAndAcceptVote2 app [sv1, sv2, sv3, sv4] $
    ARC_SvcRules with
      svcAction = SRARC_RevokeFeaturedAppRight SvcRules_RevokeFeaturedAppRight with
        rightCid

  -- the right is now revoked
  [] <- query @FeaturedAppRight provider
  pure ()

testVoteRequestRejection : Script ()
testVoteRequestRejection = do
  (_app, svc, (sv1, sv2, _sv3, sv4)) <- initMainNetCollective

  [(svcRulesCid, _)] <- query @SvcRules svc

  -- allocate an app provider, and check that there is no app right
  provider <- allocateParty "provider"
  [] <- query @FeaturedAppRight provider

  -- sv1 initiates the granting of the featured app right for the provider
  requestCid <- submitMulti [sv1] [svc] $ exerciseCmd svcRulesCid SvcRules_RequestVote2 with
    requester = sv1
    action = ARC_SvcRules with
      svcAction = SRARC_GrantFeaturedAppRight SvcRules_GrantFeaturedAppRight with
        provider
    reason = Reason with url = ""; body = "they are great!"
    voteRequestTimeout = Some (days 7) -- give everybody 7 days to vote

  -- a super-majority rejects the request
  let rejectRequest sv requestCid =  do
        submitMulti [sv] [svc] $ exerciseCmd svcRulesCid SvcRules_CastVote2 with
          requestCid
          vote = Vote2 with
            sv = sv
            accept = False
            reason = Reason with url = ""; body = "nope!"

  requestCid <- rejectRequest sv2 requestCid
  requestCid <- rejectRequest sv4 requestCid
  requestCid <- rejectRequest sv1 requestCid -- sv1 changes their opinion

  -- close aftet the 7 days have passed
  passTime (days 7)
  now <- getTime
  result <- submitMulti [sv1] [svc] $ exerciseCmd svcRulesCid SvcRules_CloseVoteRequest2 with
    requestCid
    coinRulesCid = None

  result.completedAt === now
  result.offboardedVoters === []
  result.abstainingMembers === ["sv3"]
  result.outcome === VRO_Rejected

  pure ()


testRacingMembershipRemoval : Script ()
testRacingMembershipRemoval = do
  (_, svc, (sv1, sv2, sv3, sv4)) <- initMainNetCollective

  [(svcRulesCid, _)] <- query @SvcRules svc

  -- sv1 is not happy with sv2, and issues two removal requests at the same time!
  req1 <- submitMulti [sv1] [svc] $ exerciseCmd svcRulesCid SvcRules_RequestVote2 with
    requester = sv1
    action = ARC_SvcRules with
      svcAction = SRARC_RemoveMember SvcRules_RemoveMember with
        member = sv2
    reason = Reason with url = ""; body = "they are not good for us!"
    voteRequestTimeout = Some (days 7) -- give everybody 7 days to vote

  req2 <- submitMulti [sv1] [svc] $ exerciseCmd svcRulesCid SvcRules_RequestVote2 with
    requester = sv1
    action = ARC_SvcRules with
      svcAction = SRARC_RemoveMember SvcRules_RemoveMember with
        member = sv2
    reason = Reason with url = ""; body = "they are not good for us!"
    voteRequestTimeout = Some (days 7) -- give everybody 7 days to vote

  -- sv2 counters and wants to remove sv1
  req3 <- submitMulti [sv2] [svc] $ exerciseCmd svcRulesCid SvcRules_RequestVote2 with
    requester = sv2
    action = ARC_SvcRules with
      svcAction = SRARC_RemoveMember SvcRules_RemoveMember with
        member = sv1
    reason = Reason with url = ""; body = "they are not good for us!"
    voteRequestTimeout = Some (days 7) -- give everybody 7 days to vote

  -- sv3 and sv4 are not happy with either of them, and accept both removal requests
  [req1, req2, req3] <- forA [req1, req2, req3] $ \requestCid -> do
    requestCid <- submitMulti [sv3] [svc] $ exerciseCmd svcRulesCid SvcRules_CastVote2 with
      requestCid
      vote = Vote2 with
        sv = sv3
        accept = True
        reason = Reason with url = ""; body = "OK, let them go"
    requestCid <- submitMulti [sv4] [svc] $ exerciseCmd svcRulesCid SvcRules_CastVote2 with
      requestCid
      vote = Vote2 with
        sv = sv4
        accept = True
        reason = Reason with url = ""; body = "OK, let them go"
    pure requestCid

  -- sv1 attempts to immediatly accept the request to remove sv2, which fails as sv2 didn't vote and the voting period is not over
  submitMultiMustFail [sv1] [svc] $ exerciseCmd svcRulesCid SvcRules_CloseVoteRequest2 with
    requestCid = req1
    coinRulesCid = None

  -- time passes, and the whole world is excited as to who wins the race
  passTime (days 7)

  -- well it is SV1, which held on to its leadership right
  now <- getTime
  result <- submitMulti [sv1] [svc] $ exerciseCmd svcRulesCid SvcRules_CloseVoteRequest2 with
    requestCid = req1
    coinRulesCid = None

  result.completedAt === now
  result.offboardedVoters === []
  result.abstainingMembers === ["sv2"]
  result.outcome === VRO_Accepted with effectiveAt = now

  -- and it eagerly accepts its other vote request as well
  [(svcRulesCid, _)] <- query @SvcRules svc
  result <- submitMulti [sv1] [svc] $ exerciseCmd svcRulesCid SvcRules_CloseVoteRequest2 with
    requestCid = req2
    coinRulesCid = None

  result.completedAt === now
  result.offboardedVoters === []
  result.abstainingMembers === []
  result.outcome === VRO_AcceptedButActionFailed with description = "Not a member"

  -- and forgets to turn off automation, which now submits the closing of the vote request to remove SV1
  [(svcRulesCid, _)] <- query @SvcRules svc
  result <- submitMulti [sv1] [svc] $ exerciseCmd svcRulesCid SvcRules_CloseVoteRequest2 with
    requestCid = req3
    coinRulesCid = None

  result.completedAt === now
  result.offboardedVoters === ["sv2"]
  result.abstainingMembers === ["sv1"]
  result.outcome === VRO_Accepted with effectiveAt = now

  -- There are only two members left, and sv3 is the new leader
  [(_, svcRules)] <- query @SvcRules svc
  Map.keys svcRules.members === [sv3, sv4]
  svcRules.leader === sv3

  -- The story continues: sv3 tries to remove sv4
  [(svcRulesCid, _)] <- query @SvcRules svc
  req4 <- submitMulti [sv3] [svc] $ exerciseCmd svcRulesCid SvcRules_RequestVote2 with
    requester = sv3
    action = ARC_SvcRules with
      svcAction = SRARC_RemoveMember SvcRules_RemoveMember with
        member = sv4
    reason = Reason with url = ""; body = "they are not good for us!"
    voteRequestTimeout = Some (seconds 1) -- attempt to not give sv4 enough time to vote

  passTime (seconds 1)
  result <- submitMulti [sv3] [svc] $ exerciseCmd svcRulesCid SvcRules_CloseVoteRequest2 with
    requestCid = req4
    coinRulesCid = None

  -- not so fast sv3, sv4 is still here, as at least numMembers / 2 + 1 members need to vote
  result.outcome === VRO_Expired

  pure ()


-- | Test SvcRules configuration changes.
testSvcRulesConfigChange : Script ()
testSvcRulesConfigChange = do
  (app, svc, (sv1, sv2, sv3, sv4)) <- initMainNetCollective

  [(_, svcRules)] <- query @SvcRules svc

  -- run the voting process to change the config
  let newConfig = svcRules.config with maxTextLength = svcRules.config.maxTextLength + 1024 * 1024
  initateAndAcceptVote2 app [sv1, sv2, sv3, sv4] $
    ARC_SvcRules with
      svcAction = SRARC_SetConfig SvcRules_SetConfig with
        newConfig

  -- check that the config change happened
  [(_, svcRules)] <- query @SvcRules svc
  svcRules.config === newConfig


-- | Test membership removal and GC of CoinPriceVotes
testRemoveMemberAndCoinPriceVotes : Script ()
testRemoveMemberAndCoinPriceVotes = do
  (app, svc, (sv1, sv2, sv3, sv4)) <- initMainNetCollective

  -- check that the leader is currently sv1
  [(_, svcRules)] <- query @SvcRules svc
  svcRules.leader === sv1

  -- run the voting process to change the config and remove the current leader 'sv1'
  initateAndAcceptVote2 app [sv2, sv3, sv4] $
    ARC_SvcRules with
      svcAction = SRARC_RemoveMember SvcRules_RemoveMember with
        member = sv1

  -- the voting process is only definitive after the timeout, so right now sv1 is still present
  [(_, svcRules)] <- query @SvcRules svc
  Map.keys (svcRules.members) === [sv1, sv2, sv3, sv4]

  -- pass the default voting timeout
  passTime (svcRules.config.voteRequestTimeout)
  executeAllDefinitiveVotes2 app

  -- check that the member was removed and the leader changed to sv2
  [(svcRulesCid, svcRules)] <- query @SvcRules svc
  Map.keys (svcRules.members) === [sv2, sv3, sv4]
  Map.keys (svcRules.offboardedMembers) === [sv1]
  svcRules.leader === sv2

  -- duplicate the CoinPriceVote for sv2 to test duplicate removal
  coinPriceVotes <- query @CoinPriceVote svc
  let [(sv2VoteCid1, sv2Vote)] = filter (\(_, vote) -> vote.sv == sv2) coinPriceVotes
  sv2VoteCid2 <- submit svc $ createCmd sv2Vote

  -- there should now be five votes
  coinPriceVotes <- query @CoinPriceVote svc
  length coinPriceVotes === 5

  -- garbage collect the CoinPriceVote of sv1
  let [(sv1VoteCid, _)] = filter (\(_, vote) -> vote.sv == sv1) coinPriceVotes
  submitMulti [sv2] [svc] $ exerciseCmd svcRulesCid SvcRules_GarbageCollectCoinPriceVotes with
    nonMemberVoteCids = [sv1VoteCid]
    duplicateVoteCids = [[sv2VoteCid1, sv2VoteCid2]]

  -- there should now be only three votes
  coinPriceVotes <- query @CoinPriceVote svc
  length coinPriceVotes === 3

  -- one cannot archive a vote by listing it as a duplicate of its own
  let [(sv3VoteCid, _)] = filter (\(_, vote) -> vote.sv == sv3) coinPriceVotes
  submitMultiMustFail [sv2] [svc] $ exerciseCmd svcRulesCid SvcRules_GarbageCollectCoinPriceVotes with
    nonMemberVoteCids = []
    duplicateVoteCids = [[sv3VoteCid, sv3VoteCid]]

-- | vote request contract is archived if it has expired
testVoteRequestExpire : Script ()
testVoteRequestExpire = do
  (_, svc, (sv1, _, _, _)) <- initMainNetCollective
  provider <- allocateParty "provider"

  [(svcRulesCid, _)] <- query @SvcRules svc
  requestCid <- submitMulti [sv1] [svc] $ exerciseCmd svcRulesCid SvcRules_RequestVote2 with
    requester = sv1
    action = ARC_SvcRules with
      svcAction = SRARC_GrantFeaturedAppRight SvcRules_GrantFeaturedAppRight with
        provider
    reason = Reason with url = ""; body = "they are great!"
    voteRequestTimeout = None

  -- attempt to close the vote request before its voting period
  submitMultiMustFail [sv1] [svc] $ exerciseCmd svcRulesCid SvcRules_CloseVoteRequest2 with
    requestCid = requestCid
    coinRulesCid = None

  passTime(days 7)
  now <- getTime

  -- close the vote request once the voting period is over
  result <- submitMulti [sv1] [svc] $ exerciseCmd svcRulesCid SvcRules_CloseVoteRequest2 with
    requestCid = requestCid
    coinRulesCid = None

  -- only sv1 voted to accept as they created the request
  result.completedAt === now
  result.offboardedVoters === []
  result.abstainingMembers === ["sv2", "sv3", "sv4"]
  result.outcome === VRO_Expired

  return ()


-- Coin Prices
--------------


unitTestMedian : Script ()
unitTestMedian = do
  median [1.0] === 1.0
  median [2.0, 1.0] === 1.5
  median [3.0, 1.0, 2.0] === 2.0
  median [1.0, 2.0, 3.0, 4.0] === 2.5
  median [1.0, 200.0, 3.0, 4.0, 1000.0] === 4.0


testCoinPriceVoting : Script ()
testCoinPriceVoting = do

  (app, svc, (sv1, sv2, sv3, sv4)) <- initMainNetCollective

  -- run a normal issuance so time advances and the coin price is set to 1.2 for everybody
  runNextIssuanceD app 1.2

  -- have all SV's adjust their prices
  [(svcRulesCid, _)] <- query @SvcRules svc
  forA_ (zip [1, 2, 3, 4] [sv1, sv2, sv3, sv4]) $ \(coinPriceInt, sv) -> do
    [(voteCid, _)] <- queryFilter @CoinPriceVote svc (\vote -> vote.sv == sv)
    submitMulti [sv] [svc] $ exerciseCmd svcRulesCid SvcRules_UpdateCoinPriceVote with
      sv
      coinPrice = intToDecimal coinPriceInt
      voteCid

  [(voteCid, _)] <- queryFilter @CoinPriceVote svc (\vote -> vote.sv == sv1)

  submitMulti [sv1] [svc] $ exerciseCmd svcRulesCid SvcRules_UpdateCoinPriceVote with
    sv = sv1
    coinPrice = 5.0
    voteCid

  [(coinRulesCid, coinRules)] <- query @CoinRules svc
  now <- getTime
  let coinConfig = CC.Schedule.getValueAsOf now coinRules.configSchedule
  passTime (coinConfig.tickDuration)

  -- pass enough time to advance the open mining round and lock in the price
  [(roundToArchiveCid, _), (middleRoundCid, _), (latestRoundCid, _)] <- sortOn (._2.round) <$> query @OpenMiningRound svc
  coinPriceVotes <- query @CoinPriceVote svc
  submitMulti [sv1] [svc] $ exerciseCmd svcRulesCid SvcRules_AdvanceOpenMiningRounds with
    coinRulesCid
    roundToArchiveCid
    middleRoundCid
    latestRoundCid
    coinPriceVoteCids = map fst coinPriceVotes

  -- check that the most recent round has the median a coin price of the votes
  (_, latestRound) <- (last . sortOn (._2.round)) <$> query @OpenMiningRound svc
  latestRound.coinPrice === 3.5

  pure ()

testChallengeMember : Script ()
testChallengeMember = do
  (_, svc, (sv1, sv2, _, _)) <- initMainNetCollective

  [(svcRulesCid, _)] <- query @SvcRules svc

  -- challenges enabled only on DevNet
  submitMultiMustFail [sv2] [svc] $ exerciseCmd svcRulesCid SvcRules_ChallengeMember with
    challenged = sv1
    firstChallenger = sv2


  (_, svc, (sv1, sv2, sv3, sv4)) <- initDevNetCollective
  -- check that the leader is currently sv1
  [(svcRulesCid, svcRules)] <- query @SvcRules svc
  svcRules.leader === sv1

  -- sv2 challenges sv1
  challengeCid <- submitMulti [sv2] [svc] $ exerciseCmd svcRulesCid SvcRules_ChallengeMember with
    challenged = sv1
    firstChallenger = sv2

  -- sv1 answers it
  submitMulti [sv1] [svc] $ exerciseCmd challengeCid SvChallenge_Answer

  -- challenge was archived
  None <- queryContractId @FirstSvChallenge svc challengeCid

  -- sv2 challenges sv1 again
  challengeCid <- submitMulti [sv2] [svc] $ exerciseCmd svcRulesCid SvcRules_ChallengeMember with
    challenged = sv1
    firstChallenger = sv2

  -- sv3 seconds too early
  submitMultiMustFail [sv3] [svc] $ exerciseCmd svcRulesCid SvcRules_SecondChallengeMember with
    firstChallengeCid = challengeCid
    secondChallenger = sv3

  -- pass beyond the deadline and second
  passTime $ minutes 31

  -- challenger cannot second
  submitMultiMustFail [sv2] [svc] $ exerciseCmd svcRulesCid SvcRules_SecondChallengeMember with
    firstChallengeCid = challengeCid
    secondChallenger = sv3

  -- sv3 seconds
  secondChallengeCid <- submitMulti [sv3] [svc] $ exerciseCmd svcRulesCid SvcRules_SecondChallengeMember with
    firstChallengeCid = challengeCid
    secondChallenger = sv3

  -- first challenge was archived
  None <- queryContractId @FirstSvChallenge svc challengeCid

  -- sv1 answers it
  submitMulti [sv1] [svc] $ exerciseCmd secondChallengeCid SecondSvChallenge_Answer

  -- second challenge was archived
  None <- queryContractId @SecondSvChallenge svc secondChallengeCid

  -- sv2 challenges sv1 again
  challengeCid <- submitMulti [sv2] [svc] $ exerciseCmd svcRulesCid SvcRules_ChallengeMember with
    challenged = sv1
    firstChallenger = sv2

  passTime(minutes 31)
  -- sv3 seconds
  secondChallengeCid <- submitMulti [sv3] [svc] $ exerciseCmd svcRulesCid SvcRules_SecondChallengeMember with
    firstChallengeCid = challengeCid
    secondChallenger = sv3

  -- Execute too early
  submitMultiMustFail [sv4] [svc] $ exerciseCmd svcRulesCid SvcRules_RemoveChallengedMember with
    secondChallengeCid
    executer = sv4
  -- pass beyond the deadline and execute
  passTime(minutes 31)
  submitMulti [sv4] [svc] $ exerciseCmd svcRulesCid SvcRules_RemoveChallengedMember with
    secondChallengeCid
    executer = sv4

  -- check that the member was removed and the leader changed to sv2
  [(_, svcRules)] <- query @SvcRules svc
  Map.keys (svcRules.members) === [sv2, sv3, sv4]
  svcRules.leader === sv2
