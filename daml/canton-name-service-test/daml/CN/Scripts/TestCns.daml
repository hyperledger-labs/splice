module CN.Scripts.TestCns where

import DA.Assert
import DA.Time
import Daml.Script

import CC.Amulet
import CC.AmuletRules
import CC.Scripts.Util
import CN.Cns
import CN.Scripts.CnsRulesParameters
import CN.Wallet.Subscriptions


testWithSubscription : Script ()
testWithSubscription = script do
  DefaultAppWithUsers{..} <- setupDefaultAppWithUsers

  runNextIssuance app
  runAmuletDepositBots app

  cnsRulesCid <- submitMulti [app.dso] [] $ createCmd CnsRules with
    dso = app.dso
    config = defaultCnsRulesConfig

  -- user requests entry
  requestSummary <- submitMulti [alice.primaryParty] [app.dso] $ exerciseCmd cnsRulesCid CnsRules_RequestEntry with
    name = "cns.darth.vader"
    url = "https://darth-vader-cns.com"
    description = "Darth Vader's CNS Description"
    user = alice.primaryParty

  let (entryContext, subscriptionRequest) = (requestSummary.entryCid, requestSummary.requestCid)

  -- cc wallet selects a large enough amulet
  amulet <- tap app alice 1.5
  -- cc wallet accepts subscription and first payment and locks amulet to dso

  paymentContext <- getPaymentTransferContext app alice
  (initialPaymentCid, _) <- submitMulti [alice.primaryParty, app.dso] [] $ exerciseCmd subscriptionRequest SubscriptionRequest_AcceptAndMakePayment with
    inputs = [InputAmulet amulet]
    context = paymentContext
    walletProvider = app.dso
  pure ()

  (_, round) <- getLatestActiveOpenRound app
  let transferConfigCC = transferConfigCCFromOpenRound round
  [(acceptRewardCid, reward)] <- query @CC.Amulet.AppRewardCoupon app.dso
  reward.amount ===
    transferConfigCC.createFee.fee +
    transferConfigCC.lockHolderFee.fee
  reward.featured === False

  -- dso transactionally unlocks & transfer amulets and creates cns entry and a subscription in return.
  appContext <- getAppTransferContext app app.dsoUser
  collectPaymentSummary <- submit app.dso $ exerciseCmd entryContext CnsEntryContext_CollectInitialEntryPayment with
    paymentCid = initialPaymentCid
    transferContext = appContext
    cnsRulesCid

  -- the amulet received by sv is brunt
  dsoAmulets <- queryFilter @Amulet app.dso (\amulet -> amulet.owner == app.dso)
  dsoAmulets === []

  [(_, reward)] <- filter (\(cid, _) -> cid /= acceptRewardCid) <$> query @CC.Amulet.AppRewardCoupon app.dso
  reward.amount ===
    transferConfigCC.createFee.fee +
    transferConfigCC.transferFee.initialRate * defaultCnsRulesConfig.entryFee
  reward.featured === False

  Some entry <- queryContractId alice.primaryParty collectPaymentSummary.entryCid
  Some subscriptionState <- queryContractId alice.primaryParty collectPaymentSummary.subscriptionStateCid

  entry.name === "cns.darth.vader"
  entry.user === alice.primaryParty
  subscriptionState.nextPaymentDueAt === entry.expiresAt
  subscriptionState.payData.paymentInterval === defaultCnsRulesConfig.entryLifetime

  -- cc wallet automatically selects a large enough amulet and initiates a subscription payment during the scheduled renewal period
  passTime (days 60)
  runNextIssuance app
  passTimeToRoundOpen app
  paymentContext <- getPaymentTransferContext app alice
  appContext <- getAppTransferContext app app.dsoUser

  amulet <- tap app alice 1.5
  (paymentCid, _) <- submitMulti [alice.primaryParty, app.dso] [] $ exerciseCmd collectPaymentSummary.subscriptionStateCid SubscriptionIdleState_MakePayment with
    inputs = [InputAmulet amulet]
    context = paymentContext
    walletProvider = app.dso

  -- dso transactionally unlocks & transfer amulets and renews directory entry in return
  renewalSummary <- submit app.dso $ exerciseCmd entryContext CnsEntryContext_CollectEntryRenewalPayment with
    paymentCid
    entryCid = collectPaymentSummary.entryCid
    transferContext = appContext
    cnsRulesCid

  -- the amulet received by sv is brunt
  dsoAmulets <- queryFilter @Amulet app.dso (\amulet -> amulet.owner == app.dso)
  dsoAmulets === []

  submitMustFail app.dso $ exerciseCmd renewalSummary.entryCid (CnsEntry_Expire app.dso)

  -- user can't pay earlier than `renewalDuration` from the next due date
  amulet <- tap app alice 1.5
  submitMultiMustFail [alice.primaryParty, app.dso] [] $ exerciseCmd renewalSummary.subscriptionStateCid SubscriptionIdleState_MakePayment with
    inputs = [InputAmulet amulet]
    context = paymentContext
    walletProvider = app.dso

  passTime (days 90)
  runNextIssuance app
  passTimeToRoundOpen app
  paymentContext <- getPaymentTransferContext app alice
  appContext <- getAppTransferContext app app.dsoUser

  -- cc wallet and dso can repeat the "payment and collect" cycle indefinitely
  (paymentCid, _) <- submitMulti [alice.primaryParty, app.dso] [] $ exerciseCmd renewalSummary.subscriptionStateCid SubscriptionIdleState_MakePayment with
    inputs = [InputAmulet amulet]
    context = paymentContext
    walletProvider = app.dso
  renewalSummary <- submit app.dso $ exerciseCmd entryContext CnsEntryContext_CollectEntryRenewalPayment with
    paymentCid
    entryCid = renewalSummary.entryCid
    transferContext = appContext
    cnsRulesCid

  -- the amulet received by sv is brunt
  dsoAmulets <- queryFilter @Amulet app.dso (\amulet -> amulet.owner == app.dso)
  dsoAmulets === []

  submitMustFail app.dso $ exerciseCmd renewalSummary.entryCid (CnsEntry_Expire app.dso)

  -- dso can eventually expire an unfunded entry
  passTime (days 121)
  runNextIssuance app
  passTimeToRoundOpen app
  submit app.dso $ exerciseCmd renewalSummary.entryCid (CnsEntry_Expire app.dso)

  -- dso can then also terminate the subscription
  submit app.dso $ exerciseCmd renewalSummary.subscriptionStateCid (SubscriptionIdleState_ExpireSubscription app.dso)

  pure ()

terminatedSubscriptionCanBeCleanedUp : Script ()
terminatedSubscriptionCanBeCleanedUp = script do
  DefaultAppWithUsers{..} <- setupDefaultAppWithUsers

  runNextIssuance app
  runAmuletDepositBots app

  cnsRulesCid <- submitMulti [app.dso] [] $ createCmd CnsRules with
    dso = app.dso
    config = defaultCnsRulesConfig

  requestSummary <- submitMulti [alice.primaryParty] [app.dso] $ exerciseCmd cnsRulesCid CnsRules_RequestEntry with
    name = "cns.darth.vader"
    url = "https://darth-vader-cns.com"
    description = "Darth Vader's CNS Description"
    user = alice.primaryParty

  terminated <- submitMulti [alice.primaryParty, app.dso] [] $ exerciseCmd requestSummary.requestCid SubscriptionRequest_Reject
  submit app.dso $ exerciseCmd requestSummary.entryCid (CnsEntryContext_Terminate app.dso terminated)

  entryContexts <- query @CnsEntryContext app.dso
  entryContexts === []

  terminatedSubscriptions <- query @TerminatedSubscription app.dso
  terminatedSubscriptions === []
  pure ()
