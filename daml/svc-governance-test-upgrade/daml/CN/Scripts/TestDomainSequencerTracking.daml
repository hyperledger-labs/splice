module CN.Scripts.TestDomainSequencerTracking where

import DA.Assert
import DA.Foldable (forA_)
import qualified DA.Map as Map
import Daml.Script

import CN.CometBft
import CN.SvcRules
import CN.SVC.GlobalDomain

import CN.Scripts.SvcTestUtils

testDomainMigration : Script ()
testDomainMigration = do
  (_, svc, (sv1, sv2, sv3, sv4)) <- initMainNetCollective
  let svs = [sv1, sv2, sv3, sv4]
      domainId = "domain-id"

  -- SV's onboard their nodes
  now <- getTime
  forA_ svs $ \sv -> do
    [(svcRulesCid, _)] <- query @SvcRules svc
    submitMulti [sv] [svc] $ exerciseCmd svcRulesCid SvcRules_SetDomainNodeConfig with
      sv
      domainId = domainId
      newNodeConfig = DomainNodeConfig with
        cometBft = CometBftConfig with
          nodes = Map.fromList [("nodeId-1-" <> partyToText sv, CometBftNodeConfig ("pubKey-" <> partyToText sv) 1)]
          sequencingKeys = []
          governanceKeys = []
        sequencer = Some SequencerConfig with
          sequencerId = "sequencer-id-" <> partyToText sv
          url = "sequencer-" <> partyToText sv <> ".address:1234"
          availableAfter = Some now
        mediator = Some MediatorConfig with
          mediatorId = "mediator-id-" <> partyToText sv

  -- sequencer info are published to svcRules and coinRules
  [(_, svcRules)] <- query @SvcRules svc
  forA_ svs $ \sv -> do
    let Some(memberInfo) = Map.lookup sv svcRules.members
        Some(domainConfig) = Map.lookup domainId memberInfo.domainNodes
    domainConfig.sequencer === Some SequencerConfig with
      sequencerId = "sequencer-id-" <> partyToText sv
      url = "sequencer-" <> partyToText sv <> ".address:1234"
      availableAfter = Some now
