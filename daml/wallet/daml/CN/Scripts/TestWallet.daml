createPaymentRequest : CCApp -> Party -> Party -> [(Party, PaymentAmount)] -> Script (ContractId AppPaymentRequest)
createPaymentRequest app provider sender receiverAmounts = do
  t <- getTime
  let description = "multi, sender: " <> show sender <> ", amount: " <> show receiverAmounts
  -- multi-party submit to simplify test
  submitMulti (sender :: provider :: map fst receiverAmounts) [] $ createCmd AppPaymentRequest with
    sender
    provider
    svc = app.svc
    receiverAmounts = map (uncurry ReceiverAmount) receiverAmounts
    expiresAt = t `addRelTime` minutes 5
    description

createSingleReceiverPaymentRequest : CCApp -> Party -> Party -> Party -> PaymentAmount -> Script (ContractId AppPaymentRequest)
createSingleReceiverPaymentRequest app provider sender receiver amount = do
  createPaymentRequest app provider sender [(receiver, amount)]

acceptPaymentRequest : CCApp -> CCUser -> Party -> Optional(ContractId FeaturedAppRight) -> ContractId AppPaymentRequest -> ContractId Coin -> Script (ContractId AcceptedAppPayment)
acceptPaymentRequest app sender walletProvider providerFeaturedAppRight transferRequest coin = do
  context <- getPaymentTransferContextFeaturedApp app sender providerFeaturedAppRight
  -- TODO(#2957): remove read-as SVC.
  (accept, _change) <- submitMulti [sender.primaryParty, walletProvider] [app.svc] $ exerciseCmd transferRequest AppPaymentRequest_Accept with
    inputs = [InputCoin coin]
    context
    walletProvider
  return accept

collectAcceptedPayment : CCApp -> CCUser -> ContractId AcceptedAppPayment -> Script AcceptedAppPayment_Collect_Result
collectAcceptedPayment app provider acceptedAppPayment = do
  (_, round) <- getLatestOpenRound app
  collectAcceptedPaymentInRound app round.round provider acceptedAppPayment

collectAcceptedPaymentInRound : CCApp -> Round -> CCUser -> ContractId AcceptedAppPayment -> Script AcceptedAppPayment_Collect_Result
collectAcceptedPaymentInRound app round provider acceptedAppPayment = do
  Some acceptedPayment <- queryContractId provider.primaryParty acceptedAppPayment
  context <- getAppTransferContextForRound app provider round
  -- multi party submit to simplify test
  submitMulti (signatory acceptedPayment) [app.svc] $ exerciseCmd acceptedAppPayment (AcceptedAppPayment_Collect context)

collectAcceptedPaymentMustFail : CCApp -> CCUser -> ContractId AcceptedAppPayment -> Script ()
collectAcceptedPaymentMustFail app provider acceptedAppPayment = do
  Some acceptedPayment <- queryContractId provider.primaryParty acceptedAppPayment
  context <- getAppTransferContext app provider
  -- multi party submit to simplify test
  _ <- submitMultiMustFail (signatory acceptedPayment) [app.svc] $ exerciseCmd acceptedAppPayment (AcceptedAppPayment_Collect context)
  pure ()

checkCoinPositions : CCUser -> [Decimal] -> Script ()
checkCoinPositions owner expectedAmounts = do
    let ownerParty = owner.primaryParty
    actualCoins <- queryFilter @Coin ownerParty (\c -> c.owner == ownerParty)
    sort (map (._2.amount.initialAmount) actualCoins) === sort expectedAmounts

testSingleReceiverCCPaymentRequest : Script ()
testSingleReceiverCCPaymentRequest = script do
  DefaultAppWithUsers{..} <- setupDefaultAppWithUsers
  runNextIssuance app
  runCoinDepositBots app

  featureApp app provider1

  aliceInitialCoins <- query @Coin alice.primaryParty

  let paymentAmount = 41.5 -- chosen to not return sender change
  coin <- tap app alice 42.0
  transferRequest <- createSingleReceiverPaymentRequest app
    provider1.primaryParty alice.primaryParty bob.primaryParty
    (PaymentAmount paymentAmount CC)

  acceptedPaymentCid <- acceptPaymentRequest app alice aliceValidator.primaryParty None transferRequest coin
  Some acceptedPayment <- queryContractId alice.primaryParty acceptedPaymentCid
  [(lockedCoinCid, lockedCoin)] <- query @LockedCoin alice.primaryParty
  -- all of Alice's tapped coin is used up
  aliceCoins <- query @Coin alice.primaryParty
  aliceCoins === aliceInitialCoins
  acceptedPayment === AcceptedAppPayment with
    sender = alice.primaryParty
    provider = provider1.primaryParty
    svc = app.svc
    lockedCoin = lockedCoinCid
    ccReceiverAmounts = [
      (ReceiverCCAmount with receiver = bob.primaryParty, ccAmount = paymentAmount)
      ]
    round = lockedCoin.coin.amount.createdAt
    reference = transferRequest

  AcceptedAppPayment_Collect_Result [(receiver, coinCid)] <- collectAcceptedPayment app provider1 acceptedPaymentCid
  receiver === bob.primaryParty

  Some coin <- queryContractId bob.primaryParty coinCid
  coin.amount.initialAmount === paymentAmount

  pure ()

testExpiringCCPaymentRequest : Script ()
testExpiringCCPaymentRequest = script do
  DefaultAppWithUsers{..} <- setupDefaultAppWithUsers
  runNextIssuance app
  runCoinDepositBots app

  transferRequest <- createSingleReceiverPaymentRequest app
    provider1.primaryParty alice.primaryParty bob.primaryParty
    (PaymentAmount 30.0 CC)

  install <- submitMulti [alice.primaryParty, aliceValidator.primaryParty] [] $ createCmd $ WalletAppInstall with
    endUserParty = alice.primaryParty
    endUserName = "alice"
    svcParty = app.svc
    validatorParty = aliceValidator.primaryParty

  -- Try expiring too early
  submitMultiMustFail [aliceValidator.primaryParty] [alice.primaryParty] $ exerciseCmd install
        WalletAppInstall_AppPaymentRequest_Expire with
          cid = transferRequest

  passTime (minutes 6)

  submitMulti [aliceValidator.primaryParty] [alice.primaryParty] $ exerciseCmd install
        WalletAppInstall_AppPaymentRequest_Expire with
          cid = transferRequest

  pure ()

testSingleReceiverUSDPaymentRequest : Script ()
testSingleReceiverUSDPaymentRequest = script do
  DefaultAppWithUsers{..} <- setupDefaultAppWithUsers
  advanceToIssuanceWithPrice app 0.5
  runCoinDepositBots app

  coin <- tap app alice 62.0 -- Need to cover a 30USD payment with 1USD=2CC
  transferRequest <- createSingleReceiverPaymentRequest app
    provider1.primaryParty alice.primaryParty bob.primaryParty
    (PaymentAmount 30.0 USD)

  acceptedPaymentCid <- acceptPaymentRequest app alice aliceValidator.primaryParty None transferRequest coin
  Some acceptedPayment <- queryContractId alice.primaryParty acceptedPaymentCid
  [(lockedCoinCid, lockedCoin)] <- query @LockedCoin alice.primaryParty
  [_, _] <- query @Coin alice.primaryParty
  acceptedPayment === AcceptedAppPayment with
    sender = alice.primaryParty
    provider = provider1.primaryParty
    svc = app.svc
    lockedCoin = lockedCoinCid
    ccReceiverAmounts = [
      (ReceiverCCAmount with receiver = bob.primaryParty, ccAmount = 60.0)
      ]
    round = lockedCoin.coin.amount.createdAt
    reference = transferRequest

  pure ()

testCCPaymentRequest : Script ()
testCCPaymentRequest = script do
  DefaultAppWithUsers{..} <- setupDefaultAppWithUsers
  advanceToIssuanceWithPrice app 1.0
  runCoinDepositBots app

  validatorUserId <- validateUserId "alice_validator"
  featuredValidator <- featureApp app (CCUser validatorUserId aliceValidator.primaryParty)

  -- retrieve the config
  config <- getCoinConfig app
  let transferConfig = config.transferConfig
  coin <- tap app alice 27.0
  transferRequest <-
    createPaymentRequest app provider1.primaryParty alice.primaryParty [
      (bob.primaryParty, PaymentAmount 15.0 CC),
      (charlie.primaryParty, PaymentAmount 10.0 CC)]
  acceptedPaymentCid <- acceptPaymentRequest app alice aliceValidator.primaryParty (Some featuredValidator) transferRequest coin
  Some acceptedPayment <- queryContractId alice.primaryParty acceptedPaymentCid
  [(lockedCoin, lockedCoinPayload)] <- query @LockedCoin alice.primaryParty
  lockedCoinPayload.coin.amount.initialAmount ===
    15.0 +
    10.0 +
    transferConfig.createFee.fee + chargeSteppedRate transferConfig.transferFee 15.0 +
    transferConfig.createFee.fee + chargeSteppedRate transferConfig.transferFee 10.0
  lockedCoinPayload.lock.holders === map (.primaryParty) [bob, charlie, provider1]
  acceptedPayment === AcceptedAppPayment with
    sender = alice.primaryParty
    ccReceiverAmounts = [
      (ReceiverCCAmount with receiver = bob.primaryParty, ccAmount = 15.0),
      (ReceiverCCAmount with receiver = charlie.primaryParty, ccAmount = 10.0)
      ]
    provider = provider1.primaryParty
    svc = app.svc
    lockedCoin = lockedCoin
    round = lockedCoinPayload.coin.amount.createdAt
    reference = transferRequest

  checkCoinPositions alice [1.0, 1.615]
  checkCoinPositions bob [1.0]
  checkCoinPositions charlie [1.0]

  -- Check that the locked-coin is visible to charlie
  [(charlieLockedCoinCid, _)] <- query @LockedCoin charlie.primaryParty
  charlieLockedCoinCid === lockedCoin


  result <- collectAcceptedPayment app alice acceptedPaymentCid

  case sortOn (._1) result.receiverCoins of
    [(bob', bobCoin), (charlie', charlieCoin)] ->  do
      bob' === bob.primaryParty
      charlie' === charlie.primaryParty
      Some coin <- queryContractId bob' bobCoin
      coin.amount.initialAmount === 15.0
      Some coin <- queryContractId charlie' charlieCoin
      coin.amount.initialAmount === 10.0
    _ -> abort $ "Expected exactly two coins but got " <> show result.receiverCoins

  checkCoinPositions alice [1.0, 1.615]
  checkCoinPositions bob [1.0, 15.0]
  checkCoinPositions charlie [1.0, 10.0]

  (_, round) <- getLatestActiveOpenRound app

  [(_, coupon)] <- query @AppRewardCoupon provider1.primaryParty
  let transferConfigCC = transferConfigCCFromOpenRound round
  coupon.amount ===
    transferConfigCC.transferFee.initialRate * (15.0 + 10.0) +
    transferConfigCC.createFee.fee * 2.0
  coupon.featured === False

  [(_, coupon)] <- query @AppRewardCoupon aliceValidator.primaryParty
  coupon.amount ===
    transferConfigCC.createFee.fee + -- for one locked coin
    transferConfigCC.lockHolderFee.fee * 3.0
  coupon.provider === aliceValidator.primaryParty
  coupon.featured === True

  pure ()

testCCPaymentCollectionRoundInLatestRoundMustFail : Script ()
testCCPaymentCollectionRoundInLatestRoundMustFail = script do
  DefaultAppWithUsers{..} <- setupDefaultAppWithUsers
  advanceToIssuanceWithPrice app 1.0
  runCoinDepositBots app

  coin <- tap app alice 27.0
  transferRequest <-
    createPaymentRequest app provider1.primaryParty alice.primaryParty [
      (bob.primaryParty, PaymentAmount 15.0 CC),
      (charlie.primaryParty, PaymentAmount 10.0 CC)]


  acceptedPaymentCid <- acceptPaymentRequest app alice aliceValidator.primaryParty None transferRequest coin

  Some acceptedPayment <- queryContractId alice.primaryParty acceptedPaymentCid

  runNextIssuance app

  collectAcceptedPaymentMustFail app alice acceptedPaymentCid

  collectAcceptedPaymentInRound app acceptedPayment.round alice acceptedPaymentCid

  pure ()

