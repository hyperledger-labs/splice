assertTerminatedPayment : Party -> ContractId AppPaymentRequest -> Script ()
assertTerminatedPayment p reference = do
  terminated <- queryFilter @TerminatedAppPayment p (\c -> c.reference == reference)
  unless (length terminated == 1) $ abort ("Expected one TerminatedAppPayment for " <> show reference <> " but got " <> show terminated)

testTerminatedPayments : Script ()
testTerminatedPayments = script do
  DefaultAppWithUsers{..} <- setupDefaultAppWithUsers
  runNextIssuance app
  runCoinDepositBots app

  featureApp app provider1

  let paymentAmount = 41.5

  let createPaymentRequest = createSingleReceiverPaymentRequest app
        provider1.primaryParty alice.primaryParty bob.primaryParty
        (PaymentAmount paymentAmount CC)

  paymentRequest <- createPaymentRequest
  submit alice.primaryParty $ exerciseCmd paymentRequest AppPaymentRequest_Reject
  assertTerminatedPayment alice.primaryParty paymentRequest

  paymentRequest <- createPaymentRequest
  submit bob.primaryParty $ exerciseCmd paymentRequest AppPaymentRequest_Withdraw
  assertTerminatedPayment alice.primaryParty paymentRequest

  let createAcceptedPayment = do
        coin <- tap app alice 42.0
        paymentRequest <- createPaymentRequest
        accepted <- acceptPaymentRequest app alice aliceValidator.primaryParty None paymentRequest coin
        pure (paymentRequest, accepted)

  (paymentRequest, acceptedPayment) <- createAcceptedPayment
  context <- getAppTransferContext app alice
  submitMulti [bob.primaryParty] [app.svc] $ exerciseCmd acceptedPayment (AcceptedAppPayment_Reject context)
  assertTerminatedPayment alice.primaryParty paymentRequest

  (paymentRequest, acceptedPayment) <- createAcceptedPayment
  context <- getAppTransferContext app alice
  passTime (minutes 10)
  submitMulti [alice.primaryParty, bob.primaryParty] [app.svc] $ exerciseCmd acceptedPayment (AcceptedAppPayment_Expire context)
  assertTerminatedPayment alice.primaryParty paymentRequest

  pure ()

testSuccessfulBatchCCPaymentRequests : Script ()
testSuccessfulBatchCCPaymentRequests = script do
  DefaultAppWithUsers{..} <- setupDefaultAppWithUsers
  runNextIssuance app
  runCoinDepositBots app

  coin <- tap app alice 42.0
  transferRequest <- createSingleReceiverPaymentRequest app
    provider1.primaryParty alice.primaryParty bob.primaryParty
    (PaymentAmount 1.0 CC)
  transferRequest2 <-
    createPaymentRequest app provider1.primaryParty alice.primaryParty [
      (bob.primaryParty, PaymentAmount 2.0 CC),
      (alice.primaryParty, PaymentAmount 2.0 CC)]

  let endUserName = "wallet_service_participant_user"
  install <- submitMulti [alice.primaryParty, aliceValidator.primaryParty] [] $ createCmd $ WalletAppInstall with
    endUserParty = alice.primaryParty
    endUserName = endUserName
    svcParty = app.svc
    validatorParty = aliceValidator.primaryParty

  context <- getPaymentTransferContext app alice
  executeBatchResult <- submitMulti [aliceValidator.primaryParty] [alice.primaryParty, app.svc] $ exerciseCmd install WalletAppInstall_ExecuteBatch with
    context
    inputs = [InputCoin coin]
    operations = [CO_AppPayment transferRequest, CO_AppPayment transferRequest2]

  let [COO_AcceptedAppPayment payment1Cid, COO_AcceptedAppPayment payment2Cid] = executeBatchResult.outcomes
  Some acceptedPayment <- queryContractId alice.primaryParty payment1Cid
  Some acceptedPayment2 <- queryContractId alice.primaryParty payment2Cid
  lockedCoins <- query @LockedCoin alice.primaryParty
  let [(lockedCoinCid, lockedCoin), (lockedCoinCid2, lockedCoin2)] = sortOn (\(_, lockedCoin) -> lockedCoin.coin.amount.initialAmount) lockedCoins
  [_, _] <- query @Coin alice.primaryParty

  -- check results
  executeBatchResult.endUserName === endUserName
  acceptedPayment === AcceptedAppPayment with
    sender = alice.primaryParty
    provider = provider1.primaryParty
    svc = app.svc
    lockedCoin = lockedCoinCid
    ccReceiverAmounts = [
      ReceiverCCAmount with receiver = bob.primaryParty, ccAmount = 1.0 ]
    round = lockedCoin.coin.amount.createdAt
    reference = transferRequest

  acceptedPayment2 === AcceptedAppPayment with
    sender = alice.primaryParty
    ccReceiverAmounts = [
      (ReceiverCCAmount with receiver = bob.primaryParty, ccAmount = 2.0),
      (ReceiverCCAmount with receiver = alice.primaryParty, ccAmount = 2.0)
      ]
    provider = provider1.primaryParty
    svc = app.svc
    lockedCoin = lockedCoinCid2
    round = lockedCoin2.coin.amount.createdAt
    reference = transferRequest2

  pure ()


testInsufficientFundsBatchCCPaymentRequests : Script ()
testInsufficientFundsBatchCCPaymentRequests = script do
  DefaultAppWithUsers{..} <- setupDefaultAppWithUsers
  runCoinDepositBots app
  coin <- tap app alice 42.0

  install <- submitMulti [alice.primaryParty, aliceValidator.primaryParty] [] $ createCmd $ WalletAppInstall with
    endUserParty = alice.primaryParty
    endUserName = "wallet_service_participant_user"
    svcParty = app.svc
    validatorParty = aliceValidator.primaryParty

  transferRequest3 <- createSingleReceiverPaymentRequest app
    provider1.primaryParty alice.primaryParty bob.primaryParty
    (PaymentAmount 10000.0 CC)
  transferRequest4 <-
    createPaymentRequest app provider1.primaryParty alice.primaryParty [
      (bob.primaryParty, PaymentAmount 3.0 CC),
      (alice.primaryParty, PaymentAmount 3.0 CC)]
  -- trying to fulfill the request for 10,000 CC will fail
  context <- getPaymentTransferContext app alice
  ExecuteBatchResult { outcomes } <- submitMulti [aliceValidator.primaryParty] [alice.primaryParty, app.svc] $ exerciseCmd install WalletAppInstall_ExecuteBatch with
    inputs = [InputCoin coin]
    operations = [CO_AppPayment transferRequest3, CO_AppPayment transferRequest4]
    context

  -- first command errors, second command is still executed
  let [COO_Error _, COO_AcceptedAppPayment payment3Cid] = outcomes
  Some acceptedPayment4 <- queryContractId alice.primaryParty payment3Cid

  -- Only one command executed, so there's only one locked coin
  lockedCoins <- query @LockedCoin alice.primaryParty
  let [(lockedCoinCid4, lockedCoin4)] = lockedCoins

  acceptedPayment4 === AcceptedAppPayment with
    sender = alice.primaryParty
    ccReceiverAmounts = [
      (ReceiverCCAmount with receiver = bob.primaryParty, ccAmount = 3.0),
      (ReceiverCCAmount with receiver = alice.primaryParty, ccAmount = 3.0)
      ]
    provider = provider1.primaryParty
    svc = app.svc
    lockedCoin = lockedCoinCid4
    round = lockedCoin4.coin.amount.createdAt
    reference = transferRequest4

  pure ()


-- Smoke test - this functionality is tested more extensively in the WalletIntegrationTests
testCO_MergeTransferInputs : Script ()
testCO_MergeTransferInputs = script do
  DefaultAppWithUsers{..} <- setupDefaultAppWithUsers
  runNextIssuance app
  runCoinDepositBots app

  coin <- tap app alice 42.0
  coin2 <- tap app alice 43.0

  install <- submitMulti [alice.primaryParty, aliceValidator.primaryParty] [] $ createCmd $ WalletAppInstall with
    endUserParty = alice.primaryParty
    endUserName = "wallet_service_participant_user"
    svcParty = app.svc
    validatorParty = aliceValidator.primaryParty


  context <- getPaymentTransferContext app alice

  ExecuteBatchResult { outcomes } <- submitMulti [aliceValidator.primaryParty] [alice.primaryParty, app.svc] $ exerciseCmd install WalletAppInstall_ExecuteBatch with
    inputs = [InputCoin coin, InputCoin coin2]
    operations = [CO_MergeTransferInputs]
    context

  let [COO_MergeTransferInputs (Some resultCoin)] = outcomes
  aliceCoins <- query @Coin alice.primaryParty
  let [_, (mergedCoinCid, _)] = sortOn (\(_, p) -> p.amount.initialAmount) aliceCoins
  resultCoin === mergedCoinCid

  pure ()


-- Test to sanity check that buying member traffic works
testBuyMemberTraffic : Script ()
testBuyMemberTraffic = script do
  DefaultAppWithUsers{..} <- setupDefaultAppWithUsers
  runNextIssuance app
  runCoinDepositBots app
  (_, openRound) <- getLatestOpenRound app

  now <- getTime
  [(coinRulesCid, coinRules)] <- query @CoinRules app.svc
  let globalDomainConfig = (CC.Schedule.getValueAsOf now coinRules.configSchedule).globalDomain
  let extraTrafficPrice = globalDomainConfig.fees.extraTrafficPrice
  let domainId = globalDomainConfig.activeDomain
  let testParticipantId = "alice_validator_participant_id"

  -- Test that self top-ups work

  -- set the validator up with some coin and its own wallet install contract
  submit aliceValidator.primaryParty $ createCmd $ WalletAppInstall with
    endUserParty = aliceValidator.primaryParty
    endUserName = "alice_validator_wallet_user"
    svcParty = app.svc
    validatorParty = aliceValidator.primaryParty

  -- create initial validator top-up state contract
  topupStateCid <- submit aliceValidator.primaryParty $
    createCmd (initialValidatorTopUpState aliceValidator.primaryParty testParticipantId domainId)

  -- test that buying less extra traffic than the configured min topup amount fails
  let minTopupAmount = globalDomainConfig.fees.minTopupAmount
  outcome <- executeCoinOperation app aliceValidator $
    CO_BuyMemberTraffic (minTopupAmount-1) testParticipantId domainId (minutes 1) (Some topupStateCid)
  let errorMsg = "The requirement 'trafficAmount " <> show (minTopupAmount-1) <> " is at least as much as the configured minTopupAmount " <> show minTopupAmount <> "' was not met."
  outcome === COO_Error (ITR_Other errorMsg)

  -- test that providing an invalid global domain ID fails
  let invalidDomainId = domainId <> "_invalid"
  invalidTopupStateCid <- submit aliceValidator.primaryParty $
    createCmd (initialValidatorTopUpState aliceValidator.primaryParty testParticipantId invalidDomainId)
  outcome <- executeCoinOperation app aliceValidator $
    CO_BuyMemberTraffic (minTopupAmount-1) testParticipantId invalidDomainId (minutes 1) (Some invalidTopupStateCid)
  outcome === COO_Error (ITR_Other ("The requirement 'Known domain-id' was not met."))
  submit aliceValidator.primaryParty $ archiveCmd invalidTopupStateCid

  -- test that creating the initial traffic contract works
  COO_BuyMemberTraffic trafficCid1 <- executeCoinOperation app aliceValidator $
    CO_BuyMemberTraffic minTopupAmount testParticipantId domainId (minutes 1) (Some topupStateCid)

  -- validate the state of the member traffic contract
  Some traffic1 <- queryContractId @MemberTraffic app.svc trafficCid1
  let totalPurchased = minTopupAmount
  let usdSpent = intToDecimal totalPurchased / 1e6 * extraTrafficPrice
  let ccSpent = usdSpent / openRound.coinPrice
  traffic1.totalPurchased === totalPurchased
  traffic1.numPurchases === 1
  traffic1.ccSpent === ccSpent
  traffic1.usdSpent === usdSpent

  -- validate that the topup state got updated
  [(topupStateCid2, topupState2)] <- query @ValidatorTopUpState aliceValidator.primaryParty
  topupStateCid2 =/= topupStateCid
  topupState2.lastPurchasedAt === now

  -- check that the app reward coupons were issued to aliceValidator
  [(coupon1Cid, coupon1)] <- query @AppRewardCoupon app.svc
  coupon1.provider === aliceValidator.primaryParty
  coupon1.round === openRound.round

  -- topping up too soon fails
  outcome <- executeCoinOperation app aliceValidator $
    CO_BuyMemberTraffic minTopupAmount testParticipantId domainId (minutes 1) (Some topupStateCid2)
  outcome === COO_Error (ITR_Other ("The requirement 'enough time has elapsed since the last topup' was not met."))

  -- once a minute has passed, the same topup succeeds
  passTime (minutes 1)
  COO_BuyMemberTraffic trafficCid2 <- executeCoinOperation app aliceValidator $
    CO_BuyMemberTraffic minTopupAmount testParticipantId domainId (minutes 1) (Some topupStateCid2)
  Some traffic2 <- queryContractId @MemberTraffic app.svc trafficCid2

  -- check the app reward coupons once more
  [(coupon2Cid, coupon2), (coupon1Cid_, coupon1_)] <- query @AppRewardCoupon app.svc
  (coupon1Cid_, coupon1_) === (coupon1Cid, coupon1_)
  coupon2Cid =/= coupon1Cid
  coupon2.provider === aliceValidator.primaryParty
  coupon2.round === openRound.round

  -- Test that third-party top-ups work

  -- advance rounds to ensure that reward coupons issued have a different round number
  runNextIssuance app
  (_, openRound2) <- getLatestOpenRound app
  openRound2.round.number === openRound.round.number + 1

  -- create a wallet install contract and tap some coins for provider1 validator
  submit provider1Validator.primaryParty $ createCmd $ WalletAppInstall with
    endUserParty = provider1Validator.primaryParty
    endUserName = "provider1_validator_wallet_user"
    svcParty = app.svc
    validatorParty = provider1Validator.primaryParty
  _ <- tap app provider1Validator 10.0

  -- provider1 purchases extra traffic for the same participant
  COO_BuyMemberTraffic providerTrafficCid <- executeCoinOperation app provider1Validator $
    CO_BuyMemberTraffic (minTopupAmount + 1) testParticipantId domainId (minutes 1) None

  -- validate the state of the member traffic contract
  Some providerTraffic <- queryContractId @MemberTraffic app.svc providerTrafficCid
  let totalPurchased = minTopupAmount + 1
  let usdSpent = intToDecimal totalPurchased / 1e6 * extraTrafficPrice
  let ccSpent = usdSpent / openRound2.coinPrice
  providerTraffic.totalPurchased === totalPurchased
  providerTraffic.numPurchases === 1
  providerTraffic.ccSpent === ccSpent
  providerTraffic.usdSpent === usdSpent

  -- check that the app reward coupons were issued to the provider
  [(providerCouponCid, providerCoupon)] <- query @AppRewardCoupon provider1Validator.primaryParty
  providerCouponCid =/= coupon1Cid
  providerCouponCid =/= coupon2Cid
  providerCoupon.provider === provider1Validator.primaryParty
  providerCoupon.round === openRound2.round

  -- test that the SVC can merge multiple member traffic contracts
  let trafficCids = [trafficCid1, trafficCid2, providerTrafficCid]
  submit app.svc $ exerciseCmd coinRulesCid CoinRules_MergeMemberTrafficContracts with trafficCids
  [(mergedTrafficCid, mergedTraffic)] <- queryFilter @MemberTraffic app.svc (\t -> t.memberId == testParticipantId)
  assert $ notElem mergedTrafficCid trafficCids
  mergedTraffic.totalPurchased === 3 * minTopupAmount + 1
  mergedTraffic.numPurchases === 3
  mergedTraffic.usdSpent === traffic1.usdSpent + traffic2.usdSpent + providerTraffic.usdSpent
  mergedTraffic.ccSpent === traffic1.ccSpent + traffic2.ccSpent + providerTraffic.ccSpent

  -- at least 1 contract must be provided to merge
  submitMustFail app.svc $ exerciseCmd coinRulesCid CoinRules_MergeMemberTrafficContracts with
    trafficCids = []

  pure ()


testInsufficientFundsBatchSubscriptions : Script ()
testInsufficientFundsBatchSubscriptions = script do
  app <- setupApp
  runNextIssuance app
  runCoinDepositBots app

  validator <- setupValidator app "validator1"
  alice <- setupUser app "alice" validator
  pizzeria <- setupUser app "pizzeria" validator
  provider <- setupUser app "la_famiglia" validator

  install <- submitMulti [alice.primaryParty, validator] [] $ createCmd $ WalletAppInstall with
    endUserParty = alice.primaryParty
    endUserName = "wallet_service_participant_user"
    svcParty = app.svc
    validatorParty = validator

  let payData = SubscriptionPayData with
        paymentInterval = days 28
        paymentDuration = days 1
        paymentAmount = PaymentAmount 10.0 USD

  let subscriptionData = SubscriptionData with
        sender = alice.primaryParty
        receiver = pizzeria.primaryParty
        provider = provider.primaryParty
        svc = app.svc
        description = "test subscription"

  subscriptionRequestCid <- submitMulti [alice.primaryParty, pizzeria.primaryParty, provider.primaryParty] [] $ createCmd (SubscriptionRequest subscriptionData payData)

  context <- getPaymentTransferContext app alice
  coin <- tap  app alice 5.0
  -- TODO(#2957): remove read-as SVC.
  ExecuteBatchResult { outcomes } <- submitMulti [alice.primaryParty, validator] [app.svc] $ exerciseCmd install WalletAppInstall_ExecuteBatch with
    inputs = [InputCoin coin]
    operations = [CO_SubscriptionAcceptAndMakeInitialPayment subscriptionRequestCid]
    context

  outcomes === [COO_Error (ITR_InsufficientFunds (5.17))]

  coin <- tap app alice 15.0
  -- TODO(#2957): remove read-as SVC.
  ExecuteBatchResult { outcomes } <- submitMulti [alice.primaryParty, validator] [app.svc] $ exerciseCmd install WalletAppInstall_ExecuteBatch with
    inputs = [InputCoin coin]
    operations = [CO_SubscriptionAcceptAndMakeInitialPayment subscriptionRequestCid]
    context
  initialPaymentCid <- case outcomes of
    [COO_SubscriptionInitialPayment cid] -> pure cid
    _ -> abort $ "Expected initial subscription payment to succeed but got " <> show outcomes

  (_, subscriptionIdleStateCid, _) <- collectInitialSubscriptionPayment app provider pizzeria alice.primaryParty initialPaymentCid

  passTime (days 27)
  runNextIssuance app
  passTimeToRoundOpen app
  context <- getPaymentTransferContext app alice

  coin <- tap app alice 5.0
  -- TODO(#2957): remove read-as SVC.
  ExecuteBatchResult { outcomes } <- submitMulti [alice.primaryParty, validator] [app.svc] $ exerciseCmd install WalletAppInstall_ExecuteBatch with
    inputs = [InputCoin coin]
    operations = [CO_SubscriptionMakePayment subscriptionIdleStateCid]
    context
  outcomes === [COO_Error (ITR_InsufficientFunds (5.17))]

  coin <- tap app alice 15.0
  -- TODO(#2957): remove read-as SVC.
  ExecuteBatchResult { outcomes } <- submitMulti [alice.primaryParty, validator] [app.svc] $ exerciseCmd install WalletAppInstall_ExecuteBatch with
    inputs = [InputCoin coin]
    operations = [CO_SubscriptionMakePayment subscriptionIdleStateCid]
    context
  case outcomes of
    [COO_SubscriptionPayment _] -> pure ()
    _ -> abort $ "Expected subscription payment to succeed but got " <> show outcomes
  pure ()

-- Utilities
------------

withError : CanAbort m => [CoinOperationOutcome] -> (InvalidTransferReason -> m a) -> m a
withError outcomes f = case outcomes of
  [COO_Error e] -> f e
  _ -> abort $ "Expected COO_Error but got " <> show outcomes

executeCoinOperation : CCApp -> CCUser -> CoinOperation -> Script CoinOperationOutcome
executeCoinOperation app user op = do
  [(installCid, _)] <- query @WalletAppInstall user.primaryParty
  context <- getPaymentTransferContext app user
  coins <- queryFilter @Coin user.primaryParty (\coin -> coin.owner == user.primaryParty)
  result <- submitUser user.userId $ exerciseCmd installCid WalletAppInstall_ExecuteBatch with
    inputs = [InputCoin coin._1 | coin <- coins]
    operations = [op]
    context
  let [outcome] = result.outcomes
  pure outcome
