module CC.Scripts.TestCoinImport where

import DA.Assert
import Daml.Script

import CC.Coin
import CC.CoinImport
import CC.Scripts.Util

testImportCrates: Script ()
testImportCrates = do
  DefaultAppWithUsers{..} <- setupDefaultAppWithUsers

  coin1Cid <- tap app alice 33.0
  coins <- query @Coin app.svc
  let [(_, coin1)] = filter (\(cid, _) -> cid == coin1Cid) coins

  -- create a fresh SVC party with its coinRules and user party
  newApp <- genericSetupApp "new"
  (newCoinRulesCid, _) <- getCoinRules newApp
  (newOpenRoundCid, newOpenRound) <- getLatestActiveOpenRound newApp

  newAlice <- allocateParty "newAlice"
  newAliceXyz <- allocateParty "newAlice::xyz"


  pkg1 <- submit newApp.svc $ createCmd ImportCrate with
    svc = newApp.svc
    receiverName = partyToText newAlice
    exactMatch = True
    payload = coin1

  pkg2 <- submit newApp.svc $ createCmd ImportCrate with
    svc = newApp.svc
    receiverName = partyToText newAlice
    exactMatch = False
    payload = coin1

  -- exact match is checked
  submitMultiMustFail [newAliceXyz] [newApp.svc] $ exerciseCmd pkg1 ImportCrate_Receive with
    receiver = newAliceXyz
    openRound = newOpenRoundCid
    coinRules = newCoinRulesCid

  submitMulti [newAlice] [newApp.svc] $ exerciseCmd pkg1 ImportCrate_Receive with
    receiver = newAlice
    openRound = newOpenRoundCid
    coinRules = newCoinRulesCid

  -- this import crate can be received as only the prefix is checked
  submitMulti [newAliceXyz] [newApp.svc] $ exerciseCmd pkg2 ImportCrate_Receive with
    receiver = newAliceXyz
    openRound = newOpenRoundCid
    coinRules = newCoinRulesCid

  -- check import crate and coins of the newApp.svc
  pkgs <- query @ImportCrate newApp.svc
  pkgs === []

  -- need to adjust the round of the newAmount, it changes between the initial tap and the reminting
  let newAmount = coin1.amount with createdAt = newOpenRound.round
  let newCoin1 = Coin with svc = newApp.svc; owner = newAlice; amount = newAmount
  let newCoin2 = Coin with svc = newApp.svc; owner = newAliceXyz; amount = newAmount
  newCoins <- query @Coin newApp.svc
  map snd newCoins === [newCoin2, newCoin1]

  pure ()
