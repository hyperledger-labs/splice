  issuancePerValidatorRewardCoupon = 0.0491375587
  issuancePerFeaturedAppRewardCoupon = 0.1637918624
  issuancePerUnfeaturedAppRewardCoupon = 0.1637918624
  coinsToIssueToSvc = 45662.1004566210
  unclaimedAppRewards = 0.0
  unclaimedValidatorRewards = 0.0

expectedParameters_E2_1p5_5 : IssuingRoundParameters
expectedParameters_E2_1p5_5 = IssuingRoundParameters with
  issuancePerValidatorRewardCoupon = 0.0368531690
  issuancePerFeaturedAppRewardCoupon = 0.1269386933
  issuancePerUnfeaturedAppRewardCoupon = 0.1269386933
  coinsToIssueToSvc = 9512.9375951294
  unclaimedAppRewards = 0.0
  unclaimedValidatorRewards = 0.0

expectedParameters_E2_5_10 : IssuingRoundParameters
expectedParameters_E2_5_10 = IssuingRoundParameters with
  issuancePerValidatorRewardCoupon = 0.0214976819
  issuancePerFeaturedAppRewardCoupon = 0.0706352406
  issuancePerUnfeaturedAppRewardCoupon = 0.0706352406
  coinsToIssueToSvc = 2378.2343987824
  unclaimedAppRewards = 0.0
  unclaimedValidatorRewards = 0.0

expectedParameters_E2_10plus : IssuingRoundParameters
expectedParameters_E2_10plus = IssuingRoundParameters with
  issuancePerValidatorRewardCoupon = 0.0102369914
  issuancePerFeaturedAppRewardCoupon = 0.0383887177
  issuancePerUnfeaturedAppRewardCoupon = 0.0383887177
  coinsToIssueToSvc = 594.5585996956
  unclaimedAppRewards = 0.0
  unclaimedValidatorRewards = 0.0


testE2 : Script ()
testE2 = script do
  validateOpenMiningRoundSummary summaryExample2

  expectedParameters_E2_0_0p5 === computeIssuingRoundParameters issuanceConfig_0_0p5 summaryExample2
  expectedParameters_E2_0p5_1p5 === computeIssuingRoundParameters issuanceConfig_0p5_1p5 summaryExample2
  expectedParameters_E2_1p5_5 === computeIssuingRoundParameters issuanceConfig_1p5_5 summaryExample2
  expectedParameters_E2_5_10 === computeIssuingRoundParameters issuanceConfig_5_10 summaryExample2
  expectedParameters_E2_10plus === computeIssuingRoundParameters issuanceConfig_10plus summaryExample2


-- Example 3: all zeros
-----------------------

summaryExample3 : OpenMiningRoundSummary
summaryExample3 = OpenMiningRoundSummary with
  totalValidatorRewardCoupons = 0.0
  totalFeaturedAppRewardCoupons = 0.0
  totalUnfeaturedAppRewardCoupons = 0.0

expectedParameters_E3_0_0p5 : IssuingRoundParameters
