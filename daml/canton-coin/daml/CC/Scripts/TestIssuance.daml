  issuancePerFeaturedAppRewardCoupon = 0.1228438968
  issuancePerUnfeaturedAppRewardCoupon = 0.1228438968
  coinsToIssueToSvc = 152207.0015220700
  unclaimedAppRewards = 0.0
  unclaimedValidatorRewards = 0.0

