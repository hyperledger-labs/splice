module CC.Scripts.TestDesignExample where

import DA.Assert
import DA.List.Total
import qualified DA.Map as Map
import DA.Time
import Daml.Script

import CN.Util
import CC.Coin
import CC.CoinRules
import CC.Expiry
import CC.Types
import CC.RelRound
import CC.Fees
import CC.Scripts.Util

arbiterPaymentAmount : Decimal
arbiterPaymentAmount = 1.0

template Escrow
  with
    svc : Party
    arbiter : Party
    p : Party
  where
    signatory arbiter
    observer p
    nonconsuming choice Refresh : TransferResult
      with
        lockedCoin : ContractId LockedCoin
        paymentCoin : ContractId Coin
        transferContext : AppTransferContext
      controller p
      do LockedCoin{lock,coin=locked} <- fetchButArchiveLater (ForOwner with svc; owner = p) lockedCoin -- archived as part of unlocking
         require "lock holder matches locked coin " ([arbiter] == lock.holders)
         CoinCreateSummary cid _ _ <- exercise lockedCoin (LockedCoin_Unlock transferContext.openMiningRound)
         let transfer = Transfer with
               sender = p
               provider = arbiter
               inputs = [InputCoin cid, InputCoin paymentCoin]
               outputs =
                 [ TransferOutput with
                     receiver = p
                     amount = locked.amount.initialAmount
                     lock = Some TimeLock with
                       holders = [arbiter]
                       expiresAt = lock.expiresAt `addRelTime` days 90
                     receiverFeeRatio = 0.0
                 , TransferOutput with
                     receiver = arbiter
                     amount = arbiterPaymentAmount
                     lock = None
                     receiverFeeRatio = 1.0
                 ]
               upgrade = Some ()
         exerciseAppTransfer transferContext transfer

-- | This matches the example in the design doc
--  https://docs.google.com/document/d/12cagZTzODP4rgEwDQ3lqoolh5ls2chXZ3ctcgH8Hl28/edit#heading=h.hivyhhs3xqs9
test : Script ()
test = do
  -- bootstrap app
  app <- setupApp

  runNextIssuance app
  runCoinDepositBots app

  alice <- setupUser app "alice" app.svc
  arbiter <- setupUser app "arbiter" app.svc
  featureApp app arbiter

  -- retrieve the config
  config <- getCoinConfig app
  let transferConfig = config.transferConfig

  -- start the example

  tap app alice 1500.0

  escrow <- submitUser arbiter.userId $ createCmd (Escrow app.svc arbiter.primaryParty alice.primaryParty)

  t0 <- getTime
  (_, c0) <- getLatestOpenRound app

  let lockedCoinAmount = 1000.25
  lockTo1 app alice arbiter.primaryParty lockedCoinAmount (days 90)

  -- check rewards that are issued for the locking tx
  [(_, appRewardCoupon)] <- queryFilter @AppRewardCoupon app.svc (\reward -> reward.round.number == 2)
  appRewardCoupon === AppRewardCoupon with
    svc = app.svc
    provider = alice.primaryParty
    featured = False
    amount = transferConfig.createFee.fee + transferConfig.lockHolderFee.fee
    round = Round 2

  [(lockedCoin, _)] <- query @LockedCoin alice.primaryParty
  -- advance 40k rounds
  runNextIssuance app
  skipNRounds app 39_999
  (_, c1) <- getLatestOpenRound app

  let refreshCoinAmount = 5.0
  pay app alice alice.primaryParty refreshCoinAmount
  -- check reward issued by this payment
  [(_, appRewardCoupon)] <- queryFilter @AppRewardCoupon app.svc (\reward -> reward.round.number == 40002)
  appRewardCoupon === AppRewardCoupon with
    svc = app.svc
    provider = alice.primaryParty
    featured = False
    amount = transferConfig.createFee.fee
    round = Round 40002

  [(paymentCoin, _)] <- queryFilter @Coin alice.primaryParty (\c -> c.amount.initialAmount == refreshCoinAmount)

  -- advance 10k rounds
  runNextIssuance app
  skipNRounds app 9_999

  (_, c2) <- getLatestOpenRound app

  prevCoinCids <- map fst <$> query @Coin app.svc
  prevLockedCoinCids <- map fst <$> query @LockedCoin app.svc

  normalizedBalanceBeforeTransfer <- getNormalizedBalance app.svc

  transferContext <- getAppTransferContext app arbiter
  result <- submitUser alice.userId $ exerciseCmd escrow Refresh with
    lockedCoin
    paymentCoin
    transferContext

  normalizedBalanceAfterTransfer <- getNormalizedBalance app.svc

  let lockedCoinFee = transferConfig.createFee.fee + transferConfig.lockHolderFee.fee
      transferredCoinFee =
        transferConfig.createFee.fee
        + chargeSteppedRate transferConfig.transferFee arbiterPaymentAmount
      holdingFees =
        (chargeRatePerRound transferConfig.holdingFee (c2.round `subRound` c1.round)
        + chargeRatePerRound transferConfig.holdingFee (c2.round `subRound` c0.round)) -- holding fees
      inputCoinHoldingFees = transferConfig.holdingFee.rate * 2.0 -- there are 2 input coins
      outputCoinHoldingFees = transferConfig.holdingFee.rate * 3.0  -- there are 2 output coins + 1 coin for the change
      outputFees = [lockedCoinFee, transferredCoinFee]
      senderChangeAmount =
        refreshCoinAmount
        - arbiterPaymentAmount
        - holdingFees
        - lockedCoinFee
        - transferConfig.createFee.fee -- fee for returning change
        -- no subtraction of transferredCoinFee as that fee is paid by the receiver

  let ignoreBalanceChanges = result.summary with balanceChanges = Map.empty
  ignoreBalanceChanges === TransferSummary with
    inputAppRewardAmount = 0.0
    inputValidatorRewardAmount = 0.0
    inputValidatorFaucetAmount = Some 0.0
    inputSvRewardAmount = 0.0
    inputCoinAmount = refreshCoinAmount + lockedCoinAmount
    balanceChanges = Map.empty
    holdingFees
    outputFees
    senderChangeAmount
    senderChangeFee = transferConfig.createFee.fee
    coinPrice = 1.0

  let totalBalanceChange = sum $ Map.values result.summary.balanceChanges

  totalBalanceChange.changeToHoldingFeesRate  === outputCoinHoldingFees - inputCoinHoldingFees
  totalBalanceChange.changeToInitialAmountAsOfRoundZero  === normalizedBalanceAfterTransfer - normalizedBalanceBeforeTransfer

  allCoins <- query @Coin app.svc
  allLockedCoins <- query @LockedCoin app.svc
  let newCoins = map snd $ filter (\(cid, _) -> cid `notElem` prevCoinCids) allCoins
      newLockedCoins = map snd $ filter (\(cid, _) -> cid `notElem` prevLockedCoinCids) allLockedCoins
  length newCoins === 2
  length newLockedCoins === 1

  let Some newLocked = head newLockedCoins
      Some change = find (\c -> c.owner == alice.primaryParty) newCoins
      Some payment = find (\c -> c.owner == arbiter.primaryParty) newCoins
  newLocked === LockedCoin with
    lock = TimeLock with
      holders = [arbiter.primaryParty]
      expiresAt = t0 `addRelTime` days 180
    coin = Coin with
      svc = app.svc
      owner = alice.primaryParty
      amount = expiringAmount transferConfig.holdingFee 1000.25 c2.round
      upgrade = Some ()
  change === Coin with
    svc = app.svc
    owner = alice.primaryParty
    amount = expiringAmount transferConfig.holdingFee senderChangeAmount c2.round
    upgrade = Some ()

  payment === Coin with
    svc = app.svc
    owner = arbiter.primaryParty
    amount =
      let amount = arbiterPaymentAmount - transferredCoinFee
      in expiringAmount transferConfig.holdingFee amount c2.round
    upgrade = Some ()

  -- check app reward issued by the escrow refresh
  [(_, appRewardCoupon)] <- queryFilter @AppRewardCoupon app.svc (\reward -> reward.round.number == 50002)
  appRewardCoupon === AppRewardCoupon with
    svc = app.svc
    provider = arbiter.primaryParty
    featured = True
    amount =
      -- rewards are issued for all output fees, but not the senderChangeFee
      sum outputFees +
      transferConfig.extraFeaturedAppRewardAmount
    round = Round 50002

  -- check that the 'arbiter' does not receive featured app rewards when he's the provider
  runNextIssuance app
  let reimbursementAmount = 0.5
  pay app arbiter alice.primaryParty reimbursementAmount

  [(_, appReward)] <- queryFilter @AppRewardCoupon app.svc (\reward -> reward.round.number == 50003)
  appReward === AppRewardCoupon with
    svc = app.svc
    provider = arbiter.primaryParty
    featured = False -- not featured despite presenting their app right as part of the 'pay' function
    amount = transferConfig.createFee.fee + chargeSteppedRate transferConfig.transferFee reimbursementAmount
    round = Round 50003

  return ()
