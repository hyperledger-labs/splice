module CC.V2Test.Coin where

import Prelude hiding (forA)

import DA.Action (foldlA)
import DA.Exception
import DA.Foldable (forA_)
import qualified DA.Set as Set
import DA.Traversable (forA)
import DA.Time

import CC.CoinConfig
import CC.Expiry
import CC.Schedule
import CC.Fees
import CC.Issuance
import CC.Round
import CC.Util

import CC.Coin as Coin

import qualified CC.API.V1.Coin as API
import qualified CC.API.V1.Round as API

import CN.Util.Assert

-- | A version of Canton Coin intended for testing upgrades.
-- It is a copy of Coin at the time of writing, with a minor change in an assertion message

template CoinV2Test
  with
    svc : Party
    owner : Party
    amount : ExpiringAmount
  where
    signatory svc, owner
    ensure validExpiringAmount amount

    interface instance API.Coin for CoinV2Test where
      view = API.CoinView with ..

    choice CoinV2Test_Expire : Party
      with
        roundCid : ContractId OpenMiningRound
        coinRulesCid : ContractId API.CoinRules
      -- For simplicity and to communicate this as the standard-case, we only allow the SVC to expire coins (see #1789 for full context)
      controller svc
      do coinRules <- view <$> fetch coinRulesCid
         requireChoiceIsEnabled "Upgraded Coin_Expire" (\c -> c.enable_Coin_Expire) coinRules
         requireCoinV2TestExpiredForAllOpenRounds roundCid this
         return owner

template LockedCoinV2Test
  with
    coin : CoinV2Test
    lock : API.TimeLock
  where
    signatory lock.holders, signatory coin

    interface instance API.LockedCoin for LockedCoinV2Test where
      view = API.LockedCoinView with
        lock
        -- Need to qualify view here, see https://github.com/digital-asset/daml/issues/15459
        coin = DA.Internal.Desugar.view (toInterface @API.Coin coin)

      lockedCoin_OwnerExpireLock coinRulesCid openRoundCid = do
        coinRules <- view <$> fetch coinRulesCid
        openMiningRound <- exercise openRoundCid (API.OpenMiningRound_Fetch coin.owner)
        requireChoiceIsEnabled "LockedCoin_OwnerExpireLock" (\c -> c.enable_LockedCoin_OwnerExpireLock) coinRules
        t <- getTime
        require "Lock is expired" (lock.expiresAt < t)
        coinCid <- toInterfaceContractId <$> create coin
        return API.CoinCreateSummary with
          coin = coinCid
          coinPrice = openMiningRound.coinPrice

      lockedCoin_Unlock coinRulesCid openRoundCid = do
        coinRules <- view <$> fetch coinRulesCid
        openMiningRound <- exercise openRoundCid (API.OpenMiningRound_Fetch coin.owner)
        requireChoiceIsEnabled "LockedCoin_Unlock" (\c -> c.enable_LockedCoin_Unlock) coinRules
        coinCid <- toInterfaceContractId <$> create coin
        return API.CoinCreateSummary with
          coin = coinCid
          coinPrice = openMiningRound.coinPrice

    choice LockedCoinV2Test_ExpireCoin : Party
      with
        roundCid : ContractId OpenMiningRound
        coinRulesCid : ContractId API.CoinRules
      -- For simplicity and to communicate this as the standard-case, we only allow the SVC to expire coins (see #1789 for full context)
      controller coin.svc
      do coinRules <- view <$> fetch coinRulesCid
         requireChoiceIsEnabled "LockedCoin_ExpireCoin" (\c -> c.enable_LockedCoin_ExpireCoin) coinRules
         requireChoiceIsEnabled "Coin_Expire" (\c -> c.enable_Coin_Expire) coinRules
         t <- getTime
         require "Lock is expired" (lock.expiresAt < t)
         requireCoinV2TestExpiredForAllOpenRounds roundCid coin
         return coin.owner

-- A version of CoinRules intended for testing upgrades.
-- It is a copy of CoinRules at the time of writing, except that the bootstrap_rounds choice has been removed.
template CoinRulesV2Test
  with
    svc : Party
    configSchedule : Schedule Time (CoinConfig USD)
    enabledChoices : API.EnabledChoices
    isDevNet : Bool
    lock: Bool
  where
    ensure validSchedule configSchedule validCoinConfig

    signatory svc

    interface instance API.CoinRules for CoinRulesV2Test where
      view = API.CoinRulesView with ..
      coinrules_Transfer_Controllers = Set.toList . transferControllers
      coinrules_ComputeFees context sender outputs = do
        requireChoiceIsEnabled "CoinRules_ComputeFees" (\c -> c.enable_CoinRules_ComputeFees) (view $ toInterface @API.CoinRules this)
        computeFees svc context sender outputs
      coinrules_Transfer coinRulesCid transfer context = do
        requireChoiceIsEnabled "CoinRules_Transfer" (\c -> c.enable_CoinRules_Transfer) (view $ toInterface @API.CoinRules this)
        executeTransferV2Test coinRulesCid context svc transfer

    -- A choice for the SVC to mint coin for the cases where the
    -- collective rules allow for that; e.g., when redeeming SVC rewards.
    nonconsuming choice CoinRulesV2Test_Mint: ContractId Coin
      with
        receiver: Party
        amount: Decimal
        openRound: ContractId OpenMiningRound
      controller svc, receiver
      do
        openRound <- fetch openRound
        let transferConfigCC = transferConfigCCFromOpenRound openRound
            expiringAmount = ExpiringAmount with
                        initialAmount = amount
                        createdAt = openRound.round
                        ratePerRound = transferConfigCC.holdingFee
        create Coin with
                  owner = receiver
                  amount = expiringAmount
                  ..

    nonconsuming choice CoinRulesV2Test_DevNet_Tap: ContractId Coin
      with
        receiver: Party
        amount: Decimal
        openRound: ContractId OpenMiningRound
      controller receiver
      do require "isDevNet flag is true" isDevNet
         requireChoiceIsEnabled "CoinRules_DevNet_Tap" (\c -> c.enable_CoinRules_DevNet_Tap) (view $ toInterface @API.CoinRules this)
         exercise self CoinRulesV2Test_Mint with ..

    nonconsuming choice CoinRulesV2Test_DevNet_FeatureApp : ContractId FeaturedAppRight
      with
        provider : Party
      controller provider
      do require "isDevNet flag is true" isDevNet
         create FeaturedAppRight with svc; provider

    nonconsuming choice CoinRulesV2Test_AdvanceOpenMiningRounds
      : (ContractId SummarizingMiningRound, ContractId OpenMiningRound)
      with
        coinPrice : Decimal
        roundToArchiveCid : ContractId OpenMiningRound
        middleRoundCid : ContractId OpenMiningRound
        latestRoundCid : ContractId OpenMiningRound
      controller svc
      do
        roundToArchive <- fetch roundToArchiveCid
        middleRound <- fetch middleRoundCid
        latestRound <- fetch latestRoundCid

        now <- getTime
        require "middleRound is one after roundToArchive" (middleRound.round.number == roundToArchive.round.number + 1)
        require "latestRound is one after middleRound" (latestRound.round.number == middleRound.round.number + 1)
        require "roundToArchive is past targetCloseAt" (roundToArchive.targetClosesAt <= now)
        require "latestRound is open" (latestRound.opensAt <= now)
        require "middle round has been open for >= 1 tick" (addRelTime middleRound.opensAt middleRound.tickDuration <= now)

        -- archive and create the rounds
        archive roundToArchiveCid
        newSummarizingRound <- create SummarizingMiningRound with
            svc
            round = roundToArchive.round
            issuanceConfig = roundToArchive.issuanceConfig
            tickDuration = roundToArchive.tickDuration
        newOpenRound <- do
          let configUsd = getValueAsOf now configSchedule
              tickDuration = configUsd.tickDuration
              -- round is in pre-fetchable state for at least 1 tick and can only open with 1-tick difference between latestRound's opensAt
              opensAt = addRelTime (max now latestRound.opensAt) tickDuration
              newOpenRoundIssuingFor = latestRound.issuingFor + latestRound.tickDuration
          create OpenMiningRound with
              svc
              round = API.Round (latestRound.round.number + 1)
              coinPrice
              opensAt
              -- round is open for two ticks.
              targetClosesAt = addRelTime opensAt (tickDuration + tickDuration)
              -- We advance the time for which the SVC has been issuing independent of how real world advances.
              -- Note that given the checks above the real time can only be slower.
              issuingFor = newOpenRoundIssuingFor
              transferConfigUsd = configUsd.transferConfig
              issuanceConfig = getValueAsOf newOpenRoundIssuingFor configUsd.issuanceCurve
              tickDuration
        return (newSummarizingRound, newOpenRound)

    nonconsuming choice CoinRulesV2Test_MiningRound_StartIssuing
      : ContractId IssuingMiningRound
      with
        miningRoundCid : ContractId SummarizingMiningRound
        -- The amount of coin burned in this round.
        summary : OpenMiningRoundSummary
      controller svc
      do
        -- archive summarizing mining round
        miningRound <- fetch miningRoundCid
        archive miningRoundCid
        require "SVC matches" (miningRound.svc == svc)
        validateOpenMiningRoundSummary summary

        let params = computeIssuingRoundParameters miningRound.tickDuration miningRound.issuanceConfig summary

        -- record reward for the SVC
        create SvcReward with
          svc
          round = miningRound.round
          amount = params.coinsToIssueToSvc

        -- record unclaimed reward contract
        create UnclaimedReward with
          svc
          amount = params.unclaimedValidatorRewards + params.unclaimedAppRewards

        -- create issuing round
        now <- getTime
        let tickDuration = miningRound.tickDuration
        let opensAt = addRelTime now tickDuration
        let targetClosesAt = addRelTime opensAt (tickDuration + tickDuration)

        create IssuingMiningRound with
          svc
          round = miningRound.round
          opensAt = opensAt
          targetClosesAt = targetClosesAt
          issuancePerValidatorRewardCoupon = params.issuancePerValidatorRewardCoupon
          issuancePerFeaturedAppRewardCoupon = params.issuancePerFeaturedAppRewardCoupon
          issuancePerUnfeaturedAppRewardCoupon = params.issuancePerUnfeaturedAppRewardCoupon


    nonconsuming choice CoinRulesV2Test_MiningRound_Close
      : ContractId ClosedMiningRound
      with
        issuingRoundCid : ContractId IssuingMiningRound
      controller svc
      do
        -- archive issuing mining round
        now <- getTime
        issuingRound <- fetch issuingRoundCid
        archive issuingRoundCid
        require "SVC matches" (issuingRound.svc == svc)
        require "Mining round is past targetClosesAt" (issuingRound.targetClosesAt <= now)

        -- create closed round
        create ClosedMiningRound with
          svc
          issuancePerValidatorRewardCoupon = issuingRound.issuancePerValidatorRewardCoupon
          issuancePerFeaturedAppRewardCoupon = issuingRound.issuancePerFeaturedAppRewardCoupon
          issuancePerUnfeaturedAppRewardCoupon = issuingRound.issuancePerUnfeaturedAppRewardCoupon
          round = issuingRound.round

    nonconsuming choice CoinRulesV2Test_MiningRound_Archive
      : ()
      with
        closedRoundCid : ContractId ClosedMiningRound
      controller svc
      do
        -- archive closed mining round
        miningRound <- fetch closedRoundCid
        archive closedRoundCid
        require "SVC matches" (miningRound.svc == svc)

    -- Batch expiry of unclaimed rewards for a specific claimed round
    nonconsuming choice CoinRulesV2Test_ClaimExpiredRewards
      : Optional (ContractId UnclaimedReward)
      with
        closedRoundCid : ContractId ClosedMiningRound
        validatorCouponCids : [ContractId ValidatorRewardCoupon]
        appCouponCids : [ContractId AppRewardCoupon]
      controller svc
      do
        -- retrieve round
        closedRound <- fetch closedRoundCid
        require "SVC matches" (closedRound.svc == svc)

        -- expire validator rewards and compute their unclaimed rewards
        expiredValidatorRewards <- forA validatorCouponCids $ \validatorCouponCid -> do
          exercise validatorCouponCid ValidatorRewardCoupon_SvcExpire with closedRoundCid

        let validatorRewards = sum expiredValidatorRewards

        -- expire app rewards and compute their unclaimed rewards
        expiredAppRewards <- forA appCouponCids $ \appCouponCid -> do
          exercise appCouponCid AppRewardCoupon_SvcExpire with closedRoundCid

        let featuredAppRewards = sum [ amount | (featured, amount) <- expiredAppRewards, featured ]
        let unfeaturedAppRewards = sum [ amount | (featured, amount) <- expiredAppRewards, not featured ]

        -- create unclaimed reward for the total
        let amount =
              validatorRewards * closedRound.issuancePerValidatorRewardCoupon +
              featuredAppRewards * closedRound.issuancePerFeaturedAppRewardCoupon +
              unfeaturedAppRewards * closedRound.issuancePerUnfeaturedAppRewardCoupon
        if (amount <= 0.0)
          then pure None
          else Some <$> create UnclaimedReward with svc; amount

    -- Batch merge of unclaimed rewards
    nonconsuming choice CoinRulesV2Test_MergeUnclaimedRewards
      : ContractId UnclaimedReward
      with
        unclaimedRewardCids : [ContractId UnclaimedReward]
      controller svc
      do
        require "More than one unclaimed reward contracts" (length unclaimedRewardCids > 1)

        -- fetch and archive all given rewards
        archivedAmounts <- forA unclaimedRewardCids $ \unclaimedRewardCid -> do
          unclaimedReward <- fetch unclaimedRewardCid
          archive unclaimedRewardCid
          require "SVC matches" (unclaimedReward.svc == svc)
          pure unclaimedReward.amount

        -- create a new unclaimed reward over the total
        create UnclaimedReward with
          svc
          amount = sum archivedAmounts

    -- This allows fetchByKey-style fetches if you have readAs
    -- but not actAs claims.
    nonconsuming choice CoinRulesV2Test_Fetch
      : (ContractId CoinRulesV2Test, CoinRulesV2Test)
      with
        p : Party
      controller p
      do pure (self, this)

    choice CoinRulesV2Test_SetEnabledChoices : ContractId CoinRulesV2Test
      with
        newEnabledChoices : API.EnabledChoices
      controller svc
      do create this with enabledChoices = newEnabledChoices

    choice CoinRulesV2Test_ConfigSchedule : ContractId CoinRulesV2Test
      with
        newConfigSchedule : Schedule Time (CoinConfig USD)
      controller svc
      do forA_ (nextChangeScheduledAt newConfigSchedule) $ \t -> do
           now <- getTime
           require "Next change is not scheduled in the future" (now < t)
         create this with configSchedule = newConfigSchedule

requireCoinV2TestExpiredForAllOpenRounds : ContractId OpenMiningRound -> CoinV2Test -> Update ()
requireCoinV2TestExpiredForAllOpenRounds roundCid coin = do
  round <- fetch roundCid
  require "SVC of the round matches SVC of the coin" (round.svc == coin.svc)
  -- Note: we exploit that there are exactly three open rounds active at any
  -- point in time; and we ensure that a coin can be expired as soon as it can
  -- definitely not be used as an input to transfer anymore.
  require "Coin is expired" (isCoinV2TestExpired round coin.amount)

isCoinV2TestExpired : OpenMiningRound -> ExpiringAmount -> Bool
isCoinV2TestExpired round coinAmount =
  let expiresAtRound = amountExpiresAt coinAmount
  in case expiresAtRound of
    -- Expiring round cannot be represented by API.Round due to coin amount is too large.
    -- This coin will never expire unless it is broken into smaller amount.
    Singleton x -> x.number <= round.round.number - 2
    AfterMaxBound -> False

executeTransferV2Test : ContractId API.CoinRules -> API.TransferContext -> Party -> API.Transfer -> Update API.TransferResult
executeTransferV2Test coinRulesCid context svc t = do
  -- compute summaries
  csum <- summarizeAndValidateContext context svc t
  isum <- summarizeAndConsumeInputsV2Test coinRulesCid csum svc t.sender t.inputs
  osum <- preprocessOutputs csum.config t.sender t.outputs
  summary <- summarizeTransfer csum.openRound csum.config isum osum
  -- check that overall transfer constraints are satisfied
  case checkTransferConstraints t summary csum.config of
    Left err -> throw (InvalidTransfer err)
    Right _ -> pure ()

  -- issue rewards for burns
  issueRewards csum t.sender t.provider summary
  -- record outputs
  (createdCoins, senderChangeCoin) <-
    createTransferOutputsV2Test csum.openRound csum.config svc t.sender summary osum

  return API.TransferResult with
    round = csum.openRound.round
    summary = summary
    ..

createTransferOutputsV2Test
  : OpenMiningRound -> TransferConfig CC -> Party -> Party -> API.TransferSummary -> TransferOutputsSummary
  -> Update ([API.CreatedCoin], Optional (ContractId API.Coin))
createTransferOutputsV2Test currentOpenRound transferConfigCC svc sender summary preprocessedOutputs = do
    outputCoins <- mapA createOutput preprocessedOutputs
    senderChangeCoin <- createSenderChange
    return (outputCoins, senderChangeCoin)
  where
    createSenderChange
      | summary.senderChangeAmount <= 0.0 = return None
      | otherwise =
          Some . toInterfaceContractId <$> create CoinV2Test with
            svc
            owner = sender
            amount = expiringAmount transferConfigCC.holdingFee summary.senderChangeAmount currentOpenRound.round
    createOutput out = do
      let coin = CoinV2Test with
            svc
            owner = out.owner
            amount = expiringAmount transferConfigCC.holdingFee out.amount currentOpenRound.round

      case out.lock of
        None -> API.TransferResultCoin . toInterfaceContractId <$> create coin
        Some lock -> do
          -- We require the lock to expire before the coin to allow CN app authors to
          -- assume that a locked coin is never archived by the SVC while the lock is held.
          require "lock expires before coin"
            (doesLockExpireBeforeCoin currentOpenRound lock coin.amount currentOpenRound.tickDuration)
          API.TransferResultLockedCoin . toInterfaceContractId <$> create LockedCoinV2Test with coin; lock

fetchCoinDetails : ContractId API.Coin -> Update (ExpiringAmount, Party, Party)
fetchCoinDetails coinCid = do
  r <- fetchFromInterface @Coin coinCid
  case r of
    Some (_, c) -> pure (c.amount, c.owner, c.svc)
    None -> do
      r <- fetchFromInterface @CoinV2Test coinCid
      case r of
        Some (_, c) -> pure (c.amount, c.owner, c.svc)
        None -> abort "unknown template"

summarizeAndConsumeInputsV2Test
  : ContractId API.CoinRules -> TransferContextSummary -> Party -> Party -> [API.TransferInput] -> Update TransferInputsSummary
summarizeAndConsumeInputsV2Test coinRulesCid csum svc sender inps = do
    foldlA (summarizeAndConsumeInput csum.openRound.round) initialSummary inps
  where
    initialSummary = TransferInputsSummary with
      totalCoinAmount = 0.0
      totalAppRewardAmount = 0.0
      totalValidatorRewardAmount = 0.0
      totalHoldingFees = 0.0
      amountArchivedAsOfRoundZero = 0.0
      changeToHoldingFeesRate = 0.0

    summarizeAndConsumeInput round s (API.InputCoin coinCid) = do
      -- fetch and archive
      (coinAmount, coinOwner, coinSvc) <- fetchCoinDetails coinCid
      archive coinCid
      -- check validity
      require "SVC matches" (svc == coinSvc)
      require "Sender matches owner" (sender == coinOwner)
      -- compute balance change
      let amount = actualAmount round coinAmount
          holdingFee = coinAmount.initialAmount - amount
      return TransferInputsSummary with
        totalCoinAmount = s.totalCoinAmount + coinAmount.initialAmount
        totalAppRewardAmount = s.totalAppRewardAmount
        totalValidatorRewardAmount = s.totalValidatorRewardAmount
        totalHoldingFees = s.totalHoldingFees + holdingFee
        amountArchivedAsOfRoundZero = s.amountArchivedAsOfRoundZero
        changeToHoldingFeesRate = s.changeToHoldingFeesRate

    summarizeAndConsumeInput _round s (API.InputAppRewardCoupon couponCid) = do
      -- fetch and archive
      (_, coupon) <- downcastInterface @AppRewardCoupon "AppRewardCoupon" couponCid
      archive couponCid
      -- check validity
      require "SVC matches" (svc == coupon.svc)
      require "Sender matches app provider" (sender == coupon.provider)
      -- compute balance change
      miningRound <- getIssuingMiningRound csum coupon.round
      let issuancePerCoupon
            | coupon.featured = miningRound.issuancePerFeaturedAppRewardCoupon
            | otherwise = miningRound.issuancePerUnfeaturedAppRewardCoupon
      return TransferInputsSummary with
        totalCoinAmount = s.totalCoinAmount
        totalAppRewardAmount = s.totalAppRewardAmount + coupon.amount * issuancePerCoupon
        totalValidatorRewardAmount = s.totalValidatorRewardAmount
        totalHoldingFees = s.totalHoldingFees
        amountArchivedAsOfRoundZero = s.amountArchivedAsOfRoundZero
        changeToHoldingFeesRate = s.changeToHoldingFeesRate

    summarizeAndConsumeInput _round s (API.InputValidatorRewardCoupon couponCid) = do
      -- fetch and archive
      (couponCid, coupon) <- downcastInterface @ValidatorRewardCoupon "ValidatorRewardCoupon" couponCid
      do
        -- we must use the validator right to actually archive the coupon of the user
        rightCid <- getValidatorRight csum coupon.user
        exercise couponCid ValidatorRewardCoupon_ArchiveAsValidator with
          validator = sender
          rightCid
          coinRulesCid
      -- check coupon
      require "SVC matches" (svc == coupon.svc)
      -- compute balance change
      miningRound <- getIssuingMiningRound csum coupon.round
      return TransferInputsSummary with
        totalCoinAmount = s.totalCoinAmount
        totalAppRewardAmount = s.totalAppRewardAmount
        totalValidatorRewardAmount = s.totalValidatorRewardAmount + coupon.amount * miningRound.issuancePerValidatorRewardCoupon
        totalHoldingFees = s.totalHoldingFees
        amountArchivedAsOfRoundZero = s.amountArchivedAsOfRoundZero
        changeToHoldingFeesRate = s.changeToHoldingFeesRate
