module CC.V2Test.Scripts.TestCoinUpgrade where

import Daml.Script
import DA.Assert
import DA.Time
import DA.Foldable (forA_)
import qualified CC.API.V1.Coin as API
import CC.Scripts.Util
import CC.Scripts.Parameters
import CC.V2Test.Coin
import CC.Coin
import CC.Issuance
import CC.Round

setupForCoinUpgradeTest: Script (CCApp, CCUser, CCUser, Party)
setupForCoinUpgradeTest = do
  app <- setupApp

  advanceToIssuanceWithPrice app 1.0
  runCoinDepositBots app

  _ <- submit app.svc $ createCmd CoinRulesV2Test with
      configSchedule = defaultCoinConfigSchedule
      enabledChoices = API.enableAllChoices
      isDevNet = True
      svc = app.svc

  validator <- setupValidator app "oldValidator"

  alice <- setupUser app "alice" validator
  bob <- setupUser app "bob" validator

  pure (app, alice, bob, validator)


testUpgrade: Script ()
testUpgrade = do

  (app, alice, bob, _) <- setupForCoinUpgradeTest

  oCid <- tap app alice 100.0

  context <- getTransferContext app alice None
  (newCoinRules, _) <- fetchCoinRulesV2TestByKey app.svc
  let newCoinRulesAPI = toInterfaceContractId @API.CoinRules newCoinRules

  let transferAmount = 10.0
  -- Transfer from an old coin
  _ <- submitMulti [alice.primaryParty, bob.primaryParty] [app.svc] $
      exerciseCmd newCoinRulesAPI API.CoinRules_Transfer with
          transfer = API.Transfer with
              sender = alice.primaryParty
              provider = alice.primaryParty
              inputs = map (\c -> API.InputCoin $ toInterfaceContractId c)[oCid]
              outputs = [ API.TransferOutput with
                      receiver = bob.primaryParty
                      receiverFeeRatio = 0.0
                      amount = transferAmount
                      lock = None
                  ]
          context = context

  -- Transfer outputs should be CoinV2Test coins
  [(aliceNewCid, aliceNewCoin : CoinV2Test)] <- query @CoinV2Test alice.primaryParty
  aliceNewCoin.amount.initialAmount === 89.84
  [(_, bobNewCoin : CoinV2Test)] <- query @CoinV2Test bob.primaryParty
  bobNewCoin.amount.initialAmount === 10.0

  let transferAmount = 10.0
  -- Transfer from a new coin
  _ <- submitMulti [alice.primaryParty, bob.primaryParty] [app.svc] $
      exerciseCmd newCoinRulesAPI API.CoinRules_Transfer with
          transfer = API.Transfer with
              sender = alice.primaryParty
              provider = alice.primaryParty
              inputs = map (\c -> API.InputCoin $ toInterfaceContractId c)[aliceNewCid]
              outputs = [ API.TransferOutput with
                      receiver = bob.primaryParty
                      receiverFeeRatio = 0.0
                      amount = transferAmount
                      lock = None
                  ]
          context = context

  [(aliceNewCid, aliceNewCoin : CoinV2Test)] <- query @CoinV2Test alice.primaryParty
  aliceNewCoin.amount.initialAmount === 79.68
  bobCoins <- query @CoinV2Test bob.primaryParty
  map (\(_, c) -> c.amount.initialAmount) bobCoins === [10.0, 10.0]

  -- Mixed transfer
  oCid <- tap app alice 100.0
  let oCidInt = toInterfaceContractId oCid
  let nCidInt = toInterfaceContractId aliceNewCid
  -- Transfer from a mix of old and new coin
  _ <- submitMulti [alice.primaryParty, bob.primaryParty] [app.svc] $
      exerciseCmd newCoinRulesAPI API.CoinRules_Transfer with
          transfer = API.Transfer with
              sender = alice.primaryParty
              provider = alice.primaryParty
              inputs = map (\c -> API.InputCoin c)[oCidInt, nCidInt]
              outputs = [ API.TransferOutput with
                      receiver = bob.primaryParty
                      receiverFeeRatio = 0.0
                      amount = transferAmount
                      lock = None
                  ]
          context = context

  [(_, aliceNewCoin : CoinV2Test)] <- query @CoinV2Test alice.primaryParty
  aliceNewCoin.amount.initialAmount === 169.52
  bobCoins <- query @CoinV2Test bob.primaryParty
  map (\(_, c) -> c.amount.initialAmount) bobCoins === [10.0, 10.0, 10.0]

  pure ()


-- TODO(#3707): everything below is copied from other places, replacing all CoinRules with CoinRulesV2Test.
-- Consider cleaning this up and reducing code duplication here.

tapThroughV2Test : CCApp -> CCUser -> Decimal -> Script (ContractId Coin)
tapThroughV2Test app user amount = do
  (openRound, _) <- getLatestOpenRound app
  submitExerciseCoinRulesV2TestByKey' app user CoinRulesV2Test_DevNet_Tap with
    receiver = user.primaryParty
    amount
    openRound


-- Advance issuance such that the next transfers use a round with the given coin-price
-- using the upgraded V2Test version of CoinRules
advanceToIssuanceWithPriceThroughV2Test : CCApp -> Decimal -> Script ()
advanceToIssuanceWithPriceThroughV2Test app coinPrice = do
  runNextIssuanceThroughV2TestInternal app coinPrice
  -- the round with the new price only becomes effective after one tick
  -- we simulate that by runing another issuance, but run the coin deposit bots before
  -- to collect eventual rewards
  runCoinDepositBots app
  runNextIssuanceThroughV2TestInternal app coinPrice


runNextIssuanceThroughV2TestInternal : CCApp -> Decimal -> Script ()
runNextIssuanceThroughV2TestInternal app coinPrice = do
  now <- getTime
  setTime (addRelTime now defaultCoinConfig.tickDuration)
  -- expire rewards for closed rounds
  closedRounds <- query @ClosedMiningRound app.svc
  forA_ closedRounds $ \(closedRoundCid, miningRound) -> do
    -- app rewards
    rewards <- queryFilter @AppRewardCoupon app.svc (\r -> r.round == miningRound.round)
    forA_ rewards $ \(rcid, _) ->
      submit app.svc $ exerciseCmd rcid AppRewardCoupon_SvcExpire with closedRoundCid
    -- validator rewards
    rewards <- queryFilter @ValidatorRewardCoupon app.svc (\r -> r.round == miningRound.round)
    forA_ rewards $ \(rcid, _) ->
      submit app.svc $ exerciseCmd rcid ValidatorRewardCoupon_SvcExpire with closedRoundCid
    -- the closed round
    submitExerciseCoinRulesV2TestByKey app [app.svc] [] CoinRulesV2Test_MiningRound_Archive with
      closedRoundCid


  -- close issuing rounds that are ready for close
  imcs <- queryFilter @IssuingMiningRound app.svc (\r -> r.targetClosesAt <= now)
  forA_ imcs $ \(issuingRoundCid, _) ->
    submitExerciseCoinRulesV2TestByKey app [app.svc] [] CoinRulesV2Test_MiningRound_Close with
      issuingRoundCid

  -- transition the oldest OpenMiningRound into a SummarizingMiningRound and
  -- create a new OpenMiningRound
  [(roundToArchiveCid, roundToArchive), (r2Cid, _), (r3Cid, _)] <- getActiveOpenRoundsSorted app
  (closingRoundCid, _) <- submitExerciseCoinRulesV2TestByKey app [app.svc] [] CoinRulesV2Test_AdvanceOpenMiningRounds with
    coinPrice
    roundToArchiveCid
    middleRoundCid = r2Cid
    latestRoundCid = r3Cid

  -- compute total burn
  appRewardCoupons <- queryFilter @AppRewardCoupon app.svc (\bc -> bc.round == roundToArchive.round)
  validatorRewardCoupons <- queryFilter @ValidatorRewardCoupon app.svc (\bc -> bc.round == roundToArchive.round)

  let summary = OpenMiningRoundSummary with
        totalValidatorRewardCoupons = sum [ c.amount | (_, c) <- validatorRewardCoupons]
        totalFeaturedAppRewardCoupons = sum [ c.amount | (_, c) <- appRewardCoupons, c.featured]
        totalUnfeaturedAppRewardCoupons = sum [ c.amount | (_, c) <- appRewardCoupons, not (c.featured)]

  -- create issuing mining round
  submitExerciseCoinRulesV2TestByKey app [app.svc] [] CoinRulesV2Test_MiningRound_StartIssuing with
    miningRoundCid = closingRoundCid
    summary

  pure ()

submitExerciseCoinRulesV2TestByKey : Choice CoinRulesV2Test c r => CCApp -> [Party] -> [Party] -> c -> Script r
submitExerciseCoinRulesV2TestByKey app actors readers arg = do
  (rules, _) <- fetchCoinRulesV2TestByKey app.svc
  -- TODO(#2957): remove read-as SVC.
  let adjustedReaders = (app.svc :: readers)
  submitMulti actors adjustedReaders $ exerciseCmd rules arg

submitExerciseCoinRulesV2TestByKey' : Choice CoinRulesV2Test c r => CCApp -> CCUser -> c -> Script r
submitExerciseCoinRulesV2TestByKey' app user arg = do
  (rules, _) <- fetchCoinRulesV2TestByKey app.svc
  submitUser user.userId $ exerciseCmd rules arg

fetchCoinRulesV2TestByKey : Party -> Script (ContractId CoinRulesV2Test, CoinRulesV2Test)
fetchCoinRulesV2TestByKey svc =
  queryCoinRulesV2TestByKey svc >>= \case
    None -> abort "No active CoinRules contract"
    Some rules -> pure rules

queryCoinRulesV2TestByKey : Party -> Script (Optional (ContractId CoinRulesV2Test, CoinRulesV2Test))
queryCoinRulesV2TestByKey svc = do
  coinRules <- query @CoinRulesV2Test svc
  case coinRules of
    [] -> pure None
    [coinRules] -> pure (Some coinRules)
    rules -> abort $ "Expected 0 or 1 CoinRules contracts but got " <> show rules
