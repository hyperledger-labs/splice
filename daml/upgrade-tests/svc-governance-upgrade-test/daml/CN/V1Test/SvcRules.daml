module CN.V1Test.SvcRules where

import DA.Action (void)
import DA.Foldable (forA_)
import DA.List as List
import qualified DA.Map as Map
import DA.Time

-- TODO(tech-debt) factor this one out of CC into its own library
import CN.Util.Assert
import CC.Coin
import CC.Round
import CC.API.V1.Round (Round(..))
import CC.DomainFees

import CC.ValidatorLicense
import CN.SvOnboarding

import CC.V1Test.Coin
import CN.SvcRules
import qualified CN.CometBft as CometBft


-- A version of SvcRules intended for testing upgrades. For now, we focus on an upgrade of the underlying CoinRules,
-- so the changes here compared to SvcRules are only those required for running against the upgraded
-- CoinRulesV1Test.
-- TODO(#4152): We currently do not tackle the coordination required for all SVs to upgrade to this version,
-- and instead assume they all start with this version loaded already (if configured to support the upgrade tests).

-- Types
---------


-- | A coin price agreed for the leader to create new open mining round.
template AgreedCoinPrice
  with
    svc : Party
    coinPrice : Decimal
  where
    ensure coinPrice > 0.0
    signatory svc

    -- | Update the agreed coin price
    choice AgreedCoinPrice_Update : ContractId AgreedCoinPrice
      with
        newCoinPrice : Decimal
      controller svc
      do create this with coinPrice = newCoinPrice

-- | Every action that requires confirmations must be inherently one-shot.
-- Each action must not be executable more than once.
-- An action that violates this rule could be executed twice by a malicious leader or
-- as the result of a race condition.
data ActionRequiringConfirmationV1Test
  = ARC_SvcRulesV1Test with
      svcAction : SvcRulesV1Test_ActionRequiringConfirmation
  | ARC_CoinRulesV1Test with
      coinRulesV1TestCid : ContractId CoinRulesV1Test
      coinRulesV1TestAction : CoinRulesV1Test_ActionRequiringConfirmation
  deriving (Eq, Show)

data CoinRulesV1Test_ActionRequiringConfirmation
  = CRARCV1Test_MiningRound_StartIssuing CoinRulesV1Test_MiningRound_StartIssuing
  | CRARCV1Test_MiningRound_Close CoinRulesV1Test_MiningRound_Close
  | CRARCV1Test_MiningRound_Archive CoinRulesV1Test_MiningRound_Archive
    -- ^ Confirmation ensures that it is only closed when there are no expired rewards left.
  deriving (Eq, Show)

data SvcRulesV1Test_ActionRequiringConfirmation
  = SRARCV1Test_AddMember SvcRulesV1Test_AddMember
  | SRARCV1Test_RemoveMember SvcRulesV1Test_RemoveMember
  | SRARCV1Test_ConfirmSvOnboarding SvcRulesV1Test_ConfirmSvOnboarding
  deriving (Eq, Show)


-- Workflow templates
---------------------

-- | A confirmation for the leader to take an action in the name of the SVC.
template ConfirmationV1Test with
    svc : Party
    confirmer : Party
    action : ActionRequiringConfirmationV1Test
    -- TODO(M3-46): add expiry
  where
    -- As for 'ElectionRequest' we only make the 'svc' a signatory.
    signatory svc


-- SV Collective rules
----------------------

-- | Rules governing the collective.
template SvcRulesV1Test with
    svc : Party        -- ^ The collective party representing this collective
    epoch : Int        -- ^ The number of leaders that have already been elected.
    nextMiningRound : Round
    members : Map.Map Party MemberInfo
    leader : Party
    config : SvcRulesConfig
  where
    ensure
      leader `Map.member` members &&
        unique (map (.name) (Map.values members)) &&
        config.numUnclaimedRewardsThreshold > 0

    -- NOTE: the members are not direct signatories as that would not give us the right fault-tolerance wrt
    -- validating choices on this contract. Instead, the members are indirect signatories by being backing
    -- members of the 'svc' collective party.
    signatory svc


    -- Membership management
    ------------------------

    choice SvcRulesV1Test_AddMember : ContractId SvcRulesV1Test
      with
        newMemberParty : Party
        newMemberName : Text
        reason : Text
      controller svc
      do
        require "Member party is new" (not $ newMemberParty `Map.member` members)
        require "Member name is new" (not $ newMemberName `elem` (map (.name) (Map.values members)))
        let info = MemberInfo with
              name = newMemberName
              joinedAsOfRound = nextMiningRound
              cometBftConfig = CometBft.emptySvNodeConfig
        create SvcRulesV1Test with
          svc
          epoch
          nextMiningRound
          leader
          members = Map.insert newMemberParty info members
          config

    choice SvcRulesV1Test_RemoveMember : ContractId SvcRulesV1Test
      with
        member : Party
        reason : Text
      controller svc
      do
        require "Member exists" (member `Map.member` members)
        create SvcRulesV1Test with
          svc
          epoch
          nextMiningRound
          leader
          -- NOTE: this immediate deletion also slashes that members share of the current round's issuance
          members = Map.delete member members
          config

    nonconsuming choice SvcRulesV1Test_AddConfirmedMember : ContractId SvcRulesV1Test
      with
        sv : Party
        svOnboardingConfirmedCid : ContractId SvOnboardingConfirmed
      controller sv
      do
        svOnboardingConfirmed <- fetch svOnboardingConfirmedCid
        archive svOnboardingConfirmedCid
        require "SVC matches" (svOnboardingConfirmed.svc == svc)
        require "SV matches" (svOnboardingConfirmed.svParty == sv)
        exercise self SvcRulesV1Test_AddMember with
          newMemberParty = sv
          newMemberName = svOnboardingConfirmed.svName
          reason = svOnboardingConfirmed.reason

    -- Leader election
    ------------------

    nonconsuming choice SvcRulesV1Test_RequestElection : ContractId ElectionRequest
      with
        requester : Party
        reason: ElectionRequestReason
        ranking : [Party]
      controller requester
      do
        -- TODO(M3-46): consider interaction with concurrent membership changes
        require "Requester is a collective member" (requester `Map.member` members)
        require "All members are ranked exactly once" (sort ranking == sort (Map.keys members))
        create ElectionRequest with
          ..

    choice SvcRulesV1Test_ElectLeader : ContractId SvcRulesV1Test
      with
        actor : Party
        requestCids : [ContractId ElectionRequest]
      controller actor
      do
        let summary = summarizeCollectiveV1Test this
        -- fetch, check, and archive all requests
        reqs <- forA requestCids $ \requestCid -> do
          req <- fetch requestCid
          archive requestCid
          require "Request is for this epoch" (req.epoch == epoch)
          require "Requestor is a collective member" (req.requester `Map.member` members)
          pure req
        let numVotes = length reqs
            numVoters = numVotes
            -- TODO(M3-46): consider whether that is the right number of votes to require
            -- as there might be more votes being taken into consideration
            numVotesForMajority = (summary.requiredNumVotes + 1) / 2
        require "Requests are from different members" (unique $ map (.requester) reqs)
        require "There are enough requests" (numVotes >= summary.requiredNumVotes)
        let rankings = [ (req.requester, req.ranking) | req <- reqs ]
            newLeader = instantRunOffVoting numVotesForMajority (numVoters - 1) rankings
        create SvcRulesV1Test with
          svc
          epoch = epoch + 1
          nextMiningRound
          members
          leader = newLeader
          config
        pure self

    nonconsuming choice SvcRulesV1Test_ArchiveOutdatedElectionRequest : ()
      with
        requestCid : ContractId ElectionRequest
      controller leader
      do
        request <- fetch requestCid
        archive requestCid
        require "Election request is outdated" (request.epoch < epoch)


    -- Executing actions with confirmation
    --------------------------------------

    nonconsuming choice SvcRulesV1Test_ConfirmAction : ContractId ConfirmationV1Test
      with
        confirmer : Party
        action : ActionRequiringConfirmationV1Test
      controller confirmer
      do
        require "Confirmer is a collective member" (confirmer `Map.member` members)
        create ConfirmationV1Test with
          svc
          confirmer
          action

    nonconsuming choice SvcRulesV1Test_ExecuteConfirmedAction : ()
      with
        action : ActionRequiringConfirmationV1Test
        confirmationCids : [ContractId ConfirmationV1Test]
      controller leader
      do
        let s = summarizeCollectiveV1Test this
        require "Enough confirmations" (length confirmationCids >= s.requiredNumConfirmations)
        confirmers <- forA confirmationCids $ \confirmationCid -> do
          confirmation <- fetch confirmationCid
          archive confirmationCid
          require "SVC matches" (confirmation.svc == svc)
          require "Confirmer is a collective member" (confirmation.confirmer `Map.member` members)
          require "Confirmed action matches" (confirmation.action == action)
          pure confirmation.confirmer
        require "No duplicate confirmers" (unique confirmers)
        executeActionRequiringConfirmationV1Test self action

    -- TODO(M3-46): remove expired confirmations


    -- Validator onboarding
    -----------------------

    nonconsuming choice SvcRulesV1Test_OnboardValidator : ContractId ValidatorLicense
      with
        sponsor : Party
        validator : Party
      controller sponsor
      do
        require "Sponsor is a collective member" (sponsor `Map.member` members)
        license <- create ValidatorLicense with ..
        _ <- create (initialValidatorTraffic svc validator)
        return license


    -- SV onboarding
    ----------------

    nonconsuming choice SvcRulesV1Test_StartSvOnboarding : ContractId SvOnboardingRequest
      with
        candidateName : Text
        candidateParty : Party
        token : Text
        sponsor : Party
      controller sponsor
      do
        require "Sponsor is a collective member" (sponsor `Map.member` members)
        now <- getTime
        let expiresAt = now `addRelTime` config.svOnboardingRequestTimeout
        create SvOnboardingRequest with ..

    nonconsuming choice SvcRulesV1Test_ExpireSvOnboardingRequest : ()
      with
        cid: ContractId SvOnboardingRequest
      controller leader
      do
        exercise cid SvOnboardingRequest_Expire

    nonconsuming choice SvcRulesV1Test_ConfirmSvOnboarding : ContractId SvOnboardingConfirmed
      with
        newMemberParty : Party
        newMemberName : Text
        reason : Text
      controller svc
      do
        require "Member party is new" (not $ newMemberParty `Map.member` members)
        require "Member name is new" (newMemberName `notElem` (map (.name) (Map.values members)))
        now <- getTime
        let expiresAt = now `addRelTime` config.svOnboardingConfirmedTimeout
        create SvOnboardingConfirmed with
          svParty = newMemberParty
          svName = newMemberName
          reason
          svc
          expiresAt

    nonconsuming choice SvcRulesV1Test_ExpireSvOnboardingConfirmed : ()
      with
        cid: ContractId SvOnboardingConfirmed
      controller leader
      do
        exercise cid SvOnboardingConfirmed_Expire

    -- Coin management driven directly by the leader
    --------------------------------------------------

    nonconsuming choice SvcRulesV1Test_Coin_Expire : Party
      with
        cid : ContractId Coin
        choiceArg : Coin_Expire
      controller leader
      do
        exercise cid choiceArg

    nonconsuming choice SvcRulesV1Test_LockedCoin_ExpireCoin : Party
      with
        cid : ContractId LockedCoin
        choiceArg : LockedCoin_ExpireCoin
      controller leader
      do
        exercise cid choiceArg

    -- Round management driven directly by the leader
    -------------------------------------------------

    nonconsuming choice SvcRulesV1Test_AdvanceOpenMiningRounds
      : (ContractId SummarizingMiningRound, ContractId OpenMiningRound)
      with
        coinRulesV1TestCid : ContractId CoinRulesV1Test
        roundToArchiveCid : ContractId OpenMiningRound
        middleRoundCid : ContractId OpenMiningRound
        latestRoundCid : ContractId OpenMiningRound
        agreedCoinPriceCid : ContractId AgreedCoinPrice
      controller leader
      do
        coinPriceContract <- fetch agreedCoinPriceCid
        let coinPrice = coinPriceContract.coinPrice
        exercise coinRulesV1TestCid CoinRulesV1Test_AdvanceOpenMiningRounds with ..

    -- Reward management driven directly by the leader
    --------------------------------------------------

    nonconsuming choice SvcRulesV1Test_CollectSvcReward : ()
      with
        rewardCid : ContractId SvcReward
      controller leader
      do
        reward <- fetch rewardCid
        archive rewardCid
        require "SVC matches" (reward.svc == svc)
        let eligibleSVs =
              [ member | (member, info) <- Map.toList members, info.joinedAsOfRound <= reward.round]
            -- TODO(M3-90): review rounding of SV issuance
            issuancePerSV = reward.amount / intToDecimal (length eligibleSVs)
        -- NOTE: we are not directly creating coin's for the SV's here, as otherwise
        -- we'd require their participants to confirm this tx, which is not fault-tolerant
        -- against some SVs being offline. Instead, we create separate reward contracts
        -- signed by the SVC only, which can then be collected by the individual SVs.
        forA_ eligibleSVs $ \sv ->
          create SvReward with
            svc
            sv
            round = reward.round
            amount = issuancePerSV

    nonconsuming choice SvcRulesV1Test_CollectSvReward : ContractId Coin
      with
        sv : Party
        rewardCid : ContractId SvReward
        coinRulesV1TestCid : ContractId CoinRulesV1Test
        openRoundCid : ContractId OpenMiningRound
      controller sv
      do
        reward <- fetch rewardCid
        archive rewardCid
        require "SVC matches" (reward.svc == svc)
        require "SV matches" (reward.sv == sv)
        openRound <- fetch openRoundCid
        -- TODO(M3-46): make collection delay configurable
        require "Reward is not too old" (openRound.round.number <= reward.round.number + 10)
        exercise coinRulesV1TestCid CoinRulesV1Test_Mint with
          receiver = sv
          amount = reward.amount
          openRound = openRoundCid

    -- Batch expiry of unclaimed rewards for a specific claimed round
    nonconsuming choice SvcRulesV1Test_ClaimExpiredRewards
      : Optional (ContractId UnclaimedReward)
      with
        coinRulesV1TestCid : ContractId CoinRulesV1Test
        choiceArg : CoinRulesV1Test_ClaimExpiredRewards
      controller leader
      do
        exercise coinRulesV1TestCid choiceArg

    -- Batch merge of unclaimed rewards
    nonconsuming choice SvcRulesV1Test_MergeUnclaimedRewards
      : ContractId UnclaimedReward
      with
        coinRulesV1TestCid : ContractId CoinRulesV1Test
        unclaimedRewardCids : [ContractId UnclaimedReward]
      controller leader
      do
        require "Number of unclaimed rewards is above the configured threshold" $ length unclaimedRewardCids > config.numUnclaimedRewardsThreshold
        exercise coinRulesV1TestCid CoinRulesV1Test_MergeUnclaimedRewards with ..


-- Utility functions
--------------------

summarizeCollectiveV1Test : SvcRulesV1Test -> CollectiveSummary
summarizeCollectiveV1Test c = CollectiveSummary with
    leader = c.leader
    numMembers
    requiredNumConfirmations = 2 * (numMembers - 1) / 3 + 1
    requiredNumVotes = 2 * (numMembers - 1) / 3 + 1
  where
    numMembers = Map.size c.members

-- | Execute an action which requires certain number of confirmations from SVs.
-- Each confirmed action can at most be executed once.
executeActionRequiringConfirmationV1Test: ContractId SvcRulesV1Test -> ActionRequiringConfirmationV1Test -> Update ()
executeActionRequiringConfirmationV1Test svcRulesCid act = case act of
  ARC_CoinRulesV1Test with .. ->
    case coinRulesV1TestAction of
      CRARCV1Test_MiningRound_StartIssuing choiceArg -> void $ exercise coinRulesV1TestCid choiceArg
      CRARCV1Test_MiningRound_Close choiceArg -> void $ exercise coinRulesV1TestCid choiceArg
      CRARCV1Test_MiningRound_Archive choiceArg -> void $ exercise coinRulesV1TestCid choiceArg
  ARC_SvcRulesV1Test with .. ->
    case svcAction of
      SRARCV1Test_AddMember choiceArg -> void $ exercise svcRulesCid choiceArg
      SRARCV1Test_RemoveMember choiceArg -> void $ exercise svcRulesCid choiceArg
      SRARCV1Test_ConfirmSvOnboarding choiceArg -> void $ exercise svcRulesCid choiceArg


-- Functions implementing instant-runoff voting
-----------------------------------------------
