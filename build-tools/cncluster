#!/usr/bin/env bash

SUBCOMMAND_NAME="$1"
shift

set -euo pipefail

source ${TOOLS_LIB}/libcli.source
source ${TOOLS_LIB}/k8s.source

SCRIPTNAME=${0##*/}

function cluster_exists() {
  CLUSTER=$(gcloud container clusters list --filter "name:${GCP_CLUSTER_NAME}"  --format 'value(name)' 2> /dev/null)

  if [ -z "${CLUSTER}" ]; then
      return 1
  else
      return 0
  fi
}

function cluster_ip() {
    gcloud compute addresses list \
           --regions=${CLOUDSDK_COMPUTE_REGION} \
           --filter "name:${GCP_CLUSTER_NAME}-ip" \
           --format 'value(address)'
}

function _cluster_apply() {
    k8s_apply $(cluster_ip)
}

function ensure_deployment_context() {
    if [ -z "${GCP_CLUSTER_NAME-}" ]; then
        _error "GCP_CLUSTER_NAME is undefined, this script must be run in a deployment/ directory."
        exit 1
    fi
}

function cluster_confirm() {
    ensure_deployment_context

    echo "CLOUDSDK_COMPUTE_REGION : ${CLOUDSDK_COMPUTE_REGION}"
    echo "CLOUDSDK_CORE_PROJECT   : ${CLOUDSDK_CORE_PROJECT}"
    echo "GCP_REPO_NAME           : ${GCP_REPO_NAME}"

    echo "GCP_MASTER_IPV4_CIDR    : ${GCP_MASTER_IPV4_CIDR}"
    echo "GCP_CLUSTER_NAME        : ${GCP_CLUSTER_NAME}"

    _confirm "\nGKE Cluster Operation: $@"
}

### Commands

function cluster_activate() {
    # Sets kubeconfig if cluster exists, else does nothing
    if cluster_exists; then
        gcloud container clusters get-credentials ${GCP_CLUSTER_NAME}
    else
        _log "Cluster must be created before activation."
    fi
}


function cluster_apply() {
    cluster_confirm "Apply configuration"

    _cluster_apply
}

function cluster_create() {
    cluster_confirm "Create cluster"

    if cluster_exists; then
        echo "Cluster already exists."
        exit 1
    else
        gcloud container clusters create ${GCP_CLUSTER_NAME} \
               --create-subnetwork name=${GCP_CLUSTER_NAME}-subnet \
               --enable-master-authorized-networks \
               --enable-ip-alias \
               --enable-private-nodes \
               --master-ipv4-cidr "${GCP_MASTER_IPV4_CIDR}" \
               --node-locations "${CLOUDSDK_COMPUTE_REGION}-a"

        #### Enable Firewall Access
        gcloud container clusters update ${GCP_CLUSTER_NAME} \
               --enable-master-authorized-networks \
               --master-authorized-networks ${GCP_VPN_NETS}

        #### Delete default firewall rules, if they exist.
        if (yes | gcloud compute firewall-rules delete \
                         default-allow-rdp \
                         default-allow-icmp \
                         default-allow-ssh 2> /dev/null); then
            _warn "Deleted default firewall rules."
        else
            _log "Default firewalls already removed and do not need to be deleted."
        fi
    fi

    #### Check for IP

    if [ -z $(cluster_ip) ]; then
        echo "Allocating IP address."
        gcloud compute addresses create "${GCP_CLUSTER_NAME}-ip" --region=${CLOUDSDK_COMPUTE_REGION}
    fi

    echo "Cluster at IP $(cluster_ip), applying configuration."

    cluster_apply
}

function cluster_delete() {
    cluster_confirm "Delete cluster"

    if cluster_exists; then
        yes | gcloud container clusters delete ${GCP_CLUSTER_NAME}
    else
        _error "Cluster does not exist, cannot delete."
        exit 1
    fi

    echo "Cluster deleted."
}

function cluster_ipaddr() {
    ensure_deployment_context

    if cluster_exists; then
        cluster_ip
    else
        _error "Cluster does not exist, no IP address."
        exit 1
    fi
}

function cluster_push() {
    module=$1

    cluster_confirm "Push module: ${module}"

    if ! cluster_exists; then
        _error "Cluster does not exist, cannot push."
        exit 1
    fi

    if [ ! -d "${REPO_ROOT}/${module}" ]; then
        _error "Unknown module: $1"
        exit 1
    fi

    tagfile="${REPO_ROOT}/${module}/target/docker.push"

    if [ ! -f ${tagfile} ]; then
        _error "Module not built: $1"
        exit 1
    fi

    image=$(<${tagfile})

    k8s_set_image "${module}" "${image}"
}

case "${SUBCOMMAND_NAME}" in
    activate)
        cluster_activate
        ;;

    apply)
        cluster_apply
        ;;

    create)
        cluster_create
        ;;

    delete)
        cluster_delete
        ;;

    ipaddr)
        cluster_ipaddr
        ;;

    push)
        cluster_push $@
        ;;

    *)
	    _error "Usage: $SCRIPTNAME {activate|apply|create|delete|ipaddr|push}" >&2
	    exit 3
	    ;;
esac
