subcommand_whitelist[reset]='Reset the state of the cluster to a fully blank state. Clears all data.'

function _cluster_reset() {
    _info "Uninstalling Pulumi canton-network-gateway stack"
    # TODO(#4560): Use an empty passphrase until we manage secrets
    local -x PULUMI_CONFIG_PASSPHRASE=''
    # TODO(#6473): Remove this line when we have the change from #6439 deployed to all clusters.
    _pulumi --stack "canton-network-gateway.${GCP_CLUSTER_BASENAME}" down --skip-preview

    _info "Uninstalling Pulumi canton-network stack"
    _uses_pulumi_stack canton-network
    subcmd_pulumi canton-network refresh --yes --skip-preview
    subcmd_pulumi canton-network down --yes --skip-preview

    _info "Uninstalling Pulumi sv-runbook stack"
    _uses_pulumi_stack sv-runbook
    subcmd_pulumi sv-runbook refresh --yes --skip-preview
    subcmd_pulumi sv-runbook down --yes --skip-preview

    _info "Cluster in reset/idle state."
}

function subcmd_reset() {
    _prompt_to_confirm

    _cluster_reset "$@"
}

subcommand_whitelist[ci_apply]='Run only by CircleCI'

function subcmd_ci_apply() {
   _assert_lock --for-ci

    # A CI-specific variant of 'cncluster apply' that removes the need
    # for manual confirmation and ensures that all pods are deleted
    # and recreated during the apply. With current (September 2022)
    # DevNet, the ledger is stored in memory and the pod reset
    # has the effect of clearing out all ledger state.

   if [ -z "${CI-}" ]; then
       _error "This subcommand is available to CI jobs only."
   fi

    # By default, this is unset and we infer the previous values based on the currently running cluster.
    # However, we allow overwriting it to account for cases where the previous cluster is broken in some way.
    if [ -n "${RESTORE_CLUSTER:-}" ] && [ -z "${BOOTSTRAPPING_CONFIG:-}" ]; then
        CLUSTER="$GCP_CLUSTER_BASENAME"
        NOW="$(date +"%Y-%m-%dT%H:%M:%S.000Z")"
        export BOOTSTRAPPING_CONFIG="{\"cluster\": \"$CLUSTER\", \"date\": \"$NOW\"}"
    fi

    _cluster_show


    if [ -n "${BOOTSTRAPPING_CONFIG:-}" ]; then
       _info "Bootstrapping cluster from ${BOOTSTRAPPING_CONFIG}"
    fi

    _info "Resetting cluster for CI deployment."
    _cluster_reset

    source_image_tag=$(get-snapshot-version)

    _info "Applying CI deployment: ${source_image_tag}"

    _cluster_apply "${source_image_tag}"
}

###

subcommand_whitelist[ci_assert_fresh_lock]='Run only by CircleCI'

function subcmd_ci_assert_fresh_lock() {
    if [ -z "${SHARED_CLUSTER:-}" ]; then
        _info "Cluster not marked as shared. No lock to check."
        exit 0
    fi

    if lockholder=$(_current_lockholder); then
        age_secs="$(_current_lock_age)"

        if (( age_secs > 21600 )); then
            _error "Cluster lock held by ${lockholder} is stale. Lock age: $(_current_lock_age_formatted)"
        else
            _info "Cluster lock held by ${lockholder} is fresh. Lock age: $(_current_lock_age_formatted)"
        fi
    else
        _info "Cluster sharable but not locked. No lock to check."
    fi
}

###

subcommand_whitelist[ci_reset_unlock]='Run only by CircleCI'

function subcmd_ci_reset_unlock() {
    # A CI-specific variant of 'cncluster reset' and 'cncluster unlock' that
    # removes the need for manual confirmation and is executed only on shared
    # clusters (like scratchnet).

    if [ -z "${CI-}" ]; then
        _error "This subcommand is available to CI jobs only."
    fi

    if [ -z "${SHARED_CLUSTER:-}" ]; then
        _info "Not resetting and unlocking because not on a shared cluster (like scratchnet)."
        return
    fi

    _cluster_reset
    if lockholder=$(_current_lockholder); then
        _unlock
        _info "Cluster unlocked. Former lockholder was: ${lockholder}"
    else
        _info "Cluster was not locked."
    fi
}

