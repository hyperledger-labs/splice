subcommand_whitelist[apply]="Apply the current Pulumi configuration (--preview to preview only)"

function subcmd_apply() {
    _production_gate
    _cluster_must_exist

    POSITIONAL_ARGS=()
    while [[ $# -gt 0 ]]; do
        case $1 in
            --preview)
                preview="yes"
                shift
                ;;
            --skip-infra)
                skipInfra="yes"
                shift
                ;;
            -*)
                _error "Unknown option $1"
                ;;
            *)
                POSITIONAL_ARGS+=("$1")
                shift
                ;;
        esac
    done
    set -- "${POSITIONAL_ARGS[@]}"

    if [ -n "${1-}" ]; then
        VERSION_NUMBER=$(get-snapshot-version)
        IMAGE_TAG=$1
        _warning "Overriding image tag: ${IMAGE_TAG} (was: ${VERSION_NUMBER})"
    fi

    subcmd_install_data_export_bucket_key

    if [ -n "${preview:-}" ]; then
        make -C "${REPO_ROOT}" cluster/helm/build -j
        _info "Previewing apply for infra:"
        subcmd_pulumi infra preview --show-sames --json "${args[@]}"
        _info "Previewing apply for canton-network:"
        subcmd_pulumi canton-network preview --show-sames --json "${args[@]}"
    else
        _prompt_to_confirm
        make -C "${REPO_ROOT}" cluster/build -j

        if [ -z "${IMAGE_TAG:-}" ]; then
            if [ -z "${CNCLUSTER_SKIP_DOCKER_CHECK-}" ]; then
                _docker_must_be_running
                if ! make -C "${REPO_ROOT}" docker-check -j; then
                    _error "Images missing from artifact registry, cannot apply."
                fi
            else
                _warning "docker-check bypassed with CNCLUSTER_SKIP_DOCKER_CHECK."
            fi
        fi

        if [ -z "${skipInfra:-}" ]; then
            subcmd_infra_up
        else
            _info "Skipping infra deployment"
        fi
        subcmd_pulumi canton-network up --yes --skip-preview "${args[@]}"
    fi
}

