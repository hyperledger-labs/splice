#!/usr/bin/env bash

SUBCOMMAND_NAME="$1"
shift

set -euo pipefail

source ${TOOLS_LIB}/libcli.source

SCRIPTNAME=${0##*/}

# Ensure we're running in a cluster deployment context

if [ -z "${GCP_CLUSTER_BASENAME-}" ]; then
    _error "GCP_CLUSTER_BASENAME is undefined, this script must be run in a deployment/ directory."
fi

##

SOURCE_IMAGE_TAG=$(version-gen)
GCP_CLUSTER_NAME="cn-${GCP_CLUSTER_BASENAME}net"
CLUSTER_DNS_NAME="${GCP_CLUSTER_BASENAME}.network.canton.global"

################################
### Utilities
################################

function _cluster_exists() {
  CLUSTER=$(gcloud container clusters list --filter "name:${GCP_CLUSTER_NAME}"  --format 'value(name)')

  if [ -z "${CLUSTER}" ]; then
      return 1
  else
      return 0
  fi
}

function _cluster_must_exist() {
    if ! _cluster_exists; then
        _error "Cluster does not exist, cannot continue."
    fi
}

function _docker_must_be_running() {
    if ! docker ps  > /dev/null 2>&1; then
        _error "Docker Daemon not found to be running."
    fi
}

function _production_gate() {
    if [ -n "${GCP_CLUSTER_PROD_LIKE-}" ] ; then
        _error "Please deploy to this cluster only via CircleCI (https://github.com/DACH-NY/the-real-canton-coin/tree/main/cluster#manually-deploying-via-ci)"
    fi
}

function _cluster_ip() {
    gcloud compute addresses list \
           --regions=${CLOUDSDK_COMPUTE_REGION} \
           --filter "name:${GCP_CLUSTER_NAME}-ip" \
           --format 'value(address)'
}

function _nat_router() {
    # Check to see if the NAT router exists
    gcloud compute routers list \
            --filter "name:${GCP_NAT_ROUTER_NAME}" \
            --format 'value(name)'
}

function _nat_config() {
    # Check to see if the NAT is configured
    gcloud compute routers nats list \
            --router=${GCP_NAT_ROUTER_NAME} \
            --format 'value(name)'
}

function _needs_auth0_management_api_creds() {
    if [ -z "${AUTH0_MANAGEMENT_API_CLIENT_ID-}" ]; then
        _error "Environment variable AUTH0_MANAGEMENT_API_CLIENT_ID undefined.\nPlease see https://github.com/DACH-NY/the-real-canton-coin#configure-auth0-environment"
      exit 1
    fi

    if [ -z "${AUTH0_MANAGEMENT_API_CLIENT_SECRET-}" ]; then
      _error "Environment variable AUTH0_MANAGEMENT_API_CLIENT_SECRET is undefined.\nPlease see https://github.com/DACH-NY/the-real-canton-coin#configure-auth0-environment"
      exit 1
    fi
}

function _cluster_apply() {
    IMAGE_TAG=$1

    # Apply cert-manager deployments
    kubectl apply -f $REPO_ROOT/cluster/manifest/cert-manager/cert-manager.yaml

    TOKEN_ARG=fixedTokens=false

    if [ ! -z "${CNCLUSTER_FIXED_TOKENS:-}" ]; then
        TOKEN_ARG=fixedTokens=true
    fi

    TICK_DURATION_ARG="tickDuration=null"

    if [ ! -z "${CNCLUSTER_TICK_DURATION:-}" ]; then
        TICK_DURATION_ARG="tickDuration=\"${CNCLUSTER_TICK_DURATION}\""
    fi

    # Apply base cluster config
    jsonnet --tla-str gcpRegion=${CLOUDSDK_COMPUTE_REGION} \
            --tla-str gcpRepoName=${GCP_REPO_NAME} \
            --tla-str gcpDnsProject=${GCP_DNS_PROJECT} \
            --tla-str gcpDnsSASecret=${GCP_DNS_SA_SECRET} \
            --tla-str imageTag=${IMAGE_TAG} \
            --tla-str ipAddr=$(_cluster_ip) \
            --tla-str clusterName=${GCP_CLUSTER_NAME} \
            --tla-str clusterDnsName=${CLUSTER_DNS_NAME} \
            --tla-code $TOKEN_ARG \
            --tla-code $TICK_DURATION_ARG \
            $REPO_ROOT/cluster/manifest/canton-network-config.jsonnet \
        | kubectl apply -f -
}

function _cluster_update_module() {
    module=$1

    _log "Pushing module: ${module}"

    pushStateFile="${REPO_ROOT}/cluster/images/${module}/target/docker.push"

    if [ ! -f ${pushStateFile} ]; then
        _error "Module not available for deployment (failure during either push or build): $1"
        exit 1
    fi

    imageTag=$(gawk -F '::' '{ print $2; }' < ${pushStateFile})

    dnames=$(kubectl get deployment --all-namespaces -l moduleName=${module} -o jsonpath='{.items[*].metadata}' \
                 | jq -r '.name + if has("namespace") then "@" + .namespace else "" end')

    if [ -z "$dnames" ]; then
        _warning "No deployment found for module: ${module}"
    else
        for dname in $dnames; do
            _log "Setting module for deployment: ${dname}"
            IFS='@' read -ra NAME_NS <<<"$dname"
            kubectl set image --namespace "${NAME_NS[1]-default}" "deployment/${NAME_NS[0]}" "${NAME_NS[0]}=${imageTag}"
        done

        _log "Deleting module pods to force restart: ${module}"

        # Delete the pods to force recreation. This forces a reload of
        # the docker image, even if the tag has not changed, due to
        # the imagePullPolicy setting of "Always".
        kubectl delete pods --all-namespaces -l "moduleName=${module}"
    fi
}

function _cluster_show() {
    _log "CLOUDSDK_COMPUTE_REGION : ${CLOUDSDK_COMPUTE_REGION}"
    _log "CLOUDSDK_CORE_PROJECT   : ${CLOUDSDK_CORE_PROJECT}"
    _log "GCP_REPO_NAME           : ${GCP_REPO_NAME}"

    _log "GCP_MASTER_IPV4_CIDR    : ${GCP_MASTER_IPV4_CIDR}"
    _log "GCP_CLUSTER_BASENAME    : ${GCP_CLUSTER_BASENAME}"
    _log "GCP_CLUSTER_NAME        : ${GCP_CLUSTER_NAME}"
    _log "CLUSTER_DNS_NAME        : ${CLUSTER_DNS_NAME}"

    _log ""
}

################################
### Commands
################################

## Subcommand dictionary
##
##    This is a map from subcommand name to help text. The definition of the
##    sumcommand's functionality itself is in a shell function named
##    cluster_${subcommand_name}. The subcommand must be defined in the
##    whitelist dictionary to be invoked.

declare -A subcommand_whitelist

function _prompt_to_confirm() {
    _cluster_show

    if [ -z "${GCP_CLUSTER_PROD_LIKE-}" ] ; then
        if [ -n "${CNCLUSTER_AUTOCONFIRM-}" ] ; then
            _warning "Automatically confirmed (via environment variable): ${subcommand_whitelist[${SUBCOMMAND_NAME}]}"
            return
        fi
    fi

    _confirm "Confirm: ${subcommand_whitelist[${SUBCOMMAND_NAME}]}"
}

###

subcommand_whitelist[activate]='Ensure cncluster is correctly authenticated to administer the cluster.'

function subcmd_activate() {
    _cluster_must_exist

    gcloud container clusters get-credentials ${GCP_CLUSTER_NAME}
}

###

subcommand_whitelist[apply]='Apply the current manifest to the cluster. Accepts an optional tag for images.'

function subcmd_apply() {
    _production_gate
    _prompt_to_confirm

    IMAGE_TAG=${SOURCE_IMAGE_TAG}

    if [ -z "${1-}" ]; then
       if [ -z "${CNCLUSTER_SKIP_DOCKER_CHECK-}" ]; then
          _docker_must_be_running
          if ! make -C ${REPO_ROOT} docker-check -j; then
             _error "Images missing from artifact registry, cannot apply."
             exit 1
         fi
       else
           _warning "docker-check bypassed with CNCLUSTER_SKIP_DOCKER_CHECK."
       fi
    else
        IMAGE_TAG=$1
       _warning "Overriding image tag (no docker-check): ${IMAGE_TAG} (was: ${SOURCE_IMAGE_TAG})"
    fi

    _cluster_apply ${IMAGE_TAG}
}

###

subcommand_whitelist[deploy]='Rebuild local working copy and deploy to cluster.'

function subcmd_deploy() {
    _production_gate
    _prompt_to_confirm
    _docker_must_be_running

    make -C ${REPO_ROOT} clean -j

    if ! make -C ${REPO_ROOT} docker-build -j; then
        _error "Error building images, cannot apply."
    fi

    if ! make -C ${REPO_ROOT} docker-push-force; then
        _error "Error pushing images, cannot apply."
    fi

    _cluster_apply ${SOURCE_IMAGE_TAG}
}

###

subcommand_whitelist[push]='Update one or more modules running on a cluster'

function subcmd_push() {
    _production_gate
    _prompt_to_confirm
    _cluster_must_exist
    _docker_must_be_running

    # Assemble target lists for parallel clean and then build.
    clean_targets=""
    db_targets=""
    dpf_targets=""
    for module in "$@"
    do
        if [ ! -d "${REPO_ROOT}/cluster/images/${module}" ]; then
            _error "Unknown module: $module"
        fi

        clean_targets="${clean_targets} cluster/images/${module}/clean"
        db_targets="${db_targets} cluster/images/${module}/docker-build"
        dpf_targets="${dpf_targets} cluster/images/${module}/docker-push-force"
    done

    if [ -z "${db_targets}" ]; then
        _error "No modules specified."
    fi

    # Clean and build in parallel
    make -C ${REPO_ROOT} ${clean_targets} -j
    make -C ${REPO_ROOT} ${db_targets} -j

    # Run the push serially (since the push is ultimately serialized across
    # the shared upload link anyway, and adding contention won't help speed
    # things up).
    make -C ${REPO_ROOT} ${dpf_targets}

    # Update all the modules in cluster
    for module in "$@"; do
        _cluster_update_module ${module}
    done
}

###

subcommand_whitelist[rlogs]='Stream a running application log stream to standard output'

function _json_log_format() {
    jq -R 'fromjson? | select(type == "object")' \
        | jq -r '"\(.["@timestamp"]) \(.level) [\(.logger_name)] - \(.message)"'
}

function subcmd_rlogs() {
    if [ "${1-}" = "--raw" ]; then
        raw=yes
        shift
    fi

    if [ -z "${1-}" ]; then
        _error "No namespace specified"
    fi

    if [ -z "${2-}" ]; then
        _error "No app specified"
    fi

    namespace=$1
    app=$2

    _cluster_must_exist

    if POD_SPEC=$(kubectl get pod \
                          -n ${namespace} \
                          -l app=${app} \
                          -o jsonpath='{range .items[0].metadata}{"-n "}{@.namespace}{" "}{@.name}{"\n"}{end}'  \
                          2> /dev/null); then


        if [ -n "${raw-}" ] ; then
            kubectl logs ${POD_SPEC} ${app} -f
        else
            kubectl logs ${POD_SPEC} ${app} -f | _json_log_format
        fi
    else
        _error "No pod for app found: ${app}"
    fi
}

###

subcommand_whitelist[logs]='View an running application log stream in lnav'

function subcmd_logs() {
    if [ -z "${1-}" ]; then
        _error "No namespace specified"
    fi

    if [ -z "${2-}" ]; then
        _error "No app specified"
    fi

    namespace=$1
    app=$2

    _cluster_must_exist

    if POD_SPEC=$(kubectl get pod \
                          -n ${namespace} \
                          -l app=${app} \
                          -o jsonpath='{range .items[0].metadata}{"-n "}{@.namespace}{" "}{@.name}{"\n"}{end}'  \
                          2> /dev/null); then


        LOGFILE=$(mktemp cnlogXXXXXXX.clog)
        (kubectl logs ${POD_SPEC} ${app} -f >> ${LOGFILE} & lnav ${LOGFILE})
        rm ${LOGFILE}
    else
        _error "No pod for app found: ${app}"
    fi
}

subcommand_whitelist[gcloud_logs]='View the logs of an application through gcloud. This allows viewing historical logs'

function subcmd_gcloud_logs() {
    if [ -z "${1-}" ]; then
        _error "No namespace specified"
    fi

    if [ -z "${2-}" ]; then
        _error "No app specified"
    fi

    if [ -z "${3-}" ]; then
        _error "No filter specified. See https://cloud.google.com/logging/docs/view/logging-query-language for docs on the query language."
    fi

    namespace="$1"
    app="$2"
    filter="$3"

    _cluster_must_exist

    LOGFILE=$(mktemp "$namespace"-"$app"-XXXX.clog)
    echo "Writing log to $LOGFILE"

    gcloud logging read --order asc --format 'json(jsonPayload)' "resource.labels.cluster_name=$GCP_CLUSTER_NAME AND resource.labels.namespace_name=$namespace AND resource.labels.container_name=$app AND $filter" \
        | jq --stream -cn 'fromstream(1 | truncate_stream(inputs) | select(.[0][0] == "jsonPayload")) | .jsonPayload' > $LOGFILE & lnav $LOGFILE
}

###

subcommand_whitelist[set_machine_type]='Rebuilds the default node pool with current cluster machine type and count'

function subcmd_set_machine_type() {
    _prompt_to_confirm
    _cluster_must_exist

    _info "Creating temporary node pool..."
    gcloud container node-pools create temp-pool --cluster "cn-${GCP_CLUSTER_BASENAME}net" \
           --machine-type ${GCP_CLUSTER_NODE_TYPE} --num-nodes 1 \
           || _error "Could not create node pool with machine type: ${GCP_CLUSTER_NODE_TYPE}"

    _info "Deleting default node pool..."
    gcloud container node-pools delete default-pool --quiet --cluster "cn-${GCP_CLUSTER_BASENAME}net" \
           || _error "Could not delete default node pool. Terminating early."

    _info "Recreading default node pool..."
    gcloud container node-pools create default-pool --cluster "cn-${GCP_CLUSTER_BASENAME}net" \
           --machine-type ${GCP_CLUSTER_NODE_TYPE} \
           --num-nodes 1 \
           --enable-autoscaling \
           --min-nodes 1 \
           --max-nodes ${GCP_CLUSTER_MAX_NODES} \
           || _error "Could not recreate default node pool. Terminating early."

    _info "Deleting temporary node pool..."
    gcloud container node-pools delete temp-pool --quiet --cluster "cn-${GCP_CLUSTER_BASENAME}net" \
           || _error "Could not delete temporary node pool."
}

