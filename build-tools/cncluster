subcommand_whitelist[activate]='Ensure cncluster is correctly authenticated to administer the cluster.'

function subcmd_activate() {
    _cluster_must_exist

  # only the mainnet GKE cluster is created in the specified zone
  if (env-bool IS_MAINNET); then
    gcloud container clusters get-credentials "${GCP_CLUSTER_NAME}"
  else
    # If the zone is set, the command will try to use it instead of the region for the cluster
    env -u CLOUDSDK_COMPUTE_ZONE gcloud container clusters get-credentials "${GCP_CLUSTER_NAME}"
  fi
}

