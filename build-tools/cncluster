#!/usr/bin/env bash

SUBCOMMAND_NAME="$1"
shift

set -euo pipefail

source ${TOOLS_LIB}/libcli.source

SCRIPTNAME=${0##*/}

# Ensure we're running in a cluster deployment context

if [ -z "${GCP_CLUSTER_BASENAME-}" ]; then
    _error "GCP_CLUSTER_BASENAME is undefined, this script must be run in a deployment/ directory."
    exit 1
fi


##

SOURCE_IMAGE_TAG=$(version-gen)
GCP_CLUSTER_NAME="cn-${GCP_CLUSTER_BASENAME}net"
CLUSTER_DNS_NAME="${GCP_CLUSTER_BASENAME}.network.canton.global"

function cluster_exists() {
  CLUSTER=$(gcloud container clusters list --filter "name:${GCP_CLUSTER_NAME}"  --format 'value(name)')

  if [ -z "${CLUSTER}" ]; then
      return 1
  else
      return 0
  fi
}

function cluster_ip() {
    gcloud compute addresses list \
           --regions=${CLOUDSDK_COMPUTE_REGION} \
           --filter "name:${GCP_CLUSTER_NAME}-ip" \
           --format 'value(address)'
}

function nat_router() {
    gcloud compute routers list \
            --filter "name:${GCP_NAT_ROUTER_NAME}" \
            --format 'value(name)'
}

function nat_config() {
    gcloud compute routers nats list \
            --router=${GCP_NAT_ROUTER_NAME} \
            --format 'value(name)'
}

function _cluster_apply() {
    IMAGE_TAG=$1

    # Apply cert-manager deployments
    kubectl apply -f $REPO_ROOT/cluster/manifest/cert-manager/cert-manager.yaml

    # Apply base cluster config
    jsonnet --tla-str gcpRegion=${CLOUDSDK_COMPUTE_REGION} \
            --tla-str gcpRepoName=${GCP_REPO_NAME} \
            --tla-str gcpDnsProject=${GCP_DNS_PROJECT} \
            --tla-str gcpDnsSASecret=${GCP_DNS_SA_SECRET} \
            --tla-str imageTag=${IMAGE_TAG} \
            --tla-str ipAddr=$(cluster_ip) \
            --tla-str clusterName=${GCP_CLUSTER_NAME} \
            --tla-str clusterDnsName=${CLUSTER_DNS_NAME} \
            $REPO_ROOT/cluster/manifest/canton-network-config.jsonnet \
        | kubectl apply -f -
}

function cluster_show() {
    echo "CLOUDSDK_COMPUTE_REGION : ${CLOUDSDK_COMPUTE_REGION}"
    echo "CLOUDSDK_CORE_PROJECT   : ${CLOUDSDK_CORE_PROJECT}"
    echo "GCP_REPO_NAME           : ${GCP_REPO_NAME}"

    echo "GCP_MASTER_IPV4_CIDR    : ${GCP_MASTER_IPV4_CIDR}"
    echo "GCP_CLUSTER_BASENAME    : ${GCP_CLUSTER_BASENAME}"
    echo "GCP_CLUSTER_NAME        : ${GCP_CLUSTER_NAME}"

    echo "CLUSTER_DNS_NAME        : ${CLUSTER_DNS_NAME}"
    echo "SOURCE_IMAGE_TAG        : ${SOURCE_IMAGE_TAG}"
}

function cluster_confirm() {
    cluster_show

    _confirm "\nGKE Cluster Operation: $@"
}

### Commands

function cluster_activate() {
    # Sets kubeconfig if cluster exists, else does nothing
    if cluster_exists; then
        gcloud container clusters get-credentials ${GCP_CLUSTER_NAME}
    else
        _log "Cluster must be created before activation."
        exit 1
    fi
}

function cluster_apply() {
    cluster_confirm "Apply configuration"

    IMAGE_TAG=${SOURCE_IMAGE_TAG}

    if [ -z "${1-}" ]; then
       if ! make -C ${REPO_ROOT}/cluster docker-check; then
           _error "Images missing from artifact registry, cannot apply."
           exit 1
       fi
    else
        IMAGE_TAG=$1
       _warning "Overriding image tag (no docker-check): ${IMAGE_TAG} (was: ${SOURCE_IMAGE_TAG})"
    fi

    _cluster_apply ${IMAGE_TAG}
}

function cluster_deploy() {
    cluster_confirm "Build and apply configuration"

    if ! make -C ${REPO_ROOT}/cluster docker-push; then
        _error "Error building images, cannot apply."
        exit 1
    fi

    _cluster_apply ${SOURCE_IMAGE_TAG}
}

function cluster_create() {
    cluster_confirm "Create cluster"

    if cluster_exists; then
        echo "Cluster already exists."
        exit 1
    else
        #### Cluster can be resized from deployment directories with the following command:
        ####   gcloud container clusters resize "cn-${GCP_CLUSTER_BASENAME}net" --num-nodes 4
        gcloud container clusters create ${GCP_CLUSTER_NAME} \
               --create-subnetwork name=${GCP_CLUSTER_NAME}-subnet \
               --enable-master-authorized-networks \
               --enable-ip-alias \
               --enable-private-nodes \
               --machine-type e2-highmem-8 \
               --num-nodes 2 \
               --master-ipv4-cidr "${GCP_MASTER_IPV4_CIDR}" \
               --node-locations "${CLOUDSDK_COMPUTE_REGION}-a" \
               --node-labels digitalasset.com/cluster-name=${GCP_CLUSTER_NAME} \
               --addons=GcePersistentDiskCsiDriver

        #### Enable Firewall Access
        gcloud container clusters update ${GCP_CLUSTER_NAME} \
               --enable-master-authorized-networks \
               --master-authorized-networks ${GCP_VPN_NETS}

        #### Delete default firewall rules, if they exist.
        if (yes | gcloud compute firewall-rules delete \
                         default-allow-rdp \
                         default-allow-icmp \
                         default-allow-ssh 2> /dev/null); then
            _warning "Deleted default firewall rules."
        else
            _log "Default firewalls already removed and do not need to be deleted."
        fi
    fi

    #### Store DNS service account secret for cert-manager DNS-01 authorizer to use
    #### TODO(#1447)
    if ! kubectl get secret ${GCP_DNS_SA_SECRET} > /dev/null; then

        _log "Missing DNS Service Account secret, creating key..."
        # This can fail with a precondition error on an attempt to create
        # keys beyond the tenth.
        gcloud iam service-accounts keys create /tmp/key.json \
            --iam-account dns01-solver@$GCP_DNS_PROJECT.iam.gserviceaccount.com

        _log "...storing secret"
        kubectl create secret generic $GCP_DNS_SA_SECRET \
            --from-file=key.json=/tmp/key.json
        rm /tmp/key.json
    fi

    #### Check for IP

    if [ -z $(cluster_ip) ]; then
        _log "Allocating IP address."
        gcloud compute addresses create "${GCP_CLUSTER_NAME}-ip" --region=${CLOUDSDK_COMPUTE_REGION}
    fi

    IPADDR=$(cluster_ip)

    if [ -z ${IPADDR} ]; then
        _error "Could not determine cluster IP address."
        exit 1
    fi

    gcloud dns record-sets create ${CLUSTER_DNS_NAME} \
           --project="${GCP_DNS_PROJECT}" \
           --zone="canton-global" \
           --type=A \
           --ttl=60 \
           --rrdatas="${IPADDR}"

    gcloud dns record-sets create "*.${CLUSTER_DNS_NAME}" \
           --project="${GCP_DNS_PROJECT}" \
           --zone="canton-global" \
           --type=A \
           --ttl=60 \
           --rrdatas="${IPADDR}"

    echo "Cluster at IP ${IPADDR}, applying configuration."

    #### Check for Cloud NAT rules
    if [ -z $(nat_router) ]; then
        _log "NAT router ${GCP_NAT_ROUTER_NAME} not found, creating..."
        gcloud compute routers create "${GCP_NAT_ROUTER_NAME}" \
            --network default \
            --region "${CLOUDSDK_COMPUTE_REGION}"
    else
        _log "NAT router ${GCP_NAT_ROUTER_NAME} exists, skipping..."
    fi

    if [ -z $(nat_config) ]; then
        _log "NAT config ${GCP_NAT_CONFIG_NAME} not found, creating..."
        gcloud compute routers nats create "${GCP_NAT_CONFIG_NAME}" \
                --router-region "${CLOUDSDK_COMPUTE_REGION}" \
                --router "${GCP_NAT_ROUTER_NAME}" \
                --nat-all-subnet-ip-ranges \
                --auto-allocate-nat-external-ips
    else
        _log "NAT config ${GCP_NAT_CONFIG_NAME} exists, skipping..."
    fi

    cluster_update_secrets

    _cluster_apply ${SOURCE_IMAGE_TAG}
}

function _check_cluster_grpc_port() {
    PORT=$1

    _log "Checking gRPC API: $2"

    if ! grpcurl -plaintext ${CLUSTER_DNS_NAME}:${PORT} list > /dev/null; then
        _error "API not reachable"
    fi
}

function _check_cluster_ledger() {
    if ! CLUSTER_ADDR="${CLUSTER_DNS_NAME}" coin \
         --config ${REPO_ROOT}/build-tools/cluster-test.conf \
         --bootstrap ${REPO_ROOT}/build-tools/cluster-test.canton; then
        _error "Cannot run ledger access test."
    fi
}

function cluster_check() {
    cluster_show

    _check_cluster_grpc_port 5008 "Canton Domain Connection"
    _check_cluster_grpc_port 5009 "Canton Domain Admin"

    _check_cluster_grpc_port 5001 "Ledger Participant API"
    _check_cluster_grpc_port 5002 "Ledger Participant Admin API"

    _check_cluster_grpc_port 5005 "SVC App API"
    _check_cluster_grpc_port 5012 "Scan App API"

    _check_cluster_grpc_port 5101 "Validator1: Ledger Participant API"
    _check_cluster_grpc_port 5102 "Validator1: Ledger Participant Admin API"
    _check_cluster_grpc_port 5103 "Validator1: Validator App API"
    _check_cluster_grpc_port 5104 "Validator1: Wallet App API"

    _check_cluster_grpc_port 5201 "Splitwise: Ledger Participant API"
    _check_cluster_grpc_port 5202 "Splitwise: Ledger Participant Admin API"
    _check_cluster_grpc_port 5203 "Splitwise: Validator App API"
    _check_cluster_grpc_port 5213 "Splitwise: Splitwise App API"

    _log "Checking cluster via ping test..."
    _check_cluster_ledger
}

function _cluster_reset() {
    kubectl delete StatefulSet --all
    kubectl delete PersistentVolumeClaim --all
    kubectl delete PersistentVolume --all
    kubectl delete Deployment --all
    kubectl delete Pods --all
}

function cluster_ciapply() {
    # A CI specific variant of 'cncluster apply' that removes the need
    # for manual confirmation and ensures that all pods are deleted
    # and recreated during the apply. With current (September 2022)
    # DevNet, the ledger is stored in memory and the pod reset
    # has the effect of clearing out all ledger state.

    if [ -z "${CI-}" ]; then
        _error "This subcommand available to CI jobs only."
        exit 1
    fi

    cluster_show

    _cluster_reset
    _cluster_apply ${SOURCE_IMAGE_TAG}
}

function cluster_delete() {
    cluster_confirm "Delete cluster"

    if cluster_exists; then
        if gcloud dns record-sets delete \
                  --project="${GCP_DNS_PROJECT}" \
                  --zone="canton-global" \
                  --type=A \
                  ${CLUSTER_DNS_NAME}; then
            _log "DNS record deleted for ${CLUSTER_DNS_NAME}"
        else
            _warning "No DNS record to delete for ${CLUSTER_DNS_NAME}"
        fi

        if gcloud dns record-sets delete \
                  --project="${GCP_DNS_PROJECT}" \
                  --zone="canton-global" \
                  --type=A \
                  "*.${CLUSTER_DNS_NAME}"; then
            _log "DNS record deleted for *.${CLUSTER_DNS_NAME}"
        else
            _warning "No DNS record to delete for *.${CLUSTER_DNS_NAME}"
        fi

        yes | gcloud container clusters delete ${GCP_CLUSTER_NAME}
    else
        _error "Cluster does not exist, cannot delete."
        exit 1
    fi

    echo "Cluster deleted."
}

function cluster_ipaddr() {
    if cluster_exists; then
        cluster_ip
    else
        _error "Cluster does not exist, no IP address."
        exit 1
    fi
}


function cluster_preflight() {
    _log "Starting preflight"

    run_sbt_for_preflight "testOnly *PreflightIntegrationTest"
}

function run_sbt_for_preflight() {
    if [ -z "${AUTH0_MANAGEMENT_API_CLIENT_ID-}" ]; then
        _error "Environment variable AUTH0_MANAGEMENT_API_CLIENT_ID undefined.\nPlease see https://github.com/DACH-NY/the-real-canton-coin#configure-auth0-environment"
      exit 1
    fi

    if [ -z "${AUTH0_MANAGEMENT_API_CLIENT_SECRET-}" ]; then
      _error "Environment variable AUTH0_MANAGEMENT_API_CLIENT_SECRET is undefined.\nPlease see https://github.com/DACH-NY/the-real-canton-coin#configure-auth0-environment"
      exit 1
    fi

    (cd ${REPO_ROOT} && \
         sbt -DDOMAIN_URL=http://${GCP_CLUSTER_BASENAME}.network.canton.global:5008 \
             -DNETWORK_APPS_ADDRESS=${GCP_CLUSTER_BASENAME}.network.canton.global \
             -DAUTH0_TENANT=dev "$@")
}

function cluster_reset() {
    cluster_confirm "Reset cluster state by deleting ALL pods."

    _cluster_reset
}

function _show_ports() {
    curl -L http://scratch.network.canton.global/manifest.json 2> /dev/null \
        | jq -r '(["SERVICE","PORT NAME","PORT","AS GRPC"],(.ports|.[]|[.service, .name, .port, .proxyToGrpc]))|@csv' \
        | column -s ',' -t
}

function cluster_services() {
    cluster_show

    _log ""
    _log "Available Ports:"
    _show_ports
}

function cluster_stats() {
    cluster_show

    _log ""
    _log "Available Ports:"
    _show_ports

    _log ""
    _log "Node Usage:"

    kubectl top node

    _log ""
    _log "Pod Usage:"

    kubectl top pod
}

function cluster_wait() {
    cluster_show

    _log "Waiting for all pods to become ready"
    kubectl wait --for=condition=Ready --all pod --timeout=5m
}

function _set_auth0_secret() {
  SECRET_NAME=$1
  ENV_NAME=$2

  _log "Setting secret $SECRET_NAME"

  CLIENT_ID_EV="${ENV_NAME}_CLIENT_ID"
  if [ -z "${!CLIENT_ID_EV-}" ]; then
      _error "Environment variable ${CLIENT_ID_EV} is undefined.\nPlease see https://github.com/DACH-NY/the-real-canton-coin/tree/main/cluster#auth0-secrets"
      exit 1
  fi
  CLIENT_ID=${!CLIENT_ID_EV}

  CLIENT_SECRET_EV="${ENV_NAME}_CLIENT_SECRET"
  if [ -z "${!CLIENT_SECRET_EV-}" ]; then
      _error "Environment variable ${CLIENT_SECRET_EV} is undefined.\nPlease see https://github.com/DACH-NY/the-real-canton-coin/tree/main/cluster#auth0-secrets"
      exit 1
  fi
  CLIENT_SECRET=${!CLIENT_SECRET_EV}


  USER_NAME="${CLIENT_ID}@clients"

  WELL_KNOWN_URL='https://canton-network-dev.us.auth0.com/.well-known/openid-configuration'

  # Delete secret if it exists, easier than editing existing secrets
  if kubectl get secret ${SECRET_NAME} > /dev/null; then
      kubectl delete secret ${SECRET_NAME}
  fi

  kubectl create secret generic ${SECRET_NAME} \
    --from-literal=url="${WELL_KNOWN_URL}" \
    --from-literal=client-id="${CLIENT_ID}" \
    --from-literal=client-secret="${CLIENT_SECRET}" \
    --from-literal=daml-user-name="${USER_NAME}"
}

function cluster_update_secrets() {
  _set_auth0_secret "cn-app-wallet-ledger-api-auth" "CN_APP_WALLET_LEDGER_API_AUTH"
  _set_auth0_secret "cn-app-validator-ledger-api-auth" "CN_APP_VALIDATOR_LEDGER_API_AUTH"
  _set_auth0_secret "cn-app-svc-ledger-api-auth" "CN_APP_SVC_LEDGER_API_AUTH"
  _set_auth0_secret "cn-app-sv1-ledger-api-auth" "CN_APP_SV1_LEDGER_API_AUTH"
  _set_auth0_secret "cn-app-sv2-ledger-api-auth" "CN_APP_SV2_LEDGER_API_AUTH"
  _set_auth0_secret "cn-app-sv3-ledger-api-auth" "CN_APP_SV3_LEDGER_API_AUTH"
  _set_auth0_secret "cn-app-sv4-ledger-api-auth" "CN_APP_SV4_LEDGER_API_AUTH"
  _set_auth0_secret "cn-app-scan-ledger-api-auth" "CN_APP_SCAN_LEDGER_API_AUTH"
  _set_auth0_secret "cn-app-directory-ledger-api-auth" "CN_APP_DIRECTORY_LEDGER_API_AUTH"
  _set_auth0_secret "cn-app-splitwise-ledger-api-auth" "CN_APP_SPLITWISE_LEDGER_API_AUTH"
  _set_auth0_secret "cn-app-splitwise-validator-ledger-api-auth" "CN_APP_SPLITWISE_VALIDATOR_LEDGER_API_AUTH"
}

case "${SUBCOMMAND_NAME}" in
    activate)
        cluster_activate $@
        ;;

    apply)
        cluster_apply $@
        ;;

    create)
        cluster_create $@
        ;;

    check)
        cluster_check $@
        ;;

    ciapply)
        cluster_ciapply $@
        ;;

    delete)
        cluster_delete $@
        ;;

    deploy)
        cluster_deploy $@
        ;;

    ipaddr)
        cluster_ipaddr $@
        ;;

    preflight)
        cluster_preflight $@
        ;;

    sbt_for_preflight)
        run_sbt_for_preflight $@
        ;;

    reset)
        cluster_reset $@
        ;;

    services)
        cluster_services $@
        ;;

    stats)
        cluster_stats $@
        ;;

    wait)
        cluster_wait $@
        ;;

    update_secrets)
        cluster_update_secrets
        ;;

    *)
	    _error "Usage: $SCRIPTNAME {activate|apply|create|check|delete|deploy|ipaddr|reset|stats|wait|update_secrets}" >&2
	    exit 3
	    ;;
esac
