subcommand_whitelist[restore_node]='Restore a full CN node from backup'

function subcmd_restore_node() {
    _cluster_must_exist

    local force=""
    POSITIONAL_ARGS=()
    while [[ $# -gt 0 ]]; do
        case $1 in
            --force)
                force="--force"
                shift
                ;;
            -*)
                _error "Unknown option $1"
                ;;
            *)
                POSITIONAL_ARGS+=("$1")
                shift
                ;;
        esac
    done
    set -- "${POSITIONAL_ARGS[@]}"

    node="${1-}"
    backup_run_id="${2-}"

    if [ -z "$node" ]; then
        _error "Usage: $SCRIPTNAME restore_node <namespace_name> [<backup_run_id>]"
    fi

    if [ -z "$backup_run_id" ]; then
        _info "No backup run_id given, looking for the latest backup"
        backup_run_id=$("$REPO_ROOT"/cluster/scripts/find-recent-backup.sh "$node")
        if [[ -z "$backup_run_id" || "$backup_run_id" == "null" ]]; then
            _error "No recent backup found for $node"
        fi
        _info "Found latest backup run ID: $backup_run_id"
    fi

    case "$node" in
        sv-1|sv-2|sv-3|sv-4)
            if [ "$node" == "sv-1" ]; then
                sv_name="Digital-Asset-2"
            else
                sv_name=${node/sv/Digital-Asset-Eng}
            fi
            _info "Silencing SV report creation alerts for $sv_name for 1 hour"
            subcmd_silence_grafana_alerts "1 hour" "alertname=Report Creation Time Lag" "report_publisher=$sv_name"
            _info "Restoring sv node $node"
            "$REPO_ROOT"/cluster/scripts/node-restore.sh $force "$node" "$backup_run_id" cometbft-0 sequencer-0 participant-0 mediator-0 cn-apps
            ;;
        validator1|splitwell)
            _info "Restoring validator node $node"
            "$REPO_ROOT"/cluster/scripts/node-restore.sh $force "$node" "$backup_run_id" participant-0 validator
            ;;
        *)
            _error "Unknown node $node"
            ;;
    esac
}

subcommand_whitelist[hard_domain_migration_prepare]='Prepare a hard domain migration'

function subcmd_hard_domain_migration_prepare() {

  _prompt_to_confirm
  _cluster_must_exist

  if [ "$#" -gt 0 ]; then
    if ! _contained "$1" "all" "core" "sv"; then
      _error "Usage: $0 hard_domain_migration_prepare [all|core|sv] [active_version] [upgrade_version] [pulumi-args...]"
    fi
    scope="$1"
    shift
  else
    scope="all"
  fi

  # You can substitute `local` for any of those versions to use the locally built charts
  if [ "$#" -gt 0 ]; then
    # the default, active version
    export CHARTS_VERSION="$1"
    shift
  fi
  if [ "$#" -gt 0 ]; then
    # the version of the new pods
    export GLOBAL_DOMAIN_UPGRADE_VERSION="$1"
    shift
  fi

  export GLOBAL_DOMAIN_UPGRADE_MIGRATION_ID=1

  # this ensures we redeploy the pods on the old domain during the prepare step already
  # so the actual migrate step does not have to redeploy them and is therefore faster.
  export DISABLE_CANTON_AUTO_INIT="true"
  export DISABLE_COMETBFT_STATE_SYNC="true"

  # pulumi will show a preview and ask us to confirm each deployment step

  if [ "$scope" == "all" ] || [ "$scope" == "core" ]; then
    subcmd_pulumi canton-network up "$@"
  fi

  if [ "$scope" == "all" ] || [ "$scope" == "sv" ]; then
    subcmd_pulumi sv-runbook up "$@"
  fi
}

