subcommand_whitelist[update_secrets]='Update Auth0 Kubernetes Secrets'

function _set_auth0_secret() {
  SECRET_NAME=$1
  CLIENT_ID=$2
  CLIENT_SECRET=$3
  NAMESPACE=$4

  _log "Setting secret $SECRET_NAME ($NAMESPACE)"

  USER_NAME="${CLIENT_ID}@clients"

  WELL_KNOWN_URL='https://canton-network-dev.us.auth0.com/.well-known/openid-configuration'

  # Delete secret if it exists, easier than editing existing secrets
  if kubectl get --namespace "$NAMESPACE" secret ${SECRET_NAME} > /dev/null 2>&1; then
      kubectl delete --namespace "$NAMESPACE" secret ${SECRET_NAME}
  fi

  # Create the namespace if it does not exist (no harm should be caused if it does)
  kubectl create namespace $NAMESPACE --dry-run=client -o yaml | kubectl apply -f -

  if [ ! -z "${CNCLUSTER_FIXED_TOKENS:-}" ]; then
    TOKEN_RESPONSE=$(curl -s --show-error --fail --request POST \
      --url https://canton-network-dev.us.auth0.com/oauth/token \
      --header 'content-type: application/json' \
      --data "{\"client_id\":\"$CLIENT_ID\",\"client_secret\":\"$CLIENT_SECRET\",\"audience\":\"https://canton.network.global\",\"grant_type\":\"client_credentials\"}")

    ACCESS_TOKEN=$(echo $TOKEN_RESPONSE | jq -r ".access_token")

    kubectl create --namespace "$NAMESPACE" secret generic ${SECRET_NAME} \
      --from-literal=ledger-api-user="${USER_NAME}" \
      --from-literal=token="${ACCESS_TOKEN}"
  else
    kubectl create --namespace "$NAMESPACE" secret generic ${SECRET_NAME} \
      --from-literal=url="${WELL_KNOWN_URL}" \
      --from-literal=client-id="${CLIENT_ID}" \
      --from-literal=client-secret="${CLIENT_SECRET}" \
      --from-literal=ledger-api-user="${USER_NAME}"
  fi
}

function _set_auth0_api_user() {
    # Add/update secret only containing the `ledger-api-user` field
    local -r APP_NAME="$1"
    local -r NAMESPACE="$2"
    local -r CLIENT_ID="$3"
    local SECRET_NAME="cn-app-${APP_NAME,,}-ledger-api-auth"
    SECRET_NAME="${SECRET_NAME//_/-}"

    _log "Setting user-only secret $SECRET_NAME ($NAMESPACE)"

    # Delete secret if it exists, easier than editing existing secrets
    if kubectl get --namespace "$NAMESPACE" secret ${SECRET_NAME} &> /dev/null; then
       kubectl delete --namespace "$NAMESPACE" secret ${SECRET_NAME}
    fi

    kubectl create --namespace "$NAMESPACE" secret generic "${SECRET_NAME}" \
            "--from-literal=ledger-api-user=${CLIENT_ID}@clients"
}

