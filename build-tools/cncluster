subcommand_whitelist[get_token]='Get an auth0 token for a given admin user'

function subcmd_get_token() {

  if [ "$#" -ne 1 ]; then
     _error "Usage: $0 <node>"
  fi

  node="$1"
  configType="cantonNetwork"
  if [ "$node" == "sv" ]; then
    configType="svRunbook"
  fi
  if [ "$node" == "validator" ]; then
    configType="validatorRunbook"
  fi

  client_ids=$(subcmd_pulumi infra stack output --json | grep -v "Running Pulumi Command")
  client_id=$(echo "$client_ids" | jq -r '.auth0."'"$configType"'".appToClientId."'"$node"'"')
  if [ -z "$client_id" ] || [ "$client_id" == "null" ]; then
    known=$(echo "$client_ids" | jq -r '.auth0."'"$configType"'".appToClientId')
    _error "No client ID found for node $node in infra stack. Known client IDs are: $known"
  fi
  secrets=$(kubectl get secret auth0-preflight-token-cache -o jsonpath="{.data}")
  encoded=$(echo "$secrets" | jq -r --arg client_id "$client_id" '.[$client_id]')
  if [ -z "$encoded" ] || [ "$encoded" == "null" ]; then
    _error "no secret found for client ID $client_id. Did you run \"preflight_refresh_auth0_credentials\"? Are we fetching a secret for this client (hint: look at Auth0CredentialsPreflightIntegrationTest)?"
  fi
  token=$(echo "$encoded" | base64 --decode | jq -r .accessToken)
  echo "$token"
}

