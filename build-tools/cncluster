function subcmd_pulumi() {
    _production_gate

    pulumi_project="${1-}"
    pulumi_cmd="${2-}"
    if [ -z "${pulumi_cmd}" ] || [ -z "${pulumi_project}" ]; then
        _error "Usage: $SCRIPTNAME pulumi <pulumi-project> <pulumi-cmd> [options...]"
    fi

    shift 2

    # TODO(#4560): Use an empty passphrase until we manage secrets
    local -x PULUMI_CONFIG_PASSPHRASE=''

    _pulumi --logflow --logtostderr -v=9 --stack "${pulumi_project}.${GCP_CLUSTER_BASENAME}" \
           --cwd "${REPO_ROOT}/cluster/pulumi/${pulumi_project}" \
            "$pulumi_cmd" "$@"
}

###

subcommand_whitelist[apply]="Apply the current Pulumi configuration (--preview to preview only)"

function subcmd_apply() {
    _production_gate
    _cluster_must_exist

    POSITIONAL_ARGS=()
    while [[ $# -gt 0 ]]; do
        case $1 in
            --preview)
                preview="yes"
                shift
                ;;
            -*)
                _error "Unknown option $1"
                ;;
            *)
                POSITIONAL_ARGS+=("$1")
                shift
                ;;
        esac
    done
    set -- "${POSITIONAL_ARGS[@]}"

    VERSION_NUMBER=$(get-snapshot-version)

    if [ -n "${1-}" ]; then
        IMAGE_TAG=$1
        _warning "Overriding image tag: ${IMAGE_TAG} (was: ${SOURCE_IMAGE_TAG})"
    fi

    args=(-c "VERSION_NUMBER=${VERSION_NUMBER}"
          -c "CLUSTER_BASENAME=${GCP_CLUSTER_BASENAME}")

    if [ -n "${IMAGE_TAG:-}" ]; then
        args+=(-c "IMAGE_TAG=${IMAGE_TAG}")
    fi

    if [ -n "${CNCLUSTER_FIXED_TOKENS:-}" ]; then
        args+=(-c "FIXED_TOKENS=${CNCLUSTER_FIXED_TOKENS}")
    else
        args+=(-c "FIXED_TOKENS=0")
    fi

    if [ -n "${preview:-}" ]; then
        _info "Previewing apply."
        make -C "${REPO_ROOT}" cluster/helm/build -j
        subcmd_pulumi canton-network preview --show-sames --json "${args[@]}"
    else
        _prompt_to_confirm
        make -C "${REPO_ROOT}" cluster/build -j

        if [ -z "${IMAGE_TAG:-}" ]; then
            if [ -z "${CNCLUSTER_SKIP_DOCKER_CHECK-}" ]; then
                _docker_must_be_running
                if ! make -C "${REPO_ROOT}" docker-check -j; then
                    _error "Images missing from artifact registry, cannot apply."
                fi
            else
                _warning "docker-check bypassed with CNCLUSTER_SKIP_DOCKER_CHECK."
            fi
        fi

        _cluster_install_network_gateway
        subcmd_pulumi canton-network up --yes --skip-preview "${args[@]}"
    fi
}

