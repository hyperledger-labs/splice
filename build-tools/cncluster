function _cluster_reset() {
    _info "Deleting all stateful sets..."
    kubectl delete StatefulSet --all-namespaces -l clusterName=${GCP_CLUSTER_NAME}

    _info "Deleting all deployments..."
    kubectl delete Deployment --all-namespaces -l clusterName=${GCP_CLUSTER_NAME}

    _info "Deleting all pods..."
    kubectl delete Pods --all-namespaces -l clusterName=${GCP_CLUSTER_NAME}

    _info "Deleting all persistent volume claims..."
    kubectl delete PersistentVolumeClaim --all-namespaces -l clusterName=${GCP_CLUSTER_NAME}

    _info "Cluster in reset/idle state."
}

function cluster_ciapply() {
    # A CI specific variant of 'cncluster apply' that removes the need
    # for manual confirmation and ensures that all pods are deleted
    # and recreated during the apply. With current (September 2022)
    # DevNet, the ledger is stored in memory and the pod reset
    # has the effect of clearing out all ledger state.

    if [ -z "${CI-}" ]; then
        _error "This subcommand available to CI jobs only."
        exit 1
    fi

    cluster_show

    _cluster_reset
    _cluster_apply ${SOURCE_IMAGE_TAG}
}

function cluster_delete() {
    cluster_confirm "Delete cluster"
    cluster_must_exist

    if gcloud dns record-sets delete \
              --project="${GCP_DNS_PROJECT}" \
              --zone="canton-global" \
              --type=A \
              ${CLUSTER_DNS_NAME}; then
        _log "DNS record deleted for ${CLUSTER_DNS_NAME}"
    else
        _warning "No DNS record to delete for ${CLUSTER_DNS_NAME}"
    fi

    if gcloud dns record-sets delete \
              --project="${GCP_DNS_PROJECT}" \
              --zone="canton-global" \
              --type=A \
              "*.${CLUSTER_DNS_NAME}"; then
        _log "DNS record deleted for *.${CLUSTER_DNS_NAME}"
    else
        _warning "No DNS record to delete for *.${CLUSTER_DNS_NAME}"
    fi

    gcloud container clusters delete --quiet ${GCP_CLUSTER_NAME}

    echo "Cluster deleted."
}

function cluster_ipaddr() {
    cluster_must_exist

    cluster_ip
}


function cluster_preflight() {
    _log "Starting preflight"

    run_sbt_for_preflight "testOnly *PreflightIntegrationTest"
}

function run_sbt_for_preflight() {
    if [ -z "${AUTH0_MANAGEMENT_API_CLIENT_ID-}" ]; then
        _error "Environment variable AUTH0_MANAGEMENT_API_CLIENT_ID undefined.\nPlease see https://github.com/DACH-NY/the-real-canton-coin#configure-auth0-environment"
      exit 1
    fi

    if [ -z "${AUTH0_MANAGEMENT_API_CLIENT_SECRET-}" ]; then
      _error "Environment variable AUTH0_MANAGEMENT_API_CLIENT_SECRET is undefined.\nPlease see https://github.com/DACH-NY/the-real-canton-coin#configure-auth0-environment"
      exit 1
    fi

    (cd ${REPO_ROOT} && \
         DOMAIN_URL=http://${GCP_CLUSTER_BASENAME}.network.canton.global:5008 \
         NETWORK_APPS_ADDRESS=${GCP_CLUSTER_BASENAME}.network.canton.global \
         NETWORK_APPS_ADDRESS_PROTOCOL=https \
             sbt -DAUTH0_TENANT=dev "$@")
}

function cluster_reset() {
    cluster_confirm "Reset cluster state by deleting ALL pods."

    _cluster_reset
}

function cluster_ports() {
    cluster_show
    cluster_must_exist

    curl -L http://scratch.network.canton.global/manifest.json 2> /dev/null \
        | jq -r '(["SERVICE","PORT-NAME","PORT","AS-GRPC"],(.ports|.[]|[.service, .name, .port, .proxyToGrpc]))|@tsv' \
        | column -t
}

function cluster_services() {
    cluster_show

    _show_ports
}

function cluster_info() {
    cluster_show
    cluster_must_exist

    kubectl get po -o json \
        | jq -r '(["NAMESPACE", "POD-NAME", "CONTAINER", "IMAGE", "MEM-LIMIT", "CPU-REQ", "CPU-LIMIT"],(.items[] | .metadata as $pod | .spec.containers[] as $c | $c.resources as $r | [$pod.namespace, $pod.name, $c.name, ($c.image | split(":")[1]), $r.limits.memory, $r.requests.cpu, $r.limits.cpu]))|@tsv' \
        | sort \
        | column -t

}

function cluster_top() {
    cluster_show
    cluster_must_exist

	_log "Node Usage:"
    kubectl top node

    _log ""
	_log "Pod Usage:"
    kubectl top pod --all-namespaces -l clusterName=${GCP_CLUSTER_NAME}
}

function cluster_wait() {
    cluster_show

    _log "Waiting for all pods to become ready"
    kubectl wait --for=condition=Ready --all pod --timeout=5m
}

function _set_auth0_secret() {
  SECRET_NAME=$1
  CLIENT_ID=$2
  CLIENT_SECRET=$3

  _log "Setting secret $SECRET_NAME"

  USER_NAME="${CLIENT_ID}@clients"

  WELL_KNOWN_URL='https://canton-network-dev.us.auth0.com/.well-known/openid-configuration'

  # Delete secret if it exists, easier than editing existing secrets
  if kubectl get secret ${SECRET_NAME} > /dev/null 2>&1; then
      kubectl delete secret ${SECRET_NAME}
  fi

  kubectl create secret generic ${SECRET_NAME} \
    --from-literal=url="${WELL_KNOWN_URL}" \
    --from-literal=client-id="${CLIENT_ID}" \
    --from-literal=client-secret="${CLIENT_SECRET}" \
    --from-literal=ledger-api-user="${USER_NAME}"
}

function cluster_update_secrets() {

  if [ -z "${AUTH0_MANAGEMENT_API_TOKEN-}" ]; then
      _error "Environment variable AUTH0_MANAGEMENT_API_TOKEN is undefined.\nPlease see https://github.com/DACH-NY/the-real-canton-coin/tree/main/cluster#auth0-secrets"
      exit 1
  fi

  _log "Fetching secrets from auth0"
  AUTH0_MANAGEMENT_API_URL="https://canton-network-dev.us.auth0.com/api/v2"
  all=$(curl -s --show-error --fail -H "Authorization: Bearer ${AUTH0_MANAGEMENT_API_TOKEN}" ${AUTH0_MANAGEMENT_API_URL}/clients)

  for i in \
    "cn-app-wallet-ledger-api-auth KChYVPmxvHHUebLDXnNo3Z125WrxJiLb" \
    "cn-app-validator-ledger-api-auth cf0cZaTagQUN59C1HBL2udiIBdFh2CWq" \
    "cn-app-svc-ledger-api-auth XJbLZ0uz6iceI4sHeQlIleuFZeCjczjC" \
    "cn-app-sv1-ledger-api-auth OBpJ9oTyOLuAKF0H2hhzdSFUICt0diIn" \
    "cn-app-sv2-ledger-api-auth rv4bllgKWAiW9tBtdvURMdHW42MAXghz" \
    "cn-app-sv3-ledger-api-auth SeG68w0ubtLQ1dEMDOs4YKPRTyMMdDLk" \
    "cn-app-sv4-ledger-api-auth CqKgSbH54dqBT7V1JbnCxb6TfMN8I1cN" \
    "cn-app-scan-ledger-api-auth nDgBS0c1gPwbzF1v07CpyVw5yahYC9c6" \
    "cn-app-directory-ledger-api-auth PRmBKfOZNmInZKg0qyIWn66RCSe9UBPs" \
    "cn-app-splitwell-ledger-api-auth ekPlYxilradhEnpWdS80WfW63z1nHvKy" \
    "cn-app-splitwell-validator-ledger-api-auth hqpZ6TP0wGyG2yYwhH6NLpuo0MpJMQZW" \
    "cn-app-splitwell-wallet-ledger-api-auth BMSnkJmJMGQqTQY8sabXNHVEzvNW5MMo"
  do
    set -- $i
    secret=$(echo $all | jq -r ".[] | select(.client_id==\"$2\") | .client_secret")
    _set_auth0_secret $1 $2 $secret
  done
}

case "${SUBCOMMAND_NAME}" in
    activate)
        cluster_activate $@
        ;;

    apply)
        cluster_apply $@
        ;;

    create)
        cluster_create $@
        ;;

    check)
        cluster_check $@
        ;;

    ciapply)
        cluster_ciapply $@
        ;;

    delete)
        cluster_delete $@
        ;;

    deploy)
        cluster_deploy $@
        ;;

    ipaddr)
        cluster_ipaddr $@
        ;;

    info)
        cluster_info $@
        ;;

    log | logs)
        cluster_logs $@
        ;;

    ports)
        cluster_ports $@
        ;;

    preflight)
        cluster_preflight $@
        ;;

    push)
        cluster_push $@
        ;;

    sbt_for_preflight)
        run_sbt_for_preflight $@
        ;;

    reset)
        cluster_reset $@
        ;;

    set_machine_type)
        cluster_set_machine_type $@
        ;;

    services)
        cluster_services $@
        ;;

    top)
        cluster_top $@
        ;;

    wait)
        cluster_wait $@
        ;;

    update_secrets)
        cluster_update_secrets
        ;;

    *)
	    _error "Usage: $SCRIPTNAME {activate|apply|create|check|delete|deploy|image_tags|ipaddr|ports|push|reset|top|wait|update_secrets}" >&2
	    exit 3
	    ;;
esac
