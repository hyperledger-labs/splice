subcommand_whitelist[reset]='Reset the state of the cluster to a fully blank state. Clears all data.'

function _cluster_reset() {
    _info "Uninstalling Pulumi canton-network-gateway stack"

    _down_stack canton-network
    _down_stack sv-runbook
    _down_stack validator-runbook

    _info "Cluster in reset/idle state."
}

function _down_stack() {
    STACK=$1

    _info "Uninstalling Pulumi ${STACK} stack"

    RETCODE=0
    ERRFILE="./.tmp_ERRFILE"
    ERRMSG=""

    touch "$ERRFILE"

    subcmd_pulumi "$STACK" down --yes --skip-preview 2> >(tee ${ERRFILE} >&2) || { RETCODE="$?"; ERRMSG=$(cat "$ERRFILE")
    }

    rm -rf "$ERRFILE"

    if [ "$RETCODE" -ne 0 ]; then
        case "${ERRMSG}" in
            *"the stack is currently locked"*)
                echo "Retrying because of lock on stack $STACK"
                subcmd_pulumi "$STACK" cancel --yes
                subcmd_pulumi "$STACK" refresh --yes --skip-preview
                _down_stack "$STACK"

                echo "Reset complete. In case a subsequent 'cncluster apply' fails, refer to the documentation on manual cleanup (https://github.com/DACH-NY/canton-network-node/tree/main/cluster#manually-deploying-via-ci)"
                ;;

            *)
                _error "Failed uninstalling stack $STACK, aborting"
                exit 1
                ;;
        esac
    fi
}

function subcmd_reset() {
    _prompt_to_confirm

    _cluster_reset "$@"
}

subcommand_whitelist[ci_apply]='Run only by CircleCI'

function subcmd_ci_apply() {
    _assert_lock --for-ci

    # A CI-specific variant of 'cncluster apply' that removes the need
    # for manual confirmation and ensures that all pods are deleted
    # and recreated during the apply. With current (September 2022)
    # DevNet, the ledger is stored in memory and the pod reset
    # has the effect of clearing out all ledger state.

    if [ "${1-}" == "--skip-reset" ]; then
      skip_reset=yes
      shift
    fi

    if [ -z "${CI-}" ]; then
      _error "This subcommand is available to CI jobs only."
    fi

    # By default, this is unset and we infer the previous values based on the currently running cluster.
    # However, we allow overwriting it to account for cases where the previous cluster is broken in some way.
    if [ -n "${RESTORE_CLUSTER:-}" ] && [ -z "${BOOTSTRAPPING_CONFIG:-}" ]; then
        CLUSTER="$GCP_CLUSTER_BASENAME"
        NOW="$(date +"%Y-%m-%dT%H:%M:%S.000Z")"
        export BOOTSTRAPPING_CONFIG="{\"cluster\": \"$CLUSTER\", \"date\": \"$NOW\"}"
    fi

    _cluster_show

    if [ -n "${BOOTSTRAPPING_CONFIG:-}" ]; then
       _info "Bootstrapping cluster from ${BOOTSTRAPPING_CONFIG}"
    fi

    if [ -z "${skip_reset:-}" ]; then
      _info "Resetting cluster for CI deployment."
      _cluster_reset
    fi

    source_image_tag=$(get-snapshot-version)

    _info "Applying CI deployment: ${source_image_tag}"

    _cluster_apply "${source_image_tag}"
}

