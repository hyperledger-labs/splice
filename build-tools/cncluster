subcommand_whitelist[create]='Create a cluster from scratch.'

function subcmd_create() {
    _cluster_confirm "Create cluster"

    if _cluster_exists; then
        _error "Cluster already exists."
    else
        #### Cluster can be resized from deployment directories with the following command:
        ####   gcloud container clusters resize "cn-${GCP_CLUSTER_BASENAME}net" --num-nodes 4
        gcloud container clusters create ${GCP_CLUSTER_NAME} \
               --create-subnetwork name=${GCP_CLUSTER_NAME}-subnet \
               --enable-master-authorized-networks \
               --enable-ip-alias \
               --enable-private-nodes \
               --machine-type ${GCP_CLUSTER_NODE_TYPE} \
               --num-nodes 1 \
               --master-ipv4-cidr "${GCP_MASTER_IPV4_CIDR}" \
               --node-locations "${CLOUDSDK_COMPUTE_REGION}-a" \
               --node-labels digitalasset.com/cluster-name=${GCP_CLUSTER_NAME} \
               --addons=GcePersistentDiskCsiDriver \
               --enable-autoscaling \
               --min-nodes 1 \
               --max-nodes ${GCP_CLUSTER_MAX_NODES}

        #### Enable Firewall Access
        gcloud container clusters update ${GCP_CLUSTER_NAME} \
               --enable-master-authorized-networks \
               --master-authorized-networks ${GCP_VPN_NETS}

        #### Delete default firewall rules, if they exist.
        if (gcloud compute firewall-rules delete\
                         default-allow-rdp \
                         default-allow-icmp \
                         default-allow-ssh \
                         --quiet 2> /dev/null); then
            _warning "Deleted default firewall rules."
        else
            _log "Default firewalls already removed and do not need to be deleted."
        fi
    fi

    #### Store DNS service account secret for cert-manager DNS-01 authorizer to use
    #### TODO(#1447)
    if ! kubectl get secret ${GCP_DNS_SA_SECRET} > /dev/null; then

        _log "Missing DNS Service Account secret, creating key..."
        # This can fail with a precondition error on an attempt to create
        # keys beyond the tenth.
        gcloud iam service-accounts keys create /tmp/key.json \
            --iam-account dns01-solver@$GCP_DNS_PROJECT.iam.gserviceaccount.com

        _log "...storing secret"
        kubectl create secret generic $GCP_DNS_SA_SECRET \
            --from-file=key.json=/tmp/key.json
        rm /tmp/key.json
    fi

    #### Check for IP

    if [ -z $(_cluster_ip) ]; then
        _log "Allocating IP address."
        gcloud compute addresses create "${GCP_CLUSTER_NAME}-ip" --region=${CLOUDSDK_COMPUTE_REGION}
    fi

    IPADDR=$(_cluster_ip)

    if [ -z ${IPADDR} ]; then
        _error "Could not determine cluster IP address."
    fi

    gcloud dns record-sets create ${CLUSTER_DNS_NAME} \
           --project="${GCP_DNS_PROJECT}" \
           --zone="canton-global" \
           --type=A \
           --ttl=60 \
           --rrdatas="${IPADDR}"

    gcloud dns record-sets create "*.${CLUSTER_DNS_NAME}" \
           --project="${GCP_DNS_PROJECT}" \
           --zone="canton-global" \
           --type=A \
           --ttl=60 \
           --rrdatas="${IPADDR}"

    echo "Cluster at IP ${IPADDR}, applying configuration."

    #### Check for Cloud NAT rules
    if [ -z $(_nat_router) ]; then
        _log "NAT router ${GCP_NAT_ROUTER_NAME} not found, creating..."
        gcloud compute routers create "${GCP_NAT_ROUTER_NAME}" \
            --network default \
            --region "${CLOUDSDK_COMPUTE_REGION}"
    else
        _log "NAT router ${GCP_NAT_ROUTER_NAME} exists, skipping..."
    fi

    if [ -z $(_nat_config) ]; then
        _log "NAT config ${GCP_NAT_CONFIG_NAME} not found, creating..."
        gcloud compute routers nats create "${GCP_NAT_CONFIG_NAME}" \
                --router-region "${CLOUDSDK_COMPUTE_REGION}" \
                --router "${GCP_NAT_ROUTER_NAME}" \
                --nat-all-subnet-ip-ranges \
                --auto-allocate-nat-external-ips
    else
        _log "NAT config ${GCP_NAT_CONFIG_NAME} exists, skipping..."
    fi

    _log "Authenticating to newly created cluster."
    subcmd_activate

    _log "Applying current manifest to cluster."
    _cluster_apply ${SOURCE_IMAGE_TAG}

    _log "Updating cluster secrets"
    subcmd_update_secrets

    _log "Cluster ready."
}

###

subcommand_whitelist[reset]='Reset the state of the cluster to a fully blank state. Clears all data.'

function _cluster_reset() {
    _info "Deleting all stateful sets..."
    kubectl delete StatefulSet --all-namespaces -l clusterName=${GCP_CLUSTER_NAME}

    _info "Deleting all deployments..."
    kubectl delete Deployment --all-namespaces -l clusterName=${GCP_CLUSTER_NAME}

    _info "Deleting all pods..."
    kubectl delete Pods --all-namespaces -l clusterName=${GCP_CLUSTER_NAME}

    _info "Deleting all persistent volume claims..."
    kubectl delete PersistentVolumeClaim --all-namespaces -l clusterName=${GCP_CLUSTER_NAME}

    _info "Cluster in reset/idle state."
}

###

subcommand_whitelist[ciapply]='Run only by CircleCI'

function subcmd_ciapply() {
    # A CI specific variant of 'cncluster apply' that removes the need
    # for manual confirmation and ensures that all pods are deleted
    # and recreated during the apply. With current (September 2022)
    # DevNet, the ledger is stored in memory and the pod reset
    # has the effect of clearing out all ledger state.

    if [ -z "${CI-}" ]; then
        _error "This subcommand available to CI jobs only."
        exit 1
    fi

    _cluster_show
    _cluster_reset
    _cluster_apply ${SOURCE_IMAGE_TAG}
}

###

subcommand_whitelist[delete]='Delete all cluster resources.'

function subcmd_delete() {
    _cluster_confirm "Delete cluster"
    _cluster_must_exist

    if gcloud dns record-sets delete \
              --project="${GCP_DNS_PROJECT}" \
              --zone="canton-global" \
              --type=A \
              ${CLUSTER_DNS_NAME}; then
        _log "DNS record deleted for ${CLUSTER_DNS_NAME}"
    else
        _warning "No DNS record to delete for ${CLUSTER_DNS_NAME}"
    fi

    if gcloud dns record-sets delete \
              --project="${GCP_DNS_PROJECT}" \
              --zone="canton-global" \
              --type=A \
              "*.${CLUSTER_DNS_NAME}"; then
        _log "DNS record deleted for *.${CLUSTER_DNS_NAME}"
    else
        _warning "No DNS record to delete for *.${CLUSTER_DNS_NAME}"
    fi

    gcloud container clusters delete --quiet ${GCP_CLUSTER_NAME}

    echo "Cluster deleted."
}

