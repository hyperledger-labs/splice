subcommand_whitelist[delete]='Delete all cluster resources.'

function subcmd_delete() {
    _prompt_to_confirm
    _cluster_must_exist

    if gcloud dns record-sets delete \
              --project="${GCP_DNS_PROJECT}" \
              --zone="canton-global" \
              --type=A \
              ${CLUSTER_DNS_NAME}; then
        _log "DNS record deleted for ${CLUSTER_DNS_NAME}"
    else
        _warning "No DNS record to delete for ${CLUSTER_DNS_NAME}"
    fi

    if gcloud dns record-sets delete \
              --project="${GCP_DNS_PROJECT}" \
              --zone="canton-global" \
              --type=A \
              "*.${CLUSTER_DNS_NAME}"; then
        _log "DNS record deleted for *.${CLUSTER_DNS_NAME}"
    else
        _warning "No DNS record to delete for *.${CLUSTER_DNS_NAME}"
    fi

    gcloud container clusters delete --quiet ${GCP_CLUSTER_NAME}

    echo "Cluster deleted."
}

