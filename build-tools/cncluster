#!/usr/bin/env bash

SUBCOMMAND_NAME="$1"
shift

set -euo pipefail

source ${TOOLS_LIB}/libcli.source

SCRIPTNAME=${0##*/}

# Ensure we're running in a cluster deployment context

if [ -z "${GCP_CLUSTER_BASENAME-}" ]; then
    _error "GCP_CLUSTER_BASENAME is undefined, this script must be run in a deployment/ directory."
    exit 1
fi


##

SOURCE_IMAGE_TAG=$(version-gen)
GCP_CLUSTER_NAME="cn-${GCP_CLUSTER_BASENAME}net"
CLUSTER_DNS_NAME="${GCP_CLUSTER_BASENAME}.network.canton.global"

function cluster_exists() {
  CLUSTER=$(gcloud container clusters list --filter "name:${GCP_CLUSTER_NAME}"  --format 'value(name)')

  if [ -z "${CLUSTER}" ]; then
      return 1
  else
      return 0
  fi
}

function cluster_must_exist() {
    if ! cluster_exists; then
        _error "Cluster does not exist, cannot continue."
    fi
}

function cluster_ip() {
    gcloud compute addresses list \
           --regions=${CLOUDSDK_COMPUTE_REGION} \
           --filter "name:${GCP_CLUSTER_NAME}-ip" \
           --format 'value(address)'
}

function nat_router() {
    gcloud compute routers list \
            --filter "name:${GCP_NAT_ROUTER_NAME}" \
            --format 'value(name)'
}

function nat_config() {
    gcloud compute routers nats list \
            --router=${GCP_NAT_ROUTER_NAME} \
            --format 'value(name)'
}

function _cluster_apply() {
    IMAGE_TAG=$1

    # Apply cert-manager deployments
    kubectl apply -f $REPO_ROOT/cluster/manifest/cert-manager/cert-manager.yaml

    # Apply base cluster config
    jsonnet --tla-str gcpRegion=${CLOUDSDK_COMPUTE_REGION} \
            --tla-str gcpRepoName=${GCP_REPO_NAME} \
            --tla-str gcpDnsProject=${GCP_DNS_PROJECT} \
            --tla-str gcpDnsSASecret=${GCP_DNS_SA_SECRET} \
            --tla-str imageTag=${IMAGE_TAG} \
            --tla-str ipAddr=$(cluster_ip) \
            --tla-str clusterName=${GCP_CLUSTER_NAME} \
            --tla-str clusterDnsName=${CLUSTER_DNS_NAME} \
            $REPO_ROOT/cluster/manifest/canton-network-config.jsonnet \
        | kubectl apply -f -
}

function cluster_show() {
    _log "CLOUDSDK_COMPUTE_REGION : ${CLOUDSDK_COMPUTE_REGION}"
    _log "CLOUDSDK_CORE_PROJECT   : ${CLOUDSDK_CORE_PROJECT}"
    _log "GCP_REPO_NAME           : ${GCP_REPO_NAME}"

    _log "GCP_MASTER_IPV4_CIDR    : ${GCP_MASTER_IPV4_CIDR}"
    _log "GCP_CLUSTER_BASENAME    : ${GCP_CLUSTER_BASENAME}"
    _log "GCP_CLUSTER_NAME        : ${GCP_CLUSTER_NAME}"

    _log "GCP_CLUSTER_NODE_TYPE   : ${GCP_CLUSTER_NODE_TYPE}"
    _log "GCP_CLUSTER_MAX_NODES   : ${GCP_CLUSTER_MAX_NODES}"

    _log "CLUSTER_DNS_NAME        : ${CLUSTER_DNS_NAME}"
    _log "SOURCE_IMAGE_TAG        : ${SOURCE_IMAGE_TAG}"

    _log ""
}

function cluster_confirm() {
    cluster_show

    _confirm "GKE Cluster Operation: $@"
}

### Commands

function cluster_activate() {
    cluster_must_exist

    gcloud container clusters get-credentials ${GCP_CLUSTER_NAME}
}

function cluster_apply() {
    cluster_confirm "Apply configuration"

    IMAGE_TAG=${SOURCE_IMAGE_TAG}

    if [ -z "${1-}" ]; then
       if [ -z "${CNCLUSTER_SKIP_DOCKER_CHECK-}" ]; then
         if ! make -C ${REPO_ROOT} docker-check -j; then
             _error "Images missing from artifact registry, cannot apply."
             exit 1
         fi
       else
           _warning "docker-check bypassed with CNCLUSTER_SKIP_DOCKER_CHECK."
       fi
    else
        IMAGE_TAG=$1
       _warning "Overriding image tag (no docker-check): ${IMAGE_TAG} (was: ${SOURCE_IMAGE_TAG})"
    fi

    _cluster_apply ${IMAGE_TAG}
}

function cluster_deploy() {
    cluster_confirm "Rebuild and apply configuration, forcibly pushing images."

    make -C ${REPO_ROOT} clean -j

    if ! make -C ${REPO_ROOT} docker-build -j; then
        _error "Error building images, cannot apply."
    fi

    if ! make -C ${REPO_ROOT} docker-push-force; then
        _error "Error pushing images, cannot apply."
    fi

    _cluster_apply ${SOURCE_IMAGE_TAG}
}

function _cluster_update_module() {
    module=$1

    _log "Pushing module: ${module}"

    pushStateFile="${REPO_ROOT}/cluster/images/${module}/target/docker.push"

    if [ ! -f ${pushStateFile} ]; then
        _error "Module not built: $1"
        exit 1
    fi

    imageTag=$(gawk -F '::' '{ print $2; }' < ${pushStateFile})

    dnames=$(kubectl get deployment -l moduleName=${module} -o jsonpath='{.items[*].metadata.name}')

    if [ -z "$dnames" ]; then
        _warning "No deployment found for module: ${module}"
    else
        for dname in $dnames; do
            _log "Setting module for deployment: ${dname}"
            kubectl set image "deployment/${dname}" "${dname}=${imageTag}"
        done

        _log "Deleting module pods to force restart: ${module}"

        # Delete the pods to force recreation. This forces a reload of
        # the docker image, due to the imagePullPolicy setting of
        # "Always".
        kubectl delete pods -l "moduleName=${module}"
    fi
}

function cluster_push() {

    cluster_confirm "Rebuild and forcibly push module to update cluster: $@"

    cluster_must_exist

    # Assemble target lists for parallel clean and then build.
    clean_targets=""
    db_targets=""
    dpf_targets=""
    for module in "$@"
    do
        if [ ! -d "${REPO_ROOT}/cluster/images/${module}" ]; then
            _error "Unknown module: $module"
        fi

        clean_targets="${clean_targets} cluster/images/${module}/clean"
        db_targets="${db_targets} cluster/images/${module}/docker-build"
        dpf_targets="${dpf_targets} cluster/images/${module}/docker-push-force"
    done

    if [ -z "${db_targets}" ]; then
        _error "No modules specified."
    fi

    # Clean and build in parallel
    make -C ${REPO_ROOT} ${clean_targets} -j
    make -C ${REPO_ROOT} ${db_targets} -j

    # Run the push serially (since the push is ultimately serialized across
    # the shared upoad link anyway, and adding contention won't help speed
    # things up).
    make -C ${REPO_ROOT} ${dpf_targets}

    # Update all the modules in cluster
    for module in "$@"; do
        _cluster_update_module ${module}
    done
}

function _json_log_format() {
    jq -r '"\(.["@timestamp"]) \(.level) [\(.logger_name)] - \(.message)"'
}

function cluster_logs() {
    if [ "${1-}" = "--raw" ]; then
        raw=yes
        shift
    fi

    module=$1

    if [ -z "${module}" ]; then
        _error "No module specified"
    fi

    cluster_must_exist

    if POD_SPEC=$(kubectl get pod \
                          --all-namespaces \
                          -l app=${module} \
                          -o jsonpath='{range .items[0].metadata}{"-n "}{@.namespace}{" "}{@.name}{"\n"}{end}'  \
                          2> /dev/null); then

        if [ -n "${raw-}" ] ; then
            kubectl logs ${POD_SPEC} ${module} -f
        else
            kubectl logs ${POD_SPEC} ${module} -f | _json_log_format
        fi
    else
        _error "No pod for module found: ${module}"
    fi
}

function cluster_set_machine_type() {
    cluster_confirm "Set cluster machine type to current default. (This will interrupt all workloads.)"

    cluster_must_exist


    _info "Creating temporary node pool..."
    gcloud container node-pools create temp-pool --cluster "cn-${GCP_CLUSTER_BASENAME}net" \
           --machine-type ${GCP_CLUSTER_NODE_TYPE} --num-nodes 1 \
           || _error "Could not create node pool with machine type: ${GCP_CLUSTER_NODE_TYPE}"

    _info "Deleting default node pool..."
    gcloud container node-pools delete default-pool --quiet --cluster "cn-${GCP_CLUSTER_BASENAME}net" \
           || _error "Could not delete default node pool. Terminating early."

    _info "Recreading default node pool..."
    gcloud container node-pools create default-pool --cluster "cn-${GCP_CLUSTER_BASENAME}net" \
           --machine-type ${GCP_CLUSTER_NODE_TYPE} \
           --num-nodes 1 \
           --enable-autoscaling \
           --min-nodes 1 \
           --max-nodes ${GCP_CLUSTER_MAX_NODES} \
           || _error "Could not recreate default node pool. Terminating early."

    _info "Deleting temporary node pool..."
    gcloud container node-pools delete temp-pool --quiet --cluster "cn-${GCP_CLUSTER_BASENAME}net" \
           || _error "Could not delete temporary node pool."
}

function cluster_create() {
    cluster_confirm "Create cluster"

    if cluster_exists; then
        _error "Cluster already exists."
    else
        #### Cluster can be resized from deployment directories with the following command:
        ####   gcloud container clusters resize "cn-${GCP_CLUSTER_BASENAME}net" --num-nodes 4
        gcloud container clusters create ${GCP_CLUSTER_NAME} \
               --create-subnetwork name=${GCP_CLUSTER_NAME}-subnet \
               --enable-master-authorized-networks \
               --enable-ip-alias \
               --enable-private-nodes \
               --machine-type ${GCP_CLUSTER_NODE_TYPE} \
               --num-nodes 1 \
               --master-ipv4-cidr "${GCP_MASTER_IPV4_CIDR}" \
               --node-locations "${CLOUDSDK_COMPUTE_REGION}-a" \
               --node-labels digitalasset.com/cluster-name=${GCP_CLUSTER_NAME} \
               --addons=GcePersistentDiskCsiDriver \
               --enable-autoscaling \
               --min-nodes 1 \
               --max-nodes ${GCP_CLUSTER_MAX_NODES}

        #### Enable Firewall Access
        gcloud container clusters update ${GCP_CLUSTER_NAME} \
               --enable-master-authorized-networks \
               --master-authorized-networks ${GCP_VPN_NETS}

        #### Delete default firewall rules, if they exist.
        if (gcloud compute firewall-rules delete\
                         default-allow-rdp \
                         default-allow-icmp \
                         default-allow-ssh \
                         --quiet 2> /dev/null); then
            _warning "Deleted default firewall rules."
        else
            _log "Default firewalls already removed and do not need to be deleted."
        fi
    fi

    #### Store DNS service account secret for cert-manager DNS-01 authorizer to use
    #### TODO(#1447)
    if ! kubectl get secret ${GCP_DNS_SA_SECRET} > /dev/null; then

        _log "Missing DNS Service Account secret, creating key..."
        # This can fail with a precondition error on an attempt to create
        # keys beyond the tenth.
        gcloud iam service-accounts keys create /tmp/key.json \
            --iam-account dns01-solver@$GCP_DNS_PROJECT.iam.gserviceaccount.com

        _log "...storing secret"
        kubectl create secret generic $GCP_DNS_SA_SECRET \
            --from-file=key.json=/tmp/key.json
        rm /tmp/key.json
    fi

    #### Check for IP

    if [ -z $(cluster_ip) ]; then
        _log "Allocating IP address."
        gcloud compute addresses create "${GCP_CLUSTER_NAME}-ip" --region=${CLOUDSDK_COMPUTE_REGION}
    fi

    IPADDR=$(cluster_ip)

    if [ -z ${IPADDR} ]; then
        _error "Could not determine cluster IP address."
    fi

    gcloud dns record-sets create ${CLUSTER_DNS_NAME} \
           --project="${GCP_DNS_PROJECT}" \
           --zone="canton-global" \
           --type=A \
           --ttl=60 \
           --rrdatas="${IPADDR}"

    gcloud dns record-sets create "*.${CLUSTER_DNS_NAME}" \
           --project="${GCP_DNS_PROJECT}" \
           --zone="canton-global" \
           --type=A \
           --ttl=60 \
           --rrdatas="${IPADDR}"

    echo "Cluster at IP ${IPADDR}, applying configuration."

    #### Check for Cloud NAT rules
    if [ -z $(nat_router) ]; then
        _log "NAT router ${GCP_NAT_ROUTER_NAME} not found, creating..."
        gcloud compute routers create "${GCP_NAT_ROUTER_NAME}" \
            --network default \
            --region "${CLOUDSDK_COMPUTE_REGION}"
    else
        _log "NAT router ${GCP_NAT_ROUTER_NAME} exists, skipping..."
    fi

    if [ -z $(nat_config) ]; then
        _log "NAT config ${GCP_NAT_CONFIG_NAME} not found, creating..."
        gcloud compute routers nats create "${GCP_NAT_CONFIG_NAME}" \
                --router-region "${CLOUDSDK_COMPUTE_REGION}" \
                --router "${GCP_NAT_ROUTER_NAME}" \
                --nat-all-subnet-ip-ranges \
                --auto-allocate-nat-external-ips
    else
        _log "NAT config ${GCP_NAT_CONFIG_NAME} exists, skipping..."
    fi

    _log "Authenticating to newly created cluster."
    cluster_activate

    _log "Updating cluster secrets"
    cluster_update_secrets

    _log "Applying current manifest to cluster."
    _cluster_apply ${SOURCE_IMAGE_TAG}

    _log "Cluster ready."
}

function _check_cluster_grpc_port() {
    PORT=$1

    _log "Checking gRPC API: $2"

    if ! grpcurl -plaintext ${CLUSTER_DNS_NAME}:${PORT} list > /dev/null; then
        _error "API not reachable"
    fi
}

