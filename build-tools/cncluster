function _get_gcloud_secret() {
  local -r secret_name="$1"
  gcloud secrets versions access 1 --secret="$secret_name"
}

function _get_service_account_key_id() {
    local -r secret_name="$1"
    _get_gcloud_secret "$secret_name" | jq -r '.private_key_id'
}

