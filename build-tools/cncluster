function subcmd_infra_pulumi() {
  # Use an empty passphrase until we manage secrets
  local -x PULUMI_CONFIG_PASSPHRASE=''
  local -a args=( --cwd "${REPO_ROOT}/cluster/pulumi/infrastructure" )

  # some pulumi commands / sub-commands do not support the --stack flag
  if [[ "$1" != stack || "$2" != export ]]; then
    args+=( --stack "infra.${GCP_CLUSTER_BASENAME}" )
  fi

  if [[ "$1" == up ]]; then
    # Use the existing secret to populate the secret needed in the
    # ingress namespace. Eventually, the secret management will be
    # done in Pulumi.
    dns_sa_key=$(kubectl get secret clouddns-dns01-solver-svc-acct --namespace=default -ojson \
                     | jq -r '.data["key.json"]')

      args+=( -c "DNS_SA_KEY=${dns_sa_key}" )
  fi

  local -x PULUMI_BACKEND_URL

  if [[ "$GCP_CLUSTER_BASENAME" == @(dev|test) ]]; then
    PULUMI_BACKEND_URL=gs://da-cn-pulumi-dev-stacks
  else
    PULUMI_BACKEND_URL=gs://da-cn-pulumi-stacks
  fi

  pulumi "${args[@]}" "$@"
}

