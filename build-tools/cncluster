subcommand_whitelist[set_machine_type]='Rebuilds the default node pool with current cluster machine type and count'

function subcmd_set_machine_type() {
    _prompt_to_confirm
    _cluster_must_exist

    _info "Creating temporary node pool..."
    gcloud container node-pools create temp-pool --cluster "cn-${GCP_CLUSTER_BASENAME}net" \
           --machine-type "${GCP_CLUSTER_NODE_TYPE}" --num-nodes 1 \
           || _error "Could not create node pool with machine type: ${GCP_CLUSTER_NODE_TYPE}"

    _info "Deleting default node pool..."
    gcloud container node-pools delete default-pool --quiet --cluster "cn-${GCP_CLUSTER_BASENAME}net" \
           || _error "Could not delete default node pool. Terminating early."

    _info "Recreating default node pool..."
    gcloud container node-pools create default-pool --cluster "cn-${GCP_CLUSTER_BASENAME}net" \
           --machine-type "${GCP_CLUSTER_NODE_TYPE}" \
           --num-nodes 2 \
           --enable-autoscaling \
           --min-nodes 2 \
           --max-nodes "${GCP_CLUSTER_MAX_NODES}" \
           || _error "Could not recreate default node pool. Terminating early."

    _info "Deleting temporary node pool..."
    gcloud container node-pools delete temp-pool --quiet --cluster "cn-${GCP_CLUSTER_BASENAME}net" \
           || _error "Could not delete temporary node pool."
}

