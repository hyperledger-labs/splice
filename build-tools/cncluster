subcommand_whitelist[papply]="Apply the current Pulumi configuration"

function subcmd_papply() {
    _production_gate
    _prompt_to_confirm
    _cluster_must_exist

    VERSION_NUMBER=$(get-snapshot-version)

    if [ -z "${1-}" ]; then
        if [ -z "${CNCLUSTER_SKIP_DOCKER_CHECK-}" ]; then
            _docker_must_be_running
            if ! make -C "${REPO_ROOT}" docker-check -j; then
                _error "Images missing from artifact registry, cannot apply."
                exit 1
            fi
        else
            _warning "docker-check bypassed with CNCLUSTER_SKIP_DOCKER_CHECK."
        fi
    else
        IMAGE_TAG=$1
        _warning "Overriding image tag (no docker-check): ${IMAGE_TAG} (was: ${SOURCE_IMAGE_TAG})"
    fi

    make -C "${REPO_ROOT}" cluster/build

    # Use the existing secret to populate the secret needed in the
    # ingress namespace. Eventually, the secret management will be
    # done in Pulumi.
    dns_sa_key=$(kubectl get secret clouddns-dns01-solver-svc-acct --namespace=default -ojson \
                     | jq -r '.data["key.json"]')

    args=(-c "VERSION_NUMBER=${VERSION_NUMBER}"
          -c "CLUSTER_BASENAME=${GCP_CLUSTER_BASENAME}" \
          -c "DNS_SA_KEY=${dns_sa_key}")

    if [ -n "${IMAGE_TAG:-}" ]; then
        args+=(-c "IMAGE_TAG=${IMAGE_TAG}")
    fi

    if [ -n "${CNCLUSTER_FIXED_TOKENS:-}" ]; then
        args+=(-c "FIXED_TOKENS=${CNCLUSTER_FIXED_TOKENS}")
    else
        args+=(-c "FIXED_TOKENS=0")
    fi

    subcmd_pulumi up --yes --show-sames "${args[@]}"
}
