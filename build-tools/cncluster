###

subcommand_whitelist[install_dns01_key]='Allocate an DNS SA Key for the project and store it in a secret.'

function subcmd_install_dns01_key() {
    _prompt_to_confirm --no-lock

    SECRET=$(gcloud secrets list --filter "name:${DNS01_SA_KEY_SECRET}" --format 'value(name)')

    if [ -z "${SECRET}" ]; then
        _info "Allocating service account key and storing as secret."
        gcloud iam service-accounts keys create /tmp/key.json \
               --iam-account "${DNS01_SA_IAM_ACCOUNT}"

        gcloud secrets create "${DNS01_SA_KEY_SECRET}" --data-file=/tmp/key.json

        rm /tmp/key.json
    else
        SA_KEY_ID=$(subcmd_get_dns01_key_id)

        _info "DNS Service Account key secret already exists: ${SA_KEY_ID}"
    fi
}
###

subcommand_whitelist[uninstall_dns01_key]='Delete the DNS SA Key for the project and the corresponding secret'

function subcmd_uninstall_dns01_key() {
    _prompt_to_confirm --no-lock

    SECRET=$(gcloud secrets list --filter "name:${DNS01_SA_KEY_SECRET}" --format 'value(name)')

    if [ -z "${SECRET}" ]; then
        _warning "No service account key secret to delete."
    else
        SA_KEY_ID=$(subcmd_get_dns01_key_id)

        _info "Deleting SA Key: ${SA_KEY_ID}"

        gcloud iam service-accounts keys delete \
               --iam-account "${DNS01_SA_IAM_ACCOUNT}" \
               --quiet \
               "${SA_KEY_ID}" || true

        gcloud secrets delete --quiet "${DNS01_SA_KEY_SECRET}"

        _info "Service account key deleted."
    fi
}

