# -*- shell-script -*-

function k8s_apply() {
    IP_ADDR=${1:-127.0.0.1}

    jsonnet --tla-str imageTag=$(version-gen)\
            --tla-str ipAddr=${IP_ADDR}\
            $REPO_ROOT/cluster/canton-network-config.jsonnet \
        | kubectl apply -f -
}

function k8s_set_image() {
    echo "Set Image: $1 $2"

    kubectl set image "deployment/$1" "$1=$2"
}
