#! /usr/bin/env bash

script_dir="$( cd "$( dirname "${BASH_SOURCE[0]}" )" >/dev/null 2>&1 && pwd )"
source "${script_dir}/lib/libcli.source"

if [ -z "$1" ]; then
    _error "Usage: $0 <image-tag>"
else
    imageTag=$1
fi

if [ "$2" = "--force" ]; then
    force=yes
fi

[[ -z "${MAKE}" || ! -f 'target/docker.id' ]] && _error 'must be run from within from make'

imageId="$(<target/docker.id)"

targetPushState="${imageId}::${imageTag}"

# matching tag file (without force) skips build

if [ -f "target/docker.push" ]; then

    prevPushState="$(<target/docker.push)"

    if [ "${targetPushState}" = "${prevPushState}" ]; then
        if [ -z "${force}" ]; then
            _log "Docker image already tagged and pushed."
            exit 0
        fi
    else
        _warning "Docker image previously pushed, but with different tag or image. Tagging and Pushing again."
    fi
fi

if docker-check "${imageTag}" --optional; then
  if [ -z "${force}" ]; then
    _warning "Cowardly refusing to push, tag already exists in repo:\n${imageTag}\n You can force push with make docker-push-force"
    exit 0
  else
    _warning "Forcing push, tag already exists in repo:\n${imageTag}"
  fi
fi

if docker-check "${imageId}" --optional; then
  _error "Expected docker image for tag and push not found: ${imageId}"
  exit 1
fi

if ! _set_x docker tag "${imageId}" "${imageTag}"; then
    _error "Could not tag image."
    exit 1
fi

if ! _set_x docker push "${imageTag}"; then
    _error "Could not push image."
    exit 1
fi

echo "${targetPushState}" > target/docker.push
