module Tests.Init where

import DA.Time
import Daml.Script

import CC.Coin
import CC.Scripts.Util

import CN.Directory

setup = script do
  app <- setupApp

  runNextIssuance app 1.0
  runCoinDepositBots app

  provider <- setupUser app "provider" app.svc
  user <- setupUser app "user" app.svc

  ccWalletId <- validateUserId "cc_wallet"
  createUser (User ccWalletId (Some user)) [CanActAs user, CanReadAs provider, CanReadAs app.svc]

  directoryUiId <- validateUserId "directory_ui"
  createUser (User directoryUiId (Some user)) [CanActAs user, CanReadAs provider, CanReadAs app.svc]

  pay app app.svc user 5.0 ""

  -- create one installation per user
  directoryInstallRequest <- submit user $ createCmd DirectoryInstallRequest with
    provider = provider
    user = user

  directoryInstall <- submit provider $ exerciseCmd directoryInstallRequest DirectoryInstallRequest_Accept with
    svc = app.svc
    entryFee = 1.0
    collectionDuration = minutes 5
    approveDuration = minutes 5

  pay app user user 0.1 ""
  [(installCoin, _)] <- queryFilter @Coin user (\c -> c.quantity.initialQuantity == 0.1)

  pure ()
