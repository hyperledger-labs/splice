# -*- shell-script -*-

### Separate (out of direnv) the env vars that are sourced both locally *and* in CircleCI
export REPO_ROOT="${PWD}"
export TOOLS_LIB=$REPO_ROOT/build-tools/lib


### Setup the VPN Whitelist.

# This is the whitelist used for configuring and administering the
# cluster. It intentionally does not and should not include the
# consultant VPN used by external customers of the Canton Network.

# Add the IP Addresses for the three 'Full Tunnel' DA VPN's
# See: https://digitalasset.atlassian.net/wiki/spaces/DEVSECOPS/pages/1076822828/VPN+IP+Whitelist+for+Digital+Asset
GCP_VPN_NETS=35.194.81.56/32
GCP_VPN_NETS=${GCP_VPN_NETS},35.198.147.95/32
GCP_VPN_NETS=${GCP_VPN_NETS},35.189.40.124/32
# Add CN Network VPN. We use that on CI.
GCP_VPN_NETS=${GCP_VPN_NETS},34.132.91.75/32
# Add consultant VPN so consultants can work on the project
GCP_VPN_NETS=${GCP_VPN_NETS},18.210.210.130/32

# CircleCI IPs -- see https://circleci.com/docs/ip-ranges
GCP_VPN_NETS=${GCP_VPN_NETS},54.166.105.113/32,35.169.17.173/32,54.92.235.88/32,52.72.72.233/32,52.6.77.249/32,3.210.128.175/32,34.194.144.202/32,34.197.6.234/32,54.205.138.102/32,52.21.153.129/32,52.22.215.219/32,52.20.166.242/32,34.197.216.176/32,35.174.249.131/32,54.161.182.76/32,52.206.105.184/32,3.228.39.90/32,52.3.128.216/32,54.172.26.132/32,52.5.58.121/32,54.236.156.101/32,54.209.115.53/32,35.174.253.146/32,54.167.72.230/32,34.194.94.201/32,18.213.67.41/32,54.208.72.234/32,52.4.195.249/32,18.214.70.5/32,18.214.156.84/32,54.164.161.41/32

export GCP_VPN_NETS

### Set up Cloud NAT parameters
# Required to allow cert-manager's pods to reach out to LetsEncrypt's API server and request certs

export GCP_NAT_ROUTER_NAME="cert-manager-nat-router"
export GCP_NAT_CONFIG_NAME="${GCP_NAT_ROUTER_NAME}-config"

### Set up GCE region parameters

export CLOUDSDK_COMPUTE_REGION="us-central1"
# Default to the scratch environment
export CLOUDSDK_CORE_PROJECT="da-cn-scratchnet"

export GCP_DNS_PROJECT="da-gcp-canton-domain"
export GCP_DNS_SERVICE_ACCOUNT="clouddns-dns01-solver-svc-acct"

### The name of the repository for Docker images.
#
# Entities (CI/CD or individuals) that write docker images as part of
# the build process will need to have write access to this project and
# artifat registry.
#
# Entities (k8s mainly) that read docker images will need to have read
# access. This can be granted by creating a role binding in the
# da-cn-images project between the default service account for the
# cluster's GCE project and the the "Artifact Registry Service Agent"
# role.
export GCP_REPO_NAME="da-cn-images/cn-images"

export SBT_OPTS="-Xmx4G -Xms2G"

# Shortcut var to refer to release bundle contents
export BUNDLE=${REPO_ROOT}/apps/app/target/release/coin

export PATH=${PATH}:${REPO_ROOT}/build-tools
export PATH=${PATH}:${BUNDLE}/bin

# Postgres settings

export POSTGRES_HOST="localhost"
export POSTGRES_USER=postgres
export POSTGRES_PASSWORD=postgres
